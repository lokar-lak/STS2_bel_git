msgstr "Форма рэха"

# [ua] Отримайте додаткову [gold]Енергію[/gold] наступного ходу.
# [pl] W następnej turze zyskaj dodatkowe pkt. [gold]Energii[/gold].
# [ru] Даст дополнительную [gold]энергию[/gold] в следующем ходу.
msgctxt "powers.json:ENERGY_NEXT_TURN_POWER.description"
msgid "Gain additional [gold]Energy[/gold] next turn."
msgstr "Наступным ходам атрымаеце дадатковую [gold]энергію[/gold]."

# [ua] Отримайте [blue]{Amount}[/blue] додаткових
# {energyPrefix:energyIcons(1)} наступного ходу.
