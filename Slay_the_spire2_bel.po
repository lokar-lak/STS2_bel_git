# (Дает {CalculatedBlock:diff()} [gold]защиты[/gold])|}
msgctxt "cards.json:DEMONIC_SHIELD.description"
msgid "Lose {HpLoss:diff()} HP.\n"
"Give another player [gold]Block[/gold] equal to your [gold]Block[/gold].{InCombat:\n"
"(Gives {CalculatedBlock:diff()} [gold]Block[/gold])|}"
msgstr "Вы губляеце {HpLoss:diff()} АЗ.\n"
"Дае іншаму гульцу столькі [gold]брані[/gold], колькі [gold]брані[/gold] маеце вы.{InCombat:\n"
"(Дае {CalculatedBlock:diff()} [gold]брані[/gold])|}"

# [ua] Демонічний Щит
# [pl] Demoniczna tarcza
# [ru] Демонический щит
msgctxt "cards.json:DEMONIC_SHIELD.title"
msgid "Demonic Shield"
msgstr "Дэманічны шчыт"

# [ua] На початку вашого ходу отримуєте {StrengthPower:diff()}
# [gold]Міці[/gold].
# [pl] Na początku tury zyskaj {StrengthPower:diff()} pkt. [gold]Siły[/gold].
# [ru] Дает {StrengthPower:diff()} [gold]силы[/gold] в начале хода.
msgctxt "cards.json:DEMON_FORM.description"
msgid "At the start of your turn, gain {StrengthPower:diff()} [gold]Strength[/gold]."
msgstr "На пачатку вашага ходу дае {StrengthPower:diff()} [gold]моцы[/gold]."

# [ua] Демонічна Форма
# [pl] Demon
# [ru] Облик демона
msgctxt "cards.json:DEMON_FORM.title"
msgid "Demon Form"
msgstr "Форма дэмана"

# [ua] Цю карту було вилучено з гри.
# [pl] [blue]Ta karta została usunięta w ostatniej aktualizacji.[/blue]
