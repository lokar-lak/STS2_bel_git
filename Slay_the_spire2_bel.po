msgid "Choose [blue]1[/blue] starter card to [gold]Transform[/gold] into [gold]{BirdCard}[/gold]."
msgstr "[gold]Пераўтварыць[/gold] [blue]1[/blue] выбраную пачатковую карту ў [gold]«{BirdCard}»[/gold]."

# [ua] Пташка
# [pl] Ptak
# [ru] Птица
msgctxt "events.json:WOOD_CARVINGS.pages.INITIAL.options.BIRD.title"
