msgctxt "cards.json:DRAIN_POWER.description"
msgid "Deal {Damage:diff()} damage.\n"
"[gold]Upgrade[/gold] {Cards:diff()} random {Cards:plural:card|cards} in your [gold]Discard Pile[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"[gold]Паляпшае[/gold] {Cards:diff()} {Cards:plural:выпадковую карту|выпадковыя карты|выпадковых карт} у [gold]стосе скідання[/gold]."

# [ua] Виснаження Сил
# [pl] Wysysanie mocy
# [ru] Изнеможение
