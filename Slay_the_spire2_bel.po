msgid "Unrelenting"
msgstr "Няўмольнасць"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
msgctxt "cards.json:UNTOUCHABLE.description"
msgid "Gain {Block:diff()} [gold]Block[/gold]."
msgstr "Дае {Block:diff()} [gold]брані[/gold]."

# [ua] Недоторканний
