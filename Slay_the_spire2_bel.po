msgid "{IsRevealed:Unlocked|Unlock} by accumulating score."
msgstr "{IsRevealed:Адкрылася|Адкрыецца}, калі вы {IsRevealed:назапасілі|назапасіце} дастаткова пунктаў."

# [ua] Відкрито [blue]Підводдя[/blue], альтернативний Акт 1.
# [pl] Odblokowano [blue]Nabrzeże[/blue], alternatywny Akt 1.
# [ru] Вы открыли [blue]Пристань[/blue], альернативную версию Акта 1.
msgctxt "epochs.json:UNDERDOCKS_EPOCH.unlockText"
msgid "Unlocked the [blue]Underdocks[/blue], an alternate Act 1."
msgstr "Вы адкрылі [blue]Ніжнія прыстані[/blue], альтэрнатыўны 1-ы акт."

