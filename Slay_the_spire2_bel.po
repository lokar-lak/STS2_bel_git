msgstr "Адкрыты Старажытны: Антыквар Дарв цяпер будзе з'яўляцца ў вашых будучых выправах..."

# [ua] Наступні карти з'являтимуться в майбутніх забігах.
# [pl] Te karty będą się pojawiać w przyszłych wyprawach.
# [ru] В будущих вылазках вам встретятся новые карты.
msgctxt "timeline.json:UNLOCK_CARDS"
msgid "The following cards will appear in future runs."
msgstr "У будучых выправах вы зможаце знайсці наступныя карты."

# [ua] Карти відкрито!
# [pl] Odblokowano karty!
# [ru] Новые карты!
msgctxt "timeline.json:UNLOCK_CARDS_BANNER"
msgid "Cards Unlocked!"
msgstr "Новыя карты!"

# [ua] Підтвердити
# [pl] Potwierdź
# [ru] Подтвердить
