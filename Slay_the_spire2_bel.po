msgctxt "cards.json:TRAINING_STRIKE.description"
msgid "Deal {Damage:diff()} damage.\n"
"If [gold]Fatal[/gold], Cocoon gains 1 experience."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Калі яна [gold]ўмярцвіць[/gold] праціўніка, «Кокан» атрымае 1 пункт досведу."

# [ua] Тренувальний удар
# [pl] Treningowe uderzenie
# [ru] Тренировочный удар
