# [ua] Слава
# [pl] Splendor
# [ru] Чертог
msgctxt "acts.json:GLORY.title"
msgid "Glory"
msgstr "Хорам"

# [ua] Вулик
# [pl] Rój
# [ru] Улей
msgctxt "acts.json:HIVE.title"
msgid "Hive"
msgstr "Вулей"

# [ua] Хащі
# [pl] Zarośla
# [ru] Заросли
msgctxt "acts.json:OVERGROWTH.title"
