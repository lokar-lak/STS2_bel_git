msgid "Devour Life"
msgstr "Паглынанне жыцця"

# [ua] [gold]Призиваєте[/gold] {Summon:diff()} X разів.
# Додаєте X [gold]{IfUpgraded:show:Душ+|Душ}[/gold] у ваш [gold]Добір[/gold].
# [pl] [gold]Przywołaj[/gold] {Summon:diff()} X razy.
# Dodaj [gold]{IfUpgraded:show:Duszę+|Duszę}[/gold] do [gold]stosu
