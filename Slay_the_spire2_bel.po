msgid "Deal {Damage:diff()} damage.\n"
"Double the damage ALL Hang cards deal to this enemy."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Падвойвае пашкоджанне ўсіх карт «Павешанне» супраць выбранага праціўніка."

# [ua] Підвішування
# [pl] Powieszenie
# [ru] Повешение
msgctxt "cards.json:HANG.title"
msgid "Hang"
msgstr "Павешанне"

# [ua] Щоразу, коли Ви граєте [gold]Душу[/gold], випадковий ворог втрачає
# {HpLoss:diff()} ОЗ.
