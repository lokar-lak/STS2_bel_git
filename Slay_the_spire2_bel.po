# Атаки или Таланта из [gold]руки[/gold] на выбор.
msgctxt "cards.json:DUAL_WIELD.description"
msgid "Choose an Attack or Power card. Add {IfUpgraded:show:{Cards} copies|a copy} of that card into your [gold]Hand[/gold]."
msgstr "Вы выбіраеце карту Атакі або Сілы. Дадае {IfUpgraded:show:{Cards} копіі|копію} гэтай карты ў [gold]руку[/gold]."

# [ua] Оберіть карту для копіювання.
# [pl] Wybierz kartę do skopiowania
# [ru] Выберите карту, которую хотите скопировать.
msgctxt "cards.json:DUAL_WIELD.selectionScreenPrompt"
msgid "Choose a card to Copy."
msgstr "Выберыце карту, якую хочаце скапіяваць."

# [ua] Двозброєність
# [pl] Oburęczność
# [ru] Парное оружие
msgctxt "cards.json:DUAL_WIELD.title"
msgid "Dual Wield"
msgstr "Парная зброя"

# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам. Усі вороги втрачають
# {StrengthLoss:diff()} [gold]Міці[/gold] цього ходу.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom. W tej turze
# WSZYSCY przeciwnicy tracą {StrengthLoss:diff()} pkt. [gold]Siły[/gold].
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам. Отнимает у ВСЕХ врагов
# {StrengthLoss:diff()} [gold]силы[/gold] на этот ход.
msgctxt "cards.json:DYING_STAR.description"
msgid "Deal {Damage:diff()} damage to ALL enemies. ALL enemies lose {StrengthLoss:diff()} [gold]Strength[/gold] this turn."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам. УСЕ праціўнікі ў гэтым ходзе губляюць {StrengthLoss:diff()} [gold]моцы[/gold]."

# [ua] Зірка, що Гасне
# [pl] Umierająca gwiazda
# [ru] Умирающая звезда
msgctxt "cards.json:DYING_STAR.title"
msgid "Dying Star"
msgstr "Зорная агонія"

# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам.
# Повторює ефект за кожного вбитого ворога.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom.
# Powtórz ten efekt za każdego zabitego przeciwnika.
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам.
# Наносит урон еще раз за каждого убитого врага.
msgctxt "cards.json:ECHOING_SLASH.description"
msgid "Deal {Damage:diff()} damage to ALL enemies.\n"
"Repeat this effect for each enemy killed."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам.\n"
"Паўтарае гэты эфект за кожнага забітага праціўніка."

# [ua] Відлунний Розтин
# [pl] Echo cięcie
# [ru] Рассечение
msgctxt "cards.json:ECHOING_SLASH.title"
msgid "Echoing Slash"
msgstr "Рэха клінкоў"

# [ua] Перша карта, зіграна вами кожного ходу, відтворюється ще раз.
# [pl] W każdej turze pierwsza zagrana karta jest zagrywana dwukrotnie.
# [ru] Первая карта за ход разыгрывается еще раз.
msgctxt "cards.json:ECHO_FORM.description"
msgid "The first card you play each turn is played an extra time."
msgstr "Першая разыграная за ход карта разыгрываецца яшчэ раз."

# [ua] Форма Відлуння
# [pl] Echo
# [ru] Облик эхо
msgctxt "cards.json:ECHO_FORM.title"
msgid "Echo Form"
msgstr "Форма рэха"

# [ua] [gold]Спалюєте[/gold] [gold]Руку[/gold].
# Якщо таким чином було [gold]Спалено[/gold] 9 карт, отримуєте 1
# [gold]Невразливості[/gold].
# [pl] [gold]Wyczerp[/gold] swoją [gold]rękę[/gold].
# Jeżeli [gold]Wyczerpano[/gold] 9 kart w ten sposób, zyskaj 1 pkt.
# [gold]Nieuchwytności[/gold].
# [ru] [gold]Сжигает[/gold] все карты в [gold]руке[/gold].
# Дает 1 [gold]неосязаемости[/gold], если [gold]сжигает[/gold] 9 карт за раз.
msgctxt "cards.json:EIDOLON.description"
msgid "[gold]Exhaust[/gold] your [gold]Hand[/gold].\n"
"If 9 cards were [gold]Exhausted[/gold] this way, gain 1 [gold]Intangible[/gold]."
msgstr "[gold]Спальвае[/gold] вашу [gold]руку[/gold].\n"
"Калі такім чынам было [gold]спалена[/gold] прынамсі 9 карт, дае 1 [gold]бесцялеснасць[/gold]."

# [ua] Ейдолон
# [pl] Upiór
# [ru] Фантом
msgctxt "cards.json:EIDOLON.title"
msgid "Eidolon"
msgstr "Эйдалон"

# [ua] Накладаєте {DoomPower:diff()} [gold]Приреченості[/gold] на ВСІХ
# ворогів.
# Вбиваєте ворогів, у яких [gold]Приреченість[/gold] не менша за ОЗ.
# [pl] Nałóż {DoomPower:diff()} pkt. [gold]Zagłady[/gold] na WSZYSTKICH
# przeciwników.
# Zabij przeciwników, których pkt. [gold]Zagłady[/gold] są równe ich PŻ lub
# większe.
# [ru] Накладывает {DoomPower:diff()} [gold]злого рока[/gold] на ВСЕХ врагов.
# Убивает врагов, чей [gold]злой рок[/gold] не ниже их ОЗ.
msgctxt "cards.json:END_OF_DAYS.description"
msgid "Apply {DoomPower:diff()} [gold]Doom[/gold] to ALL enemies.\n"
"Kill enemies with at least as much [gold]Doom[/gold] as HP."
msgstr "Накладае {DoomPower:diff()} [gold]пагібелі[/gold] на УСІХ праціўнікаў.\n"
"Забівае праціўнікаў, у якіх [gold]пагібелі[/gold] не менш за АЗ."

# [ua] Кінець Днів
# [pl] Kres życia
# [ru] Конец света
msgctxt "cards.json:END_OF_DAYS.title"
msgid "End of Days"
msgstr "Канец свету"

# [ua] ВСІ гравці отримують {Energy:energyIcons()}.
# [pl] WSZYSCY gracze otrzymują {Energy:energyIcons()}.
# [ru] Дает {Energy:energyIcons()} ВСЕМ игрокам.
msgctxt "cards.json:ENERGY_SURGE.description"
msgid "ALL players gain {Energy:energyIcons()}."
msgstr "УСЕ гульцы атрымліваюць {Energy:energyIcons()}."

# [ua] Сплеск Енергії
# [pl] Przypływ Energii
# [ru] Всплеск энергии
msgctxt "cards.json:ENERGY_SURGE.title"
msgid "Energy Surge"
msgstr "Усплёск энергіі"

# [ua] Ворог втрачає {StrengthLoss:diff()} [gold]Міці[/gold] цього ходу.
# [pl] W tej turze przeciwnik traci [blue]{StrengthLoss:diff()}[/blue] pkt.
# [gold]Siły[/gold].
# [ru] Отнимает у врага {StrengthLoss:diff()} [gold]силы[/gold] на этот ход.
msgctxt "cards.json:ENFEEBLING_TOUCH.description"
msgid "Enemy loses {StrengthLoss:diff()} [gold]Strength[/gold] this turn."
msgstr "Праціўнік у гэтым ходзе губляе {StrengthLoss:diff()} [gold]моцы[/gold]."

# [ua] Знесилюючий Дотик
# [pl] Wycieńczenie
# [ru] Истощающее касание
msgctxt "cards.json:ENFEEBLING_TOUCH.title"
msgid "Enfeebling Touch"
msgstr "Мардоўны дотык"

# [ua] Зменшує вартість ВСІХ карт у [gold]Руці[/gold] до 1 на
# {IfUpgraded:show:весь бій|цей хід}.
# [pl] Zredukuj koszt WSZYSTKICH kart w [gold]ręce[/gold] do 1
# {IfUpgraded:show:na czas tej walki|na czas tej tury}.
# [ru] Понижает стоимость ВСЕХ карт в [gold]руке[/gold] до 1
# {IfUpgraded:show:на этот бой|на этот ход}.
msgctxt "cards.json:ENLIGHTENMENT.description"
msgid "Reduce the cost of ALL cards in your [gold]Hand[/gold] to 1 this {IfUpgraded:show:combat|turn}."
msgstr "Зніжае кошт УСІХ карт у вашай [gold]руцэ[/gold] да 1 на {IfUpgraded:show:ўвесь бой|гэты ход}."

# [ua] Просвітлення
# [pl] Oświecenie
# [ru] Просветление
msgctxt "cards.json:ENLIGHTENMENT.title"
msgid "Enlightenment"
msgstr "Прасвятленне"

# [ua] Якщо ця карта у [gold]Руці[/gold], її потрібно зіграти перед іншими
# картами.
# [pl] Jeżeli trzymasz tę kartę w [gold]ręce[/gold], musisz ją zagrać przed
# innymi kartami.
# [ru] Вы не можете разыгрывать другие карты, пока эта карта в
# [gold]руке[/gold].
msgctxt "cards.json:ENTHRALLED.description"
msgid "If this is in your [gold]Hand[/gold], it must be played before other cards."
msgstr "Калі гэтая карта ў вашай [gold]руцэ[/gold], яе трэба разыграць раней за астатнія карты."

# [ua] Підкорений
# [pl] Fascynacja
# [ru] Порабощение
msgctxt "cards.json:ENTHRALLED.title"
msgid "Enthralled"
msgstr "Заварожанасць"

# [ua] Подвоюєте вашу [gold]Броню[/gold].
# [pl] Podwój swój obecny [gold]Blok[/gold].
# [ru] Удваивает вашу [gold]защиту[/gold].
msgctxt "cards.json:ENTRENCH.description"
msgid "Double your [gold]Block[/gold]."
msgstr "Падвойвае вашу [gold]браню[/gold]."

# [ua] Укріплення
# [pl] Umocnienie
# [ru] Окоп
msgctxt "cards.json:ENTRENCH.title"
msgid "Entrench"
msgstr "Акоп"

# [ua] На початку вашого ходу [gold]Перетворюєте[/gold] {Cards:diff()}
# {Cards:plural:карту|карти|карт} у [gold]Руці[/gold].
# [pl] Na początku tury [gold]Zmień[/gold] {Cards:diff()}
# {Cards:plural:kartę|karty|kart} w [gold]ręce[/gold].
# [ru] [gold]Преобразует[/gold] {Cards:diff()}
# {Cards:plural(ru):карту|карты|карт} в [gold]руке[/gold] в начале хода.
msgctxt "cards.json:ENTROPY.description"
msgid "At the start of your turn, [gold]Transform[/gold] {Cards:diff()} {Cards:plural:card|cards} in your [gold]Hand[/gold]."
msgstr "На пачатку вашага ходу [gold]пераўтварае[/gold] {Cards:diff()} {Cards:plural:карту|карты|карт} у вашай [gold]руцэ[/gold]."

# [ua] Ентропія
# [pl] Entropia
# [ru] Энтропия
msgctxt "cards.json:ENTROPY.title"
msgid "Entropy"
msgstr "Энтрапія"

# [ua] Щоразу, коли Атака завдає непоглиненої шкоди, накладаєте
# {EnvenomPower:diff()} [gold]Отрути[/gold].
# [pl] Kiedykolwiek Atak zada niezablokowane obrażenia, nałóż
# {EnvenomPower:diff()} pkt. [gold]Trucizny[/gold].
# [ru] Накладывает на врага {EnvenomPower:diff()} [gold]яда[/gold], когда
# Атака наносит урон по его ОЗ.
msgctxt "cards.json:ENVENOM.description"
msgid "Whenever an Attack deals unblocked damage, apply {EnvenomPower:diff()} [gold]Poison[/gold]."
msgstr "Накладае на праціўніка {EnvenomPower:diff()} [gold]атруты[/gold] штораз, калі карта Атакі прычыняе яму незаблакаванае пашкоджанне."

# [ua] Отруєння
# [pl] Zatruwanie
# [ru] Отравление
msgctxt "cards.json:ENVENOM.title"
msgid "Envenom"
msgstr "Атручванне"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# [gold]Ховаєте[/gold] [gold]Руку[/gold] цього ходу.
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# W tej turze [gold]Zachowaj[/gold] swoją [gold]rękę[/gold].
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# В этом ходу вы [gold]оставляете[/gold] карты в [gold]руке[/gold].
msgctxt "cards.json:EQUILIBRIUM.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"[gold]Retain[/gold] your [gold]Hand[/gold] this turn."
msgstr "Дае {Block:diff()} [gold]брані[/gold].\n"
"[gold]Захоўвае[/gold] вашу [gold]руку[/gold] у гэтым ходзе."

# [ua] Рівновага
# [pl] Równowaga
# [ru] Эквилибриум
msgctxt "cards.json:EQUILIBRIUM.title"
msgid "Equilibrium"
msgstr "Раўнавага"

# [ua] Нанести {Damage:diff()} шкоди X разів.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń X razy.
# [ru] Наносит {Damage:diff()} урона X раз.
msgctxt "cards.json:ERADICATE.description"
msgid "Deal {Damage:diff()} damage X times."
msgstr "Прычыняе {Damage:diff()} пашкоджання X разоў."

# [ua] Знищення
# [pl] Zlikwidowanie
# [ru] Прах к праху
msgctxt "cards.json:ERADICATE.title"
msgid "Eradicate"
msgstr "Зніштажэнне"

# [ua] Берете 1 карту.
# Якщо ви берете Вміння, отримуєте {Block:diff()} [gold]Броні[/gold].
# [pl] Dobierz 1 kartę.
# Jeżeli dobierzesz Umiejętność, zyskaj {Block:diff()} pkt.
# [gold]Bloku[/gold].
# [ru] Вы добираете 1 карту.
# Дает {Block:diff()} [gold]защиты[/gold], если вы добрали Навык.
msgctxt "cards.json:ESCAPE_PLAN.description"
msgid "Draw 1 card.\n"
"If you draw a Skill, gain {Block:diff()} [gold]Block[/gold]."
msgstr "Вы дабіраеце 1 карту.\n"
"Калі вы дабралі Уменне, дае {Block:diff()} [gold]брані[/gold]."

# [ua] План Втечі
# [pl] Plan ucieczki
# [ru] План побега
msgctxt "cards.json:ESCAPE_PLAN.title"
msgid "Escape Plan"
msgstr "План уцёкаў"

# [ua] Отримайте {PlatingPower:diff()} [gold]Захисту[/gold].
# [pl] Zyskaj {PlatingPower:diff()} pkt. [gold]Opancerzenia[/gold].
# [ru] Дает {PlatingPower:diff()} [gold]панциря[/gold].
msgctxt "cards.json:ETERNAL_ARMOR.description"
msgid "Gain {PlatingPower:diff()} [gold]Plating[/gold]."
msgstr "Дае {PlatingPower:diff()} [gold]панцыра[/gold]."

# [ua] Вічна Броня
# [pl] Wieczne opancerzenie
# [ru] Нерушимые латы
msgctxt "cards.json:ETERNAL_ARMOR.title"
msgid "Eternal Armor"
msgstr "Вечная браня"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# Отримайте ще {Block:diff()} [gold]Броні[/gold], якщо [gold]Спалили[/gold]
# карту цього ходу.
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# Zyskaj dodatkowo {Block:diff()} pkt. [gold]Bloku[/gold], jeżeli
# [gold]Wyczerpano[/gold] kartę w tej turze.
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# Дает еще {Block:diff()} [gold]защиты[/gold] , если вы [gold]сжигали[/gold]
# карты в этом ходу.
msgctxt "cards.json:EVIL_EYE.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Gain another {Block:diff()} [gold]Block[/gold] if you have [gold]Exhausted[/gold] a card this turn."
msgstr "Дае {Block:diff()} [gold]брані[/gold].\n"
"Дае яшчэ {Block:diff()} [gold]брані[/gold], калі вы [gold]спалілі[/gold] карту ў гэтым ходзе."

# [ua] Лихе Око
# [pl] Złe oko
# [ru] Сглаз
msgctxt "cards.json:EVIL_EYE.title"
msgid "Evil Eye"
msgstr "Падзіў"

# [ua] Отримайте {energyPrefix:energyIcons(1)} за кожну Атаку у
# [gold]Руці[/gold].{InCombat:
# (Отримуєте {CalculatedEnergy:energyIcons()}.)|}
# [pl] Zyskaj {energyPrefix:energyIcons(1)} za każdy Atak w [gold]ręce[/gold].
# Nie możesz zyskać więcej {energyPrefix:energyIcons(1)} w tej
# turze.{InCombat:
# (Zyskaj {CalculatedEnergy:energyIcons()})|}
# [ru] Дает {energyPrefix:energyIcons(1)} за каждую Атаку в [gold]руке[/gold].
# Вы не сможете получать {energyPrefix:energyIcons(1)} до конца
# хода.{InCombat:
# (Дает {CalculatedEnergy:energyIcons()})|}
msgctxt "cards.json:EXPECT_A_FIGHT.description"
msgid "Gain {energyPrefix:energyIcons(1)} for each Attack in your [gold]Hand[/gold].\n"
"You cannot gain\n"
"additional {energyPrefix:energyIcons(1)} this turn.{InCombat:\n"
"(Gain {CalculatedEnergy:energyIcons()})|}"
msgstr "Дае {energyPrefix:energyIcons(1)} за кожную карту Атакі ў [gold]руцэ[/gold].\n"
"У гэтым ходзе вы не можаце атрымліваць\n"
"дадатковай {energyPrefix:energyIcons(1)}.{InCombat:\n"
"(Дае {CalculatedEnergy:energyIcons()})|}"

# [ua] Готовність до Бою
# [pl] Przygotowanie do walki
# [ru] Неизбежная схватка
msgctxt "cards.json:EXPECT_A_FIGHT.title"
msgid "Expect a Fight"
msgstr "Гатоўнасць да бою"

# [ua] Берете карти, доки в [gold]Руці[/gold] не буде {Cards:diff()}.
# [pl] Dobieraj karty, aż będziesz mieć ich {Cards:diff()} w
# [gold]ręce[/gold].
# [ru] Вы добираете карты, пока в [gold]руке[/gold] не будет {Cards:diff()}
# карт.
msgctxt "cards.json:EXPERTISE.description"
msgid "Draw cards until you have {Cards:diff()} in your [gold]Hand[/gold]."
msgstr "Вы дабіраеце карты, пакуль у вашай [gold]руцэ[/gold] не будзе {Cards:diff()} карт."

# [ua] Майстерність
# [pl] Ekspertyza
# [ru] Мастерство
msgctxt "cards.json:EXPERTISE.title"
msgid "Expertise"
msgstr "Майстэрства"

# [ua] Знімаєте весь [gold]Артефакт[/gold] та [gold]Броню[/gold] з ворога.
# Накладаєте {Power:diff()} [gold]Уразливості[/gold].
# [pl] Usuń przeciwnikowi wszystkie pkt. [gold]Ochrony[/gold] i
# [gold]Bloku[/gold].
# Nałóż {Power:diff()} pkt. [gold]Wrażliwości[/gold].
# [ru] Снимает все [gold]артефакты[/gold] и [gold]защиту[/gold].
# Накладывает {Power:diff()} [gold]уязвимости[/gold].
msgctxt "cards.json:EXPOSE.description"
msgid "Remove all [gold]Artifact[/gold] and [gold]Block[/gold] from the enemy.\n"
"Apply {Power:diff()} [gold]Vulnerable[/gold]."
msgstr "Здымае з праціўніка ўсю [gold]артэфактнасць[/gold] і [gold]браню[/gold].\n"
"Накладае {Power:diff()} [gold]безабароннасці[/gold]."

# [ua] Викриття
# [pl] Obezwładnienie
# [ru] Слабое место
msgctxt "cards.json:EXPOSE.title"
msgid "Expose"
msgstr "Выкрыццё"

# [ua] Нанести {Damage:diff()} шкоди {Repeat:diff()} разів ВСІМ ворогам.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń {Repeat:diff()} razy WSZYSTKIM
# przeciwnikom.
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам {Repeat:diff()}
# {Repeat:plural(ru):раз|раза|раза}.
msgctxt "cards.json:EXTERMINATE.description"
msgid "Deal {Damage:diff()} damage {Repeat:diff()} times to ALL enemies."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам {Repeat:diff()} разоў."

# [ua] Знищення
# [pl] Tępienie szkodników
# [ru] Истребление
msgctxt "cards.json:EXTERMINATE.title"
msgid "Exterminate"
msgstr "Вынішчэнне"

# [ua] Нанести {Damage:diff()} шкоди.
# Накладаєте {WeakPower:diff()} [gold]Ослаблення[/gold].
# Накладаєте {VulnerablePower:diff()} [gold]Уразливості[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Nałóż {WeakPower:diff()} pkt. [gold]Słabości[/gold].
# Nałóż {VulnerablePower:diff()} pkt. [gold]Wrażliwości[/gold].
# [ru] Наносит {Damage:diff()} урона.
# Накладывает {WeakPower:diff()} [gold]слабости[/gold].
# Накладывает {VulnerablePower:diff()} [gold]уязвимости[/gold].
msgctxt "cards.json:FALLING_STAR.description"
msgid "Deal {Damage:diff()} damage.\n"
"Apply {WeakPower:diff()} [gold]Weak[/gold].\n"
