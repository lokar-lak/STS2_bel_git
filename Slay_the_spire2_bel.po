# [ua] Божевільна Наука
# [pl] Szalony eksperyment
# [ru] Безумный гений
msgctxt "cards.json:MAD_SCIENCE.title"
msgid "Mad Science"
msgstr "Шалёная навука"

# [ua] Нанести {Damage:diff()} шкоди.
# Кожні {Cards:diff()} {Cards:plural:Вміння|Вміння|Вмінь}, які Ви граєте за
# хід, поверніть це до своєї [gold]Руки[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Po zagraniu {Cards:diff()} Umiejętności, umieść tę kartę w
# [gold]ręce[/gold].
# [ru] Наносит {Damage:diff()} урона.
# Возвращается в [gold]руку[/gold], когда вы разыгрываете {Cards:diff()}
# {Cards:plural(ru):Навык|Навыка|Навыков} за ход.
msgctxt "cards.json:MAKE_IT_SO.description"
msgid "Deal {Damage:diff()} damage.\n"
"Every {Cards:diff()} {Cards:plural:Skill|Skills} you play in a turn, put this into your [gold]Hand[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Вяртаецца ў [gold]руку[/gold] штораз, калі вы разаграваеце {Cards:diff()} {Cards:plural:карту Умення|карты Умення|карт Умення} за ход."

# [ua] Зробіть Це
# [pl] Rozkaz Kapitana
# [ru] Да будет так
msgctxt "cards.json:MAKE_IT_SO.title"
msgid "Make It So"
msgstr "Хай будзе так"

# [ua] Ворог втрачає X{IfUpgraded:show:+1} [gold]Міці[/gold]. Накласти
# X{IfUpgraded:show:+1} [gold]Ослаблення[/gold].
# [pl] Przeciwnik traci X{IfUpgraded:show:+1} pkt. [gold]Siły[/gold]. Nałóż
# X{IfUpgraded:show:+1} pkt. [gold]Słabości[/gold].
# [ru] Отнимает у врага X{IfUpgraded:show:+1} [gold]силы[/gold]. Накладывает
# X{IfUpgraded:show:+1} [gold]слабости[/gold].
msgctxt "cards.json:MALAISE.description"
msgid "Enemy loses X{IfUpgraded:show:+1} [gold]Strength[/gold]. Apply X{IfUpgraded:show:+1} [gold]Weak[/gold]."
msgstr "Праціўнік губляе X{IfUpgraded:show:+1} [gold]моцы[/gold]. Накладае X{IfUpgraded:show:+1} [gold]слабасці[/gold]."

# [ua] Нудьга
# [pl] Marazm
# [ru] Хворь
msgctxt "cards.json:MALAISE.title"
msgid "Malaise"
msgstr "Млявасць"

# [ua] Нанести {Damage:diff()} шкоди.
# Ворог втрачає {StrengthLoss:diff()} [gold]Міці[/gold] цього ходу.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Przeciwnik traci {StrengthLoss:diff()} pkt. [gold]Siły[/gold] w tej turze.
# [ru] Наносит {Damage:diff()} урона.
# Отнимает у врага {StrengthLoss:diff()} [gold]силы[/gold] на этот ход.
msgctxt "cards.json:MANGLE.description"
msgid "Deal {Damage:diff()} damage.\n"
"Enemy loses {StrengthLoss:diff()} [gold]Strength[/gold] this turn."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Праціўнік у гэтым ходзе губляе {StrengthLoss:diff()} [gold]моцы[/gold]."

# [ua] Каліцтво
# [pl] Zniekształcenie
# [ru] Увечья
msgctxt "cards.json:MANGLE.title"
msgid "Mangle"
msgstr "Калецтва"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# Додайте 1 випадкову{IfUpgraded:show: [gold]Поліпшену[/gold]} Безбарвну карту
# до своєї [gold]Руки[/gold].
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# Dodaj 1{IfUpgraded:show: [gold]Ulepszoną[/gold]} bezbarwną kartę do
# [gold]ręki[/gold].
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# Добавляет в [gold]руку[/gold] 1 случайную{IfUpgraded:show: [gold]
# улучшенную[/gold]} бесцветную карту.
msgctxt "cards.json:MANIFEST_AUTHORITY.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Add 1 random{IfUpgraded:show: [gold]Upgraded[/gold]} Colorless card into your [gold]Hand[/gold]."
msgstr "Дае {Block:diff()} [gold]Брані[/gold].\n"
"Дадае 1 выпадковую{IfUpgraded:show: [gold]палепшаную[/gold]} бясколерную карту ў вашу [gold]руку[/gold]."

# [ua] Прояв Влади
# [pl] Majestat władzy
# [ru] Бразды правления
msgctxt "cards.json:MANIFEST_AUTHORITY.title"
msgid "Manifest Authority"
msgstr "Бясспрэчная ўлада"

# [ua] Берете {Cards:diff()} карти.
# [pl] Dobierz {Cards:diff()} karty.
# [ru] Вы добираете {Cards:diff()} {Cards:plural(ru):карту|карты|карт}.
msgctxt "cards.json:MASTER_OF_STRATEGY.description"
msgid "Draw {Cards:diff()} cards."
msgstr "Вы дабіраеце {Cards:diff()} {Cards:plural:карту|карты|карт}."

# [ua] Майстер Стратегії
# [pl] Mistrz strategii
# [ru] Верховный стратег
msgctxt "cards.json:MASTER_OF_STRATEGY.title"
msgid "Master of Strategy"
msgstr "Вярхоўны стратэг"

# [ua] Коли Ви граєте Вміння, воно отримує [gold]Хитрість[/gold].
# [pl] Gdy zagrasz Umiejętność, dodaj do niej [gold]Chytra[/gold].
# [ru] Разыгрываемые Навыки становятся [gold]коварными[/gold].
msgctxt "cards.json:MASTER_PLANNER.description"
msgid "When you play a Skill, it gains [gold]Sly[/gold]."
msgstr "Калі вы разыгрываеце карту Уменне, яна атрымлівае [gold]«круцельства»[/gold]."

# [ua] Майстер Планування
# [pl] Mistrz planowania
# [ru] Наготове
msgctxt "cards.json:MASTER_PLANNER.title"
msgid "Master Planner"
msgstr "У поўным узбраенні"

# [ua] Нанести {Damage:diff()} шкоди двічі.
# Збільшіть шкоду ВСІХ карт Каліцтво на {Increase:diff()} у цьому бою.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń dwukrotnie.
# Zwiększ obrażenia zadawane przez WSZYSTKIE Rozwalenia w tej walce o
# {Increase:diff()} pkt.
# [ru] Наносит {Damage:diff()} урона 2 раза.
# Повышает урон ВСЕХ «Побоев» на {Increase:diff()} до конца боя.
msgctxt "cards.json:MAUL.description"
msgid "Deal {Damage:diff()} damage twice.\n"
"Increase the damage of ALL Maul cards by {Increase:diff()} this combat."
msgstr "Двойчы прычыняе {Damage:diff()} пашкоджання.\n"
"Павялічвае пашкоджанне УСІХ карт «Шкуматанне» на {Increase:diff()} у гэтым баі."

# [ua] Розтерзати
# [pl] Rozwalenie
# [ru] Побои
msgctxt "cards.json:MAUL.title"
msgid "Maul"
msgstr "Шкуматанне"

# [ua] На початку вашого ходу, зіграйте верхню карту вашого
# [gold]Добору[/gold].
# [pl] Na początku tury zagraj kartę ze szczytu [gold]stosu
# rozgrywającego[/gold].
# [ru] Вы разыгрываете карту с верха [gold]стопки добора[/gold] в начале хода.
msgctxt "cards.json:MAYHEM.description"
msgid "At the start of your turn, play the top card of your [gold]Draw Pile[/gold]."
msgstr "На пачатку вашага ходу разыгрывае верхнюю карту са [gold]стоса дабору[/gold]."

# [ua] Хаос
# [pl] Rozwałka
# [ru] Беспредел
msgctxt "cards.json:MAYHEM.title"
msgid "Mayhem"
msgstr "Вэрхал"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# Зменшіть вартість цієї карти на {Energy:energyIcons()} щоразу, коли БУДЬ-ХТО
# помирає.
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# Zredukuj koszt tej karty o {Energy:energyIcons()}, gdy KTOKOLWIEK umrze.
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# Стоит на {Energy:energyIcons()} меньше, когда КТО УГОДНО погибает.
msgctxt "cards.json:MELANCHOLY.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Reduce this card's cost by {Energy:energyIcons()} whenever ANYONE dies."
msgstr "Дае {Block:diff()} [gold]брані[/gold].\n"
"Каштуе на {Energy:energyIcons()} менш, калі ХТО-КОЛЬВЕК загіне."

# [ua] Меланхолія
# [pl] Melancholia
# [ru] Меланхолия
msgctxt "cards.json:MELANCHOLY.title"
msgid "Melancholy"
msgstr "Меланхолія"

# [ua] Нанести {CalculatedDamage:diff()} шкоди.
# Завдає {ExtraDamage:diff()} додаткової шкоди за кожну скинуту цього ходу
# карту.
# [pl] Zadaj {CalculatedDamage:diff()} pkt. obrażeń.
# Zadaje dodatkowo {ExtraDamage:diff()} pkt. obrażeń za każdą odrzuconą kartę
# w tej turze.
# [ru] Наносит {CalculatedDamage:diff()} урона.
# Наносит на {ExtraDamage:diff()} урона больше за каждую сброшенную в этом
# ходу карту.
msgctxt "cards.json:MEMENTO_MORI.description"
msgid "Deal {CalculatedDamage:diff()} damage.\n"
"Deals {ExtraDamage:diff()} additional damage for each card discarded this turn."
msgstr "Прычыняе {CalculatedDamage:diff()} пашкоджання.\n"
"Прычыняе на {ExtraDamage:diff()} пашкоджання больш за кожную карту, скінутую падчас гэтага ходу."

# [ua] Пам'ятай про Смерть
# [pl] Memento Mori
# [ru] Мементо мори
msgctxt "cards.json:MEMENTO_MORI.title"
msgid "Memento Mori"
msgstr "Memento Mori"

# [ua] Додайте {Cards:diff()} випадкових Атак до вашого [gold]Добору[/gold].
# Цього бою їх можна грати безкоштовно.
# [pl] Dodaj {Cards:diff()} losowe bezbarwne karty do [gold]stosu
# rozgrywającego[/gold]. W tej walce są darmowe.
# [ru] Добавляет {Cards:diff()} {Cards:plural(ru):случайную Атаку|случайные
# Атаки|случайных Атак} в [gold]стопку добора[/gold]. В этом бою они
# бесплатные.
msgctxt "cards.json:METAMORPHOSIS.description"
msgid "Add {Cards:diff()} random Attacks into your [gold]Draw Pile[/gold]. They're free to play this combat."
msgstr "Дадае {Cards:diff()} {Cards:plural:выпадковую карту Атакі|выпадковыя карты Атакі|выпадковых карт Атакі} у [gold]стос дабору[/gold]. У гэтай бітве іх можна разыграць задарма."

# [ua] Метаморфоза
# [pl] Metamorfoza
# [ru] Метаморфоза
msgctxt "cards.json:METAMORPHOSIS.title"
msgid "Metamorphosis"
msgstr "Метамарфоза"

# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам.
# Накласти {WeakPower:diff()} [gold]Ослаблення[/gold] та
# [gold]Уразливості[/gold] ВСІМ ворогам.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom.
# Nałóż {WeakPower:diff()} pkt. [gold]Słabości[/gold] i {WeakPower:diff()}
# pkt. [gold]Wrażliwości[/gold] na WSZYSTKICH przeciwników.
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам.
# Накладывает {WeakPower:diff()} [gold]слабости[/gold] и
# [gold]уязвимости[/gold] на ВСЕХ врагов.
msgctxt "cards.json:METEOR_SHOWER.description"
msgid "Deal {Damage:diff()} damage to ALL enemies.\n"
"Apply {WeakPower:diff()} [gold]Weak[/gold] and [gold]Vulnerable[/gold] to ALL enemies."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам.\n"
"Накладае {WeakPower:diff()} [gold]слабасці[/gold] і [gold]безабароннасці[/gold] на УСІХ праціўнікаў."

# [ua] Метеоритний Дощ
# [pl] Deszcz meteorytów
# [ru] Метеоритный дождь
msgctxt "cards.json:METEOR_SHOWER.title"
msgid "Meteor Shower"
msgstr "Метэарытны дождж"

# [ua] Нанести {Damage:diff()} шкоди.
# [gold]Призвати[/gold] 3 [gold]Плазми[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# [gold]Załaduj[/gold] 3 [gold]Sfery Plazmy[/gold].
# [ru] Наносит {Damage:diff()} урона.
# [gold]Заряжает[/gold] 3 [gold]сферы плазмы[/gold].
msgctxt "cards.json:METEOR_STRIKE.description"
msgid "Deal {Damage:diff()} damage.\n"
"[gold]Channel[/gold] 3 [gold]Plasma[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"[gold]Зараджае[/gold] 3 [gold]сферы плазмы[/gold]."

# [ua] Метеоритний Удар
# [pl] Uderzenie meteorytu
# [ru] Метеоритный удар
msgctxt "cards.json:METEOR_STRIKE.title"
msgid "Meteor Strike"
msgstr "Метэарытны ўдар"

# [ua] Отримайте [gold]Броню[/gold] рівну [gold]Броні[/gold] іншого гравця.
# [pl] Zyskaj [gold]Blok[/gold] równy obecnemu [gold]Blokowi[/gold] innego
# gracza.
# [ru] Дает [gold]защиту[/gold], равную [gold]защите[/gold] другого игрока.
msgctxt "cards.json:MIMIC.description"
msgid "Gain [gold]Block[/gold] equal to the [gold]Block[/gold] on another player."
msgstr "Дае [gold]браню[/gold], роўную [gold]брані[/gold] іншага гульца."

# [ua] Мімік
# [pl] Dasz mi przepisać?
# [ru] Подражание
msgctxt "cards.json:MIMIC.title"
msgid "Mimic"
msgstr "Пераймальніцтва"

# [ua] Нанести шкоду рівну кількості карт у вашому
# [gold]Доборі[/gold].{InCombat:
# (Завдає {CalculatedDamage:diff()} шкоди)|}
# [pl] Zadaj obrażenia równe liczbie kart na [gold]stosie
# rozgrywającym[/gold].{InCombat:
# (Zadaje {CalculatedDamage:diff()} pkt. obrażeń)|}
# [ru] Наносит урон, равный количеству карт в [gold]стопке
# добора[/gold].{InCombat:
# (Наносит {CalculatedDamage:diff()} урона)|}
msgctxt "cards.json:MIND_BLAST.description"
msgid "Deal damage equal to the number of cards in your [gold]Draw Pile[/gold].{InCombat:\n"
"(Deals {CalculatedDamage:diff()} damage)|}"
msgstr "Прычыняе пашкоджанне, роўнае колькасці карт у вашым [gold]стосе дабору[/gold].{InCombat:\n"
"(Прычыняе {CalculatedDamage:diff()} пашкоджання)|}"

# [ua] Розумовий Вибух
# [pl] Wybuch mózgu
# [ru] Ментальный взрыв
