msgid "Fasten"
msgstr "Перавязка"

# [ua] Щоразу, коли картку Спалено, отримайте [blue]3[/blue]
# [gold]Броні[/gold].
# [pl] Kiedykolwiek karta zostanie [gold]Wyczerpana[/gold], zyskaj
# [blue]3[/blue] pkt. [gold]Bloku[/gold].
# [ru] Дает [blue]3[/blue] [gold]защиты[/gold], когда сжигается карта.
msgctxt "powers.json:FEEL_NO_PAIN_POWER.description"
msgid "Whenever a card is Exhausted, gain [blue]3[/blue] [gold]Block[/gold]."
msgstr "Штораз, калі карта [gold]спальваецца[/gold], дае [blue]3[/blue] [gold]брані[/gold]."

# [ua] Щоразу, коли картку [gold]Спалено[/gold], отримайте
# [blue]{Amount}[/blue] [gold]Броні[/gold].
# [pl] Kiedykolwiek karta zostanie [gold]Wyczerpana[/gold], zyskaj
# [blue]{Amount}[/blue] pkt. [gold]Bloku[/gold].
# [ru] Дает [blue]{Amount}[/blue] [gold]защиты[/gold], когда сжигается карта.
msgctxt "powers.json:FEEL_NO_PAIN_POWER.smartDescription"
msgid "Whenever a card is [gold]Exhausted[/gold], gain [blue]{Amount}[/blue] [gold]Block[/gold]."
