# [ru] Украденная картa вернется в [gold]руку[/gold], когда этот враг
# погибнет.
msgctxt "powers.json:SWIPE_POWER.description"
msgid "Upon killing this enemy, the stolen card is returned."
msgstr "Калі гэтага праціўніка забіць, скрадзеная карта вернецца."

