msgid "Gain {Block:diff()} [gold]Block[/gold]."
msgstr "Дае {Block:diff()} [gold]брані[/gold]."

# [ua] Абсолютний захист
# [pl] Ultra Obrona
# [ru] Превосходная оборона
msgctxt "cards.json:ULTIMATE_DEFEND.title"
msgid "Ultimate Defend"
msgstr "Абсалютная абарона"

