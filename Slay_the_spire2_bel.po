# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам.
# На початку вашого ходу відтворюється з [gold]Спаленого[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom.
# Na początku tury zagraj tę kartę, jeżeli znajduje się na [gold]stosie kart
# wyczerpanych[/gold].
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам.
# Разыгрывается в начале хода, если находится в [gold]стопке пепла[/gold].
msgctxt "cards.json:HOWL_FROM_BEYOND.description"
msgid "Deal {Damage:diff()} damage to ALL enemies.\n"
"At the start of your turn, if this is in your [gold]Exhaust Pile[/gold], play it."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам.\n"
"Разыгрываецца на пачатку вашага ходу, калі знаходзіцца ў [gold]стосе спаленых карт[/gold]."

# [ua] Виття з Безодні
# [pl] Ryk z piekieł
# [ru] Потусторонний вой
msgctxt "cards.json:HOWL_FROM_BEYOND.title"
msgid "Howl from Beyond"
msgstr "Тагасветнае выццё"

# [ua] ВСІ союзники беруть {Cards:diff()} карт.
# [pl] WSZYSCY gracze dobierają {Cards:diff()} karty.
# [ru] ВСЕ игроки добирают по {Cards:diff()}
# {Cards:plural(ru):карте|карты|карт}.
msgctxt "cards.json:HUDDLE_UP.description"
msgid "ALL players draw {Cards:diff()} cards."
msgstr "УСЕ гульцы дабіраюць {Cards:diff()} {Cards:plural:карту|карты|карт}."

# [ua] Збір
# [pl] Dobieramy
# [ru] Сплочение
msgctxt "cards.json:HUDDLE_UP.title"
msgid "Huddle Up"
msgstr "Згуртаванасць"

# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам.
# Втрачаєте {FocusPower:diff()} [gold]Зосередження[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom.
# Utrać {FocusPower:diff()} pkt. [gold]Skupienia[/gold].
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам.
# Вы теряете {FocusPower:diff()} [gold]фокуса[/gold].
msgctxt "cards.json:HYPERBEAM.description"
msgid "Deal {Damage:diff()} damage to ALL enemies.\n"
"Lose {FocusPower:diff()} [gold]Focus[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам.\n"
"Вы губляеце {FocusPower:diff()} [gold]канцэнтрацыі[/gold]."

# [ua] Гіпер-Промінь
# [pl] Hiperpromień
# [ru] Гиперлуч
msgctxt "cards.json:HYPERBEAM.title"
msgid "Hyperbeam"
msgstr "Гіперпрамень"

# [ua] Нанести {Damage:diff()} шкоди.
# [gold]Призиваєте[/gold] {Repeat:diff()} [gold]Морозу[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# [gold]Załaduj[/gold] {Repeat:diff()} [gold]Sfery Mrozu[/gold].
# [ru] Наносит {Damage:diff()} урона.
# [gold]Заряжает[/gold] {Repeat:diff()}
# [gold]{Repeat:plural(ru):сферу|сферы|сфер} льда[/gold].
msgctxt "cards.json:ICE_LANCE.description"
msgid "Deal {Damage:diff()} damage.\n"
"[gold]Channel[/gold] {Repeat:diff()} [gold]Frost[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"[gold]Зараджае[/gold] {Repeat:diff()} [gold]{Repeat:plural:сферу марозу|сферы марозу|сфер марозу}[/gold]."

# [ua] Крижане Спис
# [pl] Lanca lodowa
# [ru] Ледяное копье
msgctxt "cards.json:ICE_LANCE.title"
msgid "Ice Lance"
msgstr "Ледзяная дзіда"

# [ua] Інший гравець [gold]Призиває[/gold] [gold]Плазму[/gold].
# [pl] Inny gracz [gold]Załadowuje[/gold] [gold]Sferę Plazmy[/gold].
# [ru] Другой игрок [gold]заряжает[/gold] [gold]сферу плазмы[/gold].
msgctxt "cards.json:IGNITION.description"
msgid "Another player [gold]Channels[/gold] [gold]Plasma[/gold]."
msgstr "Іншы гулец [gold]зараджае[/gold] [gold]сферу плазмы[/gold]."

# [ua] Займання
# [pl] Zapłon
# [ru] Зажигание
msgctxt "cards.json:IGNITION.title"
msgid "Ignition"
msgstr "Запальванне"

# [ua] Втрачаєте {HpLoss:diff()} ОЗ.
# Отримайте {IntangiblePower:diff()} [gold]Невразливості[/gold].
# [pl] Utrać {HpLoss:diff()} PŻ.
# Zyskaj {IntangiblePower:diff()} pkt. [gold]Nieuchwytności[/gold].
# [ru] Вы теряете {HpLoss:diff()} ОЗ.
# Дает {IntangiblePower:diff()} [gold]неосязаемости[/gold].
msgctxt "cards.json:IMMORTALITY.description"
msgid "Lose {HpLoss:diff()} HP.\n"
"Gain {IntangiblePower:diff()} [gold]Intangible[/gold]."
msgstr "Вы губляеце {HpLoss:diff()} АЗ.\n"
"Дае {IntangiblePower:diff()} [gold]бесцялеснасці[/gold]."

# [ua] Безсмертя
# [pl] Nieśmiertelność
# [ru] Бессмертие
msgctxt "cards.json:IMMORTALITY.title"
msgid "Immortality"
msgstr "Несмяротнасць"

# [ua] Нанести {Damage:diff()} шкоди.
# Накладаєте {PoisonPower:diff()} [gold]Отрути[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Nałóż {PoisonPower:diff()} pkt. [gold]Trucizny[/gold].
# [ru] Наносит {Damage:diff()} урона.
# Накладывает {PoisonPower:diff()} [gold]яда[/gold].
msgctxt "cards.json:IMPALE.description"
msgid "Deal {Damage:diff()} damage.\n"
"Apply {PoisonPower:diff()} [gold]Poison[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Накладае {PoisonPower:diff()} [gold]атруты[/gold]."

# [ua] Насаджування
# [pl] Przebicie
# [ru] Рогатина
msgctxt "cards.json:IMPALE.title"
msgid "Impale"
msgstr "Працінанне"

# [ua] Якщо у вас немає Атак у [gold]Руці[/gold], берете {Cards:diff()} карт.
# [pl] Jeżeli nie masz Ataku w [gold]ręce[/gold], dobierz {Cards:diff()}
# karty.
# [ru] Вы добираете {Cards:diff()} {Cards:plural(ru):карту|карты|карт}, если в
# [gold]руке[/gold] нет Атак.
msgctxt "cards.json:IMPATIENCE.description"
msgid "If you have no Attacks in your [gold]Hand[/gold], draw {Cards:diff()} cards."
msgstr "Калі ў вашай [gold]руцэ[/gold] няма карт Атакі, вы дабіраеце {Cards:diff()} {Cards:plural:карту|карты|карт}."

# [ua] Нетерплячість
# [pl] Niecierpliwość
# [ru] Неудержимость
msgctxt "cards.json:IMPATIENCE.title"
msgid "Impatience"
msgstr "Нецярплівасць"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
msgctxt "cards.json:IMPERVIOUS.description"
msgid "Gain {Block:diff()} [gold]Block[/gold]."
msgstr "Дае {Block:diff()} [gold]брані[/gold]."

# [ua] Невразливість
# [pl] Nieczułość
# [ru] Непробиваемость
msgctxt "cards.json:IMPERVIOUS.title"
msgid "Impervious"
msgstr "Непрыступнасць"

# [ua] Наприкінці вашого ходу, якщо ця карта у [gold]Руці[/gold], отримуєте
# {Damage:diff()} шкоди.
# [pl] Jeżeli trzymasz tę kartę w [gold]ręce[/gold] pod koniec tury, otrzymaj
# {Damage:diff()} pkt. obrażeń.
# [ru] Вы получите {Damage:diff()} урона, если эта карта останется в
# [gold]руке[/gold] до конца хода.
msgctxt "cards.json:INFECTION.description"
msgid "At the end of your turn, if this is in your [gold]Hand[/gold], take {Damage:diff()} damage."
msgstr "Калі гэта карта ёсць у вас на [gold]руцэ[/gold] ў канцы ходу, вы атрымліваеце {Damage:diff()} пашкоджання."

# [ua] Зараження
# [pl] Infekcja
# [ru] Инфекция
msgctxt "cards.json:INFECTION.title"
msgid "Infection"
msgstr "Інфекцыя"

# [ua] Додаєте випадкову Атаку до [gold]Руки[/gold]. Цього ходу її можна
# зіграти безкоштовно.
# [pl] Dodaj losowy Atak do [gold]ręki[/gold]. W tej turze jest darmowy.
# [ru] Добавляет в [gold]руку[/gold] случайную Атаку. В этом ходу она
# бесплатная.
msgctxt "cards.json:INFERNAL_BLADE.description"
msgid "Add a random Attack into your [gold]Hand[/gold]. It's free to play this turn."
msgstr "Дадае на [gold]руку[/gold] выпадковую карту Атакі. У гэтым ходзе яе можна разыграць задарма."

# [ua] Пекельний Клинок
# [pl] Piekielne ostrze
# [ru] Адский клинок
msgctxt "cards.json:INFERNAL_BLADE.title"
msgid "Infernal Blade"
msgstr "Пякельны клінок"

# [ua] На початку вашого ходу втрачаєте 1 ОЗ.
# Щоразу, коли ви втрачаєте ОЗ протягом свого ходу, наносите
# {InfernoPower:diff()} шкоди ВСІМ ворогам.
# [pl] Na początku tury utrać 1 PŻ.
# Kiedykolwiek utracisz PŻ podczas swojej tury, zadaj {InfernoPower:diff()}
# pkt. obrażeń WSZYSTKIM przeciwnikom.
# [ru] Вы теряете 1 ОЗ в начале хода.
# Наносит {InfernoPower:diff()} урона ВСЕМ врагам, когда вы теряете ОЗ в свой
# ход.
msgctxt "cards.json:INFERNO.description"
msgid "At the start of your turn, lose 1 HP.\n"
"Whenever you lose HP on your turn, deal {InfernoPower:diff()} damage to ALL enemies."
msgstr "На пачатку вашага ходу вы губляеце 1 АЗ.\n"
"Прычыняе {InfernoPower:diff()} пашкоджання УСІМ праціўнікам, калі вы губляеце АЗ на сваім ходзе."

# [ua] Пекло
# [pl] Piekło
# [ru] Кромешный ад
msgctxt "cards.json:INFERNO.title"
msgid "Inferno"
msgstr "Пекла"

# [ua] На початку вашого ходу додаєте 1 [gold]Запоясник[/gold] до
# [gold]Руки[/gold].
# [pl] Na początku tury dodaj 1 [gold]Nóż[/gold] do [gold]ręki[/gold].
# [ru] Добавляет в [gold]руку[/gold] 1 [gold]«Заточку»[/gold] в начале хода.
msgctxt "cards.json:INFINITE_BLADES.description"
msgid "At the start of your turn, add 1 [gold]Shiv[/gold] into your [gold]Hand[/gold]."
msgstr "На пачатку вашага ходу дадае 1 [gold]«Швайку»[/gold] ў [gold]руку[/gold]."

# [ua] Нескінченні Клинки
# [pl] A nóż się przyda
# [ru] Бесконечные клинки
msgctxt "cards.json:INFINITE_BLADES.title"
msgid "Infinite Blades"
msgstr "Бясконцыя клінкі"

# [ua] Отримайте {StrengthPower:diff()} [gold]Міці[/gold].
# [pl] Zyskaj {StrengthPower:diff()} pkt. [gold]Siły[/gold].
# [ru] Дает {StrengthPower:diff()} [gold]силы[/gold].
msgctxt "cards.json:INFLAME.description"
msgid "Gain {StrengthPower:diff()} [gold]Strength[/gold]."
msgstr "Дае {StrengthPower:diff()} [gold]моцы[/gold]."

# [ua] Розпалення
# [pl] Wewnętrzny płomień
# [ru] Воспламенение
msgctxt "cards.json:INFLAME.title"
msgid "Inflame"
msgstr "Узгаранне"

# [ua] Поранення
# [pl] Kontuzja
# [ru] Травма
msgctxt "cards.json:INJURY.title"
msgid "Injury"
msgstr "Траўма"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# Перенаправляєте всі вхідні атаки, що були б спрямовані проти іншого гравця
# цього ходу, на себе.
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# W tej turze zablokuj wszystkie ataki skierowane na innego gracza.
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# Перенаправляет все атаки в этом ходу с другого игрока на вас.
msgctxt "cards.json:INTERCEPT.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Redirect all incoming attacks that would be dealt to another player this turn to you."
msgstr "Дае {Block:diff()} [gold]Брані[/gold].\n"
"Перанакіроўвае на вас усе ўваходныя атакі гэтага ходу, што былі б скіраваныя ў іншага гульца."

# [ua] Перехоплення
# [pl] Schowaj się za mną
# [ru] Перехват
msgctxt "cards.json:INTERCEPT.title"
msgid "Intercept"
msgstr "Перахоп"

# [ua] Наступного ходу [gold]Призиваєте[/gold] {Summon:diff()} та отримуєте
# {Energy:energyIcons()}.
# [pl] W następnej turze [gold]Przywołaj[/gold] {Summon:diff()} i zyskaj
# {Energy:energyIcons()}.
# [ru] Даст {Energy:energyIcons()} и [gold]призовет[/gold] {Summon:diff()} в
# начале следующего хода.
msgctxt "cards.json:INVOKE.description"
msgid "Next turn, [gold]Summon[/gold] {Summon:diff()} and gain {Energy:energyIcons()}."
msgstr "На наступным ходзе [gold]выклікае[/gold] {Summon:diff()} і дае {Energy:energyIcons()}."

# [ua] Виклик
# [pl] Inwokacja
# [ru] Заклинание
msgctxt "cards.json:INVOKE.title"
msgid "Invoke"
msgstr "Заклінанне"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# Нанести {Damage:diff()} шкоди.
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# Zadaj {Damage:diff()} pkt. obrażeń.
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# Наносит {Damage:diff()} урона.
msgctxt "cards.json:IRON_WAVE.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Deal {Damage:diff()} damage."
msgstr "Дае {Block:diff()} [gold]Брані[/gold].\n"
"Прычыняе {Damage:diff()} пашкоджання."

# [ua] Залізна Хвиля
# [pl] Żelazna fala
# [ru] Стальная волна
msgctxt "cards.json:IRON_WAVE.title"
msgid "Iron Wave"
msgstr "Жалезная хваля"

# [ua] Вперше, коли ви берете карту Статусу кожного ходу, берете
# {IterationPower:diff()} {IterationPower:plural:карту|карти|карт}.
# [pl] Gdy dobierzesz kartę Stanu po raz pierwszy w tej turze, dobierz
# {IterationPower:diff()} {IterationPower:plural:kartę|karty|kart}.
# [ru] Вы добираете {IterationPower:diff()}
# {IterationPower:plural(ru):карту|карты|карт}, когда добираете Статус первый
# раз за ход.
msgctxt "cards.json:ITERATION.description"
msgid "The first time you draw a Status each turn, draw {IterationPower:diff()} {IterationPower:plural:card|cards}."
msgstr "Першы раз за ход, калі вы дабіраеце карту Статусу, вы дабіраеце яшчэ {IterationPower:diff()} {IterationPower:plural:карту|карты|карт}."

# [ua] Ітерація
# [pl] Nowa wersja
# [ru] Пробы и ошибки
msgctxt "cards.json:ITERATION.title"
msgid "Iteration"
msgstr "Ітэрацыя"

# [ua] Отримайте {Block:diff()} [gold]Броні[/gold].
# Наприкінці вашого ходу, якщо ця карта знаходиться на вершині вашого
# [gold]Добору[/gold], зіграйте її.
# [pl] Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold].
# Pod koniec tury zagraj tę kartę, jeżeli znajduje się na szczycie [gold]stosu
# rozgrywającego[/gold].
# [ru] Дает {Block:diff()} [gold]защиты[/gold].
# Разыгрывается, если находится на верху [gold]стопки добора[/gold] в конце
# хода.
msgctxt "cards.json:I_AM_INVINCIBLE.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"At the end of your turn, if this is on top of your [gold]Draw Pile[/gold], play it."
msgstr "Дае {Block:diff()} [gold]Брані[/gold].\n"
"У канцы вашага ходу, калі гэтая карта знаходзіцца зверху вашага [gold]стоса дабору[/gold], разыгрывае сябе."

# [ua] Я Непереможний
# [pl] Jestem niezwyciężony
# [ru] Неуязвимость
msgctxt "cards.json:I_AM_INVINCIBLE.title"
msgid "I Am Invincible"
msgstr "Я непераможны"

# [ua] Нанести {Damage:diff()} шкоди.
# Додайте {Cards:diff()} випадкових{IfUpgraded:show: [gold]Поліпшених[/gold]}
# 0{energyPrefix:energyIcons(1)} {Cards:plural:карту|карти|карт} до своєї
# [gold]Руки[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Dodaj {Cards:diff()} {Cards:plural:losową
# {IfUpgraded:show:[gold]Ulepszoną[/gold] }kartę kosztującą
# 0{energyPrefix:energyIcons(1)}|losowe
# {IfUpgraded:show:[gold]Ulepszone[/gold] }karty kosztujące
# 0{energyPrefix:energyIcons(1)}|losowych
# {IfUpgraded:show:[gold]Ulepszonych[/gold] }kart kosztujących
# 0{energyPrefix:energyIcons(1)}} do [gold]ręki[/gold].
# [ru] Наносит {Damage:diff()} урона.
# Добавляет в [gold]руку[/gold] {Cards:diff()}
# {Cards:plural(ru):случайную{IfUpgraded:show: [gold]улучшенную[/gold]}
# карту|случайные{IfUpgraded:show: [gold]улучшенные[/gold]}
# карты|случайных{IfUpgraded:show: [gold]улучшенных[/gold]} карт} стоимостью 0
# {energyPrefix:energyIcons(1)}.
msgctxt "cards.json:JACKPOT.description"
msgid "Deal {Damage:diff()} damage.\n"
"Add {Cards:diff()} random{IfUpgraded:show: [gold]Upgraded[/gold]} 0{energyPrefix:energyIcons(1)} {Cards:plural:card|cards} into your [gold]Hand[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Дадае на [gold]руку[/gold] {Cards:diff()} {Cards:plural:выпадковую{IfUpgraded:show: [gold]палепшаную[/gold]} карту|выпадковыя{IfUpgraded:show: [gold]палепшаныя[/gold]} карты|выпадковых{IfUpgraded:show: [gold]палепшаных[/gold]} карт}, якія каштуюць 0 {energyPrefix:energyIcons(1)}."

# [ua] Джекпот
# [pl] Loteria
# [ru] Джекпот
msgctxt "cards.json:JACKPOT.title"
msgid "Jackpot"
msgstr "Джэкпот"

# [ua] Додайте {Cards:diff()} випадкових Безбарвних
# {Cards:plural:карту|карти|карт} до своєї [gold]Руки[/gold].
# [pl] Dodaj {Cards:diff()} {Cards:plural:losową bezbarwną kartę|losowe
# bezbarwne karty|losowych bezbarwnych kart} do [gold]ręki[/gold].
# [ru] Добавляет в [gold]руку[/gold] {Cards:diff()}
# {Cards:plural(ru):случайную бесцветную карту|случайные бесцветные
# карты|случайных бесцветных карт}.
msgctxt "cards.json:JACK_OF_ALL_TRADES.description"
msgid "Add {Cards:diff()} random Colorless {Cards:plural:card|cards} into your [gold]Hand[/gold]."
msgstr "Дадае ў вашу [gold]руку[/gold] {Cards:diff()} {Cards:plural:выпадковую бясколерную карту|выпадковыя бясколерныя карты|выпадковых бясколерных карт}."

# [ua] Майстер на Всі Руки
# [pl] Złota rączka
# [ru] Мастер на все руки
msgctxt "cards.json:JACK_OF_ALL_TRADES.title"
msgid "Jack of All Trades"
msgstr "Майстар на ўсе рукі"

# [ua] Щоразу, коли Ви отримуєте [gold]Броню[/gold], нанести
# {JuggernautPower:diff()} шкоди випадковому ворогу.
# [pl] Kiedykolwiek zyskasz [gold]Blok[/gold], zadaj {JuggernautPower:diff()}
