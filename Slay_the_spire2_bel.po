msgid "Deal {Damage:diff()} damage X times.\n"
"Double X if it's {Energy:diff()} or more."
msgstr "Прычыняе {Damage:diff()} пашкоджання X разоў.\n"
"Падвойвае X, калі яно роўнае {Energy:diff()} або больш."

# [ua] Небесне Свердло
# [pl] Gwiazda Śmierci
# [ru] Ангельский бур
msgctxt "cards.json:HEAVENLY_DRILL.title"
msgid "Heavenly Drill"
msgstr "Нябесны свідар"

