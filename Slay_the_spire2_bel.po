msgid "Apply {VulnerablePower:diff()} [gold]Vulnerable[/gold].\n"
"Gain {StrengthPerVulnerable:diff()} [gold]Strength[/gold] for each [gold]Vulnerable[/gold] on the enemy."
msgstr "Накладае {VulnerablePower:diff()} [gold]безабароннасці[/gold].\n"
"Дае {StrengthPerVulnerable:diff()} [gold]моцы[/gold] за кожную адзінку [gold]безабароннасці[/gold] на праціўніку."

# [ua] Домінування
# [pl] Dominacja
# [ru] Превосходство
