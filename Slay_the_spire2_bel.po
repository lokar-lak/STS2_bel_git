msgid "You'll need more coin."
msgstr "Вам трэба больш манет."

# [ua] [sine]Це не благодійність.[/sine]
# [pl] [sine]Ja tego nie robię charytatywnie.[/sine]
# [ru] [sine]Благотворительностью не занимаюсь.[/sine]
msgctxt "merchant_room.json:MERCHANT.talk.purchaseFailureGold.line2"
msgid "[sine]This isn't a charity.[/sine]"
msgstr "[sine]Гэта вам не дабрачыннасць.[/sine]"

# [ua] Повертайтеся, коли станете трохи [jitter]заможнішим[/jitter].
# [pl] Wróć, jak już nie będziesz tak śmierdzieć [jitter]biedą[/jitter].
# [ru] Возвращайся, когда немного [jitter]разбогатеешь[/jitter]!
