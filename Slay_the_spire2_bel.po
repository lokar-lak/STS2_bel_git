# [ua] Переможіть у забігу з повністю поліпшеною колодою.
# [pl] Wygraj talią składającą się wyłącznie z ulepszonych kart.
# [ru] Выиграйте вылазку с полностью улучшенной колодой.
msgctxt "achievements.json:ALL_CARDS_UPGRADED.description"
msgid "Win a Run with a fully-upgraded deck."
msgstr "Выйграйце выправу з цалкам палепшанай калодай."

# [ua] Ідеальна колода
# [pl] Perfekcyjna talia
# [ru] Идеальная колода
msgctxt "achievements.json:ALL_CARDS_UPGRADED.title"
msgid "The Perfect Deck"
msgstr "Ідэальная калода"

# [ua] Виконайте всі інші Досягнення.
# [pl] Ukończ wszystkie pozostałe osiągnięcia.
# [ru] Получите все достижения.
msgctxt "achievements.json:ALL_OTHER_ACHIEVEMENTS.description"
msgid "Complete all other Achievements."
msgstr "Атрымайце ўсе іншыя дасягненні."

# [ua] Вічний
# [pl] Wiekopomny
# [ru] Вечность
msgctxt "achievements.json:ALL_OTHER_ACHIEVEMENTS.title"
msgid "Eternal One"
msgstr "Вечнасць"

# [ua] Спаліть 20 карт за один бій.
# [pl] Wyczerp 20 kart w jednej walce.
# [ru] Сожгите 20 карт за один бой.
msgctxt "achievements.json:CHARACTER_SKILL_IRONCLAD1.description"
msgid "Exhaust 20 cards in a single combat."
msgstr "Спаліце 20 карт за адзін бой."

# [ua] Пакт виконано
# [pl] Pakt spełniony
# [ru] Пакт выполнен
msgctxt "achievements.json:CHARACTER_SKILL_IRONCLAD1.title"
msgid "Pact Fulfilled"
msgstr "Пакт выкананы"

# [ua] Завдайте 999 Шкоди одним ударом.
# [pl] Zadaj 999 pkt. obrażeń jednym atakiem.
# [ru] Нанесите 999 урона одним ударом.
msgctxt "achievements.json:CHARACTER_SKILL_IRONCLAD2.description"
msgid "Deal 999 Damage in a single blow."
msgstr "Прычыніце 999 пашкоджання адным ударам."

# [ua] Найважчий клинок
# [pl] Najcięższe ostrze
# [ru] Тяжелейший клинок
msgctxt "achievements.json:CHARACTER_SKILL_IRONCLAD2.title"
msgid "Heaviest Blade"
msgstr "Найцяжэйшы клінок"

# [ua] Накладіть 999 Приреченості на одного ворога.
# [pl] Nałóż 999 pkt. Zagłady na jednego przeciwnika.
# [ru] Наложите 999 злого рока на одного врага.
msgctxt "achievements.json:CHARACTER_SKILL_NECROBINDER1.description"
msgid "Apply 999 Doom to a single enemy."
msgstr "Накладзіце 999 пагібелі на аднаго праціўніка."

# [ua] Вже мертвий
# [pl] Już nie żyjesz
# [ru] Не жилец
msgctxt "achievements.json:CHARACTER_SKILL_NECROBINDER1.title"
msgid "Already Dead"
msgstr "Не жылец"

# [ua] Накладіть 50 Міці на Ості.
# [pl] Dodaj Kostkowi 50 pkt. Siły.
# [ru] Наложите 50 силы на Костю.
msgctxt "achievements.json:CHARACTER_SKILL_NECROBINDER2.description"
msgid "Apply 50 Strength to Osty."
msgstr "Дадайце Костусю 50 моцы."

# [ua] Молоко
# [pl] Pij mleko! Będziesz wielki
# [ru] Молоко
msgctxt "achievements.json:CHARACTER_SKILL_NECROBINDER2.title"
msgid "Milk"
msgstr "Малако"

# [ua] Скуйте Владичний клинок, що завдає щонайменше 999 шкоди.
# [pl] Wykuj Niebiańskie Ostrze, które zadaje co najmniej 999 pkt. obrażeń.
# [ru] Скуйте Клинок монарха, который нанесет как минимум 999 урона.
msgctxt "achievements.json:CHARACTER_SKILL_REGENT1.description"
msgid "Forge a Sovereign Blade that does at least 999 damage."
msgstr "Загартуйце «Клінок манарха», які прычыняе прынамсі 999 пашкоджання."

# [ua] Клинок для монарха
# [pl] Ostrze godne króla
# [ru] Клинок, достойный монарха
msgctxt "achievements.json:CHARACTER_SKILL_REGENT1.title"
msgid "Blade Fit for a Monarch"
msgstr "Клінок, годны манарха"

# [ua] Маєте 20 Зірок одночасно.
# [pl] Miej 20 Gwiazd naraz.
# [ru] Накопите 20 Звезд.
msgctxt "achievements.json:CHARACTER_SKILL_REGENT2.description"
msgid "Have 20 Stars at once."
msgstr "Назапасьце 20 зорак."

# [ua] Сонця в небі
# [pl] Gwiazdy na niebie
# [ru] Небесные светила
msgctxt "achievements.json:CHARACTER_SKILL_REGENT2.title"
msgid "Suns in the Sky"
msgstr "Сонцы на небе"

# [ua] Зіграйте 5 карт через Хитрість з однієї карти.
# [pl] Zagraj 5 Chytrych kart za pomocą jednej karty.
# [ru] Разыграйте 5 коварных карт при помощи одной карты.
msgctxt "achievements.json:CHARACTER_SKILL_SILENT1.description"
msgid "Play 5 cards using Sly off a single card."
msgstr "Разыграйце 5 круцельскіх карт з дапамогай адной карты."

# [ua] Підступна Хитрість
# [pl] Chytry jak wonsz rzeczny
# [ru] Коварный хитрец
msgctxt "achievements.json:CHARACTER_SKILL_SILENT1.title"
msgid "Sneaky Sly"
msgstr "Падступная круцелька"

# [ua] Накладіть 99 Отрути на одного ворога.
# [pl] Nałóż 99 pkt. Trucizny na jednego przeciwnika.
# [ru] Наложите 99 яда на одного врага.
msgctxt "achievements.json:CHARACTER_SKILL_SILENT2.description"
msgid "Apply 99 Poison to a single enemy."
msgstr "Накладзіце 99 атруты на аднаго праціўніка."

# [ua] Кілька крапель
# [pl] Wystarczy kilka kropli
# [ru] Пара капель
msgctxt "achievements.json:CHARACTER_SKILL_SILENT2.title"
msgid "A Few Drops"
msgstr "Некалькі кропляў"

# [ua] Пройдіть Акт 4.
# [pl] Ukończ Akt 4.
# [ru] Пройдите 4-й акт.
msgctxt "achievements.json:COMPLETE_ACT4.description"
msgid "Complete Act 4."
msgstr "Завяршыце 4-ы акт."

# [ua] Справжній фінал
# [pl] Prawdziwe zakończenie
# [ru] Настоящая концовка
msgctxt "achievements.json:COMPLETE_ACT4.title"
msgid "True Ending"
msgstr "Сапраўдная канцоўка"

# [ua] Завершіть Хронологію.
# [pl] Ukończ Oś Czasu.
# [ru] Закончите Летопись.
msgctxt "achievements.json:COMPLETE_TIMELINE.description"
msgid "Complete the Timeline."
msgstr "Завяршыце Летапіс."

# [ua] Історик
# [pl] Historyk
# [ru] Историк
msgctxt "achievements.json:COMPLETE_TIMELINE.title"
msgid "Historian"
msgstr "Гісторык"

# [ua] Переможіть кожного ворога у Славі.
# [pl] Pokonaj każdego przeciwnika w Splendorze.
# [ru] Победите всех врагов в Чертоге.
msgctxt "achievements.json:DEFEAT_GLORY_ENEMIES.description"
msgid "Defeat every enemy in the Glory."
msgstr "Перамажыце ўсіх праціўнікаў у Хораме."

# [ua] Слава
# [pl] Splendor
# [ru] Чертог
msgctxt "achievements.json:DEFEAT_GLORY_ENEMIES.title"
msgid "The Glory"
msgstr "Хорам"

# [ua] Переможіть кожного ворога у Вулику.
# [pl] Pokonaj każdego przeciwnika w Roju.
# [ru] Победите всех врагов в Улье.
msgctxt "achievements.json:DEFEAT_HIVE_ENEMIES.description"
msgid "Defeat every enemy in the Hive."
msgstr "Перамажыце ўсіх праціўнікаў у Вуллі."

# [ua] Вулик
# [pl] Rój
# [ru] Улей
msgctxt "achievements.json:DEFEAT_HIVE_ENEMIES.title"
msgid "The Hive"
msgstr "Вулей"

# [ua] Переможіть Князя.
# [pl] Pokonaj Bossa.
# [ru] Победите босса.
msgctxt "achievements.json:DEFEAT_ONE_BOSS.description"
msgid "Defeat a Boss."
msgstr "Перамажыце боса."

# [ua] Перший з багатьох
# [pl] Jeden z wielu
# [ru] Первый, но не последний
msgctxt "achievements.json:DEFEAT_ONE_BOSS.title"
msgid "First of Many"
msgstr "Першы з многіх"

# [ua] Переможіть кожного ворога у Хащах.
# [pl] Pokonaj każdego przeciwnika w Zaroślach.
# [ru] Победите всех врагов в Зарослях.
msgctxt "achievements.json:DEFEAT_OVERGROWTH_ENEMIES.description"
msgid "Defeat every enemy in the Overgrowth."
msgstr "Перамажыце ўсіх праціўнікаў у Зарасніку."

# [ua] Хащі
# [pl] Zarośla
# [ru] Заросли
msgctxt "achievements.json:DEFEAT_OVERGROWTH_ENEMIES.title"
msgid "The Overgrowth"
msgstr "Зараснік"

# [ua] Переможіть кожного ворога у Підводді.
# [pl] Pokonaj każdego przeciwnika w Nabrzeżu.
# [ru] Победите всех врагов на Пристани.
msgctxt "achievements.json:DEFEAT_UNDERDOCKS_ENEMIES.description"
msgid "Defeat every enemy in the Underdocks."
msgstr "Перамажыце ўсіх праціўнікаў у Ніжніх прыстанях."

# [ua] Підводдя
# [pl] Nabrzeże
# [ru] Пристань
msgctxt "achievements.json:DEFEAT_UNDERDOCKS_ENEMIES.title"
msgid "The Underdocks"
msgstr "Ніжнія прыстані"

# [ua] Пройдіть Випробування 10 за Ґанджа.
# [pl] Ukończ grę na 10. poziomie Wyniesienia Defektem.
# [ru] Пройдите Возвышение 10 за Дефекта.
msgctxt "achievements.json:DEFECT_ASCENSION10.description"
msgid "Beat Ascension 10 as the Defect."
msgstr "Прайдзіце 10-ы ўзровень Узнясення за Дэфекта."

# [ua] Відлуння
# [pl] Echo
# [ru] Эхо
msgctxt "achievements.json:DEFECT_ASCENSION10.title"
msgid "Echo"
msgstr "Рэха"

# [ua] Переможіть за Ґанджа.
# [pl] Wygraj Defektem.
# [ru] Победите в вылазке за Дефекта.
msgctxt "achievements.json:DEFECT_WIN.description"
msgid "Win as the Defect."
msgstr "Перамажыце за Дэфекта."

# [ua] Ґандж
# [pl] The Defect
# [ru] Дефект
msgctxt "achievements.json:DEFECT_WIN.title"
msgid "The Defect"
msgstr "Дэфект"

# [ua] {Description}
# 
# [gold]Відкрито:[/gold] {UnlockTime}
# [pl] {Description}
# 
# [gold]Odblokowano:[/gold] {UnlockTime}
# [ru] {Description}
# 
# [gold]Разблокировано:[/gold] {UnlockTime}
msgctxt "achievements.json:DESCRIPTION_WITH_UNLOCK_TIME"
msgid "{Description}\n\n"
"[gold]Unlocked:[/gold] {UnlockTime}"
msgstr "{Description}\n\n"
"[gold]Разблакавана:[/gold] {UnlockTime}"

# [ua] Відкрийте всі Карти.
# [pl] Odkryj wszystkie karty.
# [ru] Найдите все карты.
msgctxt "achievements.json:DISCOVER_ALL_CARDS.description"
msgid "Discover all Cards."
msgstr "Знайдзіце ўсе карты."

# [ua] Колекціонер
# [pl] Kolekcjoner
# [ru] Коллекционер
msgctxt "achievements.json:DISCOVER_ALL_CARDS.title"
msgid "Collector"
msgstr "Калекцыянер"

# [ua] Зустріньте всі Події.
# [pl] Napotkaj się na wszystkie wydarzenia.
# [ru] Поучаствуйте во всех событиях.
msgctxt "achievements.json:DISCOVER_ALL_EVENTS.description"
msgid "Encounter all Events."
msgstr "Вазьміце ўдзел ва ўсіх падзеях."

# [ua] Дослідник
# [pl] Podróżnik
# [ru] Исследователь
msgctxt "achievements.json:DISCOVER_ALL_EVENTS.title"
msgid "Explorer"
msgstr "Даследчык"

# [ua] Відкрийте всі Амулети.
# [pl] Odkryj wszystkie Artefakty.
# [ru] Найдите все реликвии.
msgctxt "achievements.json:DISCOVER_ALL_RELICS.description"
msgid "Discover all Relics."
msgstr "Знайдзіце ўсе рэліквіі."

# [ua] Археолог
# [pl] Archeolog
# [ru] Археолог
msgctxt "achievements.json:DISCOVER_ALL_RELICS.title"
msgid "Archaeologist"
msgstr "Археолаг"

# [ua] Подолайте 10 000 поверхів.
# [pl] Pokonaj 10 000 pięter.
# [ru] Покорите 10 000 этажей.
msgctxt "achievements.json:FLOOR_TEN_THOUSAND.description"
msgid "Climb 10,000 floors."
msgstr "Прайдзіце 10 000 паверхаў."

# [ua] Багато сходинок
# [pl] Dużo schodów
# [ru] Бесконечная лестница
msgctxt "achievements.json:FLOOR_TEN_THOUSAND.title"
msgid "A Lot of Stairs"
msgstr "Бясконцыя сходы"

# [ua] Пройдіть Випробування 10 за Броненосця.
# [pl] Ukończ grę na 10. poziomie Wyniesienia Pancernikiem.
# [ru] Пройдите Возвышение 10 за Латоносца.
msgctxt "achievements.json:IRONCLAD_ASCENSION10.description"
msgid "Beat Ascension 10 as the Ironclad."
msgstr "Прайдзіце 10-ы ўзровень Узнясення за Браняносца."

# [ua] Демон
# [pl] Demon
# [ru] Демон
msgctxt "achievements.json:IRONCLAD_ASCENSION10.title"
msgid "Demon"
msgstr "Дэман"

# [ua] Переможіть за Броненосця.
# [pl] Wygraj Pancernikiem.
# [ru] Пройдите вылазку за Латоносца.
msgctxt "achievements.json:IRONCLAD_WIN.description"
msgid "Win as the Ironclad."
msgstr "Перамажыце за Браняносца."

# [ua] Броненосець
# [pl] The Ironclad
# [ru] Латоносец
msgctxt "achievements.json:IRONCLAD_WIN.title"
msgid "The Ironclad"
msgstr "Браняносец"

# [ua] Деталі цього Досягнення — таємниця...
# [pl] Szczegóły tego osiągnięcia są tajne...
# [ru] Это достижение покрыто тайной.
msgctxt "achievements.json:LOCKED.secretDescription"
msgid "The details for this Achievement are a secret..."
msgstr "Падрабязнасці гэтага дасягнення — таямніца..."

# [ua] Закрито
# [pl] Zablokowane
# [ru] Закрыто
msgctxt "achievements.json:LOCKED.title"
msgid "Locked"
msgstr "Недаступна"

# [ua] Пройдіть Випробування 10 за Некромантку.
# [pl] Ukończ grę na 10. poziomie Wyniesienia Nekromantką.
# [ru] Пройдите Возвышение 10 за Призывающую.
msgctxt "achievements.json:NECROBINDER_ASCENSION10.description"
msgid "Beat Ascension 10 as the Necrobinder."
