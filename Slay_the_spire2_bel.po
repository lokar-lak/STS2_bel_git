msgctxt "powers.json:SLIPPERY_POWER.smartDescription"
msgid "The next {Amount:plural:time|[blue]{}[/blue] times} [gold]{OwnerName}[/gold] loses HP, it only loses [blue]1[/blue] HP instead."
msgstr "Наступн{Amount:plural:ым разам|ыя [blue]{}[/blue] разы|ыя [blue]{}[/blue] разоў}, калі [gold]{OwnerName}[/gold] губляе АЗ, ён губляе толькі [blue]1[/blue] АЗ."

# [ua] Слизький
# [pl] Śliskość
# [ru] Изворотливость
msgctxt "powers.json:SLIPPERY_POWER.title"
msgid "Slippery"
msgstr "Слізкасць"

# [ua] Ви не можете зігравати більше [blue]3[/blue] карт за хід.
# [pl] W każdej turze nie możesz zagrać więcej niż [blue]3[/blue] karty.
# [ru] Вы можете разыграть не более [blue]3[/blue] карт за ход.
msgctxt "powers.json:SLOTH_POWER.description"
msgid "You cannot play more than [blue]3[/blue] cards each turn."
msgstr "Вы не можаце разыгрываць больш за [blue]3[/blue] карты за ход."

# [ua] Ви не можете зігравати більше [blue]{Amount}[/blue]
# {Amount:plural:карту|карти|карт} за хід.
# [pl] W każdej turze nie możesz zagrać więcej niż [blue]{Amount}[/blue]
# {Amount:plural:kartę|karty|kart}.
# [ru] Вы можете разыграть не более [blue]{Amount}[/blue]
# {Amount:plural(ru):карты|карт|карт} за ход.
msgctxt "powers.json:SLOTH_POWER.smartDescription"
msgid "You cannot play more than [blue]{Amount}[/blue] {Amount:plural:card|cards} each turn."
msgstr "Вы не можаце разыгрываць больш за [blue]{Amount}[/blue] {Amount:plural:карту|карты|карт} за ход."

# [ua] Лінощі
# [pl] Lenistwo
# [ru] Лень
msgctxt "powers.json:SLOTH_POWER.title"
msgid "Sloth"
msgstr "Лянота"

# [ua] Щоразу, як Ви граєте карту, цей ворог отримує на [blue]10%[/blue]
# більше шкоди від Атак цього ходу.
# [pl] Kiedykolwiek zagrasz kartę, ten przeciwnik otrzymuje [blue]10%[/blue]
# więcej obrażeń od Ataków w tej turze.
# [ru] Получает на [blue]10%[/blue] больше урона от Атак в этом ходу, когда вы
# разыгрываете карты.
msgctxt "powers.json:SLOW_POWER.description"
msgid "Whenever you play a card, this enemy receives [blue]10%[/blue] more damage from Attacks this turn."
msgstr "Штораз, калі вы разыгрываеце карту, гэты праціўнік атрымлівае на [blue]10%[/blue] больш пашкоджання ад Атак у гэтым ходзе."

# [ua] Щоразу, як Ви граєте карту, {OnPlayer:Ви отримуєте|цей ворог отримує}
# на [blue]10%[/blue] більше шкоди від Атак цього ходу.{Amount:plural:||
# (Отримує на [blue]{Amount}%[/blue] більше шкоди)}
# [pl] Kiedykolwiek zagrasz kartę, {OnPlayer:otrzymujesz|ten przeciwnik
# otrzymuje} [blue]10%[/blue] więcej obrażeń od Ataków w tej
# turze.{Amount:plural:|| (Otrzymuje [blue]{Amount}%[/blue] więcej obrażeń)}
# [ru] {OnPlayer:Вы получаете|Получает} на [blue]10%[/blue] больше урона от
# Атак в этом ходу после того, как{OnPlayer:| вы} разыгрываете
# карту.{Amount:plural:||}
msgctxt "powers.json:SLOW_POWER.smartDescription"
msgid "Whenever you play a card, {OnPlayer:you receive|this enemy receives} [blue]10%[/blue] more damage from Attacks this turn.{Amount:plural:|| (Receives [blue]{Amount}%[/blue] more damage)}"
msgstr "Штораз, калі вы разыгрываеце карту, {OnPlayer:вы атрымліваеце|гэты праціўнік атрымлівае} на [blue]10%[/blue] больш пашкоджання ад Атак у гэтым ходзе.{Amount:plural:|| (Атрымлівае на [blue]{Amount}%[/blue] больш пашкоджання)}"

# [ua] Уповільнення
# [pl] Spowolnienie
# [ru] Медлительность
msgctxt "powers.json:SLOW_POWER.title"
msgid "Slow"
msgstr "Запаволенне"

# [ua] Прокидається після того, як проходять ходи або втрачає ОЗ 3 рази.
# [pl] Budzi się po rozegraniu 3 tur lub po utraceniu PŻ 3 razy.
# [ru] Пробуждается через 3 хода или после того, как 3 раза потеряет ОЗ.
msgctxt "powers.json:SLUMBER_POWER.description"
msgid "Awakens upon taking turns or losing HP 3 times."
msgstr "Прачынаецца пасля свайго ходу або пасля 3 разоў страты АЗ."

# [ua] Прокидається після того, як проходять ходи або втрачає ОЗ
# [blue]{Amount}[/blue] {Amount:plural:раз|рази|разів}.
# [pl] Budzi się po rozegraniu [blue]{Amount}[/blue]
# {Amount:plural:tury|tur|tur} lub po utraceniu PŻ [blue]{Amount}[/blue]
# {Amount:plural:raz|razy|razy}.
# [ru] Пробуждается {Amount:plural(ru):в конце этого хода|через
# [blue]{}[/blue] хода|через [blue]{}[/blue] ходов} или после того, как
# потеряет ОЗ [blue]{Amount}[/blue] {Amount:plural(ru):раз|раза|раз}.
msgctxt "powers.json:SLUMBER_POWER.smartDescription"
msgid "Awakens upon taking turns or losing HP [blue]{Amount}[/blue] {Amount:plural:time|times}."
msgstr "Прачынаецца пасля свайго ходу або пасля [blue]{Amount}[/blue] {Amount:plural:разу страты|разоў страты|разоў страты} АЗ."

# [ua] Сон
# [pl] Sen
# [ru] Дремота
msgctxt "powers.json:SLUMBER_POWER.title"
msgid "Slumber"
msgstr "Дрымота"

# [ua] Ви можете зігравати лише [blue]1[/blue] Вміння за хід.
# [pl] W każdej turze możesz zagrać tylko [blue]1[/blue] Umiejętność.
# [ru] Вы можете разыграть не больше [blue]1[/blue] Навыка за ход.
msgctxt "powers.json:SMOGGY_POWER.description"
msgid "You can only play [blue]1[/blue] Skill per turn."
msgstr "Вы можаце разыграць толькі [blue]1[/blue] карту Умення за ход."

# [ua] Ви можете зігравати лише [blue]{Amount}[/blue] Вміння за хід.
# [pl] W każdej turze możesz zagrać tylko [blue]{Amount}[/blue]
# {Amount:plural:Umiejętność|Umiejętności|Umiejętności}.
# [ru] Вы можете разыграть не больше [blue]{Amount}[/blue]
# {Amount:plural(ru):Навыка|Навыков|Навыков} за ход.
msgctxt "powers.json:SMOGGY_POWER.smartDescription"
msgid "You can only play [blue]{Amount}[/blue] Skill per turn."
msgstr "Вы можаце разыграць толькі [blue]{Amount}[/blue] {Amount:plural:карту Умення|карты Умення|карт Умення} за ход."

# [ua] Задимлений
# [pl] Pełno smogu
# [ru] Смог
msgctxt "powers.json:SMOGGY_POWER.title"
msgid "Smoggy"
msgstr "Смог"

# [ua] Щоразу, як Ви створюєте Статус, наносите шкоду ВСІМ ворогам.
# [pl] Kiedykolwiek stworzysz kartę Stanu, zadaj obrażenia WSZYSTKIM
# przeciwnikom.
# [ru] Наносит урон ВСЕМ врагам, когда вы создаете Статус.
msgctxt "powers.json:SMOKESTACK_POWER.description"
msgid "Whenever you create a Status, deal damage to ALL enemies."
msgstr "Штораз, калі вы ствараеце карту Статусу, прычыняе пашкоджанне УСІМ праціўнікам."

# [ua] Щоразу, як Ви створюєте Статус, наносите [blue]{Amount}[/blue] шкоди
# ВСІМ ворогам.
# [pl] Kiedykolwiek stworzysz kartę Stanu, zadaj [blue]{Amount}[/blue] pkt.
# obrażeń WSZYSTKIM przeciwnikom.
# [ru] Наносит [blue]{Amount}[/blue] урона ВСЕМ врагам, когда вы создаете
# Статус.
msgctxt "powers.json:SMOKESTACK_POWER.smartDescription"
msgid "Whenever you create a Status, deal [blue]{Amount}[/blue] damage to ALL enemies."
msgstr "Штораз, калі вы ствараеце карту Статусу, прычыняе [blue]{Amount}[/blue] пашкоджання УСІМ праціўнікам."

# [ua] Димохід
# [pl] Komin
# [ru] Дымоход
msgctxt "powers.json:SMOKESTACK_POWER.title"
msgid "Smokestack"
msgstr "Дымар"

# [ua] Щоразу, як інший гравець атакує ворога, Ви отримуєте
# [gold]Броню[/gold].
# [pl] Kiedykolwiek inny gracz zaatakuje przeciwnika, zyskaj
# [gold]Blok[/gold].
# [ru] Дает [gold]защиту[/gold], когда другой игрок атакует врага.
msgctxt "powers.json:SNEAKY_POWER.description"
msgid "Whenever another player attacks an enemy, gain [gold]Block[/gold]."
msgstr "Штораз, калі іншы гулец атакуе праціўніка, вы атрымліваеце [gold]браню[/gold]."

# [ua] Щоразу, як інший гравець атакує ворога, Ви отримуєте
# [blue]{Amount}[/blue] [gold]Броні[/gold].
# [pl] Kiedykolwiek inny gracz zaatakuje przeciwnika, zyskaj
# [blue]{Amount}[/blue] pkt. [gold]Bloku[/gold].
# [ru] Дает [blue]{Amount}[/blue] [gold]защиты[/gold], когда другой игрок
# атакует врага.
msgctxt "powers.json:SNEAKY_POWER.smartDescription"
msgid "Whenever another player attacks an enemy, gain [blue]{Amount}[/blue] [gold]Block[/gold]."
msgstr "Штораз, калі іншы гулец атакуе праціўніка, вы атрымліваеце [blue]{Amount}[/blue] [gold]брані[/gold]."

# [ua] Хитрий
# [pl] Cwaniaczek
# [ru] Скрытность
msgctxt "powers.json:SNEAKY_POWER.title"
msgid "Sneaky"
msgstr "Стоенасць"

# [ua] Отримує на [gold]50%[/gold] менше шкоди від атак, доки не приземлиться.
# [pl] Otrzymuje [gold]50%[/gold] mniej obrażeń od ataków aż do wylądowania.
# [ru] Получает [gold]50%[/gold] урона от Атак, пока не приземлится.
msgctxt "powers.json:SOAR_POWER.description"
msgid "Receives [gold]50%[/gold] less attack damage until it lands."
msgstr "Атрымлівае на [gold]50%[/gold] менш пашкоджання ад Атак, пакуль не прызямліцца."

# [ua] Отримує на [blue]{DamageDecrease}%[/blue] менше шкоди від атак, доки не
# приземлиться.
# [pl] Otrzymuje [blue]{DamageDecrease}%[/blue] mniej obrażeń od ataków aż do
# wylądowania.
# [ru] Получает [gold]{DamageDecrease}%[/gold] урона от Атак, пока не
# приземлится.
msgctxt "powers.json:SOAR_POWER.smartDescription"
msgid "Receives [blue]{DamageDecrease}%[/blue] less attack damage until it lands."
msgstr "Атрымлівае на [blue]{DamageDecrease}%[/blue] менш пашкоджання ад Атак, пакуль не прызямліцца."

# [ua] Політ
# [pl] Lot
# [ru] Крылья
msgctxt "powers.json:SOAR_POWER.title"
msgid "Soar"
msgstr "Палёт"

# [ua] Після того, як Душевний Нексус завдає Вам незаблокованої шкоди від атак
# 9 разів, він завдає Вам 999 шкоди.
# [pl] Gdy Spojenie Dusz zada ci niezablokowane obrażenia od ataku 9 razy,
# zadaje ci 999 pkt. obrażeń.
# [ru] Вы получите 999 урона, когда Чистилище нанесет вам урон по ОЗ атаками 9
# раз.
msgctxt "powers.json:SOUL_WITHER.description"
msgid "After Soul Nexus deals unblocked attack damage to you 9 times, it deals 999 damage to you."
msgstr "Пасля таго як вузел душ 9 разоў прычыніць вам незаблакаванае пашкоджанне ад Атак, ён прычыніць вам 999 пашкоджання."

# [ua] Після того, як Душевний Нексус завдає Вам незаблокованої шкоди від атак
# [blue]{Amount}[/blue] {Amount:plural:раз|рази|разів}, він завдає Вам
# [blue]{Damage}[/blue] шкоди.
# [pl] Gdy Spojenie Dusz zada ci niezablokowane obrażenia od ataku
# [blue]{Amount}[/blue] {Amount:plural:raz|razy|razy}, zadaje ci
# [blue]{Damage}[/blue] pkt. obrażeń.
# [ru] Вы получите [blue]{Damage}[/blue] урона, если потеряете ОЗ от атак
# Чистилища еще [blue]{Amount}[/blue] {Amount:plural(ru):раз|раза|раз}.
msgctxt "powers.json:SOUL_WITHER.smartDescription"
msgid "After Soul Nexus deals unblocked attack damage to you [blue]{Amount}[/blue] {Amount:plural:time|times}, it deals [blue]{Damage}[/blue] damage to you."
msgstr "Пасля таго як вузел душ [blue]{Amount}[/blue] {Amount:plural:раз|разы|разоў} прычыніць вам незаблакаванае пашкоджанне ад Атак, ён прычыніць вам [blue]{Damage}[/blue] пашкоджання."

# [ua] Виснаження Душі
# [pl] Uschnięcie duszy
# [ru] Увядание души
msgctxt "powers.json:SOUL_WITHER.title"
msgid "Soul Wither"
msgstr "Завяданне душы"

# [ua] [gold]Заховати[/gold] [blue]1[/blue] випадкову карту у Вашій
# [gold]Руці[/gold] цього ходу.
# [pl] [gold]Zachowaj[/gold] [blue]1[/blue] losową kartę w [gold]ręcę[/gold] w
# tej turze.
# [ru] В этом ходу вы [gold]оставляете[/gold] [blue]1[/blue] случайную карту в
# [gold]руке[/gold].
msgctxt "powers.json:SOW_POWER.description"
msgid "[gold]Retain[/gold] [blue]1[/blue] random card in your [gold]Hand[/gold] this turn."
msgstr "[gold]Захоўвае[/gold] [blue]1[/blue] выпадковую карту ў вашай [gold]руцэ[/gold] у гэтым ходзе."

# [ua] [gold]Заховати[/gold] [blue]{Amount}[/blue] випадкових
# {Amount:plural:карту|карти|карт} у Вашій [gold]Руці[/gold] цього ходу.
# [pl] [gold]Zachowaj[/gold] [blue]{Amount}[/blue] {Amount:plural:losową
# kartę|losowe karty|losowych kart|losowych kart} w [gold]ręcę[/gold] w tej
# turze.
# [ru] В этом ходу вы [gold]оставляете[/gold] [blue]{Amount}[/blue]
# {Amount:plural(ru):случайную карту|случайные карты|случайных карты} в
# [gold]руке[/gold].
msgctxt "powers.json:SOW_POWER.smartDescription"
msgid "[gold]Retain[/gold] [blue]{Amount}[/blue] random {Amount:plural:card|cards} in your [gold]Hand[/gold] this turn."
msgstr "[gold]Захоўвае[/gold] [blue]{Amount}[/blue] выпадков{Amount:plural:ую карту|ыя карты|ых карт} у вашай [gold]руцэ[/gold] у гэтым ходзе."

# [ua] Посів
# [pl] Zasiew
# [ru] Посев
msgctxt "powers.json:SOW_POWER.title"
msgid "Sow"
msgstr "Сяўба"

# [ua] На початку Вашого ходу додайте [blue]1[/blue] випадкову Безбарвну карту
# до Вашої [gold]Руки[/gold].
# [pl] Na początku tury dodaj [blue]1[/blue] losową bezbarwną kartę do
# [gold]ręki[/gold].
# [ru] Добавляет в [gold]руку[/gold] [blue]1[/blue] случайную бесцветную карту
# в начале хода.
msgctxt "powers.json:SPECTRUM_SHIFT_POWER.description"
msgid "At the start of your turn, add [blue]1[/blue] random Colorless card into your [gold]Hand[/gold]."
msgstr "На пачатку вашага ходу дадае [blue]1[/blue] выпадковую бясколерную карту ў вашу [gold]руку[/gold]."

# [ua] На початку Вашого ходу додайте [blue]{Amount}[/blue] випадкових
# Безбарвних {Amount:plural:карту|карти|карт} до Вашої [gold]Руки[/gold].
# [pl] Na początku tury dodaj [blue]{Amount}[/blue] {Amount:plural:losową
# bezbarwną kartę|losowe bezbarwne karty|losowych bezbarwnych kart} do
# [gold]ręki[/gold].
# [ru] Добавляет в [gold]руку[/gold] [blue]{Amount}[/blue]
# {Amount:plural(ru):случайную бесцветную карту|случайные бесцветные
# карты|случайных бесцветных карт} в начале хода.
msgctxt "powers.json:SPECTRUM_SHIFT_POWER.smartDescription"
msgid "At the start of your turn, add [blue]{Amount}[/blue] random Colorless {Amount:plural:card|cards} into your [gold]Hand[/gold]."
msgstr "На пачатку вашага ходу дадае [blue]{Amount}[/blue] {Amount:plural:выпадковую бясколерную карту|выпадковыя бясколерныя карты|выпадковых бясколерных карт} у вашу [gold]руку[/gold]."

# [ua] Зміщення Спектру
# [pl] Przesunięcie spektrum
# [ru] Спектральный сдвиг
msgctxt "powers.json:SPECTRUM_SHIFT_POWER.title"
msgid "Spectrum Shift"
msgstr "Спектральны зрух"

# [ua] Щоразу, як Ви тягнете карту під час Вашого ходу, наносите
# [blue]1[/blue] шкоди ВСІМ ворогам.
# [pl] Kiedykolwiek dobierzesz kartę podczas swojej tury, zadaj [blue]1[/blue]
# pkt. obrażeń WSZYSTKIM przeciwnikom.
# [ru] Наносит [blue]1[/blue] урона ВСЕМ врагам, когда вы добираете карту в
# этом ходу.
msgctxt "powers.json:SPEEDSTER_POWER.description"
msgid "Whenever you draw a card during your turn, deal [blue]1[/blue] damage to ALL enemies."
msgstr "Штораз, калі вы дабіраеце карту падчас свайго ходу, прычыняе [blue]1[/blue] пашкоджанне УСІМ праціўнікам."

# [ua] Щоразу, як Ви тягнете карту під час Вашого ходу, наносите
# [blue]{Amount}[/blue] шкоди ВСІМ ворогам.
# [pl] Kiedykolwiek dobierzesz kartę podczas swojej tury, zadaj
# [blue]{Amount}[/blue] pkt. obrażeń WSZYSTKIM przeciwnikom.
# [ru] Наносит [blue]{Amount}[/blue] урона ВСЕМ врагам, когда вы добираете
# карту в этом ходу.
msgctxt "powers.json:SPEEDSTER_POWER.smartDescription"
msgid "Whenever you draw a card during your turn, deal [blue]{Amount}[/blue] damage to ALL enemies."
msgstr "Штораз, калі вы дабіраеце карту падчас свайго ходу, прычыняе [blue]{Amount}[/blue] пашкоджання УСІМ праціўнікам."

# [ua] Швидкун
# [pl] Szybcior
# [ru] Гонка
msgctxt "powers.json:SPEEDSTER_POWER.title"
msgid "Speedster"
msgstr "Спрытнюга"

# [ua] На початку Вашого ходу [gold]Спрямовуєте[/gold] [blue]1[/blue]
# [gold]Скло[/gold].
# [pl] Na początku tury [gold]Załaduj[/gold] [blue]1[/blue] [gold]Sferę
# Szkła[/gold].
# [ru] [gold]Заряжает[/gold] [blue]1[/blue] [gold]сферу стекла[/gold] в начале
# хода.
msgctxt "powers.json:SPINNER_POWER.description"
msgid "At the start of your turn, [gold]Channel[/gold] [blue]1[/blue] [gold]Glass[/gold]."
msgstr "На пачатку вашага ходу [gold]зараджае[/gold] [blue]1[/blue] [gold]сферу шкла[/gold]."

# [ua] На початку Вашого ходу [gold]Спрямовуєте[/gold] [blue]{Amount}[/blue]
# [gold]Скла[/gold].
# [pl] Na początku tury [gold]Załaduj[/gold] [blue]{Amount}[/blue]
# [gold]{Amount:plural:Sferę|Sfery|Sfer} Szkła[/gold].
# [ru] [gold]Заряжает[/gold] [blue]{Amount}[/blue]
# [gold]{Amount:plural(ru):сферу стекла|сферы стекла|сфер стекла}[/gold] в
# начале хода.
msgctxt "powers.json:SPINNER_POWER.smartDescription"
msgid "At the start of your turn, [gold]Channel[/gold] [blue]{Amount}[/blue] [gold]Glass[/gold]."
msgstr "На пачатку вашага ходу [gold]зараджае[/gold] [blue]{Amount}[/blue] [gold]{Amount:plural:сферу шкла|сферы шкла|сфер шкла}[/gold]."

# [ua] Прядка
# [pl] Szklana wirówka
# [ru] Спиннер
msgctxt "powers.json:SPINNER_POWER.title"
msgid "Spinner"
msgstr "Кручэнне сфер"

# [ua] Щоразу, як Ви граєте [gold]Ефемерну[/gold] карту, отримуєте
# [blue]4[/blue] [gold]Броні[/gold].
# [pl] Kiedykolwiek zagrasz [gold]Eteryczną[/gold] kartę, zyskaj
# [blue]4[/blue] pkt. [gold]Bloku[/gold].
# [ru] Дает [blue]4[/blue] [gold]защиты[/gold], когда вы разыгрываете
