msgid "None"
msgstr "Няма"

# [ua] Гучність музики
# [pl] Głośność muzyki
# [ru] Громкость музыки
msgctxt "settings_ui.json:MUSIC_VOLUME"
msgid "BGM Volume"
msgstr "Гучнасць фонавай музыкі"

# [pl] Tryb fobii
# [ru] Режим фобии
msgctxt "settings_ui.json:PHOBIA_MODE"
msgid "Phobia Mode"
msgstr "Рэжым фобіі"

# [pl] Redukuje lub zamienia niepokojące efekty wizualne i animacje.
# [ru] Заменяет некоторые визуальные элементы, которые могут вызывать тревогу
# у игроков.
msgctxt "settings_ui.json:PHOBIA_MODE_DESCRIPTION"
msgid "Reduces or replaces disturbing visuals and animations for players affected by disturbing patterns and unsettling animations."
msgstr "Змяншае або замяняе візуальныя эфекты і анімацыі, якія могуць выклікаць трывогу."

# [ua] Скинути налаштування
# [pl] Przywróć ustawienia domyślne
# [ru] Сбросить настройки
msgctxt "settings_ui.json:RESET_CONFIRMATION.header"
msgid "Reset Settings"
msgstr "Скінуць налады"

# [ua] Скинути за замовчуванням
# [pl] Przywróć ustawienia domyślne
# [ru] По умолчанию
msgctxt "settings_ui.json:RESET_DEFAULT"
msgid "Reset to Default"
msgstr "Скінуць налады да прадвызначаных"

# [ua] Ви впевнені, що хочете скинути всі ігрові налаштування за
# замовчуванням?
# [pl] Czy chcesz przywrócić wszystkie domyślne ustawienia rozgrywki?
# [ru] Вы точно хотите восстановить настройки игрового процесса по умолчанию?
msgctxt "settings_ui.json:RESET_GAMEPLAY_CONFIRMATION.body"
msgid "Are you sure you want to reset all gameplay settings to default?"
msgstr "Вы ўпэўнены, што хочаце скінуць усе налады гульнявога працэсу да прадвызначаных?"

# [ua] Ви впевнені, що хочете скинути всі графічні налаштування за
# замовчуванням?
# [pl] Czy chcesz przywrócić wszystkie domyślne ustawienia grafiki?
# [ru] Вы точно хотите восстановить настройки графики по умолчанию?
msgctxt "settings_ui.json:RESET_GRAPHICS_CONFIRMATION.body"
msgid "Are you sure you want to reset all graphics settings to default?"
msgstr "Вы ўпэўнены, што хочаце скінуць усе налады графікі да прадвызначаных?"

# [ua] Скинути
# [pl] Zresetuj
# [ru] Сбросить
msgctxt "settings_ui.json:RESET_SETTINGS_BUTTON"
msgid "Reset"
msgstr "Скінуць"

# [ua] Роздільна здатність вікна
# [pl] Rozdzielczość w trybie okna
# [ru] Разрешение окна
msgctxt "settings_ui.json:RESOLUTION"
msgid "Windowed Resolution"
msgstr "Раздзяляльнасць акна"

# [ua] Зберегти і вийти
# [pl] Zapisz i wyjdź
# [ru] Сохранить и выйти
msgctxt "settings_ui.json:SAVE_EXIT"
msgid "Save & Exit"
msgstr "Захаваць і выйсці"

# [ua] Тремтіння екрана
# [pl] Drżenie ekranu
# [ru] Тряска экрана
msgctxt "settings_ui.json:SCREENSHAKE"
msgid "Screenshake"
msgstr "Трасенне экрана"

# [ua] КАААР!
# [pl] KRAAA!
# [ru] КАР-Р-Р!
msgctxt "settings_ui.json:SCREENSHAKE_CAAAW"
msgid "CAAAW!"
msgstr "К-А-А-А-Р!"

# [ua] Налаштуйте, наскільки сильно тремтить екран під час атаки чи отримання
# шкоди та інших ігрових дій.
# [pl] Dopasuj, jak mocno ekran trzęsie się podczas atakowania, otrzymywania
# obrażeń i innych akcji w grze.
# [ru] Настройте уровень дрожания экрана в ответ на ваши атаки, получение
# урона и прочие игровые действия.
msgctxt "settings_ui.json:SCREENSHAKE_DESCRIPTION"
msgid "Adjust how much the screen moves when you attack or receive damage and other in-game actions."
msgstr "Рэгулюйце, наколькі будзе дрыжаць экран, калі вы атакуеце, атрымліваеце пашкоджанне ці выконваеце іншыя гульнявыя дзеянні."

# [ua] Тремтіння екрана
# [pl] Trzęsienie ekranu
# [ru] Тряска экрана
msgctxt "settings_ui.json:SCREENSHAKE_HEADER"
msgid "Screenshake"
msgstr "Трасенне экрана"

# [ua] Багато
# [pl] Mocniejsze
# [ru] Сильная
msgctxt "settings_ui.json:SCREENSHAKE_LOTS"
msgid "Lots"
msgstr "Шмат"

# [ua] Немає
# [pl] Wyłącz
# [ru] Нет
msgctxt "settings_ui.json:SCREENSHAKE_NONE"
msgid "None"
msgstr "Няма"

# [ua] Звичайне
# [pl] Mocne
# [ru] Обычная
msgctxt "settings_ui.json:SCREENSHAKE_NORMAL"
msgid "Normal"
msgstr "Звычайна"

# [ua] Трохи
# [pl] Słabe
# [ru] Легкая
msgctxt "settings_ui.json:SCREENSHAKE_SOME"
msgid "Some"
msgstr "Трохі"

# [ua] Надіслати відгук
# [pl] Wyślij opinię
# [ru] Отправить отзыв
msgctxt "settings_ui.json:SEND_FEEDBACK"
msgid "Send Feedback"
msgstr "Даслаць водгук"

# [ua] Відгук
# [pl] Opinia
# [ru] Обратная связь
msgctxt "settings_ui.json:SEND_FEEDBACK_BUTTON_LABEL"
msgid "Feedback"
msgstr "Зваротная сувязь"

# [ua] Гучність звукових ефектів
# [pl] Głośność efektów
# [ru] Громкость эффектов
msgctxt "settings_ui.json:SFX_VOLUME"
msgid "SFX Volume"
msgstr "Гучнасць эфектаў"

# [ua] Показує позицію карти в руці над картою.
# [pl] Pokazuje pozycję karty w twojej ręce.
# [ru] Показывает над картой ее позицию в руке.
msgctxt "settings_ui.json:SHOW_HAND_CARD_COUNT_DESCRIPTION"
msgid "Shows the position of a card in your hand above the card."
msgstr "Паказвае над картай яе пазіцыю ў вашай руцэ."

# [ua] Показувати номер карти в руці
# [pl] Pokaż liczbę kart w ręce
# [ru] Показывать количество карт в руке
msgctxt "settings_ui.json:SHOW_HAND_CARD_COUNT_HEADER"
msgid "Show Hand Card Count"
msgstr "Паказваць нумар карты ў руцэ"

# [pl] Przełącza widok rysunków innych graczy na mapie w trybie wieloosobowym.
# 
# Może być przydatne, jeśli grasz z obcymi.
# [ru] Определяет видимость рисунков других игроков при совместной игре.
# 
# Может пригодиться при игре с малознакомыми напарниками.
msgctxt "settings_ui.json:SHOW_MP_DRAWINGS_DESCRIPTION"
msgid "Controls whether other players' map drawings are shown in multiplayer.\n\n"
"May be useful to turn off if you are playing with strangers."
msgstr "Кіруе тым, ці будуць адлюстроўвацца малюнкі іншых гульцоў у сумесным рэжыме.\n\n"
"Можа прыдацца, калі вы гуляеце з незнаёмцамі."

# [pl] Pokaż rysunki w trybie wieloosobowym
# [ru] Рисунки других игроков
msgctxt "settings_ui.json:SHOW_MP_DRAWINGS_HEADER"
msgid "Show Multiplayer Drawings"
msgstr "Паказваць малюнкі ў сумесным рэжыме"

# [ua] Показувати таймер забігу
# [pl] Pokaż czas wyprawy
# [ru] Показывать время вылазки
msgctxt "settings_ui.json:SHOW_RUN_TIMER"
msgid "Show Run Timer"
msgstr "Паказваць час выправы"

# [ua] Відображає таймер у верхній панелі весь час.
# [pl] Zawsze wyświetla czas gry na górnym pasku.
# [ru] Отображать время вылазки на верхней панели.
msgctxt "settings_ui.json:SHOW_RUN_TIMER_DESCRIPTION"
msgid "Displays the Timer in the top bar all the time."
msgstr "Заўсёды адлюстроўваць час выправы на верхняй панэлі."

# [ua] Завжди показувати таймер
# [pl] Pokaż czas gry
# [ru] Всегда показывать время
msgctxt "settings_ui.json:SHOW_RUN_TIMER_HEADER"
msgid "Always show the Timer"
msgstr "Заўсёды паказваць час"

# [ua] Переводить одразу до головного меню при запуску гри.
# [pl] Przenosi cię prosto do menu głównego po uruchomieniu gry.
# [ru] При запуске игры вы будете сразу попадать в главное меню.
msgctxt "settings_ui.json:SKIP_INTRO_LOGO_DESCRIPTION"
msgid "Takes you straight to the main menu when the game is started."
msgstr "Пасля запуску гульні вы адразу трапляеце ў галоўнае меню."

# [ua] Пропустити заставку
# [pl] Pomiń wstęp
# [ru] Пропускать логотип
msgctxt "settings_ui.json:SKIP_INTRO_LOGO_HEADER"
msgid "Skip Intro Logo"
msgstr "Прапускаць застаўку"

# [ua] Загальне
# [pl] Ogólne
# [ru] Общие
msgctxt "settings_ui.json:TAB_GENERAL"
msgid "General"
msgstr "Агульныя"

# [ua] Графіка
# [pl] Grafika
# [ru] Графика
msgctxt "settings_ui.json:TAB_GRAPHICS"
msgid "Graphics"
msgstr "Графіка"

# [ua] Керування
# [pl] Sterowanie
# [ru] Управление
msgctxt "settings_ui.json:TAB_INPUT"
msgid "Input"
msgstr "Кіраванне"

# [ua] Звук
# [pl] Dźwięk
# [ru] Звук
msgctxt "settings_ui.json:TAB_SOUND"
msgid "Sound"
msgstr "Гук"

# [ua] Текстові ефекти
# [pl] Efekty tekstu
# [ru] Эффекты текста
msgctxt "settings_ui.json:TEXT_EFFECTS"
msgid "Text Effects"
msgstr "Эфекты тэксту"

# [ua] Контролює, чи ввімкнені текстові ефекти, такі як хвилястий або
# тремтливий текст.
# [pl] Przełącza efekty tekstu takie jak falowanie lub drżenie.
# [ru] Включите или отключите эффекты текста: например, волны или дрожащие
# буквы.
msgctxt "settings_ui.json:TEXT_EFFECTS_DESCRIPTION"
msgid "Controls whether text effects, such as wavy or shaky text, are enabled."
msgstr "Уключае ці адключае эфекты тэксту, такія як хвалістасць або дрыжанне."

# [ua] Розмір тексту
# [pl] Rozmiar tekstu
# [ru] Размер текста
msgctxt "settings_ui.json:TEXT_SIZE"
msgid "Text Size"
msgstr "Памер тэксту"

# [ua] Бойові дії та переходи між екранами будуть повільнішими.
# [pl] Walki i przejścia będą wolniejsze.
# [ru] Обычная скорость боевых действий и переходов между экранами.
msgctxt "settings_ui.json:TOAST_FAST_MODE_OFF"
msgid "Combat actions and screen transitions will be slower."
msgstr "Баявыя дзеянні і пераходы паміж экранамі будуць павольнейшымі."

# [ua] Бойові дії та переходи між екранами будуть швидшими.
# [pl] Walki i przejścia będą szybsze.
# [ru] Высокая скорость боевых действий и переходов между экранами.
msgctxt "settings_ui.json:TOAST_FAST_MODE_ON"
msgid "Combat actions and screen transitions will be faster."
msgstr "Баявыя дзеянні і пераходы паміж экранамі будуць хутчэйшымі."

# [ua] Ігрові метрики та журнали помилок не будуть завантажуватись.
# [pl] Dane rozgrywki i dzienniki błędów nie będą wysyłane.
# [ru] Игровые метрики и отчеты об ошибках не отправятся в Mega Crit.
msgctxt "settings_ui.json:TOAST_GAMEPLAY_DATA_OFF"
msgid "Gameplay metrics and error logs will not be uploaded."
msgstr "Метрыкі гульнявога працэсу і журналы памылак не будуць адпраўляцца ў Mega Crit."

# [ua] Ігрові метрики та журнали помилок будуть надсилатися до Mega Crit.
# [pl] Dane rozgrywki i dzienniki błędów będą wysyłane do Mega Crit.
# [ru] Игровые метрики и отчеты об ошибках отправятся в Mega Crit.
msgctxt "settings_ui.json:TOAST_GAMEPLAY_DATA_ON"
msgid "Gameplay metrics and error logs will be sent to Mega Crit."
msgstr "Метрыкі гульнявога працэсу і журналы памылак будуць адпраўляцца ў Mega Crit."

# [ua] Номери не будуть показані над картами в бою.
# [pl] Cyfry nie będą pokazywane nad kartami w czasie walki.
# [ru] Не отображать номера карт в бою.
msgctxt "settings_ui.json:TOAST_HAND_CARD_COUNT_OFF"
msgid "Numbers will not be shown above cards in combat."
msgstr "Падчас бою парадкавыя нумары карт не будуць адлюстроўвацца над імі."

# [ua] Тепер номери будуть показані над картами в бою.
# [pl] Cyfry będą pokazywane nad kartami w czasie walki.
# [ru] Отображать номера карт в бою.
msgctxt "settings_ui.json:TOAST_HAND_CARD_COUNT_ON"
msgid "Numbers will now be shown above cards in combat."
msgstr "Цяпер парадкавыя нумары карт будуць адлюстроўвацца над імі падчас бою."

# [ua] Обмеження FPS у фоні вимкнено.
# [pl] Wyłączono limit FPS w tle.
# [ru] Ограничение FPS в фоновом окне отключено.
msgctxt "settings_ui.json:TOAST_LIMIT_FPS_IN_BACKGROUND_OFF"
msgid "Background FPS limiting disabled."
msgstr "Абмежаванне FPS у фонавым рэжыме адключана."

# [ua] Обмеження FPS у фоні ввімкнено.
# [pl] Włączono limit FPS w tle.
# [ru] Ограничение FPS в фоновом окне включено.
msgctxt "settings_ui.json:TOAST_LIMIT_FPS_IN_BACKGROUND_ON"
msgid "Background FPS limiting enabled."
msgstr "Абмежаванне FPS у фонавым рэжыме ўключана."

# [ua] Гра тепер відтворюватиме звук навіть без фокусу.
# [pl] Gra będzie odtwarzać dźwięk poza oknem.
# [ru] Звук в игре будет слышно, даже если окно не активно.
msgctxt "settings_ui.json:TOAST_MUTE_IN_BACKGROUND_OFF"
msgid "The game will now play sound even if unfocused."
msgstr "Гукі ў гульні будуць чуваць, нават калі акно гульні неактыўнае."

# [ua] Гра більше не відтворюватиме звук без фокусу.
# [pl] Gra nie będzie odtwarzać dźwięku poza oknem.
# [ru] Звук в игре не будет слышно, если окно не активно.
msgctxt "settings_ui.json:TOAST_MUTE_IN_BACKGROUND_ON"
msgid "The game will no longer play any sound when unfocused."
msgstr "Гукаў у гульні не будзе чуваць, калі акно неактыўнае."

# [ua] Це ще не реалізовано!
# [pl] Ta opcja nie została jeszcze zaimplementowana!
# [ru] Эта функция еще в разработке!
msgctxt "settings_ui.json:TOAST_NOT_IMPLEMENTED"
msgid "This is not yet implemented!"
msgstr "Гэта яшчэ не рэалізавана!"

# [pl] Efekty i animacje będą używały zwykłych zasobów.
# [ru] Рисовка и анимации не изменены.
msgctxt "settings_ui.json:TOAST_PHOBIA_MODE_OFF"
msgid "Visuals and animations will use their original assets."
msgstr "Візуальныя элементы і анімацыі не зменены."

# [pl] Niektóre efekty i animacje będą mniej niepokojące.
# [ru] В некоторых местах рисовка и анимации изменены на менее тревожные.
msgctxt "settings_ui.json:TOAST_PHOBIA_MODE_ON"
msgid "Certain visuals and animations will be altered to be less distressing."
msgstr "Асобныя візуальныя элементы і анімацыі будуць зменены, каб выклікаць менш трывогі."

# [ua] Таймер забігу показуватиметься лише на паузі.
# [pl] Licznik czasu będzie widoczny, gdy wyprawa zostanie wstrzymana.
# [ru] Время вылазки будет отображаться, только если игра на паузе.
msgctxt "settings_ui.json:TOAST_RUN_TIMER_OFF"
msgid "Run Timer will only be shown when the run is paused."
msgstr "Час выправы будзе паказвацца толькі пры паўзе."

# [ua] Таймер забігу тепер завжди показується під час забігу.
# [pl] Licznik czasu będzie zawsze widoczny w trakcie wyprawy.
# [ru] Время вылазки отображается всегда.
msgctxt "settings_ui.json:TOAST_RUN_TIMER_ON"
msgid "Run Timer now always shown during a run."
msgstr "Час выправы цяпер заўсёды паказваецца."

# [pl] Rysunki innych graczy nie będą pokazywane.
# [ru] Рисунки других игроков скрыты.
msgctxt "settings_ui.json:TOAST_SHOW_MP_DRAWINGS_OFF"
msgid "Drawings from other players in multiplayer will be hidden."
msgstr "Малюнкі іншых гульцоў у сумесным рэжыме будуць схаваныя."

# [pl] Rysunki innych graczy będą pokazywane.
# [ru] Рисунки других игроков видны.
msgctxt "settings_ui.json:TOAST_SHOW_MP_DRAWINGS_ON"
msgid "Drawings from other players in multiplayer will be shown."
msgstr "Малюнкі іншых гульцоў у сумесным рэжыме будуць паказвацца."

# [ua] Логотип Mega Crit показуватиметься при запуску гри.
# [pl] Logo Mega Crit będzie pokazywane przy uruchamianiu gry.
# [ru] При запуске игры будет отображаться логотип Mega Crit.
msgctxt "settings_ui.json:TOAST_SKIP_INTRO_LOGO_OFF"
msgid "Mega Crit logo will be shown when opening the game."
msgstr "Лагатып Mega Crit будзе паказвацца пры запуску гульні."

# [ua] Логотип Mega Crit більше не показуватиметься при запуску гри.
# [pl] Logo Mega Crit nie będzie pokazywane przy uruchamianiu gry.
# [ru] Логотип Mega Crit не будет отображаться при запуске игры.
msgctxt "settings_ui.json:TOAST_SKIP_INTRO_LOGO_ON"
msgid "Mega Crit logo will no longer be shown when opening the game."
msgstr "Лагатып Mega Crit больш не будзе паказвацца пры запуску гульні."

# [ua] Текстові ефекти вимкнено.
# [pl] Efekty tekstu są wyłączone.
# [ru] Эффекты текста отключены.
msgctxt "settings_ui.json:TOAST_TEXT_EFFECTS_OFF"
msgid "Text effects are off."
msgstr "Эфекты тэксту выключаны."

# [ua] [sine]Текстові ефекти ввімкнено.[/sine]
# [pl] [sine]Efekty tekstu są włączone.[/sine]
# [ru] [sine]Эффекты текста включены.[/sine]
msgctxt "settings_ui.json:TOAST_TEXT_EFFECTS_ON"
msgid "[sine]Text effects are on.[/sine]"
msgstr "[sine]Эфекты тэксту ўключаны.[/sine]"

# [ua] Розмір вікна гри більше не можна змінювати.
# [pl] Nie można zmieniać rozmiaru okna gry.
# [ru] Размер игрового окна нельзя изменить.
msgctxt "settings_ui.json:TOAST_WINDOW_RESIZING_OFF"
msgid "The game window can no longer be resized."
msgstr "Памер акна гульні больш нельга змяніць."

# [ua] Тепер розмір вікна гри можна змінювати.
# [pl] Można zmieniać rozmiar okna gry.
# [ru] Размер игрового окна можно изменить.
msgctxt "settings_ui.json:TOAST_WINDOW_RESIZING_ON"
msgid "The game window can now be resized."
msgstr "Цяпер памер акна гульні можна змяніць."

# [ua] Скинути навчання
# [pl] Zresetuj samouczki
# [ru] Сбросить обучение
msgctxt "settings_ui.json:TUTORIAL_RESET"
msgid "Reset Tutorials"
msgstr "Скінуць прагрэс навучання"

# [ua] Скинути
# [pl] Zresetuj
# [ru] Сбросить
msgctxt "settings_ui.json:TUTORIAL_RESET_BUTTON_LABEL"
msgid "Reset"
msgstr "Скінуць"

# [ua] Це скине всі навчальні підказки та спливаючі вікна.
# 
# Корисно, якщо Ви давно не грали.
# [pl] Ta opcja zresetuje wszystkie samouczki i okienka z podpowiedziami.
# 
# Przydatne jeżeli nie grało się od dawna.
# [ru] Эта настрофка возвращает игровое обучение и все подсказки.
# 
# Может пригодиться, если вы давно не играли.
msgctxt "settings_ui.json:TUTORIAL_RESET_POPUP_DESCRIPTION"
msgid "This will reset all of the tutorials and tip popups.\n\n"
"Useful if you haven't played in a very long time."
msgstr "Скіне прагрэс навучання і ўсе падказкі.\n\n"
"Карысна, калі вы даўно не гулялі."

# [ua] Скинути навчання?
# [pl] Czy chcesz zresetować samouczki?
# [ru] Сбросить обучение?
msgctxt "settings_ui.json:TUTORIAL_RESET_POPUP_HEADER"
msgid "Reset Tutorials?"
msgstr "Скінуць прагрэс навучання?"

# [ua] Завантаження ігрових даних
# [pl] Prześlij dane rozgrywki
# [ru] Отправлять игровые данные
msgctxt "settings_ui.json:UPLOAD_GAMEPLAY_DATA"
msgid "Upload Gameplay Data"
msgstr "Адпраўляць гульнявыя даныя"

# [ua] Ігрові дані та журнали помилок надсилаються до Mega Crit для
# виправлення помилок та балансування гри.
# 
# Особисті дані НЕ збираються.
# [pl] Dane rozgrywki i dzienniki błędów są wysyłane do Mega Crit w celu
# balansowania gry i naprawiania błędów.
# 
# Dane umożliwiające identyfikację użytkownika NIE SĄ zbierane.
# [ru] Игровые данные и логи с ошибками отправляются в Mega Crit, что помогает
# балансировать игру и исправлять баги.
# 
# Мы НЕ собираем личные данные .
msgctxt "settings_ui.json:UPLOAD_GAMEPLAY_DATA_DESCRIPTION"
msgid "Gameplay data and error logs are sent to Mega Crit to fix bugs and balance the game.\n\n"
"Personally identifying information is NOT collected."
msgstr "Даныя пра гульнявы працэс і журналы памылак будуць адпраўляцца ў Mega Crit для выпраўлення хібаў і балансавання гульні.\n\n"
"Ваша асабістая інфармацыя НЕ збіраецца."

# [ua] Завантаження ігрових даних
# [pl] Prześlij dane gry
# [ru] Отправлять игровые данные
msgctxt "settings_ui.json:UPLOAD_GAMEPLAY_DATA_HEADER"
msgid "Upload Gameplay Data"
msgstr "Адпраўляць гульнявыя даныя"

# [ua] Верт. синхронізація
# [pl] VSync
# [ru] Вертикальная синхронизация
msgctxt "settings_ui.json:VSYNC"
msgid "VSync"
msgstr "Вертыкальная сінхранізацыя"

# [ua] Адаптивна
# [pl] Adaptacyjny
# [ru] Адаптивная
msgctxt "settings_ui.json:VSYNC_ADAPTIVE"
msgid "Adaptive"
msgstr "Адаптыўная"

# [ua] Вимк.
# [pl] Wyłącz
# [ru] Выключить
msgctxt "settings_ui.json:VSYNC_OFF"
msgid "Off"
msgstr "Выкл."

# [ua] Увімк.
# [pl] Włącz
# [ru] Включить
msgctxt "settings_ui.json:VSYNC_ON"
msgid "On"
msgstr "Укл."

# [ua] Дозволяє змінювати розмір вікна гри перетягуванням його країв.
# [pl] Umożliwia zmianę rozmiaru okna poprzez przeciąganie jego krawędzi.
# [ru] Позволяет регулировать размер игрового окна.
msgctxt "settings_ui.json:WINDOW_RESIZE_DESCRIPTION"
msgid "Allows you to resize the game window by dragging its edges."
msgstr "Дазваляе змяняць памер акна гульні, перацягваючы яго краі."

# [ua] Зміна розміру вікна
# [pl] Zmiana rozmiaru okna
# [ru] Изменение размера окна
msgctxt "settings_ui.json:WINDOW_RESIZE_HEADER"
msgid "Window Resizing"
msgstr "Змяненне памеру акна"

# [ua] Зміна розміру вікна
# [pl] Zmiana rozmiaru okna
# [ru] Изменение размера окна
msgctxt "settings_ui.json:WINDOW_RESIZING"
msgid "Window Resizing"
msgstr "Змяненне памеру акна"

# [ua] До наступного ходу запобігає шкоді.
# [pl] Pochłania otrzymywane obrażenia.
# [ru] Предотвращает урон до следующего хода.
msgctxt "static_hover_tips.json:BLOCK.description"
msgid "Until next turn, prevents damage."
msgstr "Да наступнага ходу прадухіляе пашкоджанне."

# [ua] Броня
# [pl] Blok
# [ru] Защита
msgctxt "static_hover_tips.json:BLOCK.title"
msgid "Block"
msgstr "Браня"

# [ua] Наприкінці акту Ви битиметеся з [gold]{BossName}[/gold].
# [pl] Pod koniec aktu zmierzysz się z [gold]{BossName:choose(Leśny
# Stróż|Tytan Pustki|Krab Cesarski|Demon Wiedzy|Matka
# Lagavulinów|Królowa|Dusza
# Rypki|Eksperyment|Nienasycony|Kapłan|Fantom|Kaskadowy Olbrzym):Leśnym
# Stróżem|Tytanem Pustki|Krabem Cesarskim|Demonem Wiedzy|Matką
# Lagavulinów|Królową|Duszą
# Rypki|Eksperymentem|Nienasyconym|Kapłanem|Fantomem|Kaskadowym
# Olbrzymem}[/gold].
# [ru] В конце акта с вами сразится [gold]{BossName}[/gold].
msgctxt "static_hover_tips.json:BOSS.description"
msgid "At the end of the act, you will fight [gold]{BossName}[/gold]."
msgstr "[gold]{BossName}[/gold] пазмагаецца з вамі ў канцы акта."

# [ua] {BossName}
# [pl] {BossName}
# [ru] {BossName}
msgctxt "static_hover_tips.json:BOSS.title"
msgid "{BossName}"
msgstr "{BossName}"

# [ua] Набір з [blue]3[/blue] випадкових карт. Ви можете обрати
# [blue]1[/blue], щоб додати до своєї [gold]Колоди[/gold].
# [pl] Pakiet [blue]3[/blue] losowych kart. Możesz dodać [blue]1[/blue] z nich
# do swojej [gold]talii[/gold].
# [ru] Набор из [blue]3[/blue] случайных карт. Вы можете выбрать
# [blue]1[/blue] из них, которую хотите добавить в [gold]колоду[/gold].
msgctxt "static_hover_tips.json:CARD_REWARD.description"
msgid "A pack of [blue]3[/blue] random cards. You may choose [blue]1[/blue] to add to your [gold]Deck[/gold]."
msgstr "Набор з [blue]3[/blue] выпадковых карт. Вы можаце выбраць [blue]1[/blue] з іх і дадаць у [gold]калоду[/gold]."

# [ua] Нагорода картами
# [pl] Łupy
# [ru] Наградная карта
msgctxt "static_hover_tips.json:CARD_REWARD.title"
msgid "Card Reward"
msgstr "Карта-ўзнагарода"

# [ua] Спрямування Сфери поміщає її в перший вільний слот. Якщо вільних слотів
# немає, перша Сфера автоматично [gold]Вивільняється[/gold], щоб звільнити
# місце.
# [pl] Umieszcza Sferę w pierwsze wolne miejsce. Jeżeli nie masz wolnych
# miejsc, twoja pierwsza Sfera zostaje [gold]Wyładowana[/gold].
# [ru] Заряженные сферы попадают в первый пустой слот. Если пустых слотов нет,
# первая сфера автоматически [gold]разряжается[/gold], освобождая место.
msgctxt "static_hover_tips.json:CHANNELING.description"
msgid "Channeling an Orb puts it into your first empty slot. If you have no empty slots, your first Orb is automatically [gold]Evoked[/gold] to make room."
msgstr "Зараджаная сфера змяшчаецца ў вашу першую вольную ячэйку. Калі ў вас няма вольных ячэек, ваша першая сфера аўтаматычна [gold]разраджаецца[/gold], каб вызваліць месца."

# [ua] Спрямування
# [pl] Załadowanie
# [ru] Зарядка сфер
msgctxt "static_hover_tips.json:CHANNELING.title"
msgid "Channel"
msgstr "Зараджанне сфер"

# [ua] Перегляньте всі карти, зілля та амулети, які Ви зустріли протягом
# сходження Шпилем.
# [pl] Wyświetl wszystkie karty, mikstury i artefkaty znalezione w Iglicy.
# [ru] Содержит список всех карт, зелий и реликвий, которые повстречались вам
# в Шпиле.
msgctxt "static_hover_tips.json:COMPENDIUM.description"
msgid "View all of the cards, potions, and relics you have encountered throughout the Spire."
msgstr "Праглядзіце ўсе карты, зеллі і рэліквіі, якія трапляліся вам у Шпілі."

# [ua] Довідник
# [pl] Kompendium
# [ru] Компендиум
msgctxt "static_hover_tips.json:COMPENDIUM.title"
msgid "Compendium"
msgstr "Кампендыум"

# [ua] [gold]Вилучіть[/gold] [blue]2[/blue] карти з Вашої [gold]Колоди[/gold]
# та отримайте [green]9[/green] макс. ОЗ у [gold]Таборі[/gold].
# [pl] [gold]Usuń[/gold] [blue]2[/blue] karty z [gold]talii[/gold] i zyskaj
# [green]9[/green] maks. PŻ w [gold]Obozowisku[/gold].
# [ru] Готовка позволяет [gold]удалить[/gold] [blue]2[/blue] карты из
# [gold]колоды[/gold] и повысить макс. ОЗ на [green]9[/green] в
# [gold]лагере[/gold].
msgctxt "static_hover_tips.json:COOK.description"
msgid "[gold]Remove[/gold] [blue]2[/blue] cards from your [gold]Deck[/gold] and gain [green]9[/green] Max HP at a [gold]Rest Site[/gold]."
msgstr "[gold]Выдаліце[/gold] [blue]2[/blue] карты з [gold]калоды[/gold] і павысьце максімум АЗ на [green]9[/green] на [gold]стаянцы[/gold]."

# [ua] Готувати
# [pl] Gotuj
# [ru] Готовка
msgctxt "static_hover_tips.json:COOK.title"
msgid "Cook"
msgstr "Гатаваць"

# [ua] Перегляньте всі карти у Вашій колоді.
# [pl] Wyświetl wszystkie karty w swojej talii.
# [ru] Показывает все карты в колоде.
msgctxt "static_hover_tips.json:DECK.description"
msgid "View all of the cards in your deck."
msgstr "Паказаць усе карты ў калодзе."

# [ua] Колода (D)
# [pl] Talia (D)
# [ru] Колода (D)
msgctxt "static_hover_tips.json:DECK.title"
msgid "Deck (D)"
msgstr "Калода (D)"

# [ua] Якщо Добір порожній, Відбій перетасовується в Добір.
# 
# Натисніть, щоб переглянути карти у Відбої.
# [pl] Jeżeli stos rozgrywający jest pusty, stos kart odrzuconych zostanie do
# niego wtasowany.
# 
# Kliknij, aby wyświetlić karty na stosie kart odrzuconych.
# [ru] Если стопка добора пуста, в нее замешивается стопка сброса.
# 
# Нажмите, чтобы посмотреть карты в стопке сброса.
msgctxt "static_hover_tips.json:DISCARD_PILE.description"
msgid "If your draw pile is empty, the discard pile is shuffled into the draw pile.\n\n"
"Click to view the cards in your discard pile."
msgstr "Калі ваш стос дабору пусты, у яго замешваюцца ператасаваныя карты са стоса скідання.\n\n"
"Націсніце, каб праглядзець карты ў стосе скідання."

# [ua] Відбій (S)
# [pl] Stos kart odrzuconych (S)
# [ru] Стопка сброса (S)
msgctxt "static_hover_tips.json:DISCARD_PILE.title"
msgid "Discard Pile (S)"
msgstr "Стос скідання (S)"

# [ua] Наприкінці акту Ви битиметеся з [gold]{BossName1}[/gold] та
# [gold]{BossName2}[/gold].
# [pl] Pod koniec aktu zmierzysz się z [gold]{BossName1:choose(Leśny
# Stróż|Tytan Pustki|Krab Cesarski|Demon Wiedzy|Matka
# Lagavulinów|Królowa|Dusza
# Rypki|Eksperyment|Nienasycony|Kapłan|Fantom|Kaskadowy Olbrzym):Leśnym
# Stróżem|Tytanem Pustki|Krabem Cesarskim|Demonem Wiedzy|Matką
# Lagavulinów|Królową|Duszą
# Rypki|Eksperymentem|Nienasyconym|Kapłanem|Fantomem|Kaskadowym
# Olbrzymem}[/gold] i [gold]{BossName2:choose(Leśny Stróż|Tytan Pustki|Krab
# Cesarski|Demon Wiedzy|Matka Lagavulinów|Królowa|Dusza
# Rypki|Eksperyment|Nienasycony|Kapłan|Fantom|Kaskadowy Olbrzym):Leśnym
# Stróżem|Tytanem Pustki|Krabem Cesarskim|Demonem Wiedzy|Matką
# Lagavulinów|Królową|Duszą
# Rypki|Eksperymentem|Nienasyconym|Kapłanem|Fantomem|Kaskadowym
# Olbrzymem}[/gold].
# [ru] В конце акта вам с вами сразятся [gold]{BossName1}[/gold] и
# [gold]{BossName2}[/gold].
msgctxt "static_hover_tips.json:DOUBLE_BOSS.description"
msgid "At the end of the act, you will fight [gold]{BossName1}[/gold] and [gold]{BossName2}[/gold]."
msgstr "[gold]{BossName1}[/gold] і [gold]{BossName2}[/gold] пазмагаюцца з вамі ў канцы акта."

# [ua] {BossName1} та {BossName2}
# [pl] {BossName1} i {BossName2}
# [ru] {BossName1} и {BossName2}
msgctxt "static_hover_tips.json:DOUBLE_BOSS.title"
msgid "{BossName1} & {BossName2}"
msgstr "{BossName1} і {BossName2}"

# [ua] На початку кожного ходу
# звідси добираються [blue]5[/blue] карт.
# 
# Натисніть, щоб переглянути карти в Доборі (перетасовані).
# [pl] Na początku każdej tury
# dobierasz stąd [blue]5[/blue] kart.
# 
# Kliknij, aby wyświetlić (potasowane) karty na stosie rozgrywającym.
# [ru] В начале каждого хода вы берете
# [blue]5[/blue] карт из этой стопки.
# 
# Нажмите, чтобы посмотреть карты в стопке добора (в перемешанном виде).
msgctxt "static_hover_tips.json:DRAW_PILE.description"
msgid "At the start of each turn,\n"
"[blue]5[/blue] cards are drawn from here.\n\n"
"Click to view the cards in your draw pile (shuffled)."
msgstr "На пачатку кожнага ходу адсюль дабіраюцца\n"
"[blue]5[/blue] карт.\n\n"
"Націсніце, каб праглядзець карты ў стосе дабору (яны будуць перамешаны)."

# [ua] Добір (A)
# [pl] Stos rozgrywający (A)
# [ru] Стопка добора (A)
msgctxt "static_hover_tips.json:DRAW_PILE.title"
msgid "Draw Pile (A)"
msgstr "Стос дабору (A)"

# [ua] Натискання цієї кнопки завершить Ваш хід.
# 
# Ви скинете руку, вороги зроблять свій хід, Ви доберете [blue]5[/blue] карт,
# після чого знову буде Ваш хід.
# [pl] Naciśnięcie tego przycisku zakończy twoją turę.
# 
# Odrzucisz wszystkie karty w ręce, przeciwnicy przeprowadzą swoją turę,
# dobierzesz [blue]5[/blue] kart, po czym znów rozpocznie się twoja tura.
# [ru] Нажав на эту кнопку, вы завершите ход.
# 
# Вы сбрасываете все карты в руке. После вражеского хода вы возьмете
# [blue]5[/blue] карт и начнете новый ход.
msgctxt "static_hover_tips.json:END_TURN.description"
msgid "Pressing this button will end your turn.\n\n"
"You will discard your hand, enemies will take their turn, you will draw [blue]5[/blue] cards, then it will be your turn again."
msgstr "Націснуўшы гэтую кнопку, вы завяршыце ход.\n\n"
"Усе карты, што засталіся ў вашай руцэ, будуць скінуты, праціўнікі зробяць свой ход, затым вы дабераце [blue]5[/blue] карт, пасля чаго зноў будзе ваш ход."

# [ua] Завершити хід (E)
# [pl] Zakończ turę (E)
# [ru] Завершить ход (E)
msgctxt "static_hover_tips.json:END_TURN.title"
msgid "End Turn (E)"
msgstr "Завяршыць ход (E)"

# [ua] Енергія використовується для гри карт з Вашої [gold]Руки[/gold].
# [pl] Energia jest używana do zagrywania kart z [gold]ręki[/gold].
# [ru] Энергия нужна, чтобы разыгрывать карты в [gold]руке[/gold].
msgctxt "static_hover_tips.json:ENERGY.description"
msgid "Energy is used to play cards from your [gold]Hand[/gold]."
msgstr "Энергія ўжываецца, каб разыгрываць карты з [gold]рукі[/gold]."

# [ua] Енергія
# [pl] Energia
# [ru] Энергия
msgctxt "static_hover_tips.json:ENERGY.title"
msgid "Energy"
msgstr "Энергія"

# [ua] Ваша поточна кількість Енергії ({energyPrefix:energyIcons(1)}). Для гри
# карт потрібна {energyPrefix:energyIcons(1)}, що вказана у верхньому лівому
# куті.
# [pl] Twoja obecna Energia ({energyPrefix:energyIcons(1)}). Karty wymagają
# {energyPrefix:energyIcons(1)} do zagrania. Koszt jest oznaczony w lewym
# górnym rogu karty.
# [ru] Текущее количество энергии ({energyPrefix:energyIcons(1)}). Каждая
# карта стоит определенное число {energyPrefix:energyIcons(1)}, стоимость
# указана в левом верхнем углу.
msgctxt "static_hover_tips.json:ENERGY_COUNT.description"
msgid "Your current Energy ({energyPrefix:energyIcons(1)}) count. Cards require {energyPrefix:energyIcons(1)} to play, indicated in the top left corner."
msgstr "Бягучая колькасць вашай энергіі ({energyPrefix:energyIcons(1)}). Разыгрыванне кожнай карты каштуе вызначаную колькасць {energyPrefix:energyIcons(1)}, што паказана ў левым верхнім куце."

# [ua] Енергія
# [pl] Energia
# [ru] Энергия
msgctxt "static_hover_tips.json:ENERGY_COUNT.title"
msgid "Energy"
msgstr "Энергія"

# [ua] Споживає Вашу крайню праву Сферу та активує її ефект Вивільнення.
# [pl] Pochłoń swoją pierwszą Sferę i aktywuj jej efekt Wyładowania.
# [ru] Сфера справа исчезнет, разыграв эффект разрядки.
msgctxt "static_hover_tips.json:EVOKE.description"
msgid "Consume your rightmost Orb and use its Evoke effect."
msgstr "Паглынае крайнюю правую сферу і актывуе эфект разраджэння сфер."

# [ua] Вивільнити
# [pl] Wyładowanie
# [ru] Разрядка сфер
msgctxt "static_hover_tips.json:EVOKE.title"
msgid "Evoke"
msgstr "Разраджэнне сфер"

# [ua] Натисніть, щоб переглянути карти, спалені у цьому бою.
# [pl] Kliknij, aby wyświetlić karty Wyczerpane w tej walce.
# [ru] Нажмите, чтобы просмотреть сожженные в этом бою карты.
msgctxt "static_hover_tips.json:EXHAUST_PILE.description"
msgid "Click to view cards Exhausted this combat."
msgstr "Націсніце, каб праглядзець спаленыя ў гэтым баі карты."

# [ua] Спалені карти (X)
# [pl] Wyczerpane karty (X)
# [ru] Сожженные карты (X)
msgctxt "static_hover_tips.json:EXHAUST_PILE.title"
msgid "Exhausted Cards (X)"
msgstr "Спаленыя карты (X)"

# [ua] Спрацьовує щоразу, коли ця карта вбиває ворога, що не є прислужником.
# [pl] Efekt aktywuje się, gdy ta karta zabije przeciwnika, który nie jest
# stworkiem.
# [ru] Эффект срабатывает, если эта карта убивает врага (не считая
# приспешников).
msgctxt "static_hover_tips.json:FATAL.description"
msgid "Triggers whenever this card kills a non-minion enemy."
msgstr "Эфект спрацоўвае штораз, калі гэтая карта забівае праціўніка (не лічачы паслугачоў)."

# [ua] Фатальний
# [pl] Uśmiercenie
# [ru] Казнь
msgctxt "static_hover_tips.json:FATAL.title"
msgid "Fatal"
msgstr "Умярцвенне"

# [ua] Як високо Ви піднялися.
# [pl] Pokazuje liczbę pokonanych pięter.
# [ru] Этаж Шпиля, на котором вы находитесь.
msgctxt "static_hover_tips.json:FLOOR.description"
msgid "How far up you have climbed."
msgstr "Наколькі высока вы ўзняліся."

# [ua] Поверх
# [pl] Piętro
# [ru] Этаж
msgctxt "static_hover_tips.json:FLOOR.title"
msgid "Floor"
msgstr "Паверх"

# [ua] Перше [gold]Кування[/gold] у кожному бою додає [gold]Суверенний
# Клинок[/gold] до Вашої [gold]Руки[/gold]. Додає додаткову шкоду до
# [gold]Суверенного Клинка[/gold].
# [pl] Gdy zagrasz kartę z [gold]Wykuj[/gold] po raz pierwszy w walce, dodaj
# [gold]Niebańskie Ostrze[/gold] do [gold]ręki[/gold]. Zwiększ obrażenia
# zadawane przez [gold]Niebiańskie Ostrze[/gold].
# [ru] Первая [gold]закалка[/gold] в бою добавляет [gold]Клинок монарха[/gold]
# к вам в [gold]руку[/gold]. После этого закалка повышает урон [gold]Клинка
# монарха[/gold].
msgctxt "static_hover_tips.json:FORGE.description"
msgid "The first time you [gold]Forge[/gold] each combat, add [gold]Sovereign Blade[/gold] into your [gold]Hand[/gold]. Adds additional damage to [gold]Sovereign Blade[/gold]."
msgstr "Калі вы [gold]загартоўваеце[/gold] першы раз за бой, дадае вам у [gold]руку[/gold] [gold]«Клінок манарха»[/gold]. Пасля гэтага загартоўка павялічвае пашкоджанне [gold]«Клінка манарха»[/gold] на пазначаную лічбу."

# [ua] Кування
# [pl] Wykuj
# [ru] Закалка
msgctxt "static_hover_tips.json:FORGE.title"
msgid "Forge"
msgstr "Загартоўка"

# [ua] Якщо ОЗ закінчаться, Ви помрете.
# [pl] Kiedy skończą ci się PŻ, umierasz.
# [ru] Как только запас ОЗ иссякнет, вы погибните.
msgctxt "static_hover_tips.json:HIT_POINTS.description"
msgid "If you run out of HP, you die."
msgstr "Калі ў вас скончыцца запас АЗ, вы згінеце."

# [ua] Очки Здоров'я (ОЗ)
# [pl] Punkty Życia (PŻ)
# [ru] Очки здоровья (ОЗ)
msgctxt "static_hover_tips.json:HIT_POINTS.title"
msgid "Hit Points (HP)"
msgstr "Адзінкі здароўя (АЗ)"

# [ua] Ви можете обрати лише [blue]1[/blue] нагороду з цього набору.
# [pl] Możesz wybrać tylko [blue]1[/blue] opcję z tego zestawu.
# [ru] Из этого набора можно выбрать только [blue]1[/blue] награду.
msgctxt "static_hover_tips.json:LINKED_REWARDS.description"
msgid "You can only select [blue]1[/blue] reward from this set."
msgstr "Вы можаце выбраць толькі [blue]1[/blue] узнагароду з гэтага набору."

# [ua] Пов'язані нагороди
# [pl] Połączone Łupy
# [ru] Связанные награды
msgctxt "static_hover_tips.json:LINKED_REWARDS.title"
msgid "Linked Rewards"
msgstr "Звязаныя ўзнагароды"

# [ua] Перегляньте мапу поточного Акту.
# [pl] Wyświetl mapę obecnego Aktu.
# [ru] Посмотреть карту текущего акта.
msgctxt "static_hover_tips.json:MAP.description"
msgid "View this current Act's map."
msgstr "Прагледзець карту бягучага акта."

# [ua] Мапа (M)
# [pl] Map (M)
# [ru] Карта (M)
msgctxt "static_hover_tips.json:MAP.title"
msgid "Map (M)"
msgstr "Мапа (М)"

# [ua] Скільки у Вас Золота. Золото — це валюта у Шпилі.
# [pl] Pokazuje, ile posiadasz Złota. Jest ono główną walutą w Iglicy.
# [ru] Количество вашего золота. Золото — основная валюта в Шпиле.
msgctxt "static_hover_tips.json:MONEY_POUCH.description"
msgid "How much Gold you have. Gold is the currency within the Spire."
msgstr "Колькасць вашага золата. Золата — асноўная валюта ў Шпілі."

# [ua] Золото
# [pl] Złoto
# [ru] Золото
msgctxt "static_hover_tips.json:MONEY_POUCH.title"
msgid "Gold"
msgstr "Золата"

# [ua] Ваше з'єднання з хостом ([gold]{Player}[/gold]) погане.
# Це може бути проблемою з Вашим інтернетом або його.
# [pl] Twoje połączenie z gospodarzem ([gold]{Player}[/gold]) jest słabe.
# Może to być problem albo z twoim, albo z jego internetem.
# [ru] Медленное соединение с создателем игры ([gold]{Player}[/gold]).
# Возможно, кто-то из вас не подключен к интернету.
msgctxt "static_hover_tips.json:NETWORK_PROBLEM_CLIENT.description"
msgid "Your connection with the host ([gold]{Player}[/gold]) is poor.\n"
"This could be a problem with your internet or theirs."
msgstr "Злучэнне з арганізатарам ([gold]{Player}[/gold]) слабое.\n"
"Магчыма, у кагосьці з вас ёсць праблемы з інтэрнэт-злучэннем."

# [ua] Погане з'єднання!
# [pl] Słabe połączenie!
# [ru] Медленное соединение!
msgctxt "static_hover_tips.json:NETWORK_PROBLEM_CLIENT.title"
msgid "Poor Connection!"
msgstr "Слабое злучэнне!"

# [ua] Ваше з'єднання з [gold]{Player}[/gold] погане.
# Це може бути проблемою з Вашим інтернетом або його.
# [pl] Twoje połączenie z graczem ([gold]{Player}[/gold]) jest słabe.
# Może to być problem albo z twoim, albo z jego internetem.
# [ru] Медленное соединение с игроком [gold]{Player}[/gold].
# Возможно, кто-то из вас не подключен к интернету.
msgctxt "static_hover_tips.json:NETWORK_PROBLEM_HOST.description"
msgid "Your connection with [gold]{Player}[/gold] is poor.\n"
"This could be a problem with your internet or theirs."
msgstr "Злучэнне з гульцом [gold]{Player}[/gold] слабое.\n"
"Магчыма, у кагосьці з вас ёсць праблемы з інтэрнэт-злучэннем."

# [ua] Погане з'єднання!
# [pl] Słabe połączenie!
# [ru] Медленное соединение!
msgctxt "static_hover_tips.json:NETWORK_PROBLEM_HOST.title"
msgid "Poor Connection!"
msgstr "Слабое злучэнне!"

# [ua] Використовуйте зілля під час бою, щоб отримати [green]бонуси[/green]
# або [red]послабити[/red] ворогів.
# [pl] W trakcie walki używaj mikstur do zyskiwania [green]wzmocnień[/green]
# lub do [red]osłabiania[/red] przeciwników.
# [ru] Используйте зелья во время боя, чтобы получить [green]бонусы[/green]
# или [red]навредить[/red] врагам.
msgctxt "static_hover_tips.json:POTION_SLOT.description"
msgid "Use potions during combat to gain [green]bonuses[/green] or [red]hinder[/red] enemies."
msgstr "Выкарыстоўвайце зеллі падчас бою, каб атрымаць [green]бонусы[/green] або [red]нашкодзіць[/red] праціўнікам."

# [ua] Слот зілля
# [pl] Miejsce na Miksturę
# [ru] Место для зелья
msgctxt "static_hover_tips.json:POTION_SLOT.title"
msgid "Potion Slot"
msgstr "Ячэйка для зелля"

# [ua] [gold]Повтор[/gold] {Times}.
# [pl] [gold]Powtórka[/gold] {Times}
# [ru] {Times} [gold]{Times:plural(ru):повтор|повтора|повторов}[/gold].
msgctxt "static_hover_tips.json:REPLAY.extraText"
msgid "[gold]Replay[/gold] {Times}."
msgstr "[gold]Паўтор[/gold] {Times}."

# [ua] Грає цю карту додатково {Times:plural:раз|[blue]{}[/blue]
# рази|[blue]{}[/blue] разів}.
# [pl] Zagraj tę kartę {Times:plural:dodatkowy raz|[blue]{}[/blue] dodatkowe
# razy|[blue]{}[/blue] dodatkowych razy}.
# [ru] Эта карта разыгрывается {Times:plural(ru):дополнительный
# раз|[blue]{}[/blue] дополнительных раза|[blue]{}[/blue] дополнительных раз}.
msgctxt "static_hover_tips.json:REPLAY_DYNAMIC.description"
msgid "Plays this card an additional {Times:plural:time|[blue]{}[/blue] times}."
msgstr "Гэтая карта разыгрываецца яшчэ {Times:plural:раз|[blue]{}[/blue] разы|[blue]{}[/blue] разоў}."

# [ua] Повтор
# [pl] Powtórka
# [ru] Повтор
msgctxt "static_hover_tips.json:REPLAY_DYNAMIC.title"
msgid "Replay"
msgstr "Паўтор"

# [ua] Грає цю карту додатково один раз.
# [pl] Karta jest zagrywana dodatkowy raz.
# [ru] Карта разыгрывается дополнительный раз.
msgctxt "static_hover_tips.json:REPLAY_STATIC.description"
msgid "Plays this card an additional time."
msgstr "Карта разыгрываецца яшчэ раз."

# [ua] Повтор
# [pl] Powtórka
# [ru] Повтор
msgctxt "static_hover_tips.json:REPLAY_STATIC.title"
msgid "Replay"
msgstr "Паўтор"

# [ua] Стародавні мешкають у цих кімнатах.
# 
# Вони дарують неймовірні бонуси, скарби та знання.
# [pl] W tym pomieszczeniu przebywa Starożytny.
# 
# Otrzymasz od niego specjalne wzmocnienia, drogocenne skarby oraz przydatną
# wiedzę.
# [ru] Здесь обитает Древний.
# 
# Вас ждут невероятные дары, сокровища и знания.
msgctxt "static_hover_tips.json:ROOM_ANCIENT.description"
msgid "Ancients reside in these rooms.\n\n"
"They grant incredible bonuses, treasures, and knowledge."
msgstr "У гэтых пакоях жывуць старажытныя.\n\n"
"Яны дораць неверагодныя бонусы, скарбы і веды."

# [ua] Стародавній
# [pl] Starożytny
# [ru] Древний
msgctxt "static_hover_tips.json:ROOM_ANCIENT.title"
msgid "Ancient"
msgstr "Старажытны"

# [ua] Найнебезпечніший ворог у цій місцевості.
# 
# Перемога над ним дозволить перейти до наступного Акту.
# [pl] Najgroźniejszy przeciwnik.
# 
# Za jego pokonanie dostaniesz się do następnego Aktu.
# [ru] Самый смертоносный враг.
# 
# Победив его, вы перейдете в следующий акт.
msgctxt "static_hover_tips.json:ROOM_BOSS.description"
msgid "The deadliest foe in the area.\n\n"
"Defeating them will let you proceed to the next Act."
msgstr "Найсмяротнейшы праціўнік у ваколіцы.\n\n"
"Перамога над ім дазволіць перайсці да наступнага акта."

# [ua] Князь
# [pl] Boss
# [ru] Босс
msgctxt "static_hover_tips.json:ROOM_BOSS.title"
msgid "Boss"
msgstr "Бос"

# [ua] У цих кімнатах перебувають потужні вороги.
# 
# За їх перемогу Ви отримаєте [gold]Амулет[/gold].
# [pl] Potężni przeciwnicy okupują to pomieszczenie.
# 
# Za ich pokonanie otrzymasz [gold]Artefakt[/gold].
# [ru] Здесь обитают мощные враги.
# 
# За победу полагается [gold]реликвия[/gold].
msgctxt "static_hover_tips.json:ROOM_ELITE.description"
msgid "Powerful foes are in these rooms.\n\n"
"Defeating them will reward you a [gold]Relic[/gold]."
msgstr "У гэтых пакоях жывуць магутныя праціўнікі.\n\n"
"Перамога над імі прынясе вам [gold]рэліквію[/gold]."

# [ua] Еліта
# [pl] Elitarny
# [ru] Элитный враг
msgctxt "static_hover_tips.json:ROOM_ELITE.title"
msgid "Elite"
msgstr "Элітны праціўнік"

# [ua] У цих кімнатах мешкають ворожі істоти.
# [pl] Przeciwnicy okupują to pomieszczenie.
# [ru] Здесь обитают враги.
msgctxt "static_hover_tips.json:ROOM_ENEMY.description"
msgid "Hostile enemies reside in these rooms."
msgstr "У гэтых пакоях жывуць праціўнікі."

# [ua] Ворог
# [pl] Przeciwnik
# [ru] Враг
msgctxt "static_hover_tips.json:ROOM_ENEMY.title"
msgid "Enemy"
msgstr "Праціўнік"

# [ua] У цих кімнатах трапляється щось незвичайне...
# [pl] W tym pomieszczeniu dzieje się coś niespotykanego...
# [ru] Здесь происходит нечто необычное…
msgctxt "static_hover_tips.json:ROOM_EVENT.description"
msgid "Something unusual occurs in these rooms..."
msgstr "У гэтых пакоях адбываецца нешта незвычайнае..."

# [ua] Подія
# [pl] Unikalna
# [ru] Событие
msgctxt "static_hover_tips.json:ROOM_EVENT.title"
msgid "Event"
msgstr "Падзея"

# [ua] Місце, де можна спланувати свій наступний крок.
# [pl] Miejsce, w którym możesz zaplanować swój następny ruch.
# [ru] Здесь можно спланировать свой следующий шаг.
msgctxt "static_hover_tips.json:ROOM_MAP.description"
msgid "A place where you can plan your next move."
msgstr "Месца, дзе вы можаце спланаваць свой наступны крок."

# [ua] Передпокій
# [pl] Przedpokój
# [ru] Вестибюль
msgctxt "static_hover_tips.json:ROOM_MAP.title"
msgid "Antechamber"
msgstr "Перадпакой"

# [ua] Таємничий Торговець продає свій товар у цих кімнатах.
# 
# Витрачайте чесно зароблене [gold]Золото[/gold] тут!
# [pl] W tym pomieszczeniu spotkasz Handlarza sprzedającego różnorodne towary.
# 
# Możesz tutaj wydać całe ciężko zarobione [gold]Złoto[/gold]!
# [ru] Здесь работает таинственный Торговец.
# 
# Здесь можно потратить свое честно заработанное [gold]золото[/gold]!
msgctxt "static_hover_tips.json:ROOM_MERCHANT.description"
msgid "The mysterious Merchant sells his wares in these rooms.\n\n"
"Spend your well-earned [gold]Gold[/gold] here!"
msgstr "Таямнічы гандляр прадае свае тавары ў гэтых пакоях.\n\n"
"Выдаткуйце тут сваё старанна заробленае [gold]золата[/gold]!"

# [ua] Крамниця
# [pl] Handlarz
# [ru] Магазин
msgctxt "static_hover_tips.json:ROOM_MERCHANT.title"
msgid "Shop"
msgstr "Крама"

# [ua] Завітайте до цих кімнат, щоб [green]зцілити[/green] трохи ОЗ або
# [gold]поліпшити[/gold] карту.
# [pl] W tym pomieszczeniu możesz [green]przywrócić[/green] utracone PŻ lub
# [gold]Ulepszyć[/gold] kartę.
# [ru] Здесь можно [green]восполнить[/green] немного ОЗ или
# [gold]улучшить[/gold] карту.
msgctxt "static_hover_tips.json:ROOM_REST.description"
msgid "Stop by these rooms to [green]Heal[/green] some HP or [gold]Upgrade[/gold] a card."
msgstr "У такіх пакоях можна [green]аднавіць[/green] трошкі АЗ або [gold]палепшыць[/gold] карту."

# [ua] Табір
# [pl] Obozowisko
# [ru] Лагерь
msgctxt "static_hover_tips.json:ROOM_REST.title"
msgid "Rest Site"
msgstr "Стаянка"

# [ua] [gold]Амулети[/gold] та [gold]Золото[/gold] можна знайти в цих бажаних
# кімнатах.
# [pl] W tym pomieszczeniu znajdziesz [gold]Artefakty[/gold] oraz
# [gold]Złoto[/gold].
# [ru] Здесь можно найти [gold]реликвии[/gold] и [gold]золото[/gold].
msgctxt "static_hover_tips.json:ROOM_TREASURE.description"
msgid "[gold]Relics[/gold] and [gold]Gold[/gold] can be found in these coveted rooms."
msgstr "У гэтых запаветных пакоях можна знайсці [gold]рэліквіі[/gold] і [gold]золата[/gold]."

# [ua] Кімната зі скарбами
# [pl] Skarb
# [ru] Сокровище
msgctxt "static_hover_tips.json:ROOM_TREASURE.title"
msgid "Treasure Room"
msgstr "Скарбніца"

# [ua] Раніше невідома кімната, де перебувають потужні вороги.
# [pl] Poprzednio nieznane pomieszczenie pełne potężnych przeciwników.
# [ru] Ранее неизведанная комната, в которой оказались могучие враги.
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_ELITE.description"
msgid "A previously unknown room containing powerful foes."
msgstr "Раней невядомы пакой з магутнымі праціўнікамі."

# [ua] Невідомо — Еліта
# [pl] Nieznane: Elitarny przeciwnik
# [ru] Неизвестная комната с элитным врагом
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_ELITE.title"
msgid "Unknown - Elite"
msgstr "Невядома — элітны праціўнік"

# [ua] Раніше невідома кімната, де мешкають ворожі істоти.
# [pl] Poprzednio nieznane pomieszczenie pełne przeciwników.
# [ru] Ранее неизведанная комната, в которой оказались враги.
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_ENEMY.description"
msgid "A previously unknown room containing hostile enemies."
msgstr "Раней невядомы пакой з варожымі істотамі."

# [ua] Невідомо — Ворог
# [pl] Nieznane: Przeciwnik
# [ru] Неизвестная комната с врагом
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_ENEMY.title"
msgid "Unknown - Enemy"
msgstr "Невядома — праціўнік"

# [ua] Раніше невідома кімната з подією.
# 
# У цих кімнатах трапляється щось незвичайне...
# [pl] Poprzednio nieznane pomieszczenie, w którym odbywa się wydarzenie.
# 
# W tym pomieszczeniu dzieje się coś niespotykanego...
# [ru] Ранее неизведанная комната, в которой оказалось событие.
# 
# Здесь происходит нечто необычное…
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_EVENT.description"
msgid "A previously unknown room containing an event.\n\n"
"Something unusual occurs in these rooms..."
msgstr "Раней невядомы пакой, у якім адбываецца падзея.\n\n"
"У гэтых пакоях адбываецца нешта незвычайнае..."

# [ua] Невідомо — Подія
# [pl] Nieznane: Wydarzenie
# [ru] Неизвестная комната с событием
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_EVENT.title"
msgid "Unknown - Event"
msgstr "Невядома — падзея"

# [ua] Раніше невідома кімната з таємничим торговцем.
# 
# Витрачайте чесно зароблене [gold]Золото[/gold] тут!
# [pl] Poprzednio nieznane pomieszczenie, w którym znajduje się Handlarz.
# 
# Możesz tutaj wydać całe ciężko zarobione [gold]Złoto[/gold]!
# [ru] Ранее неизведанная комната, в которой оказался Торговец.
# 
# Здесь можно потратить свое честно заработанное [gold]золото[/gold]!
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_MERCHANT.description"
msgid "A previously unknown room containing the mysterious merchant.\n\n"
"Spend your well-earned [gold]Gold[/gold] here!"
msgstr "Раней невядомы пакой з таямнічым гандляром.\n\n"
"Выдаткуйце тут сваё старанна заробленае [gold]золата[/gold]!"

# [ua] Невідомо — Торговець
# [pl] Nieznane: Handlarz
# [ru] Неизвестная комната с Торговцем
msgctxt "static_hover_tips.json:ROOM_UNKNOWN_MERCHANT.title"
msgid "Unknown - Merchant"
msgstr "Невядома — гандляр"

# [ua] Раніше невідома кімната з бажаними скарбами.
