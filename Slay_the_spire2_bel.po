msgid "Gain an additional [blue]4[/blue] [gold]Block[/gold] from Defend cards."
msgstr "Вы атрымліваеце на [blue]4[/blue] [gold]брані[/gold] больш з карт «Абарона»."

# [ua] Отримайте додатково [blue]{Amount}[/blue] [gold]Броні[/gold] від карток
# Захисту.
# [pl] Karty Obrony dają dodatkowo [blue]{Amount}[/blue] pkt.
# [gold]Bloku[/gold].
# [ru] Вы получаете от карт «Оборона» на [blue]{Amount}[/blue] больше
# [gold]защиты[/gold].
msgctxt "powers.json:FASTEN_POWER.smartDescription"
msgid "Gain an additional [blue]{Amount}[/blue] [gold]Block[/gold] from Defend cards."
msgstr "Вы атрымліваеце на [blue]{Amount}[/blue] [gold]брані[/gold] больш з карт «Абарона»."

# [ua] Закріплення
# [pl] Zabezpieczenie
# [ru] Предосторожность
