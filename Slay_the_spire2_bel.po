# хода.
msgctxt "cards.json:DRUM_OF_BATTLE.description"
msgid "Draw {Cards:diff()} cards.\n"
"At the start of your turn, [gold]Exhaust[/gold] the top card of your [gold]Draw Pile[/gold]."
msgstr "Вы дабіраеце {Cards:diff()} {Cards:plural:карту|карты|карт}.\n"
"На пачатку вашага ходу [gold]спальвае[/gold] верхнюю карту са [gold]стоса дабору[/gold]."

# [ua] Барабан Бою
# [pl] Bębny wojenne
# [ru] Ритм битвы
msgctxt "cards.json:DRUM_OF_BATTLE.title"
msgid "Drum of Battle"
msgstr "Баявы рытм"

# [ua] [gold]Спрямовуєте[/gold] крайню праву Сферу двічі.
# [pl] [gold]Wyładuj[/gold] pierwszą Sferę dwukrotnie.
