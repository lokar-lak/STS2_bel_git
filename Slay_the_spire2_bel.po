msgstr "У канцы вашага ходу, калі гэтая карта ў вашай [gold]руцэ[/gold], вы атрымліваеце {WeakPower:diff()} [gold]слабасці[/gold]."

# [ua] Сумнів
# [pl] Zwątpienie
# [ru] Сомнение
msgctxt "cards.json:DOUBT.title"
msgid "Doubt"
msgstr "Сумнеў"

# [ua] Нанести {Damage:diff()} шкоди.
# [gold]Поліпшує[/gold] {Cards:diff()} випадкових
# {Cards:plural:карту|карти|карт} у [gold]Відбої[/gold].
