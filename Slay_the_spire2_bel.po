# ход.
msgctxt "cards.json:HAND_TRICK.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Add [gold]Sly[/gold] to a Skill in your [gold]Hand[/gold] this turn."
msgstr "Дае {Block:diff()} [gold]брані[/gold].\n"
"Выбранае ўменне на [gold]руцэ[/gold] стане [gold]круцельскім[/gold] да канца гэтага ходу."

# [ua] Оберіть карту, до якої додати [gold]Хитрість[/gold].
# [pl] Wybierz kartę i dodaj do niej [gold]Chytra[/gold].
# [ru] Выберите карту, которую хотите сделать [gold]коварной[/gold].
msgctxt "cards.json:HAND_TRICK.selectionScreenPrompt"
msgid "Choose a card to add [gold]Sly[/gold] to."
msgstr "Выберыце карту, якую хочаце зрабіць [gold]круцельскай[/gold]."

# [ua] Хитрий Прийом
# [pl] Sztuczka
# [ru] Ловкость рук
