msgid "Ahhh, so refreshing..."
msgstr "А-а-а-ах, як жа асвяжае..."

# [ua] PLACEHOLDER: Я не торгую з мерцями.
# [pl] PLACEHOLDER: Z trupami nie gadam.
# [ru] ЗАГЛУШКА: Я с трупами не торгую.
msgctxt "merchant_room.json:MERCHANT.talk.playerDead.line1"
msgid "PLACEHOLDER: I don't do business with corpses."
msgstr "ЗАПАЎНЯЛЬНІК: Я з трупамі не гандлюю."

# [ua] PLACEHOLDER: Без ОЗ — без обслуговування.
# [pl] PLACEHOLDER: Nie ma PŻ, nie ma obsługi.
# [ru] ЗАГЛУШКА: Без ОЗ не обслуживаем.
msgctxt "merchant_room.json:MERCHANT.talk.playerDead.line2"
msgid "PLACEHOLDER: No HP, no service."
msgstr "ЗАПАЎНЯЛЬНІК: Няма АЗ — няма абслугоўвання."

# [ua] Схоже, Ви цього не можете.
# [pl] Chyba nie możesz tak zrobić.
# [ru] Похоже, такое тебе нельзя.
