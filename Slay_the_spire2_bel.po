msgctxt "powers.json:CORRUPTION_POWER.title"
msgid "Corruption"
msgstr "Скажонасць"

# [ua] На початку Вашого ходу накладіть [blue]6[/blue]
# [gold]Приреченості[/gold] на випадкового ворога.
# [pl] Na początku tury nałóż [blue]6[/blue] pkt. [gold]Zagłady[/gold] na
# losowego przeciwnika.
# [ru] Накладывает [blue]6[/blue] [gold]злого рока[/gold] на случайного врага
# в начале хода.
msgctxt "powers.json:COUNTDOWN_POWER.description"
msgid "At the start of your turn, apply [blue]6[/blue] [gold]Doom[/gold] to a random enemy."
msgstr "На пачатку ходу накладае [blue]6[/blue] [gold]пагібелі[/gold] на выпадковага праціўніка."

# [ua] На початку Вашого ходу накладіть [blue]{Amount}[/blue]
# [gold]Приреченості[/gold] на випадкового ворога.
# [pl] Na początku tury nałóż [blue]{Amount}[/blue] pkt. [gold]Zagłady[/gold]
# na losowego przeciwnika.
# [ru] Накладывает [blue]{Amount}[/blue] [gold]злого рока[/gold] на случайного
# врага в начале хода.
msgctxt "powers.json:COUNTDOWN_POWER.smartDescription"
msgid "At the start of your turn, apply [blue]{Amount}[/blue] [gold]Doom[/gold] to a random enemy."
msgstr "На пачатку ходу накладае [blue]{Amount}[/blue] [gold]пагібелі[/gold] на выпадковага праціўніка."

# [ua] Відлік
# [pl] Odliczanie
# [ru] Обратный отсчет
msgctxt "powers.json:COUNTDOWN_POWER.title"
msgid "Countdown"
msgstr "Зваротны адлік"

# [ua] Союзник прикриває Вас. Усі атаки, спрямовані на Вас, перенаправляються
# до нього.
# [pl] Sojusznik cię osłania. Wszystkie ataki skierowane na ciebie zostają
# przekierowane na sojusznika.
# [ru] Все атаки против вас перенаправляются на союзника.
msgctxt "powers.json:COVERED_POWER.description"
msgid "An ally is covering you. All attacks that would be directed to you are redirected to them instead."
msgstr "Паплечнік прыкрывае вас. Усе атакі, што мусілі б быць накіраваныя ў вас, замест гэтага перанакіроўваюцца ў яго."

# [ua] [gold]{Applier}[/gold] прикриває Вас. Усі атаки, спрямовані на Вас,
# перенаправляються до нього.
# [pl] [gold]{Applier}[/gold] cię osłania. Wszystkie ataki skierowane na
# ciebie zostają przekierowane na sojusznika.
# [ru] [gold]{Applier}[/gold] прикрывает вас. Все атаки против вас будут
# перенаправлены на этого игрока.
msgctxt "powers.json:COVERED_POWER.smartDescription"
msgid "[gold]{Applier}[/gold] is covering you. All attacks that would be directed to you are redirected to them instead."
msgstr "[gold]{Applier}[/gold] прыкрывае вас. Усе атакі, што мусілі б быць накіраваныя ў вас, замест гэтага перанакіроўваюцца ў яго."

# [ua] Під прикриттям
# [pl] Osłona
# [ru] Прикрытие
msgctxt "powers.json:COVERED_POWER.title"
msgid "Covered"
msgstr "Пад прыкрыццём"

# [ua] Коли союзник гине, ця істота отримує [blue]5[/blue] [gold]Міці[/gold]
# та [blue]99[/blue] [gold]Броні[/gold].
# [pl] Gdy sojusznik umrze, otrzymuje [blue]5[/blue] pkt. [gold]Siły[/gold] i
# [blue]99[/blue] pkt. [gold]Bloku[/gold].
# [ru] Получает [blue]5[/blue] [gold]силы[/gold] и [blue]99[/blue]
# [gold]защиты[/gold] при гибели союзника.
msgctxt "powers.json:CRAB_RAGE_POWER.description"
msgid "When an ally dies, this creature gains [blue]5[/blue] [gold]Strength[/gold] and [blue]99[/blue] [gold]Block[/gold]."
msgstr "Калі паплечнік гіне, гэтая істота атрымлівае [blue]5[/blue] [gold]моцы[/gold] і [blue]99[/blue] [gold]брані[/gold]."

# [ua] Коли союзник гине, [gold]{OwnerName}[/gold] отримує
# [blue]{StrengthPower}[/blue] [gold]Міці[/gold] та [blue]{Block}[/blue]
# [gold]Броні[/gold].
# [pl] Gdy sojusznik umrze, [gold]{OwnerName}[/gold] otrzymuje
# [blue]{StrengthPower}[/blue] pkt. [gold]Siły[/gold] i [blue]{Block}[/blue]
# pkt. [gold]Bloku[/gold].
# [ru] [gold]{OwnerName}[/gold] получает [blue]{StrengthPower}[/blue]
# [gold]силы[/gold] и [blue]{Block}[/blue] [gold]защиты[/gold] при гибели
# союзника.
msgctxt "powers.json:CRAB_RAGE_POWER.smartDescription"
msgid "When an ally dies, [gold]{OwnerName}[/gold] gains [blue]{StrengthPower}[/blue] [gold]Strength[/gold] and [blue]{Block}[/blue] [gold]Block[/gold]."
msgstr "Калі паплечнік гіне, [gold]{OwnerName}[/gold] атрымлівае [blue]{StrengthPower}[/blue] [gold]моцы[/gold] і [blue]{Block}[/blue] [gold]брані[/gold]."

# [ua] Крабова лють
# [pl] Furia
# [ru] Гнев краба
msgctxt "powers.json:CRAB_RAGE_POWER.title"
msgid "Crab Rage"
msgstr "Крабавая лютасць"

# [ua] На початку Вашого ходу додайте випадковий Талант до Вашої
# [gold]Руки[/gold].
# [pl] Na początku tury dodaj losową Moc do [gold]ręki[/gold].
# [ru] Добавляет в [gold]руку[/gold] случайный Талант в начале хода.
msgctxt "powers.json:CREATIVE_AI_POWER.description"
msgid "At the start of your turn, add a random Power into your [gold]Hand[/gold]."
msgstr "На пачатку ходу дадае выпадковую карту Сілы вам у [gold]руку[/gold]."

# [ua] На початку Вашого ходу додайте {Amount:plural:випадковий
# Талант|[blue]{}[/blue] випадкових Талантів|[blue]{}[/blue] випадкових
# Талантів} до Вашої [gold]Руки[/gold].
# [pl] Na początku tury dodaj {Amount:plural:losową Moc|[blue]{}[/blue] losowe
# Moce|[blue]{}[/blue] losowych Mocy} do [gold]ręki[/gold].
# [ru] Добавляет в [gold]руку[/gold] {Amount:plural(ru):случайный
# Талант|[blue]{}[/blue] случайных Таланта|[blue]{}[/blue] случайных Талантов}
# в начале хода.
msgctxt "powers.json:CREATIVE_AI_POWER.smartDescription"
msgid "At the start of your turn, add {Amount:plural:a random Power|[blue]{}[/blue] random Powers} into your [gold]Hand[/gold]."
msgstr "На пачатку ходу дадае {Amount:plural:выпадковую карту Сілы|[blue]{}[/blue] выпадковыя карты Сілы|[blue]{}[/blue] выпадковых карт Сілы} вам у [gold]руку[/gold]."

# [ua] Творчий ШІ
# [pl] Generatywne AI
# [ru] Находчивый ИИ
msgctxt "powers.json:CREATIVE_AI_POWER.title"
msgid "Creative AI"
msgstr "Творчы ШІ"

# [ua] На початку Вашого ходу втрачайте ОЗ та отримуйте [gold]Броню[/gold].
# [pl] Na początku tury utrać PŻ i zyskaj [gold]Blok[/gold].
# [ru] Вы теряете ОЗ и получаете [gold]защиту[/gold] в начале хода.
msgctxt "powers.json:CRIMSON_MANTLE_POWER.description"
msgid "At the start of your turn, lose HP and gain [gold]Block[/gold]."
msgstr "На пачатку свайго ходу вы губляеце АЗ, але атрымліваеце [gold]браню[/gold]."

# [ua] На початку Вашого ходу втрачайте [blue]{SelfDamage}[/blue] ОЗ та
# отримуйте [blue]{Amount}[/blue] [gold]Броні[/gold].
# [pl] Na początku tury utrać [blue]{SelfDamage}[/blue] PŻ i zyskaj
# [blue]{Amount}[/blue] pkt. [gold]Bloku[/gold].
# [ru] Вы теряете [blue]{SelfDamage}[/blue] ОЗ и получаете
# [blue]{Amount}[/blue] [gold]защиты[/gold] в начале хода.
msgctxt "powers.json:CRIMSON_MANTLE_POWER.smartDescription"
msgid "At the start of your turn, lose [blue]{SelfDamage}[/blue] HP and gain [blue]{Amount}[/blue] [gold]Block[/gold]."
msgstr "На пачатку свайго ходу вы губляеце [blue]{SelfDamage}[/blue] АЗ, але атрымліваеце [blue]{Amount}[/blue] [gold]брані[/gold]."

# [ua] Пурпуровий плащ
# [pl] Karmazynowa osłona
# [ru] Алая мантия
msgctxt "powers.json:CRIMSON_MANTLE_POWER.title"
msgid "Crimson Mantle"
msgstr "Барвовая мантыя"

# [ua] Уразливі вороги отримують додаткову шкоду.
# [pl] Wrażliwi przeciwnicy otrzymują dodatkowe obrażenia.
# [ru] [gold]Уязвимые[/gold] враги получают дополнительный урон.
msgctxt "powers.json:CRUELTY_POWER.description"
msgid "Vulnerable enemies take additional damage."
msgstr "[gold]Безабаронныя[/gold] праціўнікі атрымліваюць дадатковае пашкоджанне."

# [ua] [gold]Уразливі[/gold] вороги отримують додатково [blue]{Amount}%[/blue]
# шкоди.
# [pl] [gold]Wrażliwi[/gold] przeciwnicy otrzymują dodatkowo
# [blue]{Amount}%[/blue] obrażeń.
# [ru] [gold]Уязвимые[/gold] враги получают на [blue]{Amount}%[/blue] больше
# урона.
msgctxt "powers.json:CRUELTY_POWER.smartDescription"
msgid "[gold]Vulnerable[/gold] enemies take an additional [blue]{Amount}%[/blue] damage."
msgstr "[gold]Безабаронныя[/gold] праціўнікі атрымліваюць дадаткова [blue]{Amount}%[/blue] пашкоджання."

# [ua] Жорстокість
# [pl] Okrucieństwo
# [ru] Жестокость
msgctxt "powers.json:CRUELTY_POWER.title"
msgid "Cruelty"
msgstr "Жорсткасць"

# [ua] Таланти коштують на [blue]1[/blue] {energyPrefix:energyIcons(1)} менше.
# [pl] Moce kosztują [blue]1[/blue] {energyPrefix:energyIcons(1)} mniej.
# [ru] Таланты стоят на [blue]1[/blue] {energyPrefix:energyIcons(1)} меньше.
msgctxt "powers.json:CURIOUS_POWER.description"
msgid "Powers cost [blue]1[/blue] {energyPrefix:energyIcons(1)} less."
msgstr "Карты Сілы каштуюць на [blue]1[/blue] {energyPrefix:energyIcons(1)} менш."

# [ua] Таланти коштують на [blue]{Amount}[/blue] {energyPrefix:energyIcons(1)}
# менше.
# [pl] Moce kosztują [blue]{Amount}[/blue] {energyPrefix:energyIcons(1)}
# mniej.
# [ru] Таланты стоят на [blue]{Amount}[/blue] {energyPrefix:energyIcons(1)}
# меньше.
msgctxt "powers.json:CURIOUS_POWER.smartDescription"
msgid "Powers cost [blue]{Amount}[/blue] {energyPrefix:energyIcons(1)} less."
msgstr "Карты Сілы каштуюць на [blue]{Amount}[/blue] {energyPrefix:energyIcons(1)} менш."

# [ua] Допитливий
# [pl] Ciekawość
# [ru] Любопытство
msgctxt "powers.json:CURIOUS_POWER.title"
msgid "Curious"
msgstr "Цікаўнасць"

# [ua] Отримавши шкоду, звивається та набирає броню. (Один раз за бій)
# [pl] Po otrzymaniu obrażeń zwija się i otrzymuje blok. (Jednorazowo)
# [ru] Сворачивается и получает [gold]защиту[/gold] (один раз за бой), когда
# получает урон.
msgctxt "powers.json:CURL_UP_POWER.description"
msgid "When damaged, rolls up and gains block. (Once per combat)"
msgstr "Атрымаўшы пашкоджанне скручваецца і атрымлівае браню. (Адзін раз за бой)"

# [ua] Отримує [blue]{Amount}[/blue] [gold]Броні[/gold] після першого удару.
# [pl] Otrzymuje [blue]{Amount}[/blue] pkt. [gold]Bloku[/gold] po pierwszym
# uderzeniu.
# [ru] Сворачивается и получает [blue]{Amount}[/blue] [gold]защиты[/gold]
# (один раз за бой), когда получает урон.
msgctxt "powers.json:CURL_UP_POWER.smartDescription"
msgid "Gains [blue]{Amount}[/blue] [gold]Block[/gold] upon first being hit."
msgstr "Пры першым траплянні атрымлівае [blue]{Amount}[/blue] [gold]брані[/gold]."

# [ua] Згортання
# [pl] Zwinięcie
# [ru] Клубок
msgctxt "powers.json:CURL_UP_POWER.title"
msgid "Curl Up"
msgstr "Згортванне"

# [ua] Вашим поліпшенням — кінець!!
# [pl] Na nic twoje ulepszenia!!
# [ru] Твоим улучшениям пришел конец!
msgctxt "powers.json:DAMPEN_POWER.banter"
msgid "Your upgrades are no more!!"
msgstr "Тваім паляпшэнням канец!!"

# [ua] Поки Маг-лицар живий, ВСІХ Ваших карток [gold]Знижено[/gold].
# [pl] Dopóki Mag żyje, WSZYSTKIE twoje karty są [gold]Zdegradowane[/gold].
# [ru] ВСЕ ваши карты [gold]ухудшаются[/gold], пока Маг-рыцарь жив.
msgctxt "powers.json:DAMPEN_POWER.description"
msgid "While Magi Knight is alive, ALL your cards are [gold]Downgraded[/gold]."
msgstr "Пакуль Маг-рыцар жывы, УСЕ вашы карты [gold]пагаршаюцца[/gold]."

# [ua] Послаблення
# [pl] Zgaszenie
# [ru] Подавление
msgctxt "powers.json:DAMPEN_POWER.title"
msgid "Dampen"
msgstr "Прыглушэнне"

# [ua] Щоразу, коли Ви граєте картку вартістю [blue]2[/blue] Енергії або
# більше, отримайте [blue]7[/blue] [gold]Броні[/gold].
# [pl] Kiedykolwiek zagrasz kartę kosztującą co najmniej [blue]2[/blue] pkt.
# Energii, zyskaj [blue]7[/blue] pkt. [gold]Bloku[/gold].
# [ru] Дает [blue]7[/blue] [gold]защиты[/gold], когда вы разыгрываете карту
# стоимостью не менее [blue]2[/blue].
msgctxt "powers.json:DANSE_MACABRE_POWER.description"
msgid "Whenever you play a card that costs [blue]2[/blue] Energy or more, gain [blue]7[/blue] [gold]Block[/gold]."
msgstr "Штораз, калі вы разыгрываеце карту, якая каштуе [blue]2[/blue] энергіі або больш, дае [blue]7[/blue] [gold]брані[/gold]."

# [ua] Щоразу, коли Ви граєте картку вартістю {Energy:energyIcons()} або
# більше, отримайте [blue]{Amount}[/blue] [gold]Броні[/gold].
# [pl] Kiedykolwiek zagrasz kartę kosztującą co najmniej
# {Energy:energyIcons()}, zyskaj [blue]{Amount}[/blue] pkt.
# [gold]Bloku[/gold].
# [ru] Дает [blue]{Amount}[/blue] [gold]защиты[/gold], когда вы разыгрываете
# карту стоимостью не менее {Energy:energyIcons()}.
msgctxt "powers.json:DANSE_MACABRE_POWER.smartDescription"
msgid "Whenever you play a card that costs {Energy:energyIcons()} or more, gain [blue]{Amount}[/blue] [gold]Block[/gold]."
msgstr "Штораз, калі вы разыгрываеце карту, якая каштуе {Energy:energyIcons()} або больш, дае [blue]{Amount}[/blue] [gold]брані[/gold]."

# [ua] Танець смерті
# [pl] Taniec śmierci
# [ru] Пляска смерти
msgctxt "powers.json:DANSE_MACABRE_POWER.title"
msgid "Danse Macabre"
msgstr "Танец смерці"

# [ua] Щоразу, коли картку [gold]Спалено[/gold], витягніть [blue]1[/blue]
# картку.
# [pl] Kiedykolwiek karta zostanie [gold]Wyczerpana[/gold], dobierz
# [blue]1[/blue] kartę.
# [ru] Вы добираете [blue]1[/blue] карту, когда одна из карт
# [gold]сжигается[/gold].
msgctxt "powers.json:DARK_EMBRACE_POWER.description"
msgid "Whenever a card is [gold]Exhausted[/gold], draw [blue]1[/blue] card."
msgstr "Штораз, калі карта [gold]спальваецца[/gold], вы дабіраеце [blue]1[/blue] карту."

# [ua] Щоразу, коли картку [gold]Спалено[/gold], витягніть
# [blue]{Amount}[/blue] {Amount:plural:картку|картки|карток}.
# [pl] Kiedykolwiek karta zostanie [gold]Wyczerpana[/gold], dobierz
# [blue]{Amount}[/blue] {Amount:plural:kartę|karty|kart}.
# [ru] Вы добираете [blue]{Amount}[/blue]
# {Amount:plural(ru):карту|карты|карт}, когда одна из карт
# [gold]сжигается[/gold].
msgctxt "powers.json:DARK_EMBRACE_POWER.smartDescription"
msgid "Whenever a card is [gold]Exhausted[/gold], draw [blue]{Amount}[/blue] {Amount:plural:card|cards}."
msgstr "Штораз, калі карта [gold]спальваецца[/gold], вы дабіраеце [blue]{Amount}[/blue] {Amount:plural:карту|карты|карт}."

# [ua] Темні обійми
# [pl] Objęcia mroku
# [ru] Объятия тьмы
msgctxt "powers.json:DARK_EMBRACE_POWER.title"
msgid "Dark Embrace"
msgstr "Абдымкі цемры"

# [ua] [gold]Уразливий[/gold] та [gold]Ослаблений[/gold] вдвічі ефективніші
# протягом наступних [blue]2[/blue] ходів.
# [pl] Efekty [gold]Wrażliwości[/gold] i [gold]Słabości[/gold] na tym
# przeciwniku są podwojone przez [blue]2[/blue] tury.
# [ru] [gold]Уязвимость[/gold] и [gold]слабость[/gold] в два раза эффективнее
# в течение [blue]2[/blue] ходов.
msgctxt "powers.json:DEBILITATE_POWER.description"
msgid "[gold]Vulnerable[/gold] and [gold]Weak[/gold] are twice as effective for the next [blue]2[/blue] turns."
msgstr "[gold]Безабароннасць[/gold] і [gold]слабасць[/gold] удвая больш дзейсныя на працягу наступных [blue]2[/blue] хадоў."

# [ua] [gold]Уразливий[/gold] та [gold]Ослаблений[/gold] вдвічі ефективніші
# {Amount:plural:цього ходу|протягом наступних [blue]{}[/blue] ходів|протягом
# наступних [blue]{}[/blue] ходів}.
# [pl] Efekty [gold]Wrażliwości[/gold] i [gold]Słabości[/gold] na tym
# przeciwniku są podwojone {Amount:plural:w tej turze|przez [blue]{}[/blue]
# tury|przez [blue]{}[/blue] tur}.
# [ru] [gold]Уязвимость[/gold] и [gold]слабость[/gold] в два раза эффективнее
# {Amount:plural(ru):в этом ходу|в течение [blue]{}[/blue] ходов|в течение
# [blue]{}[/blue] ходов}.
msgctxt "powers.json:DEBILITATE_POWER.smartDescription"
msgid "[gold]Vulnerable[/gold] and [gold]Weak[/gold] are twice as effective {Amount:plural:this turn|for the next [blue]{}[/blue] turns}."
msgstr "[gold]Безабароннасць[/gold] і [gold]слабасць[/gold] удвая больш дзейсныя {Amount:plural:у гэтым ходзе|на працягу наступных [blue]{}[/blue] хадоў|на працягу наступных [blue]{}[/blue] хадоў}."

# [ua] Виснаження
# [pl] Pozbawienie sił
# [ru] Изнурение
msgctxt "powers.json:DEBILITATE_POWER.title"
msgid "Debilitate"
msgstr "Знявечванне"

# [ua] На початку Вашого ходу додайте [blue]1[/blue] випадкову
# [gold]Поліпшену[/gold] картку до Вашої руки.
# [pl] Na początku tury dodaj [blue]1[/blue] [gold]Ulepszoną[/gold] kartę do
# ręki.
# [ru] Добавляет в руку [blue]1[/blue] случайную [gold]улучшенную[/gold] карту
# в начале хода.
msgctxt "powers.json:DECREE_OF_ENTROPY_POWER.description"
msgid "At the start of your turn, add [blue]1[/blue] random [gold]Upgraded[/gold] card to your hand."
msgstr "На пачатку вашага ходу дадае [blue]1[/blue] выпадковую [gold]палепшаную[/gold] карту ў вашу руку."

# [ua] На початку Вашого ходу додайте [blue]{Amount}[/blue] випадкових
# [gold]Поліпшених[/gold] {Amount:plural:картку|картки|карток} до Вашої руки.
# [pl] Na początku tury dodaj [blue]{Amount}[/blue]
# {Amount:plural:[gold]Ulepszoną[/gold] kartę|[gold]Ulepszone[/gold]
# karty|[gold]Ulepszonych[/gold] kart} do ręki.
# [ru] Добавляет в руку [blue]{Amount}[/blue] {Amount:plural(ru):случайную
# [gold]улучшенную[/gold] карту|случайные [gold]улучшенные[/gold]
