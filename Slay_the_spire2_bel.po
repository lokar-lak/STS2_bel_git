msgid "Despair"
msgstr "Роспач"

# [ua] Нанести {Damage:diff()} шкоди.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# [ru] Наносит {Damage:diff()} урона.
msgctxt "cards.json:DEVASTATE.description"
msgid "Deal {Damage:diff()} damage."
msgstr "Прычыняе {Damage:diff()} пашкоджання."

# [ua] Спустошення
# [pl] Dewastacja
# [ru] Пустое место
msgctxt "cards.json:DEVASTATE.title"
msgid "Devastate"
msgstr "Спапяленне"

# [ua] Щоразу, коли Ви граєте [gold]Душу[/gold], [gold]Призиваєте[/gold]
# {DevourLifePower:diff()}.
# [pl] Kiedykolwiek zagrasz [gold]Duszę[/gold], [gold]Przywołaj[/gold]
