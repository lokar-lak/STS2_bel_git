# [ua] Виникла проблема з завантаженням файлу налаштувань.
# 
# Будь ласка, надішліть звіт про помилку, щоб ми могли виправити проблему.
# [pl] Wystąpił problem z wczytywaniem zapisu ustawień gry.
# 
# Prosimy o wysłanie raportu błędu, abyśmy mogli rozwiązać ten problem.
# [ru] Возникла проблема с загрузкой сохраненных настроек.
# 
# Пожалуйста, отправьте нам сообщение об ошибке.
msgctxt "main_menu_ui.json:INVALID_SAVE_POPUP.description_settings"
msgid "There was a problem loading your settings save file.\n\n"
"Please send a bug report so we can fix the issue."
msgstr "Узнікла праблема з загрузкай захаваных налад.\n\n"
"Калі ласка, дашліце нам справаздачу, каб мы маглі выправіць праблему."

# [ua] Закрити
# [pl] Zamknij
# [ru] Скрыть
msgctxt "main_menu_ui.json:INVALID_SAVE_POPUP.dismiss"
msgid "Dismiss"
msgstr "Адхіліць"

# [ua] Пошкоджене збереження!
# [pl] Uszkodzony plik zapisu!
# [ru] Поврежденное сохранение!
msgctxt "main_menu_ui.json:INVALID_SAVE_POPUP.title"
msgid "Corrupt Save!"
msgstr "Пашкоджанае захаванне!"

# [ua] Запросити
# [pl] Zaproś
# [ru] Пригласить
msgctxt "main_menu_ui.json:INVITE"
msgid "Invite"
msgstr "Запрасіць"

# [ua] Приєднатися до гри, створеної другом.
# [pl] Dołącz do gry ze znajomymi.
# [ru] Присоединиться к игре друга.
msgctxt "main_menu_ui.json:JOIN.description"
msgid "Join a game hosted by a friend."
msgstr "Далучыцца да гульні, якую арганізуе сябар."

# [ua] Приєднатися
# [pl] Dołącz
# [ru] Присоединиться
msgctxt "main_menu_ui.json:JOIN.title"
msgid "Join"
msgstr "Далучыцца"

# [ua] Жоден друг зараз не грає в мультиплеєр.
# [pl] Nikt ze znajomych nie gra obecnie w trybie wieloosobowym.
# [ru] Никто из ваших друзей сейчас не играет.
msgctxt "main_menu_ui.json:JOIN_FRIENDS_MENU.noFriends"
msgid "No friends currently playing multiplayer."
msgstr "Зараз ніхто з вашых сяброў не гуляе ў сумесным рэжыме."

# [ua] Оновити
# [pl] Odśwież
# [ru] Обновить
msgctxt "main_menu_ui.json:JOIN_FRIENDS_MENU.refresh"
msgid "Refresh"
msgstr "Абнавіць"

# [ua] Оберіть друга для приєднання
# [pl] Wybierz znajomego
# [ru] Выберите друга для совместной вылазки
msgctxt "main_menu_ui.json:JOIN_FRIENDS_MENU.title"
msgid "Choose Friend to Join"
msgstr "Выберыце сябра, да якога хочаце далучыцца"

# [ua] Переглядайте та порівнюйте свій рахунок з друзями та іншими гравцями.
# [pl] Porównaj swój wynik z innymi graczami.
# [ru] Смотрите и сравнивайте количество своих очков с друзьями и другими
# игроками.
msgctxt "main_menu_ui.json:LEADERBOARDS.description"
msgid "View and compare your score with friends and other players."
msgstr "Праглядайце і параўноўвайце свой вынік з вынікамі сяброў і іншых гульцоў."

# [ua] Ім'я
# [pl] Nazwa
# [ru] Имя
msgctxt "main_menu_ui.json:LEADERBOARDS.nameHeader"
msgid "Name"
msgstr "Імя"

# [ua] Ранг
# [pl] Ranga
# [ru] Ранг
msgctxt "main_menu_ui.json:LEADERBOARDS.rankHeader"
msgid "Rank"
msgstr "Ранг"

# [ua] Рахунок
# [pl] Wynik
# [ru] Очки
msgctxt "main_menu_ui.json:LEADERBOARDS.scoreHeader"
msgid "Score"
msgstr "Вынік"

# [ua] Таблиці лідерів
# [pl] Rankingi
# [ru] Таблица лидеров
msgctxt "main_menu_ui.json:LEADERBOARDS.title"
msgid "Leaderboards"
msgstr "Спіс лідараў"

# [ua] Завантаження...
# [pl] Wczytywanie...
# [ru] Загрузка…
msgctxt "main_menu_ui.json:LOADING_OVERLAY.label"
msgid "Loading..."
msgstr "Загрузка..."

# [ua] Запущено з модами. Завантажено {count}
# {count:plural:мод|моди|модів}{hasError: З ПОМИЛКАМИ!|.}
# [pl] Aktywowano modyfikacje. Wczytano {count}
# {count:plural:modyfikację|modyfikacje|modyfikacji}{hasError: Z BŁĘDAMI!|.}
# [ru] Запущен модовый режим. {count:plural(ru):Загружен|Загружено|Загружено}
# {count} {count:plural(ru):мод|мода|модов}. {hasError: ОБНАРУЖЕНЫ ОШИБКИ!|}
msgctxt "main_menu_ui.json:MODDED_WARNING"
msgid "Running Modded. Loaded {count} {count:plural:mod|mods}{hasError: WITH ERRORS!|.}"
msgstr "Гульня запушчана з мадыфікацыямі. Загружана {count} {count:plural:мадыфікацыя|мадыфікацыі|мадыфікацый}{hasError: З ПАМЫЛКАМІ!|.}"

# [ua] Скасувати
# [pl] Anuluj
# [ru] Отменить
msgctxt "main_menu_ui.json:MODDING_POPUP.cancel"
msgid "Cancel"
msgstr "Скасаваць"

# [ua] НЕ ЗАВАНТАЖУЙТЕ МОДИ З НЕНАДІЙНИХ ДЖЕРЕЛ! Моди можуть зашкодити Вашому
# комп'ютеру!
# 
# Якщо Ви не завантажували моди або не довіряєте їм, натисніть Скасувати.
# 
# Якщо Ви натиснете Завантажити моди, потрібно буде перезапустити гру.
# [pl] NIE WCZYTUJ MODYFIKACJI Z NIEZAUFANYCH ŹRÓDEŁ! Modyfikacje mogą
# uszkodzić twój komputer!
# 
# Jeżeli nie pobierano żadnych modyfikacji albo jeżeli im nie ufasz, naciśnij
# Anuluj.
# 
# Jeżeli naciśniesz „Wczytaj modyfikacje”, należy uruchomić grę ponownie.
# [ru] НЕ ЗАГРУЖАЙТЕ МОДЫ ИЗ НЕДОСТОВЕРНЫХ ИСТОЧНИКОВ! Моды могут навредить
# вашему компьютеру!
# 
# Если вы не доверяете загруженным модам или вовсе их не загружали, нажмите
# «Отменить».
# 
# Если вы выберете «Загрузить моды», вам придется перезапустить игру.
msgctxt "main_menu_ui.json:MODDING_POPUP.description"
msgid "DO NOT LOAD MODS FROM AN UNTRUSTED SOURCE! Mods can harm your computer!\n\n"
"If you did not download mods, or you do not trust them, press cancel.\n\n"
"If you press Load Mods, you will need to relaunch the game."
msgstr "НЕ ЗАГРУЖАЙЦЕ МАДЫФІКАЦЫІ З НЯСПРАЎДЖАНЫХ КРЫНІЦ! Яны могуць нашкодзіць вашаму камп'ютару!\n\n"
"Калі вы не спампоўвалі мадыфікацый або не давяраеце ім, націсніце «Скасаваць».\n\n"
"Калі вы націснеце «Загрузіць мадыфікацыі», вам трэба будзе перазапусціць гульню."

# [ua] Завантажити моди
# [pl] Wczytaj modyfikacje
# [ru] Загрузить моды
msgctxt "main_menu_ui.json:MODDING_POPUP.load_mods"
msgid "Load Mods"
msgstr "Загрузіць мадыфікацыі"

# [ua] Завантажити моди?
# [pl] Czy chcesz wczytać modyfikacje?
# [ru] Загрузить моды?
msgctxt "main_menu_ui.json:MODDING_POPUP.title"
msgid "Load Mods?"
msgstr "Загрузіць мадыфікацыі?"

# [pl] Nie udało się uruchomić zestawu plików DLL do modyfikacji
# [red]{id}[/red]! Sprawdź dziennik błędów po więcej informacji.
# [ru] Произошла ошибка при инициализации сборки DLL для мода [red]{id}[/red].
# Более подробную информацию вы можете найти в логах.
msgctxt "main_menu_ui.json:MOD_ERROR.ASSEMBLY_LOAD"
msgid "Assembly DLL for mod [red]{id}[/red] failed to initialize! See logs for more info."
msgstr "Памылка ініцыялізацыі зборачнай DLL-бібліятэкі для мадыфікацыі [red]{id}[/red]! Больш інфармацыі можна знайсці ў журнале памылак."

# [pl] Modyfikacja [red]{id}[/red] jest częścią zależności cyklicznej:
# {dependencyChain}. To nie jest dozwolone!
# [ru] Недопустимая ситуация: мод [red]{id}[/red] входит в цепочку круговых
# зависимостей: {dependencyChain}.
msgctxt "main_menu_ui.json:MOD_ERROR.CIRCULAR_DEPENDENCY"
msgid "Mod [red]{id}[/red] is part of a circular dependency chain: {dependencyChain}. This is not allowed!"
msgstr "Мод [red]{id}[/red] з'яўляецца часткай ланцужка кругавых залежнасцяў: {dependencyChain}. Гэта не дазволена!"

# [pl] Przynajmniej dwie modyfikacje mają to samo id: [red]{id}[/red]!
# [ru] Обнаружено два или более мода с одинаковым id: [red]{id}[/red]!
msgctxt "main_menu_ui.json:MOD_ERROR.DUPLICATE_ID"
msgid "There are two or more mods with the same id [red]{id}[/red]!"
msgstr "Знойдзены прынамсі дзве мадыфікацыі з аднолькавым ідэнтыфікатарам [red]{id}[/red]!"

# [pl] Przy wczytywaniu modyfikacji [red]{id}[/red] wygenerowano wyjątek:
# {exceptionType}! Sprawdź dziennik błędów po więcej informacji.
# [ru] При загрузке мода [red]{id}[/red] произошла ошибка с типом
# {exceptionType}! Более подробную информацию вы можете найти в логах.
msgctxt "main_menu_ui.json:MOD_ERROR.EXCEPTION"
msgid "An exception of type {exceptionType} was thrown while loading mod [red]{id}[/red]! See logs for more info."
msgstr "Падчас загрузкі мадыфікацыі [red]{id}[/red] адбылася памылка {exceptionType}! Каб атрымаць больш дэтальную інфармацыю, праглядзіце журнал памылак."

# [pl] Do modyfikacji [red]{id}[/red] brakuje {missingCount} zależności:
# {missingDependencies}
# [ru] У мода [red]{id}[/red] не хватает {missingCount}
# {missingCount:plural(ru):зависимости|зависимостей|зависимостей}:
# {missingDependencies}
msgctxt "main_menu_ui.json:MOD_ERROR.MISSING_DEPENDENCY"
msgid "Mod [red]{id}[/red] is missing {missingCount} dependencies: {missingDependencies}"
msgstr "Мадыфікацыя [red]{id}[/red] не можа знайсці {missingCount} сваіх залежнасцяў: {missingDependencies}"

# [pl] Liczba wczytanych modyfikacji: {mods}
# [ru] Загруженные моды: {mods}
msgctxt "main_menu_ui.json:MOD_ERROR.NONE"
msgid "Mods loaded: {mods}"
msgstr "Загружаныя моды: {mods}"

# [ua] Виявлено нові моди, але вони не працюватимуть до перезапуску.
# [pl] Wykryto nowe modyfikacje, ale nie zadziałają, dopóki gra nie zostanie
# uruchomiona ponownie.
# [ru] Замечены новые моды, но они не будут работать до перезапуска игры.
msgctxt "main_menu_ui.json:MOD_NOT_LOADED_POPUP.description"
msgid "New mods were detected, but they won't work until after a restart."
msgstr "Знойдзены новыя мадыфікацыі, але яны не будуць працаваць, пакуль вы не перазапусціце гульню."

# [ua] Мод не завантажено
# [pl] Nie wczytano modyfikacji
# [ru] Мод не загружен
msgctxt "main_menu_ui.json:MOD_NOT_LOADED_POPUP.title"
msgid "Mod Not Loaded"
msgstr "Мадыфікацыя не загружана"

# [ua] Виявлено мишу
# [pl] Wykryto myszkę
# [ru] Обнаружена мышь
msgctxt "main_menu_ui.json:MOUSE_DETECTED"
msgid "Mouse Detected"
msgstr "Выяўлена мыш"

# [ua] Покинути останній багатокористувацький забіг.
# [pl] Porzuć ostatnią wyprawę w trybie wieloosobowym.
# [ru] Бросить последнюю созданную совместную вылазку.
msgctxt "main_menu_ui.json:MP_ABANDON.description"
msgid "Abandon your last hosted multiplayer run."
msgstr "Пакінуць апошнюю арганізаваную вамі сумесную выправу."

# [ua] Покинути збереження
# [pl] Porzuć zapis
# [ru] Бросить сохранение
msgctxt "main_menu_ui.json:MP_ABANDON.title"
msgid "Abandon Save"
msgstr "Пакінуць захаванне"

# [ua] Продовжити останній багатокористувацький забіг. Приєднатися можуть лише
# гравці, що були в забігу.
# [pl] Kontynuuj ostatnią wyprawę w trybie wieloosobowym. Mogą dołączyć tylko
# gracze, którzy uczestniczyli w wyprawie.
# [ru] Продолжить последнюю совместную вылазку. Присоединиться смогут только
# игроки, которые уже в ней участвовали.
msgctxt "main_menu_ui.json:MP_LOAD.description"
msgid "Continue your last multiplayer run. Only players that were in the run can join."
msgstr "Працягнуць апошнюю сумесную выправу. Далучыцца могуць толькі гульцы, якія бралі ў ёй удзел першапачаткова."

# [ua] Створити зі збереження
# [pl] Zorganizuj grę z zapisu
# [ru] Создать из сохранения
msgctxt "main_menu_ui.json:MP_LOAD.title"
msgid "Host from Save"
msgstr "Арганізаваць з захаванай выправы"

# [ua] Мультиплеєр
# [pl] Tryb wieloosobowy
# [ru] Совместная игра
msgctxt "main_menu_ui.json:MULTIPLAYER"
msgid "Multiplayer"
msgstr "Сумесная гульня"

# [ua] Ви єдиний гравець!
# [pl] Jesteś jedynym graczem!
# [ru] Кроме вас в лобби никого нет!
msgctxt "main_menu_ui.json:MULTIPLAYER_CHAR_SELECT.SOLO"
msgid "You are the only player!"
msgstr "Вы адзіны гулец!"

# [ua] Акт: {act}
# [pl] Akt: {act}.
# [ru] Акт: {act}
msgctxt "main_menu_ui.json:MULTIPLAYER_LOAD_MENU.ACT"
msgid "Act: {act}"
msgstr "Акт: {act}"

# [ua] Поверх: {floor}
# [pl] Piętro: {floor}.
# [ru] Этаж: {floor}
msgctxt "main_menu_ui.json:MULTIPLAYER_LOAD_MENU.FLOOR"
msgid "Floor: {floor}"
msgstr "Паверх: {floor}"

# [ua] Та ще {others}:
# [pl] Oraz {others}:
# [ru] И еще {others} {others:plural(ru):игрок|игрока|игроков}:
msgctxt "main_menu_ui.json:MULTIPLAYER_LOAD_MENU.OTHERS"
msgid "And {others} others:"
msgstr "І яшчэ {others} {others:plural:гулец|гульцы|гульцоў}:"

# [ua] Назад
# [pl] Wróć
# [ru] Назад
msgctxt "main_menu_ui.json:MULTIPLAYER_WARNING_POPUP.back"
msgid "Back"
msgstr "Назад"

# [ua] Ми рекомендуємо спочатку спробувати одиночну гру, щоб ознайомитися з
# основами та розблокувати деякі предмети.
# 
# Вас попереджено!
# [pl] Polecamy najpierw zagrać w trybie jednoosobowym, aby zapoznać się z
# podstawami gry i odblokować trochę przedmiotów.
# 
# W razie czego ostrzegaliśmy!
# [ru] Рекомендуем начать с одиночной игры, чтобы ознакомиться с основами и
# разблокировать предметы!
# 
# Предупрежден — значит вооружен.
msgctxt "main_menu_ui.json:MULTIPLAYER_WARNING_POPUP.body"
msgid "We recommend that you first try Singleplayer to familiarize yourself with the basics and unlock some items.\n\n"
"You have been warned!"
msgstr "Мы рэкамендуем спачатку паспрабаваць гульню ў адзіночным рэжыме, каб азнаёміцца з асновамі і разблакаваць некаторыя прадметы.\n\n"
"Калі што, вас папярэджвалі!"

# [ua] Ігнорувати
# [pl] Ignoruj
# [ru] Пропустить
msgctxt "main_menu_ui.json:MULTIPLAYER_WARNING_POPUP.ignore"
msgid "Ignore"
msgstr "Ігнараваць"

# [ua] Виявлено перший забіг!
# [pl] Wykryto pierwszą wyprawę!
# [ru] Замечена первая вылазка!
msgctxt "main_menu_ui.json:MULTIPLAYER_WARNING_POPUP.title"
msgid "First Run Detected!"
msgstr "Выяўлена першая выправа!"

# [ua] Не вдалося розпочати хостинг. Перевірте інтернет-з'єднання.
# 
# Детальніше: {info}
# [pl] Organizowanie gry nie powiodło się. Sprawdź swoje połączenie z
# internetem.
# 
# Więcej informacji: {info}
# [ru] Не удалось создать игру. Проверьте подключение к интернету.
# 
# Дополнительная информация: {info}
msgctxt "main_menu_ui.json:NETWORK_ERROR.FAILED_TO_HOST.body"
msgid "Could not start hosting. Check your internet connection.\n\n"
"More info: {info}"
msgstr "Не ўдалося арганізаваць гульню. Праверце злучэнне з інтэрнэтам.\n\n"
"Больш інфармацыі: {info}"

# [ua] Хост покинув гру.
# [pl] Gospodarz opuścił grę.
# [ru] Создатель игры бросил ее.
msgctxt "main_menu_ui.json:NETWORK_ERROR.HOST_ABANDONED.body"
msgid "The host abandoned the game."
msgstr "Арганізатар пакінуў гульню."

# [ua] Сталася внутрішня помилка.
# 
# Детальніше: {info}
# [pl] Wystąpił wewnętrzny błąd.
# 
# Więcej informacji: {info}
# [ru] Возникла внутренняя ошибка.
# 
# Дополнительная информация: {info}
msgctxt "main_menu_ui.json:NETWORK_ERROR.INTERNAL_ERROR.body"
msgid "An internal error occurred.\n\n"
"More info: {info}"
msgstr "Адбылася ўнутраная памылка.\n\n"
"Больш інфармацыі: {info}"

# [ua] Ця гра більше не існує.
# [pl] Gra już nie jest dostępna.
# [ru] Игра больше не существует.
msgctxt "main_menu_ui.json:NETWORK_ERROR.INVALID_JOIN.body"
msgid "The game no longer exists."
msgstr "Гэтай гульні больш не існуе."

# [ua] Вас заблоковано або забанено кимось у лобі.
# [pl] Usunięto lub zablokowano cię z poczekalni.
# [ru] Кто-то в лобби заблокировал вас.
msgctxt "main_menu_ui.json:NETWORK_ERROR.JOIN_BLOCKED_BY_USER.body"
msgid "You were banned or blocked by someone in the lobby."
msgstr "Нехта з чакальні вас заблакаваў."

# [ua] Вас вигнано з гри.
# [pl] Wyrzucono cię z gry.
# [ru] Вас исключили из игры.
msgctxt "main_menu_ui.json:NETWORK_ERROR.KICKED.body"
msgid "You were kicked from the game."
msgstr "Вас выгналі з гульні."

# [ua] Лобі заповнене.
# [pl] Poczekalnia jest pełna.
# [ru] Лобби заполнено.
msgctxt "main_menu_ui.json:NETWORK_ERROR.LOBBY_FULL.body"
msgid "The lobby is full."
msgstr "Чакальня запоўнена."

# [ua] Невідповідність модів!
# 
# {info}
# [pl] Wykryto niezgodność modyfikacji!
# 
# {info}
# [ru] Несовместимость модов!
# 
# {info}
msgctxt "main_menu_ui.json:NETWORK_ERROR.MOD_MISMATCH.body"
msgid "Mod mismatch!\n\n"
"{info}"
msgstr "Несумяшчальнасць мадыфікацый!\n\n"
"{info}"

# [ua] У нас є моди, яких немає у хоста: {mods}
# [pl] Wykryto u nas modyfikacje, których nie ma u gospodarza: {mods}
# [ru] У вас есть моды, которых нет у создателя игры: {mods}
