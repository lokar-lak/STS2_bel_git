# [ru] Другие игроки наносят цели [blue]в {Amount}
# {Amount:plural(ru):раз|раза|раз}[/blue] больше урона от атак в этом ходу.
msgctxt "powers.json:FLANKING_POWER.smartDescription"
msgid "Other allies deal [blue]{Amount}[/blue] times more attack damage to this enemy this turn."
msgstr "Іншыя паплечнікі ў гэтым ходзе прычыняюць гэтаму праціўніку ў [blue]{Amount}[/blue] разы больш пашкоджання."

# [ua] Фланговий удар
# [pl] Oskrzydlenie
# [ru] Заход с фланга
msgctxt "powers.json:FLANKING_POWER.title"
msgid "Flanking"
msgstr "Заход з фланга"

# [ua] Отримує на [gold]50%[/gold] менше шкоди від Атак.
# [pl] Otrzymuje [gold]50%[/gold] mniej obrażeń od Ataków.
# [ru] Получает на [gold]50%[/gold] меньше урона от Атак.
msgctxt "powers.json:FLUTTER_POWER.description"
msgid "Receives [gold]50%[/gold] less damage from Attacks."
msgstr "Атрымлівае на [gold]50%[/gold] менш пашкоджання ад карт Атакі."

# [ua] Отримує на [blue]{DamageDecrease}%[/blue] менше шкоди від Атак.
# Завдайте [blue]{Amount}[/blue] {Amount:plural:раз|рази|разів} шкоди атакою,
