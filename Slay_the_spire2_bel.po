# Вы добираете 1 карту.
# Удаляется из [gold]колоды[/gold].
msgctxt "cards.json:DEPRECATED_CARD.description"
msgid "[blue]This card was removed in a recent update.[/blue]\n"
"Draw 1 card.\n"
"Remove this from your [gold]Deck[/gold]."
msgstr "[blue]Гэтую карту прыбралі з гульні ў нядаўнім абнаўленні.[/blue]\n"
"Вы дабіраеце 1 карту.\n"
"Выдаляецца з вашай [gold]калоды[/gold]."

# [ua] Застаріла Карта
# [pl] Usunięta karta
# [ru] Устаревшая карта
