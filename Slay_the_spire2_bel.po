msgctxt "cards.json:THUNDERCLAP.description"
msgid "Deal {Damage:diff()} damage and apply {VulnerablePower:diff()} [gold]Vulnerable[/gold] to ALL enemies."
msgstr "Прычыняе {Damage:diff()} пашкоджання і накладае {VulnerablePower:diff()} [gold]безабароннасці[/gold] на УСІХ праціўнікаў."

# [ua] Удар грому
# [pl] Grzmot
# [ru] Раскат грома
msgctxt "cards.json:THUNDERCLAP.title"
msgid "Thunderclap"
msgstr "Пярун"

# [ua] Нанести шкоду рівну [gold]Приреченості[/gold] ворога.{IsTargeting:
# (Завдає {CalculatedDamage:diff()} шкоди)|}
# [pl] Zadaj obrażenia równe pkt. [gold]Zagłady[/gold] na
# przeciwniku.{IsTargeting:
# (Zadaje {CalculatedDamage:diff()} pkt. obrażeń)|}
# [ru] Наносит урон, равный [gold]злому року[/gold] врага.{IsTargeting:
# (Наносит {CalculatedDamage:diff()} урона)|}
