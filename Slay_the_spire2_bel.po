msgctxt "cards.json:HEADBUTT.selectionScreenPrompt"
msgid "Choose a card to put on top of your Draw Pile."
msgstr "Выберыце карту, якая пакладзецца на верх стоса дабору."

# [ua] Удар Головою
# [pl] Z główki
# [ru] Таран
msgctxt "cards.json:HEADBUTT.title"
msgid "Headbutt"
msgstr "У лоб"

