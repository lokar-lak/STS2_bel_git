# [gold]Міці[/gold].
# [pl] Kiedykolwiek zagrasz Umiejętność, zyskuje [blue]2[/blue] pkt.
# [gold]Siły[/gold].
# [ru] Получает [blue]2[/blue] [gold]силы[/gold], когда вы разыгрываете Навык.
msgctxt "powers.json:ENRAGE_POWER.description"
msgid "Whenever you play a Skill, gains [blue]2[/blue] [gold]Strength[/gold]."
msgstr "Штоаз, калі вы разыгрываеце карту Умення, дае [blue]2[/blue] [gold]моцы[/gold]."

# [ua] Щоразу, коли Ви граєте Вміння, отримує [blue]{Amount}[/blue]
# [gold]Міці[/gold].
# [pl] Kiedykolwiek zagrasz Umiejętność, zyskuje [blue]{Amount}[/blue] pkt.
# [gold]Siły[/gold].
# [ru] Получает [blue]{Amount}[/blue] [gold]силы[/gold], когда вы разыгрываете
# Навык.
msgctxt "powers.json:ENRAGE_POWER.smartDescription"
msgid "Whenever you play a Skill, gains [blue]{Amount}[/blue] [gold]Strength[/gold]."
msgstr "Штораз, калі вы разыгрываеце карту Умення, дае [blue]{Amount}[/blue] [gold]моцы[/gold]."

# [ua] Лють
# [pl] Rozwścieczenie
# [ru] Бешенство
