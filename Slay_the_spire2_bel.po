# [pl] Wejście smoka
# [ru] Драматичный дебют
msgctxt "cards.json:DRAMATIC_ENTRANCE.title"
msgid "Dramatic Entrance"
msgstr "Эфектнае з’яўленне"

# [ua] Переміщуєте {Cards:diff()} {Cards:plural:карту|карти|карт} з
# [gold]Відбою[/gold] до [gold]Руки[/gold].
# [pl] Przenieś {Cards:diff()} {Cards:plural:kartę|karty|kart} ze [gold]stosu
# kart odrzuconych[/gold] do [gold]ręki[/gold].
# [ru] Вы берете {Cards:diff()} {Cards:plural(ru):выбранную карту|выбранные
# карты|выбранных карт} из [gold]стопки сброса[/gold].
msgctxt "cards.json:DREDGE.description"
msgid "Put {Cards:diff()} {Cards:plural:card|cards} from your [gold]Discard Pile[/gold] into your [gold]Hand[/gold]."
msgstr "Вы кладзяце {Cards:diff()} {Cards:plural: выбраную карту| выбраныя карты|выбраных карт} са [gold]стоса скідання[/gold] у сваю [gold]руку[/gold]."

# [ua] Оберіть {Amount} {Amount:plural:карту|карти|карт}, щоб перемістити до
# [gold]Руки[/gold]
# [pl] Wybierz {Amount} {Amount:plural:kartę|karty|kart} do [gold]ręki[/gold].
# [ru] Выберите {Amount} {Amount:plural(ru):карту, которую|карты,
# которые|карт, которые} хотите взять.
msgctxt "cards.json:DREDGE.selectionScreenPrompt"
msgid "Choose {Amount} {Amount:plural:card|cards} to put into your [gold]Hand[/gold]"
msgstr "Выберыце {Amount} {Amount:plural:карту|карты|карт}, каб пакласці ў [gold]руку[/gold]"

# [ua] Підйом
# [pl] Pogłębianie
# [ru] Эксгумация
msgctxt "cards.json:DREDGE.title"
msgid "Dredge"
msgstr "Эксгумацыя"

# [ua] Берете {Cards:diff()} карти.
# На початку вашого ходу [gold]Спалюєте[/gold] верхню карту
# [gold]Добору[/gold].
