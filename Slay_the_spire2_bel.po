# [ua] На початку вашого ходу завдайте {RollingBoulderPower:diff()} шкоди ВСІМ
# ворогам і збільшіть цю шкоду на {IncrementAmount:diff()}.
# [pl] Na początku tury zadaj {RollingBoulderPower:diff()} pkt. obrażeń
# WSZYSTKIM przeciwnikom, następnie zwiększ te obrażenia o
# {IncrementAmount:diff()} pkt.
# [ru] Наносит {RollingBoulderPower:diff()} урона ВСЕМ врагам в начале хода,
# затем урон повышается на {IncrementAmount:diff()}.
msgctxt "cards.json:ROLLING_BOULDER.description"
msgid "At the start of your turn, deal {RollingBoulderPower:diff()} damage to ALL enemies and increase this damage by {IncrementAmount:diff()}."
msgstr "На пачатку вашага ходу прычыняе {RollingBoulderPower:diff()} пашкоджання УСІМ праціўнікам і павялічвае гэтае пашкоджанне на {IncrementAmount:diff()}."

# [ua] Камінь, що котиться
# [pl] Kulopłot
# [ru] Каменная лавина
msgctxt "cards.json:ROLLING_BOULDER.title"
msgid "Rolling Boulder"
msgstr "Каменная лавіна"

# [ua] Наприкінці бою отримайте {Gold:diff()} [gold]Золото[/gold].
# [pl] Zyskaj {Gold:diff()} szt. [gold]Złota[/gold] pod koniec walki.
# [ru] Дает {Gold:diff()} [gold]золота[/gold] в конце боя.
msgctxt "cards.json:ROYALTIES.description"
msgid "At the end of combat, gain {Gold:diff()} [gold]Gold[/gold]."
msgstr "Дае {Gold:diff()} [gold]золата[/gold] у канцы бою."

# [ua] Роялті
# [pl] Danina
# [ru] Дань
msgctxt "cards.json:ROYALTIES.title"
msgid "Royalties"
msgstr "Ганарар"

# [ua] Отримайте {Stars:diff()} {singleStarIcon}.
# [pl] Zyskaj {Stars:diff()} {singleStarIcon}.
# [ru] Дает {Stars:diff()} {singleStarIcon}.
msgctxt "cards.json:ROYAL_GAMBLE.description"
msgid "Gain {Stars:diff()} {singleStarIcon}."
msgstr "Дае {Stars:diff()} {singleStarIcon}."

# [ua] Королівська гра
# [pl] Królewskie ryzyko
# [ru] Королевская казна
msgctxt "cards.json:ROYAL_GAMBLE.title"
msgid "Royal Gamble"
msgstr "Каралеўская гульня"

# [ua] Щоразу, коли ви втрачаєте ОЗ у свій хід, отримуєте
# {StrengthPower:diff()} [gold]Міць[/gold].
# [pl] Kiedykolwiek utracisz PŻ podczas swojej tury, zyskaj
# {StrengthPower:diff()} pkt. [gold]Siły[/gold].
# [ru] Дает {StrengthPower:diff()} [gold]силы[/gold], когда вы теряете ОЗ в
# свой ход.
msgctxt "cards.json:RUPTURE.description"
msgid "Whenever you lose HP on your turn, gain {StrengthPower:diff()} [gold]Strength[/gold]."
msgstr "Штораз, калі вы губляеце АЗ у свой ход, дае {StrengthPower:diff()} [gold]моцы[/gold]."

# [ua] Розрив
# [pl] Masochizm
# [ru] Надрыв
msgctxt "cards.json:RUPTURE.title"
msgid "Rupture"
msgstr "Разрыў"

# [ua] Якщо [gold]Ості[/gold] живий, він гине, і ви отримуєте
# [gold]Броню[/gold] рівну подвоєному його максимальному ОЗ.
# [pl] Jeżeli [gold]Kostek[/gold] żyje, umiera i zyskujesz [gold]Blok[/gold]
# równy dwukrotności jego maks. PŻ.
# [ru] Если [gold]Костя[/gold] призван, он погибает, а вы получаете
# [gold]защиту[/gold], вдвое превышающую его максимальные ОЗ.
msgctxt "cards.json:SACRIFICE.description"
msgid "If [gold]Osty[/gold] is alive, he dies and you gain [gold]Block[/gold] equal to double his Max HP."
msgstr "Калі [gold]Костусь[/gold] жывы, ён гіне, а вы атрымліваеце [gold]браню[/gold], роўную падвоенаму яго максімуму АЗ."

# [ua] Жертва
# [pl] Poświęcenie
# [ru] Жертвоприношение
msgctxt "cards.json:SACRIFICE.title"
msgid "Sacrifice"
msgstr "Ахвяра"

# [ua] Нанести {Damage:diff()} шкоди.
# [gold]Заховати[/gold] свою [gold]Руку[/gold] цього ходу.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# [gold]Zachowaj[/gold] swoją [gold]rękę[/gold] w tej turze.
# [ru] Наносит {Damage:diff()} урона.
# В этом ходу вы [gold]оставляете[/gold] карты в [gold]руке[/gold].
msgctxt "cards.json:SALVO.description"
msgid "Deal {Damage:diff()} damage.\n"
"[gold]Retain[/gold] your [gold]Hand[/gold] this turn."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"[gold]Захоўвае[/gold] вашу [gold]руку[/gold] у гэтым ходзе."

# [ua] Залп
# [pl] Salwa
# [ru] Залп
msgctxt "cards.json:SALVO.title"
msgid "Salvo"
msgstr "Залп"

# [ua] [gold]Спалювати[/gold] карту.
# Наступного ходу отримуєте {Energy:energyIcons()}.
# [pl] [gold]Wyczerp[/gold] kartę.
# W następnej turze zyskaj {Energy:energyIcons()}.
# [ru] [gold]Сжигает[/gold] выбранную карту.
# Даст {Energy:energyIcons()} в начале следующего хода.
msgctxt "cards.json:SCAVENGE.description"
msgid "[gold]Exhaust[/gold] a card.\n"
"Next turn, gain {Energy:energyIcons()}."
msgstr "[gold]Спальвае[/gold] карту.\n"
"У наступным ходзе дае {Energy:energyIcons()}."

# [ua] Пошук
# [pl] Wygrzebywanie resztek
# [ru] Переработка
msgctxt "cards.json:SCAVENGE.title"
msgid "Scavenge"
msgstr "Перапрацоўка"

# [ua] Накласти {DoomPower:diff()} [gold]Приреченість[/gold].
# Берете {Cards:diff()} {Cards:plural:карту|карти|карток}.
# [pl] Nałóż {DoomPower:diff()} pkt. [gold]Zagłady[/gold].
# Dobierz {Cards:diff()} {Cards:plural:kartę|karty|kart}.
# [ru] Накладывает {DoomPower:diff()} [gold]злого рока[/gold].
# Вы добираете {Cards:diff()} {Cards:plural(ru):карту|карты|карт}.
msgctxt "cards.json:SCOURGE.description"
msgid "Apply {DoomPower:diff()} [gold]Doom[/gold].\n"
"Draw {Cards:diff()} {Cards:plural:card|cards}."
msgstr "Накладае {DoomPower:diff()} [gold]пагібелі[/gold].\n"
"Вы дабіраеце {Cards:diff()} {Cards:plural:карту|карты|карт}."

# [ua] Напасть
# [pl] Chłosta
# [ru] Бичевание
msgctxt "cards.json:SCOURGE.title"
msgid "Scourge"
msgstr "Біч"

# [ua] Нанести {Damage:diff()} шкоди.
# Берете {Cards:diff()} картки.
# Скиньте всі взяті таким чином картки, що не коштують 0
# {energyPrefix:energyIcons(1)}.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Dobierz {Cards:diff()} {Cards:plural:kartę|karty|kart}.
# Odrzuć wszystkie dobrane karty, które nie kosztują 0
# {energyPrefix:energyIcons(1)}.
# [ru] Наносит {Damage:diff()} урона.
# Вы добираете {Cards:diff()} {Cards:plural(ru):карту|карты|карт}.
# Вы сбрасываете все добранные карты стоимостью более 0
# {energyPrefix:energyIcons(1)}.
msgctxt "cards.json:SCRAPE.description"
msgid "Deal {Damage:diff()} damage.\n"
"Draw {Cards:diff()} cards.\n"
"Discard all cards drawn this way that do not cost 0 {energyPrefix:energyIcons(1)}."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Вы дабіраеце {Cards:diff()} {Cards:plural:карту|карты|карт}.\n"
"Вы скідваеце ўсе карты, дабраныя такім чынам, кошт якіх не роўны 0 {energyPrefix:energyIcons(1)}."

# [ua] Здобич
# [pl] Zadrapanie
# [ru] Освежевание
msgctxt "cards.json:SCRAPE.title"
msgid "Scrape"
msgstr "Асвежаванне"

# [ua] Беріть картки, доки ваша [gold]Рука[/gold] не заповниться.
# [pl] Dobieraj karty aż do zapełnienia [gold]ręki[/gold].
# [ru] Вы добираете карты, пока [gold]рука[/gold] не заполнится.
msgctxt "cards.json:SCRAWL.description"
msgid "Draw cards until your [gold]Hand[/gold] is full."
msgstr "Вы дабіраеце карты, пакуль ваша [gold]рука[/gold] не запоўніцца."

# [ua] Черкання
# [pl] Bazgroły
# [ru] Писанина
msgctxt "cards.json:SCRAWL.title"
msgid "Scrawl"
msgstr "Крэмзанне"

# [ua] Нанести {Damage:diff()} шкоди.
# Додайте [gold]Примарний[/gold] до карти у вашій [gold]Руці[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Dodaj [gold]Eteryczna[/gold] do karty w [gold]ręce[/gold].
# [ru] Наносит {Damage:diff()} урона.
# Выбранная в [gold]руке[/gold] карта становится [gold]эфирной[/gold].
msgctxt "cards.json:SCULPTING_STRIKE.description"
msgid "Deal {Damage:diff()} damage.\n"
"Add [gold]Ethereal[/gold] to a card in your [gold]Hand[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Выбраная карта ў [gold]руцэ[/gold] становіцца [gold]эфемернай[/gold]."

# [ua] Оберіть карту, щоб додати [gold]Примарний[/gold].
# [pl] Wybierz kartę i dodaj do niej [gold]Eteryczna[/gold].
# [ru] Выберите карту, которую хотите сделать [gold]эфирной[/gold].
msgctxt "cards.json:SCULPTING_STRIKE.selectionScreenPrompt"
msgid "Choose a card to add [gold]Ethereal[/gold]."
msgstr "Выберыце карту, якую хочаце зрабіць [gold]эфемернай[/gold]."

# [ua] Ліпний удар
# [pl] Rozbijające uderzenie
# [ru] Высекающий удар
msgctxt "cards.json:SCULPTING_STRIKE.title"
msgid "Sculpting Strike"
msgstr "Удар скульптара"

# [ua] Перетворіть карту у вашому [gold]Доборі[/gold] на
# [gold]{IfUpgraded:show:Душа+|Душа}[/gold].
# [pl] Zmień kartę ze [gold]stosu rozgrywającego[/gold] w [gold]Duszę[/gold].
# [ru] [gold]Преобразует[/gold] выбранную в [gold]стопке добора[/gold] карту в
# [gold]«Душу»[/gold].
msgctxt "cards.json:SEANCE.description"
msgid "Transform a card in your [gold]Draw Pile[/gold] into [gold]Soul[/gold]."
msgstr "[gold]Пераўтварае[/gold] карту ў вашым [gold]стосе дабору[/gold] у [gold]«Душу»[/gold]."

# [ua] Спіритичний сеанс
# [pl] Seans
# [ru] Обряд
msgctxt "cards.json:SEANCE.title"
msgid "Seance"
msgstr "Сеанс"

# [ua] [gold]Спалювати[/gold] всі карти не-Атаки у вашій [gold]Руці[/gold].
# Отримуєте {Block:diff()} [gold]Броню[/gold] за кожну [gold]Спалену[/gold]
# карту.
# [pl] [gold]Wyczerp[/gold] wszystkie karty w [gold]ręce[/gold], które nie są
# Atakami. Zyskaj {Block:diff()} pkt. [gold]Bloku[/gold] za każdą
# [gold]Wyczerpaną[/gold] kartę.
# [ru] [gold]Сжигает[/gold] все карты в [gold]руке[/gold], кроме Атак. Дает по
# {Block:diff()} [gold]защиты[/gold] за каждую.
msgctxt "cards.json:SECOND_WIND.description"
msgid "[gold]Exhaust[/gold] all non-Attack cards in your [gold]Hand[/gold]. Gain {Block:diff()} [gold]Block[/gold] for each card [gold]Exhausted[/gold]."
msgstr "[gold]Спальвае[/gold] усе карты з вашай [gold]рукі[/gold], якія не з’яўляюцца Атакамі. Дае {Block:diff()} [gold]брані[/gold] за кожную [gold]спаленую[/gold] карту."

# [ua] Другий подих
# [pl] Druga szansa
# [ru] Второе дыхание
msgctxt "cards.json:SECOND_WIND.title"
msgid "Second Wind"
msgstr "Другое дыханне"

# [ua] Помістіть Вміння з вашого [gold]Добору[/gold] до вашої
# [gold]Руки[/gold].
# [pl] Przenieś Umiejętność ze [gold]stosu rozgrywającego[/gold] do
# [gold]ręki[/gold].
# [ru] Вы берете Навык из [gold]стопки добора[/gold].
msgctxt "cards.json:SECRET_TECHNIQUE.description"
msgid "Put a Skill from your [gold]Draw Pile[/gold] into your [gold]Hand[/gold]."
msgstr "Перамяшчае карту Умення з вашага [gold]стоса дабору[/gold] у вашу [gold]руку[/gold]."

# [ua] Оберіть Вміння, щоб помістити в Руку.
# [pl] Wybierz Umiejętność i umieść ją w ręce.
# [ru] Выберите Навык, который хотите взять.
msgctxt "cards.json:SECRET_TECHNIQUE.selectionScreenPrompt"
msgid "Select a Skill to put in your Hand."
msgstr "Выберыце карту Умення, якая будзе пакладзена ў руку."

# [ua] Таємна техніка
# [pl] Tajna technika
# [ru] Тайная техника
msgctxt "cards.json:SECRET_TECHNIQUE.title"
msgid "Secret Technique"
msgstr "Таемны прыём"

# [ua] Помістіть Атаку з вашого [gold]Добору[/gold] до вашої
# [gold]Руки[/gold].
# [pl] Przenieś Atak ze [gold]stosu rozgrywającego[/gold] do
# [gold]ręki[/gold].
# [ru] Вы берете Атаку из [gold]стопки добора[/gold].
msgctxt "cards.json:SECRET_WEAPON.description"
msgid "Put an Attack from your [gold]Draw Pile[/gold] into your [gold]Hand[/gold]."
msgstr "Перамяшчае карту Атакі са [gold]стоса дабору[/gold] у вашу [gold]руку[/gold]."

# [ua] Оберіть Атаку, щоб помістити в Руку.
# [pl] Wybierz Atak i umieść go w ręce.
# [ru] Выберите Атаку, которую хотите взять.
msgctxt "cards.json:SECRET_WEAPON.selectionScreenPrompt"
msgid "Select an Attack to put in your Hand."
msgstr "Выберыце карту Атакі, якая пакладзецца ў руку."

# [ua] Таємна зброя
# [pl] Tajna broń
# [ru] Тайное оружие
msgctxt "cards.json:SECRET_WEAPON.title"
msgid "Secret Weapon"
msgstr "Таемная зброя"

# [ua] Нанести {Damage:diff()} шкоди.
# Оберіть 1 з {Cards:diff()} карт у вашому [gold]Доборі[/gold], щоб додати до
# вашої [gold]Руки[/gold].
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Wybierz 1 z {Cards:diff()} kart ze [gold]stosu rozgrywającego[/gold] i dodaj
# ją do [gold]ręki[/gold].
# [ru] Наносит {Damage:diff()} урона.
# Вы берете 1 из {Cards:diff()} карт из [gold]стопки добора[/gold] на выбор.
msgctxt "cards.json:SEEKER_STRIKE.description"
msgid "Deal {Damage:diff()} damage.\n"
"Choose 1 of {Cards:diff()} cards in your [gold]Draw Pile[/gold] to add into your [gold]Hand[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Выберыце 1 з {Cards:diff()} карт у вашым [gold]стосе дабору[/gold], каб дадаць яе ў сваю [gold]руку[/gold]."

# [ua] Оберіть карту, щоб помістити в Руку.
# [pl] Wybierz kartę i umieść ją w ręce.
# [ru] Выберите карту, которую хотите взять.
msgctxt "cards.json:SEEKER_STRIKE.selectionScreenPrompt"
msgid "Select a card to put in your Hand."
msgstr "Выберыце карту, якую хочаце ўзяць у руку."

# [ua] Шукаючий удар
# [pl] Uderzenie naprowadzające
# [ru] Удар искателя
msgctxt "cards.json:SEEKER_STRIKE.title"
msgid "Seeker Strike"
msgstr "Скіраваны ўдар"

# [ua] [gold]Кування[/gold] {Forge:diff()}.
# [gold]Суверенний клинок[/gold] тепер завдає шкоди ВСІМ ворогам.
# [pl] [gold]Wykuj[/gold] {Forge:diff()}.
# Od teraz [gold]Niebańskie Ostrze[/gold] zadaje obrażenia WSZYSTKIM
# przeciwnikom.
# [ru] [gold]Закаляет[/gold] {Forge:diff()}.
# [gold]Клинок монарха[/gold] наносит урон ВСЕМ врагам.
msgctxt "cards.json:SEEKING_EDGE.description"
msgid "[gold]Forge[/gold] {Forge:diff()}.\n"
"[gold]Sovereign Blade[/gold] now deals damage to ALL enemies."
msgstr "[gold]Загартоўка[/gold] {Forge:diff()}.\n"
"[gold]«Клінок манарха»[/gold] цяпер прычыняе пашкоджанне УСІМ праціўнікам."

# [ua] Пошук переваги
# [pl] Przewaga niebios
# [ru] Жаждущий клинок
msgctxt "cards.json:SEEKING_EDGE.title"
msgid "Seeking Edge"
msgstr "Хцівы клінок"

# [ua] На початку вашого ходу додайте {SentryModePower:diff()} [gold]Пильний
# погляд[/gold] до вашої [gold]Руки[/gold].
# [ru] Добавляет в [gold]руку[/gold] {SentryModePower:diff()}
# [gold]{SentryModePower:plural(ru):«Всевидящее око»|«Всевидящих
# ока»|«Всевидящих очей»}[/gold] в начале хода.
msgctxt "cards.json:SENTRY_MODE.description"
msgid "At the start of your turn, add {SentryModePower:diff()} [gold]Sweeping Gaze[/gold] into your [gold]Hand[/gold]."
msgstr "На пачатку вашага ходу дадае {SentryModePower:diff()} [gold]{SentryModePower:plural:карту «Усёбачны позірк»|карты «Усёбачны позірк»|карт «Усёбачны позірк»}[/gold] у вашу [gold]руку[/gold]."

# [ua] Режим варти
# [pl] Warta
# [ru] Дозор
msgctxt "cards.json:SENTRY_MODE.title"
msgid "Sentry Mode"
msgstr "Рэжым вартавога"

# [ua] Щоразу, коли ви граєте карту, завдайте {SerpentFormPower:diff()} шкоди
# випадковому ворогу.
# [pl] Kiedykolwiek zagrasz kartę, zadaj {SerpentFormPower:diff()} pkt.
# obrażeń losowemu przeciwnikowi.
# [ru] Наносит {SerpentFormPower:diff()} урона случайному врагу, когда вы
# разыгрываете карту.
msgctxt "cards.json:SERPENT_FORM.description"
msgid "Whenever you play a card, deal {SerpentFormPower:diff()} damage to a random enemy."
msgstr "Штораз, калі вы разыгрываеце карту, прычыняе {SerpentFormPower:diff()} пашкоджання выпадковаму праціўніку."

# [ua] Зміїна форма
# [pl] Żmija
# [ru] Облик змеи
msgctxt "cards.json:SERPENT_FORM.title"
msgid "Serpent Form"
msgstr "Змяіная форма"

# [ua] Нанести {Damage:diff()} шкоди.
# Отримайте {StrengthPower:diff()} [gold]Міць[/gold] цього ходу.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń.
# Zyskaj {StrengthPower:diff()} pkt. [gold]Siły[/gold] w tej turze.
# [ru] Наносит {Damage:diff()} урона.
# Дает {StrengthPower:diff()} [gold]силы[/gold] на этот ход.
msgctxt "cards.json:SETUP_STRIKE.description"
msgid "Deal {Damage:diff()} damage.\n"
"Gain {StrengthPower:diff()} [gold]Strength[/gold] this turn."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"Дае {StrengthPower:diff()} [gold]моцы[/gold] у гэтым ходзе."

# [ua] Підготовчий удар
# [pl] Pierwsze uderzenie
# [ru] Удар для разогрева
msgctxt "cards.json:SETUP_STRIKE.title"
msgid "Setup Strike"
msgstr "Падрыхтоўчы ўдар"

# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам {Repeat:plural:{} раз|{}
# рази|{} разів}.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom
# {Repeat:plural:{} raz|{} razy|{} razy}.
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам {Repeat:plural(ru):{} раз|{}
# раза|{} раз}.
msgctxt "cards.json:SEVEN_STARS.description"
msgid "Deal {Damage:diff()} damage to ALL enemies {Repeat:plural:{} time|{} times}."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам {Repeat:plural:{} раз|{} разы|{} разоў}."

