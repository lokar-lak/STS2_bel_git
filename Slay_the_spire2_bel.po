msgid "Win as the Necrobinder."
msgstr "Перамажыце за Цямнарку."

# [ua] Некромантка
# [pl] Nekromantka
# [ru] Призывающая
msgctxt "achievements.json:NECROBINDER_WIN.title"
msgid "The Necrobinder"
msgstr "Цямнарка"

# [ua] Переможіть у забігу, не отримавши жодного амулета.
# [pl] Wygraj bez zdobywania żadnych Artefaktów.
# [ru] Пройдите вылазку без реликвий.
msgctxt "achievements.json:NO_RELIC_WIN.description"
msgid "Win a Run without obtaining any relics."
msgstr "Выйграйце выправу, не атрымаўшы ніводнай рэліквіі."

# [ua] Зайвий мотлох
# [pl] Niepotrzebne klamoty
# [ru] Балласт
msgctxt "achievements.json:NO_RELIC_WIN.title"
msgid "Unnecessary Clutter"
msgstr "Непатрэбны хлам"

# [ua] Зіграйте 20 карт за один хід.
# [pl] Zagraj 20 kart w jednej turze.
# [ru] Разыграйте 20 карт в одном ходу.
msgctxt "achievements.json:PLAY20_CARDS_SINGLE_TURN.description"
msgid "Play 20 cards in a single turn."
msgstr "Разыграйце 20 карт за адзін ход."

# [ua] Грати в карти — весело
# [pl] Gry karciane to wielka frajda
# [ru] Картежник
msgctxt "achievements.json:PLAY20_CARDS_SINGLE_TURN.title"
msgid "Playing Cards Is Fun"
msgstr "І карты ў рукі"

# [ua] Пройдіть Випробування 10 за Реґента.
# [pl] Ukończ grę na 10. poziomie Wyniesienia Monarchą.
# [ru] Пройдите Возвышение 10 за Наследника.
