msgid "Deprecated Card"
msgstr "Састарэлая карта"

# [ua] За кожну одиницю [gold]Приреченості[/gold] яку Ви накладаєте, отримуєте
# 1 [gold]Броні[/gold].
# [pl] Zyskaj 1 pkt. [gold]Bloku[/gold] za każdy 1 pkt. nakładanej
# [gold]Zagłady[/gold].
# [ru] Дает [gold]защиту[/gold], равную [gold]злому року[/gold], который вы
# накладываете.
msgctxt "cards.json:DESPAIR.description"
msgid "For every 1 [gold]Doom[/gold] you apply, gain 1 [gold]Block[/gold]."
msgstr "За кожную адзінку [gold]пагібелі[/gold], якую вы накладаеце, дае 1 [gold]брані[/gold]."

# [ua] Відчай
# [pl] Rozpacz
# [ru] Отчаяние
