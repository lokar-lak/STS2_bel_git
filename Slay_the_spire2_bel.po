msgid "Seems like you can't do that."
msgstr "Падобна, вам так нельга."

# [ua] Щось не так?
# [pl] Coś nie tak?
# [ru] Что случилось?
msgctxt "merchant_room.json:MERCHANT.talk.purchaseFailureForbidden.line2"
msgid "Something the matter?"
msgstr "Штосьці не так?"

# [ua] Вам потрібно більше монет.
# [pl] Potrzeba ci więcej monet.
# [ru] Нужно больше золота.
