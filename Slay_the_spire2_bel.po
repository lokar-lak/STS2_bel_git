msgid "Pay [red]{BreathingTechniquesCost}[/red] [gold]Gold[/gold]. Add [blue]2[/blue] [gold]Enlightenment[/gold] to your [gold]Deck[/gold]."
msgstr "Заплаціць [red]{BreathingTechniquesCost}[/red] [gold]золата[/gold]. Дадаць [blue]2[/blue] [gold]«Прасвятленні»[/gold] у [gold]калоду[/gold]."

# [ua] Техніки дихання
# [pl] Techniki oddechowe
# [ru] Техника дыхания
msgctxt "events.json:ZEN_WEAVER.pages.INITIAL.options.BREATHING_TECHNIQUES.title"
msgid "Breathing Techniques"
msgstr "Тэхнікі дыхання"

# [ua] Заплатити [red]{EmotionalAwarenessCost}[/red] [gold]Золота[/gold].
# Вилучити [blue]1[/blue] карту зі своєї [gold]Колоди[/gold].
# [pl] Zapłać [red]{EmotionalAwarenessCost}[/red] szt. [gold]Złota[/gold].
# Usuń [blue]1[/blue] kartę z [gold]talii[/gold].
# [ru] Заплатить [red]{EmotionalAwarenessCost}[/red] [gold]золота[/gold] и
# удалить [blue]1[/blue] карту из [gold]колоды[/gold].
msgctxt "events.json:ZEN_WEAVER.pages.INITIAL.options.EMOTIONAL_AWARENESS.description"
msgid "Pay [red]{EmotionalAwarenessCost}[/red] [gold]Gold[/gold]. Remove [blue]1[/blue] card from your [gold]Deck[/gold]."
msgstr "Заплаціць [red]{EmotionalAwarenessCost}[/red] [gold]золата[/gold]. Выдаліць [blue]1[/blue] карту з [gold]калоды[/gold]."

# [ua] Емоційна усвідомленість
# [pl] Świadomość emocjonalna
# [ru] Самопознание
