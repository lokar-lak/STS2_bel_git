# [ru] Вы получаете {DisintegrationPower:diff()} урона в конце хода.
msgctxt "cards.json:DISINTEGRATION.description"
msgid "At the end of your turn, take {DisintegrationPower:diff()} damage."
msgstr "У канцы вашага ходу вы атрымліваеце {DisintegrationPower:diff()} пашкоджання."

# [ua] Розпад
# [pl] Dezintegracja
# [ru] Расщепление
msgctxt "cards.json:DISINTEGRATION.title"
msgid "Disintegration"
msgstr "Дэзынтэграцыя"

# [ua] Нанести {Damage:diff()} шкоди.
# Якщо ворог є [gold]Уразливим[/gold], б'є двічі.
