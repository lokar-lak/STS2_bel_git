msgstr "Крадзеж сілы"

# [ua] Нанести {Damage:diff()} шкоди ВСІМ ворогам.
# [pl] Zadaj {Damage:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom.
# [ru] Наносит {Damage:diff()} урона ВСЕМ врагам.
msgctxt "cards.json:DRAMATIC_ENTRANCE.description"
msgid "Deal {Damage:diff()} damage to ALL enemies."
msgstr "Прычыняе {Damage:diff()} пашкоджання УСІМ праціўнікам."

