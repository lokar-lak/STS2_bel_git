msgid "Deal {Damage:diff()} damage."
msgstr "Прычыняе {Damage:diff()} пашкоджання."

# [ua] Абсолютний удар
# [pl] Ultra Uderzenie
# [ru] Превосходный удар
msgctxt "cards.json:ULTIMATE_STRIKE.title"
msgid "Ultimate Strike"
msgstr "Абсалютны ўдар"

