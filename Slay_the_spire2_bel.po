msgstr "Зараснік"

# [ua] Підводдя
# [pl] Nabrzeże
# [ru] Пристань
msgctxt "acts.json:UNDERDOCKS.title"
msgid "Underdocks"
msgstr "Ніжнія прыстані"

# [ua] Лише [blue]1[/blue] [gold]Пов'язану[/gold] карту можна зіграти за хід.
# Карти звільняються від [gold]Пов'язання[/gold] в кінці ходу.
# [pl] W każdej turze można zagrać tylko [blue]1[/blue] [gold]Uwięzioną[/gold]
# kartę. Karty zostają [gold]Uwolnione[/gold] pod koniec tury.
# [ru] Каждый ход можно разыграть только [blue]1[/blue]
# [gold]запечатанную[/gold] карту. [gold]Печать[/gold] снимается в конце хода.
msgctxt "afflictions.json:BOUND.description"
msgid "Only [blue]1[/blue] [gold]Bound[/gold] card can be played each turn. Cards are un-[gold]Bound[/gold] at end of turn."
msgstr "Штоход можна разыграць толькі [blue]1[/blue] [gold]скутую[/gold] карту. [gold]Скутасць[/gold] здымаецца ў канцы ходу."

# [ua] Пов'язана
# [pl] Uwięzienie
# [ru] Запечатана
msgctxt "afflictions.json:BOUND.extraCardText"
msgid "Bound"
msgstr "Скутая"

# [ua] Пов'язана
# [pl] Uwięzienie
# [ru] Печать
msgctxt "afflictions.json:BOUND.title"
msgid "Bound"
msgstr "Скутасць"

# [pl] Dodaj [gold]Wyczerpanie[/gold] do tej karty.
# [ru] Карта [gold]сжигается[/gold] при разыгрывании.
msgctxt "afflictions.json:DEVOURED.description"
msgid "Add [gold]Exhaust[/gold] to this card."
msgstr "Гэтая карта [gold]спальваецца[/gold]."

# [pl] Pożarcie
# [ru] Поглощение
msgctxt "afflictions.json:DEVOURED.title"
msgid "Devoured"
msgstr "Паглынанне"

# [ua] Коштує додатково {Amount:energyIcons()}.
# [pl] Karta kosztuje dodatkowy {Amount:energyIcons()}.
# [ru] Стоит на {Amount:energyIcons()} больше.
msgctxt "afflictions.json:ENTANGLED.description"
msgid "Costs an additional {Amount:energyIcons()}."
msgstr "Карта каштуе на {Amount:energyIcons()} больш."

# [ua] Заплутана
# [pl] Zaplątanie
# [ru] Запутана
msgctxt "afflictions.json:ENTANGLED.extraCardText"
msgid "Entangled"
msgstr "Аблытаная"

# [ua] Заплутана
# [pl] Zaplątanie
# [ru] Путы
msgctxt "afflictions.json:ENTANGLED.title"
msgid "Entangled"
msgstr "Аблытанасць"

# [ua] Отримайте [blue]{Amount}[/blue] шкоди, коли цю карту зіграно.
# [pl] Otrzymaj [blue]{Amount}[/blue] pkt. obrażeń, gdy ta karta zostanie
# zagrana.
# [ru] Вы получите [blue]{Amount}[/blue] урона, если разыграете эту карту.
msgctxt "afflictions.json:GALVANIZED.description"
msgid "Take [blue]{Amount}[/blue] damage when this card is played."
msgstr "Вы атрымаеце [blue]{Amount}[/blue] пашкоджання, калі разыграеце гэтую карту."

# [ua] Отримайте {Amount} шкоди.
# [pl] Otrzymaj {Amount} pkt. obrażeń.
# [ru] Вы получите {Amount} урона.
msgctxt "afflictions.json:GALVANIZED.extraCardText"
msgid "Take {Amount} damage."
msgstr "Вы атрымаеце {Amount} пашкоджання."

# [ua] Гальванізована
# [pl] Zelektryzowanie
# [ru] Гальванизация
msgctxt "afflictions.json:GALVANIZED.title"
msgid "Galvanized"
msgstr "Гальванізацыя"

# [ua] Додає [gold]Примарну[/gold] властивість цій карті.
# [pl] Dodaj [gold]Eteryczna[/gold] do tej karty.
# [ru] Карта становится [gold]эфирной[/gold].
msgctxt "afflictions.json:HEXED.description"
msgid "Add [gold]Ethereal[/gold] to this card."
msgstr "Гэтая карта становіцца [gold]эфемернай[/gold]."

# [ua] Зачаклована
# [pl] Zaczarowanie
# [ru] Сглаз
msgctxt "afflictions.json:HEXED.title"
msgid "Hexed"
msgstr "Сурокі"

# [ua] Mock No Unplayable Affliction
# [pl] Mock No Unplayable Affliction
# [ru] Mock No Unplayable Affliction
msgctxt "afflictions.json:MOCK_NO_UNPLAYABLE_AFFLICTION.title"
msgid "Mock No Unplayable Affliction"
msgstr "Mock No Unplayable Affliction"

# [ua] Mock Self Damage Affliction
# [pl] Mock Self Damage Affliction
# [ru] Mock Self Damage Affliction
msgctxt "afflictions.json:MOCK_SELF_DAMAGE_AFFLICTION.title"
msgid "Mock Self Damage Affliction"
msgstr "Mock Self Damage Affliction"

# [ua] Mock Useless Affliction
# [pl] Mock Useless Affliction
# [ru] Mock Useless Affliction
msgctxt "afflictions.json:MOCK_USELESS_AFFLICTION.title"
msgid "Mock Useless Affliction"
msgstr "Mock Useless Affliction"

# [ua] Ви можете зіграти лише [blue]1[/blue] карту цього ходу.
# [pl] W tej turze możesz zagrać tylko [blue]1[/blue] kartę.
# [ru] Вы можете разыграть только [blue]1[/blue] карту в этом ходу.
msgctxt "afflictions.json:RINGING.description"
msgid "You can only play [blue]1[/blue] card this turn."
msgstr "У гэтым ходзе вы можаце разыграць толькі [blue]1[/blue] карту."

# [ua] Дзвін.
# [pl] Dzwonienie.
# [ru] Звон в ушах.
msgctxt "afflictions.json:RINGING.extraCardText"
msgid "Ringing."
msgstr "Звон увушшу."

# [ua] Дзвін
# [pl] Dzwonienie
# [ru] Звон в ушах
msgctxt "afflictions.json:RINGING.title"
msgid "Ringing"
msgstr "Звон увушшу"

# [ua] Ви не можете грати додаткові [gold]Вміння[/gold] цього ходу. Зникає в
# кінці ходу.
# [pl] W tej turze nie możesz już zagrać [gold]Umiejętności[/gold]. Znika pod
# koniec tury.
# [ru] Вы больше не сможете разыгрывать [gold]Навыки[/gold] в этом ходу.
# Рассеивается в конце хода.
msgctxt "afflictions.json:SMOG.description"
msgid "You cannot play additional [gold]Skills[/gold] this turn. Clears at the end of the turn."
msgstr "На гэтым ходзе вы больш не можаце разыгрываць карт [gold]Умення[/gold]. Рассейваецца ў канцы ходу."

# [ua] Смог
# [pl] Smog
# [ru] Смог
msgctxt "afflictions.json:SMOG.title"
msgid "Smog"
msgstr "Смог"

# [pl] Utrać {Amount:energyIcons()} po zagraniu tej karty.
# [ru] Вы потеряете {Amount:energyIcons()}, если разыграете эту карту.
msgctxt "afflictions.json:WEIGHTED.description"
msgid "Lose {Amount:energyIcons()} when this card is played."
msgstr "Вы губляеце {Amount:energyIcons()}, калі разыгрываеце гэтую карту."

# [pl] Utrać {Amount:energyIcons()}.
# [ru] Вы потеряете {Amount:energyIcons()}.
msgctxt "afflictions.json:WEIGHTED.extraCardText"
msgid "Lose {Amount:energyIcons()}."
msgstr "Вы губляеце {Amount:energyIcons()}."

# [pl] Obciążenie
# [ru] Тяжесть
msgctxt "afflictions.json:WEIGHTED.title"
msgid "Weighted"
msgstr "Абцяжаранне"

# [ua] Збирач
# [pl] Zbieracz
# [ru] Антиквар
msgctxt "ancients.json:DARV.epithet"
msgid "The Hoarder"
msgstr "Антыквар"

# [ua] Ось, візьми один із цих забутих самоцвітів!
# [pl] Zobacz tylko, same perełki, wybierz coś sobie!
# [ru] Вот, возьми с собой одну из этих позабытых диковин!
msgctxt "ancients.json:DARV.talk.ANY.0-0r.ancient"
msgid "Here, take one of these forgotten gems with ya!"
msgstr "Вось, вазьміце з сабой адзін з забытых самацветаў!"

# [ua] У мене купа справ на сьогодні!
# Бери що хочеш із тієї купи!!
# [pl] Mam dziś dużo do roboty!
# Weź coś sobie z tamtej sterty!!
# [ru] У меня сегодня много дел!
# Бери что хочешь вон из той кучи!
msgctxt "ancients.json:DARV.talk.ANY.1-0r.ancient"
msgid "I’ve got things to do today!\n"
"Take whatever ya want from that pile!!"
msgstr "Ну, сёння ў мяне куча спраў!\n"
"Бяры, што хочаш, з той кучы!!"

# [ua] Ти прекрасна купа брухту, знаєш це?
# [pl] Wiesz ty co? Piękna z ciebie kupa złomu!
# [ru] Тебе уже говорили, что ты самая очаровательная груда болтов?
msgctxt "ancients.json:DARV.talk.DEFECT.0-0.ancient"
msgid "You’re a beautiful hunk of junk, you know that?"
msgstr "Ты ж і так купа хламу, ведаеш гэта?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:DARV.talk.DEFECT.0-0.next"
msgid "Reply"
msgstr "Адказаць"

# [ua] [i][font_size=22]<3[/font_size][/i]
# [pl] [i][font_size=22]<3[/font_size][/i]
# [ru] [i][font_size=22]<3[/font_size][/i]
msgctxt "ancients.json:DARV.talk.DEFECT.0-1.char"
msgid "[i][font_size=22]<3[/font_size][/i]"
msgstr "[i][font_size=22]<3[/font_size][/i]"

# [ua] Бачу, все ще тримаєшся... Подивимось, чи зможемо тебе вдосконалити!
# [pl] Wciąż się nie poddajesz, jak widzę... Zobaczmy, które części tobie
# przypasują.
# [ru] Никак не сдаешься, да? Давай-ка попробуем тебя откалибровать!
msgctxt "ancients.json:DARV.talk.DEFECT.1-0r.ancient"
msgid "Still keeping at it, I see... Let’s see if we can upgrade ya!"
msgstr "Бачу, усё яшчэ не здаешся... Паглядзім, ці зможам цябе палепшыць!"

# [ua] Я зберігав річ твого друга, е-е... гм.
# Нічого, нічого!!
# [pl] Gdzieś tu trzymałem części twojego kole... yyy...
# Albo nieważne już, nieważne!!
# [ru] У меня тут завалялось кое-что от твоего дру…
# Неважно, забыли!
msgctxt "ancients.json:DARV.talk.DEFECT.2-0.ancient"
msgid "I’ve been holding on to your friend’s uhh... um.\n"
"Nevermind nevermind!!"
msgstr "Я недзе тут меў рэчы твайго, сяб... э-э.\n"
"Нічога, забылі!!"

# [ua] Запитати
# [pl] Zapytaj
# [ru] Задать вопрос
msgctxt "ancients.json:DARV.talk.DEFECT.2-0.next"
msgid "Question"
msgstr "Запытаць"

# [ua] [i][font_size=22]<Допитливі сигнали>[/font_size][/i]
# [pl] [i][font_size=22]<Dociekliwe pikanie>[/font_size][/i]
# [ru] [i][font_size=22]<Озадаченное бибиканье>[/font_size][/i]
msgctxt "ancients.json:DARV.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]<Inquisitive beeps>[/font_size][/i]"
msgstr "[i][font_size=22]<Дапытлівае піканне>[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.DEFECT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Мій брухтовий крушій, забудь усе, що я сказав!
# [pl] A daj spoookój mój ty złomiarzu, zapomnij, że w ogóle o tym mówiłem!
# [ru] Моя нержавеющая жестяночка, не обращай внимания!
msgctxt "ancients.json:DARV.talk.DEFECT.2-2.ancient"
msgid "My scrappy scrapper, forget I said all that!"
msgstr "Мая ты бляшанка, забудзь усё, што я казаў!"

# [ua] Палаючий воїн повернувся!
# У мене є якраз те, що тобі потрібно!
# [pl] No proszę, kogo to wszystkie piekła zwróciły!
# Mam coś w sam raz dla ciebie!
# [ru] Пламенный воин возвращается!
# На такой случай у меня есть кое-что как раз для тебя!
msgctxt "ancients.json:DARV.talk.IRONCLAD.0-0.ancient"
msgid "The flaming warrior has returned!\n"
"I’ve got just the thing for ya!"
msgstr "Палымяны воін вярнуўся!\n"
"Я маю менавіта тое, што табе трэба!"

# [ua] Радий бачити, що ти ще б'єшся й розбиваєш голови!
# [pl] Dobrze widzieć, że nie znudziło ci się jeszcze całe to miażdżenie i
# rąbanie!
# [ru] Рад, что ты продолжаешь ломать головы и крушить черепа!
msgctxt "ancients.json:DARV.talk.IRONCLAD.1-0r.ancient"
msgid "Good to see ya still kickin’ and bashin’ em heads in!"
msgstr "Рады бачыць, што ты ўсё яшчэ калечыш і нявечыш!"

# [ua] Я все ще зберігаю той твій важкий клинок... але не можу знайти нікого,
# хто б його відновив.
# [pl] Wciąż tu trzymam ten twój ciężki miecz... No ale nikt tutaj mi go nie
# odnowi.
# [ru] Твой увесистый клинок все еще у меня… Вот только кто его восстановит?
msgctxt "ancients.json:DARV.talk.IRONCLAD.2-0.ancient"
msgid "I’m still holding on to that heavy blade of yours... but I can’t find no one to restore it."
msgstr "Я ўсё яшчэ маю твой цяжкі меч... але не магу знайсці нікога, хто б яго адрамантаваў."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.IRONCLAD.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [i][font_size=22]Залізнолад дивиться на Дарва.[/font_size][/i]
# [pl] [i][font_size=22]Pancernik wpatruje się w Darva.[/font_size][/i]
# [ru] [i][font_size=22]Латоносец пристально смотрит на Дарва.[/font_size][/i]
msgctxt "ancients.json:DARV.talk.IRONCLAD.2-1.char"
msgid "[i][font_size=22]The Ironclad stares at Darv.[/font_size][/i]"
msgstr "[i][font_size=22]Браняносец утаропліваецца на Дарва.[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.IRONCLAD.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Може, Архітектор щось знає.
# [pl] Może Architekt coś będzie wiedział.
# [ru] Может, Архитектор что-то знает?
msgctxt "ancients.json:DARV.talk.IRONCLAD.2-2.ancient"
msgid "Maybe the Architect knows somethin’."
msgstr "Магчыма, Архітэктар нешта ведае."

# [ua] Бачу, ти серйозна особа. Що я можу для тебе зробити, пані?
# [pl] Panienka wygląda na poważną klientkę. W czym pomóc?
# [ru] Ты слов на ветер не бросаешь, сразу вижу. Чем могу помочь?
msgctxt "ancients.json:DARV.talk.NECROBINDER.0-0.ancient"
msgid "I can tell you’re a serious one. What can I do for ya missy?"
msgstr "Бачу, ты пані паважная. Чым магу дапамагчы, міс?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:DARV.talk.NECROBINDER.0-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Будь-що, аби допомогти мені вбити одну огидну людину.
# [pl] W zabiciu najbardziej wstrętnego człowieka.
# [ru] Помоги мне убить того, кто заслуживает смерти.
msgctxt "ancients.json:DARV.talk.NECROBINDER.0-1.char"
msgid "Anything to help me kill a most loathsome man."
msgstr "Мне трэба ўсё, што паможа забіць тое пачварнае стварэнне."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.NECROBINDER.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ну що ж... поглянь!
# [pl] A no to... rzuć sobie okiem!
# [ru] Ну что ж… Выбирай, не стесняйся!
msgctxt "ancients.json:DARV.talk.NECROBINDER.0-2.ancient"
msgid "Very well then... have a gander!"
msgstr "Ну што ж... паглядзі!"

# [ua] Все ще на тропі війни? Я не стану тебе зупиняти!
# [pl] Nastroje wciąż bojowe? Nie przeszkadzam!
# [ru] По-прежнему идешь дорогой смерти? Не буду мешать!
msgctxt "ancients.json:DARV.talk.NECROBINDER.1-0r.ancient"
msgid "Still on that warpath? I ain’t gonna stop ya!"
msgstr "Усё яшчэ на сцяжыне вайны? Не буду замінаць!"

# [ua] Ця книга, здається, пов'язана з тобою, існує довше за тебе.
# [pl] Ta księga chyba jest z tobą związana, a jest starsza od ciebie.
# [ru] Ты так привязана к этой книге… Она ведь древнее тебя самой!
msgctxt "ancients.json:DARV.talk.NECROBINDER.2-0.ancient"
msgid "This book seems tied to ya, been around longer than you have."
msgstr "Здаецца, гэтая кніга павязана з табой, але існуе значна даўжэй."

# [ua] Звинуватити
# [pl] Oskarż
# [ru] Допросить
msgctxt "ancients.json:DARV.talk.NECROBINDER.2-0.next"
msgid "Accuse"
msgstr "Абвінаваціць"

# [ua] Як це потрапило до тебе?
# [pl] Jakim cudem to znalazłeś?
# [ru] Каким образом ты ее заполучил?
msgctxt "ancients.json:DARV.talk.NECROBINDER.2-1.char"
msgid "How did you come into possession of that?"
msgstr "Як яна да цябе трапіла?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.NECROBINDER.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]Страшні[/sine] речі мають звичку потрапляти до моєї колекції.
# [pl] Jakoś tak jest, że czasami [sine]straszne[/sine] rzeczy trafiają mi do
# kolekcji.
# [ru] У меня в коллекции бывают и [sine]страшные[/sine] вещи.
msgctxt "ancients.json:DARV.talk.NECROBINDER.2-2.ancient"
msgid "[sine]Scary[/sine] things have a way of ending up in my collection."
msgstr "[sine]Страшныя[/sine] рэчы нейкім чынам трапляюць у маю калекцыю."

# [ua] Що привело таку особу сюди? Хочеш поглянути на мою колекцію?
# [pl] A co tu wyrabia ktoś taki jak ty? Chcesz zerknąć na moją kolekcję?
# [ru] А тебя как сюда занесло? Хочешь взглянуть на мою коллекцию?
msgctxt "ancients.json:DARV.talk.REGENT.0-0.ancient"
msgid "What brings the likes of you up here? Wanna take a look at my collection?"
msgstr "А што прывяло сюды такога, як ты? Хочаш зірнуць на маю калекцыю?"

# [ua] Продовжити
# [pl] Kontynuuj
# [ru] Продолжить
msgctxt "ancients.json:DARV.talk.REGENT.0-0.next"
msgid "Proceed"
msgstr "Працягнуць"

# [ua] Я ціную гарний крам...
# [pl] Nie omieszkam...
# [ru] Роскошную утварь я люблю…
msgctxt "ancients.json:DARV.talk.REGENT.0-1.char"
msgid "I do enjoy fine wares..."
msgstr "Я цаню вытанчаныя рэчы..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.REGENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Так!
# [pl] No i fajnie!
# [ru] Отлично!
msgctxt "ancients.json:DARV.talk.REGENT.0-2.ancient"
msgid "Yeah!"
msgstr "Вось так!"

# [ua] Повертаєшся по ще, Ваша Високосте?!
# [pl] Wasza Wysokość wróciła po więcej?!
# [ru] Вернулись за добавкой, ваше величество?!
msgctxt "ancients.json:DARV.talk.REGENT.1-0r.ancient"
msgid "Back for more your highness?!"
msgstr "Вярнуліся па дабаўку, Ваша Высокасць?!"

# [ua] Для мого нового друга — маю дещо для тебе!
# [pl] Akurat mam coś w sam raz dla mojego nowego przyjaciela!
# [ru] Дорогой друг, у меня есть кое-что для тебя!
msgctxt "ancients.json:DARV.talk.REGENT.2-0.ancient"
msgid "To my new friend, do I have somethin’ for ya!"
msgstr "Акурат для новага сябра я нештачка маю!"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:DARV.talk.REGENT.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Слухаю!
# [pl] Zamieniam się w słuch!
# [ru] Я слушаю!
msgctxt "ancients.json:DARV.talk.REGENT.2-1.char"
msgid "I’m listening!"
msgstr "Я слухаю!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.REGENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Я б віддав, але Архітектор забрав це в мене!!
# Допоможи товаришу! Зроби мені послугу, а?
# [pl] Dałbym ci, gdyby mi Architekt tego nie zakosił!!
# Weź pomóż koledze! Jak spotkasz Architekta, to spytaj go, czy mi odda,
# dobra?
# [ru] Вот только это «кое-что» у меня Архитектор стащил!
# Сделай одолжение, поможешь по-дружески?
msgctxt "ancients.json:DARV.talk.REGENT.2-2.ancient"
msgid "I’d give it but the Architect nabbed it from me!!\n"
"Help a buddy out! Do me a favor will ya?"
msgstr "Я б аддаў, але гэтае «нешта» сцягнуў у мяне Архітэктар!!\n"
"Дапамажы сябруку! Разбярыся з гэтым, добра?"

# [ua] Знову у Шпилі, так?
# Не можеш встояти перед блискучими речицями, правда?!
# [pl] Też z powrotem w Iglicy?
# No nie można się oprzeć tym wszystkim błyskotkom, co?!
# [ru] И тебя угораздило вернуться в Шпиль?
# Трудно устоять перед всеми этими побрякушками, согласись?!
msgctxt "ancients.json:DARV.talk.SILENT.0-0.ancient"
msgid "Back in the Spire for you too huh?\n"
"Can’t resist those shinies right?!"
msgstr "Таксама зноў у Шпілі, га?\n"
"Цяжка выстаяць перад усімі гэтымі бліскоткамі, ці не так?!"

# [ua] Обміняю тобі щось гарне на той трофей, що ти здобула!
# [pl] Dam ci coś naprawdę ładnego za to twoje trofeum!
# [ru] Я готов обменять что-нибудь интересное на твой трофей!
msgctxt "ancients.json:DARV.talk.SILENT.1-0r.ancient"
msgid "I’ll trade ya somethin’ nice for that trophy you got there!"
msgstr "Абмяняю табе што-небудзь прыгожае на той твой трафей!"

# [ua] Шкода, що ти не пам'ятаєш усю мою щедрість!
# Так-так, знаєш, як воно з Няу...
# [pl] Szkoda, że nawet nie będziesz pamiętać, jaki hojny jestem dla ciebie!
# Ta, przecież wiesz, jaka Neow jest.
# [ru] Жаль, что ты не помнишь всю мою щедрость!
# Да-да, Ньяу, все дела…
msgctxt "ancients.json:DARV.talk.SILENT.2-0.ancient"
msgid "Pity ya don’t remember all my generosity!\n"
"Yeah yeah, you know how Neow is..."
msgstr "Шкада, што ты не памятаеш усёй маёй шчодрасці!\n"
"Так-так, ты ж ведаеш, якая Няў ёсць..."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:DARV.talk.SILENT.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] ...
# [pl] ...
# [ru] …
msgctxt "ancients.json:DARV.talk.SILENT.2-1.char"
msgid "..."
msgstr "..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:DARV.talk.SILENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ну! Давай спорядимо тебе до тієї фінальної битви чи що там!
# [pl] No! Trzeba cię dobrze uzbroić na ten wielki finał czy coś tam!
# [ru] Ладненько! Снарядим-ка тебя типа в решающий бой!
msgctxt "ancients.json:DARV.talk.SILENT.2-2.ancient"
msgid "Well! Let’s get you equipped for that final showdown or whatevah!"
msgstr "Хай так! Давай падрыхтуем цябе да апошняй бітвы, ці як гэта назваць!"

# [ua] ...куди ж я поклав... О!
# Прийшов подивитися мою колекцію!? Бери що завгодно з тієї купи, знайди їм
# застосування!
# [pl] ...gdzie ja to odłożyłem... O!
# Chcesz zobaczyć moją kolekcję!? Przejrzyj tamtą stertę i wybierz sobie coś
# ładnego!
# [ru] Где же этот… Ой!
# Интересует моя коллекция?! Возьми что-нибудь из той кучи — используй с умом!
msgctxt "ancients.json:DARV.talk.firstVisitEver.0-0.ancient"
msgid "...where did I put... Oh!\n"
"Come to see my collection!? Take anything from that pile over there, put it to good use!"
msgstr "...дзе ж я паклаў... О!\n"
"Цікавіць мая калекцыя? Бяры што хочаш з той кучы, абы цябе на карысць выйшла!"

# [ua] Дарв
# [pl] Darv
# [ru] Дарв
msgctxt "ancients.json:DARV.title"
msgid "Darv"
msgstr "Дарв"

# [ua] Ви знайшли помилку! Будь ласка, повідомте про неї за допомогою кнопки
# «Відгук» у меню налаштувань.
# [pl] Znaleziono błąd! Prosimy o zgłoszenie go, naciskając na przycisk
# „Opinia” w ustawieniach.
# [ru] Вы нашли ошибку! Сообщите нам о ней через форму обратной связи в меню
# настроек.
msgctxt "ancients.json:ERROR.description"
msgid "You found a bug! Please report it using the Feedback button in the Settings menu."
msgstr "Вы знайшлі хібу! Паведаміце пра яе, націснуўшы кнопку «Зваротная сувязь» у меню «Налады»."

# [ua] Заблоковано
# [pl] Zablokowane
# [ru] Недоступно
msgctxt "ancients.json:ERROR.title"
msgid "Locked"
msgstr "Недаступна"

# [ua] Мати Воскресіння (Вигнана)
# [pl] Matka Wskrzeszenia (wygnana)
# [ru] Праматерь воскрешения (в изгнании)
msgctxt "ancients.json:NEOW.epithet"
msgid "Mother of Resurrection (Exiled)"
msgstr "Маці Уваскрашэння (у выгнанні)"

# [ua] [sine]...привіт... ..знову.....[/sine]
# [pl] [sine]...witaj... ..ponownie.....[/sine]
# [ru] [sine]…здравствуй… …вновь…[/sine]
msgctxt "ancients.json:NEOW.talk.ANY.0-0r.ancient"
msgid "[sine]...hello... ..again.....[/sine]"
msgstr "[sine]...вітаю... ..зноў.....[/sine]"

# [ua] [sine]...прокинься...
# ..Прокинься.....[/sine]
# [pl] [sine]...obudź się...
# ..Obudź.....[/sine]
# [ru] [sine]…пробудись…
# …Пробудись…[/sine]
msgctxt "ancients.json:NEOW.talk.ANY.1-0r.ancient"
msgid "[sine]...awaken...\n"
"..Awaken.....[/sine]"
msgstr "[sine]...абудзіся...\n"
"..абудзіся.....[/sine]"

# [ua] [sine]..прийми.... це....
# ..благословення.. ...іди......[/sine]
# [pl] [sine]..przyjmij.... to....
# ..błogosławieństwo.. ...idź......[/sine]
# [ru] [sine]…получи… …мое…
# …благословение… …ступай…[/sine]
msgctxt "ancients.json:NEOW.talk.ANY.2-0r.ancient"
msgid "[sine]..receive.... this....\n"
"..blessing.. ...go......[/sine]"
msgstr "[sine]..прымі... гэта....\n"
"..дабраславенне.. ...ідзі......[/sine]"

# [ua] [sine]..я... ..повернула... ..тебе...[/sine]
# [pl] [sine]..Przywróciłam... ..cię... ..z martwych...[/sine]
# [ru] [sine]…я… …вернула… …тебя…[/sine]
msgctxt "ancients.json:NEOW.talk.ANY.3-0r.ancient"
msgid "[sine]..I’ve... ..brought... ..you back...[/sine]"
msgstr "[sine]..Я... ..вярнула... ..цябе...[/sine]"

# [ua] [sine]...вбий.. того... [red][jitter]АРХІТЕКТОРА[/jitter][/red][/sine]
# [pl] [sine]...zabij.. [red][jitter]ARCHITEKTA[/jitter][/red][/sine]
# [ru] [sine]…убей… [red][jitter]АРХИТЕКТОРА[/jitter][/red][/sine]
msgctxt "ancients.json:NEOW.talk.ANY.4-0r.ancient"
msgid "[sine]...kill.. the... [red][jitter]ARCHITECT[/jitter][/red][/sine]"
msgstr "[sine]...забі... [red][jitter]АРХІТЭКТАРА[/jitter][/red][/sine]"

# [ua] [sine]...конструкте.. ким...
# ....ти.. став...?[/sine]
# [pl] [sine]...konstrukcie.. czym...
# ....ty się.. stałeś...?[/sine]
# [ru] [sine]…агрегат… …что…
# …с тобой… …стало…[/sine]
msgctxt "ancients.json:NEOW.talk.DEFECT.0-0.ancient"
msgid "[sine]...construct.. what...\n"
"....have you.. become...?[/sine]"
msgstr "[sine]...механізм...\n"
"....чым.. ты.. стаў...?[/sine]"

# [ua] [sine]...він.. може...
# ....полагодити.. тебе.. ...все....[/sine]
# [pl] [sine]...może.. cię...
# ....naprawić.. wszystko....[/sine]
# [ru] [sine]…он… …может…
# …исправить… …тебя… …исправить… …все…[/sine]
msgctxt "ancients.json:NEOW.talk.DEFECT.1-0r.ancient"
msgid "[sine]...he.. can...\n"
"....fix.. you.. ...everything....[/sine]"
msgstr "[sine]...ён.. можа...\n"
"....выправіць.. цябе.. ...усё... выправіць...[/sine]"

# [ua] [sine]...я.. не можу... ..змусити...
# ...тебе.. забути....[/sine]
# [pl] [sine]...Nie.. mogę... ..sprawić...
# ...żebyś.. zapomniał....[/sine]
# [ru] [sine]…я… …не могу…
# …стереть… …тебе… …память…[/sine]
msgctxt "ancients.json:NEOW.talk.DEFECT.2-0.ancient"
msgid "[sine]...I.. can’t... ..make...\n"
"...you.. forget....[/sine]"
msgstr "[sine]...Я.. не... магу... ..прымусіць...\n"
"...цябе.. забыць....[/sine]"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:NEOW.talk.DEFECT.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] [i][font_size=22]<рішучі сигнали>[/font_size][/i]
# [pl] [i][font_size=22]<stanowcze pikanie>[/font_size][/i]
# [ru] [i][font_size=22]<Уверенное бибиканье>[/font_size][/i]
msgctxt "ancients.json:NEOW.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]<resolute beeping sounds>[/font_size][/i]"
msgstr "[i][font_size=22]<рашучае піканне>[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.DEFECT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]...добре....[/sine]
# [pl] [sine]...dobrze....[/sine]
# [ru] [sine]…хорошо…[/sine]
msgctxt "ancients.json:NEOW.talk.DEFECT.2-2.ancient"
msgid "[sine]...good....[/sine]"
msgstr "[sine]...добра....[/sine]"

# [ua] [sine]..встань.. мій.. воїне...
# ..час... битися...знову...[/sine]
# [pl] [sine]..powstań.. mój.. wojowniku...
# ..czas... walczyć...znowu...[/sine]
# [ru] [sine]…поднимись… …мой… …воин…
# …время… …продолжить… …сражение…[/sine]
msgctxt "ancients.json:NEOW.talk.IRONCLAD.0-0.ancient"
msgid "[sine]..arise.. my.. warrior...\n"
"..time... to fight...again...[/sine]"
msgstr "[sine]..устань.. мой.. ваяр...\n"
"..прыйшоў... час... змагання...[/sine]"

# [ua] [sine]..все ще.. втрачений.. у люті... добре...[/sine]
# [pl] [sine]..wciąż.. płoniesz.. gniewem... dobrze...[/sine]
# [ru] [sine]…хорошо… …по-прежнему… …ослеплен… …яростью…[/sine]
msgctxt "ancients.json:NEOW.talk.IRONCLAD.1-0r.ancient"
msgid "[sine]..still.. lost.. to rage... good...[/sine]"
msgstr "[sine]..усё яшчэ.. аслеплены.. лютасцю... добра...[/sine]"

# [ua] [sine]..пам'ятаєш.. перший..раз
# ...коли ..ти ..прийшов...до мене..[/sine]
# [pl] [sine]..pamiętasz.. pierwszy..raz
# ...przyszedłeś...do mnie..[/sine]
# [ru] [sine]…вспомни… …как ты… …впервые…
# …предстал… …перед… …мной…[/sine]
msgctxt "ancients.json:NEOW.talk.IRONCLAD.2-0.ancient"
msgid "[sine]..remember.. the.. first..time\n"
"...you ..came...before me..[/sine]"
msgstr "[sine]..успомні.. першы.. раз\n"
"...калі... ты.. прыйшоў... да... мяне..[/sine]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.IRONCLAD.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]..такий..лютий...[/sine]
# [pl] [sine]..taki..gniewny...[/sine]
# [ru] [sine]…столько… …гнева…[/sine]
msgctxt "ancients.json:NEOW.talk.IRONCLAD.2-1.ancient"
msgid "[sine]..so..furious...[/sine]"
msgstr "[sine]..столькі...лютасці...[/sine]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.IRONCLAD.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]...такий..корисний...[/sine]
# [pl] [sine]...taki..przydatny...[/sine]
# [ru] [sine]…это… …мне… …пригодится…[/sine]
msgctxt "ancients.json:NEOW.talk.IRONCLAD.2-2.ancient"
msgid "[sine]...so..useful...[/sine]"
msgstr "[sine]...мне..прыдасца...[/sine]"

# [ua] [sine]...ми.... маємо... ..спільну... ..мету....[/sine]
# [pl] [sine]...mamy.... wspólny... ..cel...[/sine]
# [ru] [sine]…у нас… …одна… …цель…[/sine]
msgctxt "ancients.json:NEOW.talk.NECROBINDER.0-0.ancient"
msgid "[sine]...we.... share... ..the same... ..goal....[/sine]"
msgstr "[sine]...мы.... маем... ..адну... ..мэту...[/sine]"

# [ua] Говорити
# [pl] Rozmawiaj
# [ru] Говорить
msgctxt "ancients.json:NEOW.talk.NECROBINDER.0-0.next"
msgid "Talk"
msgstr "Гаварыць"

# [ua] [jitter]ВІН УБИВ УСІХ, КОГО Я ЛЮБИЛА!![/jitter]
# [pl] [jitter]ZABIŁ WSZYSTKO, CO KOCHAM!![/jitter]
# [ru] [jitter]ОН ПОГУБИЛ ВСЕ, ЧТО МНЕ ДОРОГО![/jitter]
msgctxt "ancients.json:NEOW.talk.NECROBINDER.0-1.char"
msgid "[jitter]HE KILLED ALL THAT I LOVE!![/jitter]"
msgstr "[jitter]ЁН ЗНІШЧЫЎ УСЁ, ШТО Я ЛЮБІЛА!![/jitter]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.NECROBINDER.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]...моя сила..... твоя...[/sine]
# [pl] [sine]...moja moc..... jest twoja...[/sine]
# [ru] [sine]…моя… …сила… …принадлежит… …тебе…[/sine]
msgctxt "ancients.json:NEOW.talk.NECROBINDER.0-2.ancient"
msgid "[sine]...my power..... is yours...[/sine]"
msgstr "[sine]...мая сіла..... ёсць тваёй сілай...[/sine]"

# [ua] [sine]Він... все ще.. ....дихає...[/sine]
# [pl] [sine]On... wciąż.. ....oddycha...[/sine]
# [ru] [sine]…он… …еще… …дышит…[/sine]
msgctxt "ancients.json:NEOW.talk.NECROBINDER.1-0r.ancient"
msgid "[sine]He... still.. ....breathes...[/sine]"
msgstr "[sine]Ён... усё яшчэ.. ....дыхае...[/sine]"

# [ua] [sine]Чи... це.. ...взагалі... можливо...?[/sine]
# [pl] [sine]Czy... to.. ...w ogóle... możliwe...?[/sine]
# [ru] [sine]Это… вообще… возможно?[/sine]
msgctxt "ancients.json:NEOW.talk.NECROBINDER.2-0.char"
msgid "[sine]Is... it.. ...even... possible...?[/sine]"
msgstr "[sine]Ці... гэта... наогул... магчыма...?[/sine]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.NECROBINDER.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]... [red]Архітектор[/red].... ..слабшає....
# ..ми.... сильніші...[/sine]
# [pl] [sine]... [red]Architekt[/red].... ..słabszy....
# ..my.... silniejsi...[/sine]
# [ru] [sine]…[red]Архитектор[/red]… …слабеет…
# …мы… …сильнее…[/sine]
msgctxt "ancients.json:NEOW.talk.NECROBINDER.2-1.ancient"
msgid "[sine]... [red]Architect[/red].... ..weakening....\n"
"..we.... stronger...[/sine]"
msgstr "[sine]... [red]Архітэктар[/red].... ..слабее....\n"
"..мы.... мацнеем...[/sine]"

# [ua] Величезна синя істото, я — майбутній [orange]Король[/orange]!
# [pl] Słuchaj, ogromna, błękitna kreaturo! Jestem przyszłym
# [orange]Królem[/orange]!
# [ru] Эй, синяя громадина! Я — будущий [orange]король[/orange]!
msgctxt "ancients.json:NEOW.talk.REGENT.0-0.char"
msgid "Oversized blue creature, I am the future [orange]King[/orange]!"
msgstr "Слухай сюды, гіганцкая сіняя істота. Я — будучы [orange]кароль[/orange]!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.REGENT.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]..мило...
# ...ти... побачиш.. ..мене... ...знову....[/sine]
# [pl] [sine]..urocze...
# ...zobaczymy... się.. ..ponownie....[/sine]
# [ru] [sine]…как… …мило…
# …еще… …увидимся…[/sine]
msgctxt "ancients.json:NEOW.talk.REGENT.0-1.ancient"
msgid "[sine]..cute...\n"
"...you... will see.. ..me... ...again....[/sine]"
msgstr "[sine]..міла...\n"
"...мы... убачымся.. ...зноў....[/sine]"

# [ua] [sine]...знову..?[/sine]
# [pl] [sine]...znowu..?[/sine]
# [ru] [sine]…снова…[/sine]
msgctxt "ancients.json:NEOW.talk.REGENT.1-0r.ancient"
msgid "[sine]...again..?[/sine]"
msgstr "[sine]...зноў..?[/sine]"

# [ua] [jitter]Чому я не можу перемогти?![/jitter]
# [pl] [jitter]Czemu nie mogę wygrać?![/jitter]
# [ru] [jitter]Почему я не побеждаю?![/jitter]
msgctxt "ancients.json:NEOW.talk.REGENT.2-0.char"
msgid "[jitter]Why can’t I win?![/jitter]"
msgstr "[jitter]Чаму я не перамагаю?![/jitter]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.REGENT.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]...прийми.. це... ..благословення...[/sine]
# [pl] [sine]...przyjmij.. to... ..błogosławieństwo...[/sine]
# [ru] [sine]…вот… …мое… …благословение…[/sine]
msgctxt "ancients.json:NEOW.talk.REGENT.2-1.ancient"
msgid "[sine]...receive.. this... ..blessing...[/sine]"
msgstr "[sine]...прымі.. гэта... ..дабраславенне...[/sine]"

# [ua] Подякувати
# [pl] Podziękuj
# [ru] Поблагодарить
msgctxt "ancients.json:NEOW.talk.REGENT.2-1.next"
msgid "Thank"
msgstr "Падзякаваць"

# [ua] ...так, дякую, Няу.
# [pl] ...dobrze, dziękuję Neow.
# [ru] Да-да, спасибо, Ньяу.
msgctxt "ancients.json:NEOW.talk.REGENT.2-2.char"
msgid "...yes, thank you Neow."
msgstr "...так, дзякуй, Няў."

# [ua] [sine]...повернулася.. ззовні?
# ..знала... що ти... повернешся...[/sine]
# [pl] [sine]...wróciłaś.. z zewnątrz?
# ..wiedziałam... że... wrócisz...[/sine]
# [ru] [sine]…ты… …издалека…
# …знала… …что… …ты… …вернешься…[/sine]
msgctxt "ancients.json:NEOW.talk.SILENT.0-0.ancient"
msgid "[sine]...returned.. from... outside?\n"
"..knew... you’d... be back...[/sine]"
msgstr "[sine]...вярнулася.. здалёк?\n"
"..ведала... што... ты... вернешся...[/sine]"

# [ua] [sine]...твій..
#  ...трофей.. чекає...[/sine]
# [pl] [sine]...twoje..
#  ...trofeum.. czeka...[/sine]
# [ru] [sine]…тебя…
# …ждет… …трофей…[/sine]
msgctxt "ancients.json:NEOW.talk.SILENT.1-0r.ancient"
msgid "[sine]...your..\n"
" ...trophy.. awaits...[/sine]"
msgstr "[sine]...твой..\n"
" ...трафей.. чакае...[/sine]"

# [ua] [sine]..обидві...знаємо..агонію..родини...[/sine]
# [pl] [sine]..obie...wiemy..rodziny..nie..wybierasz...[/sine]
# [ru] [sine]…гнет… …родни… …нам… …знаком…[/sine]
msgctxt "ancients.json:NEOW.talk.SILENT.2-0.ancient"
msgid "[sine]..both...know..agony..of..family...[/sine]"
msgstr "[sine]..абедзве...спазналі..цяжар..сямейнага... гнёту[/sine]"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:NEOW.talk.SILENT.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] ...
# [pl] ...
# [ru] …
msgctxt "ancients.json:NEOW.talk.SILENT.2-1.char"
msgid "..."
msgstr "..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NEOW.talk.SILENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [sine]..все ще...шукаєш..схвалення...?
# ...[jitter]ДУРНА[/jitter]...[/sine]
# [pl] [sine]..wciąż...szukasz..aprobaty...?
# ...[jitter]GŁUPOTA[/jitter]...[/sine]
# [ru] [sine]…тоже… …жаждешь… …признания…
# …[jitter]ГЛУПОСТЬ[/jitter]…[/sine]
msgctxt "ancients.json:NEOW.talk.SILENT.2-2.ancient"
msgid "[sine]..still...seeking..approval...?\n"
"...[jitter]FOOLISH[/jitter]...[/sine]"
msgstr "[sine]..усё яшчэ...шукаеш...ухвалення...?\n"
"...[jitter]ДУРЫЦА[/jitter]...[/sine]"

# [ua] [sine]Я... відтворила тебе....
# ...іди... ..вгору.....[/sine]
# [pl] [sine]Odnowiłam... cię....
# ...idź... ..na górę.....[/sine]
# [ru] [sine]…я… …исправила… …тебя…
# …ступай… …наверх…[/sine]
msgctxt "ancients.json:NEOW.talk.firstVisitEver.0-0.ancient"
msgid "[sine]I’ve... remade you....\n"
"...go... ..up.....[/sine]"
msgstr "[sine]Я... перарабіла... цябе....\n"
"...ідзі... ..уверх.....[/sine]"

# [ua] Няу
# [pl] Neow
# [ru] Ньяу
msgctxt "ancients.json:NEOW.title"
msgid "Neow"
msgstr "Няў"

# [ua] Серендипність у плоті
# [pl] Szczęście Wcielone
# [ru] Вершит свою удачу
msgctxt "ancients.json:NONUPEIPE.epithet"
msgid "Serendipity Incarnate"
msgstr "Увасабленне памыснасці"

# [ua] Божевілля чекає на вершині. Прийми мою силу та переможи.
# [pl] Na szczycie czeka cię tylko szaleństwo. Przywdziewaj moją moc i znikaj.
# [ru] Безумие ждет на вершине. Обрети мою силу и проложи себе дорогу к
# победе.
msgctxt "ancients.json:NONUPEIPE.talk.ANY.0-0r.ancient"
msgid "Madness awaits at the top. Don my power and vanquish."
msgstr "На вяршыні чакае вар'яцтва. Зведай маёй сілы і перамажы."

# [ua] Ти пройшов такий довгий шлях, щоб дістатися до мене!
# Підійди ближче, прийми моє благословення.
# [pl] Ależ to musiała być długa podróż!
# Podejdź, przyjmij moje błogosławieństwo.
# [ru] Твой путь ко мне был тернист и долог!
# Подойди, получи мое благословение.
msgctxt "ancients.json:NONUPEIPE.talk.ANY.1-0r.ancient"
msgid "You’ve traveled so far to reach me!\n"
"Come closer, receive my blessing."
msgstr "Твой шлях быў доўгі, і ўсё ж табе ўдалося!\n"
"Падыдзі бліжэй, прымі маё дабраславенне."

# [ua] Невже конструкт справді гідний моїх благословень?
# Підійди, Дефекте. Ти станеш найпрекраснішим із усіх автоматонів.
# [pl] Czy konstrukt może naprawdę być godzień moich błogosławieństw?
# Podejdź, Defekcie. Będziesz najpiękniejszym automatonem.
# [ru] Достоин ли агрегат моих благословений?
# Подойди, Дефект. Ты станешь наипрекраснейшим из всех автоматонов.
msgctxt "ancients.json:NONUPEIPE.talk.DEFECT.0-0.ancient"
msgid "Could a construct truly be worthy of my blessings?\n"
"Come forward, Defect. You will be the most beautiful of all automata."
msgstr "Ці можа механізм быць напраўду вартым маіх дабраславенняў?\n"
"Падыдзі, Дэфект. Ты будзеш самым прыгожым з аўтаматонаў."

# [ua] Мій бідний, побитий механізме, дозволь мені вдосконалити тебе.
# [pl] Oczyszczę cię, moja biedna, poturbowana maszyno.
# [ru] Бедный, побитый механизм. Позволь тебя наладить.
msgctxt "ancients.json:NONUPEIPE.talk.DEFECT.1-0r.ancient"
msgid "My poor, battered machine, let me refine you."
msgstr "Бедны, пабіты механізм, дазволь мне цябе ўдасканаліць."

# [ua] Зазвичай я не люблю речі Архітектора, але визнаю — ти мені подобаєшся.
# [pl] Zwykle nie lubię stworzeń Architekta, ale muszę przyznać, że zaczynasz
# mi się podobać coraz bardziej.
# [ru] Вещицы Архитектора мне претят. Но должна признать, в тебе что-то есть.
msgctxt "ancients.json:NONUPEIPE.talk.DEFECT.2-0.ancient"
msgid "I usually don’t like the Architect’s things, but I admit you’re growing on me."
msgstr "Звычайна мне не даспадобы рэчы Архітэктара, але я прызнаю, што ты мне ўсё больш падабаешся."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:NONUPEIPE.talk.DEFECT.2-0.next"
msgid "Reply"
msgstr "Адказаць"

# [ua] [i][font_size=22]<збентежений сигнал>[/font_size][/i]
# [pl] [i][font_size=22]<zawstydzone cykanie>[/font_size][/i]
# [ru] [i][font_size=22]<Смущенное пиликанье>[/font_size][/i]
msgctxt "ancients.json:NONUPEIPE.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]<embarrassed chirp>[/font_size][/i]"
msgstr "[i][font_size=22]<збянтэжанае піканне>[/font_size][/i]"

# [ua] А ось і Залізнолад нарешті прибув до мене.
# Підійди, і я наділю тебе своєю силою.
# [pl] Ach, nareszcie Pancernik do mnie dotarł.
# Podejdź, a obdarzę cię moją mocą.
# [ru] Ах, наконец я лицезрею пред собой Латоносца.
# Подойди, и я наделю тебя своей силой.
msgctxt "ancients.json:NONUPEIPE.talk.IRONCLAD.0-0.ancient"
msgid "Ah, the Ironclad finally arrives before me.\n"
"Come forth and I shall endow you with my power."
msgstr "Ах, нарэшце перада мной паўстае Браняносец.\n"
"Выйдзі, і я надзялю цябе сваёй сілай."

# [ua] Залізноладе, Залізноладе... мого попереднього дару було недостатньо?
# [pl] Och, Pancerniku... Czyżby mój poprzedni dar nie wystarczył?
# [ru] Эх Латоносец, Латоносец… Неужто мои прошлые дары были напрасны?
msgctxt "ancients.json:NONUPEIPE.talk.IRONCLAD.1-0r.ancient"
msgid "Ironclad ironclad... was my previous gift not enough?"
msgstr "Браняносец ты браняносец... хіба майго папярэдняга дару было мала?"

# [ua] Ти знову повертаєшся, мій борцю? Скільки вже разів?
# Хіба тобі не вистачало сили, щоб знищити цілі клани раніше?
# [pl] Mój wojownik znów powrócił? Ile to już razy?
# Czyż nie władałeś siłą większą od całych klanów?
# [ru] Мой воин, ты снова здесь? В который раз?
# Твое могущество искореняло целые племена, что изменилось?
msgctxt "ancients.json:NONUPEIPE.talk.IRONCLAD.2-0.ancient"
msgid "You return again my champion? How many times?\n"
"Were you not strong enough to wipe out entire clans before?"
msgstr "Ты зноў вяртаешся, мой ваяўнік? Колькі ўжо разоў?\n"
"Раней ты знішчаў цэлыя кланы, што стала з тваёй моцай?"

# [ua] Твої вартові мертві, кажуть, ти можеш дарувати благословення тим, хто
# бажає смерті Архітектора.
# [pl] Twoja straż jest martwa. Chodzą pogłoski, że błogosławisz tych, którzy
# życzą śmierci Architektowi.
# [ru] Бежать некуда, твоя стража мертва. Твои благословения помогают тем, кто
# желает смерти Архитектора. Это так?
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.0-0.char"
msgid "Your guards are dead, rumors say you can bestow blessings for those who wish the Architect dead."
msgstr "Твае ахоўнікі мёртвыя. Ходзяць чуткі, што ты даруеш дабраславенне тым, хто зычыць Архітэктару смерці."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Я ціную здібних людей і дарую частку своєї сили.
# Наступного разу не вбивай моїх вартових.
# [pl] Doceniam kompetentnych śmiałków i zamierzam ich obdarzyć miarą mojej
# mocy.
# Tak na przyszłość, nie zabijaj mojej straży.
# [ru] Твоя предприимчивость впечатляет. Я поделюсь с тобой силой.
# Но в следующий раз не стоит убивать мою стражу.
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.0-1.ancient"
msgid "I appreciate someone capable and shall grant a measure of my power.\n"
"Next time, don’t kill my guards."
msgstr "Я цаню здольных, таму надам табе частку сваёй сілы.\n"
"Толькі наступным разам не забівай ахоўнікаў."

# [ua] Магу потрібне добре спорядження для битви. Підійди, Некрозв'язуюча.
# [pl] Magowi potrzeba do walki porządnych akcesoriów. Podejdź, Nekromantko.
# [ru] Любой чародейке нужна надежная экипировка для боя. Подойди,
# Призывающая.
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.1-0r.ancient"
msgid "A mage needs fine accouterments for battle. Come forth, Necrobinder."
msgstr "Чараўніцы патрэбны якасны баявы рыштунак. Падайся наперад, Цямнарка."

# [ua] Архітектор буде не радий побачити того [sine]улюбленця[/sine] твого.
# [pl] Architekt nie będzie zadowolony, jak zobaczy to twoje
# [sine]zwierzątko[/sine].
# [ru] Архитектор не обрадуется твоему [sine]питомцу[/sine].
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.2-0.ancient"
msgid "The Architect won’t be pleased to see that [sine]pet[/sine] of yours."
msgstr "Архітэктар не ўхваліць, калі ўбачыць твайго [sine]гадаванца[/sine]."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Ти маєш на увазі Ості? Він завдасть останнього удару.
# [pl] Masz na myśli Kostka? To właśnie on zada ostateczny cios.
# [ru] Ты про Костю? За ним будет решающий удар.
msgctxt "ancients.json:NONUPEIPE.talk.NECROBINDER.2-1.char"
msgid "Do you mean Osty? He will be the one to deliver the final blow."
msgstr "Ты пра Костуся? Акурат ён нанясе апошні ўдар."

# [ua] Прошу аудієнції в Нонупейпе!
# [pl] Domagam się audiencji u Nonupeipe!
# [ru] Я требую аудиенции с Нонупейпе!
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.0-0.char"
msgid "I seek audience with Nonupeipe!"
msgstr "Я вымагаю аўдыенцыі з Нанупэйпэ!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Які прекрасні шати ти привіз із далеких земель!
# Нехай твої слуги піднесуть тебе ближче, і я благословлю тебе.
# [pl] Jakież to piękne szaty z odległej krainy!
# Rozkażcie swojej służbie podejść bliżej, a Was pobłogsławię.
# [ru] На тебе такие прелестные и экзотичные шелка!
# Прикажи слугам поднести тебя поближе, и я благославлю тебя.
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.0-1.ancient"
msgid "Such beautiful robes you’ve brought from faraway lands!\n"
"Have your minions bring you closer and I will bless thee."
msgstr "Якія ж цудоўныя шаты ты прывёз з далёкіх краёў!\n"
"Няхай слугі паднясуць цябе бліжэй, і я дам сваё дабраславенне."

# [ua] Королівські благословення для королівських гостей.
# Слуги! Принесіть нам чаю.
# [pl] Królewskie błogosławieństwa dla królewskich gości.
# Służba! Proszę natychmiast zaparzyć herbatę.
# [ru] Королевские благословения для коронованных гостей.
# Прислуга! Принесите нам чаю.
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.1-0r.ancient"
msgid "Royal blessings for royal visitors.\n"
"Servants! Fetch some tea for us."
msgstr "Шляхетныя дабраславенні шляхетным гасцям.\n"
"Слугі! Запарце нам гарбаты."

# [ua] Архітектор збожеволів! Якби тільки благородний борець міг врятувати нас
# від цього лиха...
# [pl] Architekt całkowicie oszalał! Gdyby tylko jakiś bohater nas ocalił
# przed tą niedolą...
# [ru] Архитектор выжил из ума! Где же отважный воин, которому под силу спасти
# нас от его сумасбродства…
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.2-0.ancient"
msgid "The Architect has gone mad! If only a noble champion could save us from this plight..."
msgstr "Архітэктар з глузду з'ехаў! Калі б толькі які-небудзь шляхетны герой мог выратаваць нас ад гэтай бяды..."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Не бійся! Я, Регент, покладу край цьому божевіллю!
# Але спершу — чай!
# [pl] Bez obaw! Ja, Dziedzic Gwiezdnego Tronu, osobiście zakończę to
# szaleństwo!
# Ale najpierw, herbata!
# [ru] Не бойтесь! Даю слово Наследника, что положу конец этому безумию!
# Но сперва — чай!
msgctxt "ancients.json:NONUPEIPE.talk.REGENT.2-1.char"
msgid "Fear not! I, the Regent, will put an end to the madness!\n"
"But first, tea!"
msgstr "Не бойся! Я, як Рэгент, пакладу канец вар'яцтву!\n"
"Але спачатку — гарбата!"

# [ua] Маленька злодійка пробралася до моїх володінь?
# Думаєш, я тебе не бачу? Виходь!
# [pl] Jakiś złodziejaszek wkradł się na moje włości?
# Myślisz, że cię nie widać? Wychodź!
# [ru] Мелкая воровка прокралась в мои владения!
# Думаешь, я не знаю, что ты там? Покажись!
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.0-0.ancient"
msgid "A little thief has snuck into my domain?\n"
"Don’t think I can’t see you? Come on out!"
msgstr "Малая зладзейка пракралася ў мае ўладанні?\n"
"Думаеш, я цябе не бачу? Выходзь!"

# [ua] З'явитися
# [pl] Ujawnij się
# [ru] Показаться
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.0-0.next"
msgid "Appear"
msgstr "Паказацца"

# [ua] [i][font_size=22]Мовчазна виходить із тіней...[/font_size][/i]
# [pl] [i][font_size=22]Zjawa wyłania się z mroku...[/font_size][/i]
# [ru] [i][font_size=22]Безмолвная выходит из теней…[/font_size][/i]
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.0-1.char"
msgid "[i][font_size=22]The Silent steps out of the shadows...[/font_size][/i]"
msgstr "[i][font_size=22]Маўчальніца выходзіць з ценяў…[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Мисливиця, що кличе тебе назад до Шпиля?
# Підійди та одягни ці благословення.
# [pl] Łowczyni, cóż cię sprowadza do Iglicy?
# Podejdź i przywdziej te błogosławieństwa.
# [ru] Охотница? Что призвало тебя обратно в Шпиль?
# Подойди и обрети мои благословения.
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.0-2.ancient"
msgid "A huntress, what beckons your return to the Spire?\n"
"Approach and don these blessings."
msgstr "Паляўнічая, што прывяло цябе назад у Шпіль?\n"
"Падыдзі і надзень маё дабраславенне."

# [ua] Я приготував для тебе дарунки, вбивице, не соромся.
# [pl] Przyszykowałam dary dla ciebie, zabójczyni, nie wstydź się.
# [ru] Я подготовила тебе дары, хищница. Не стесняйся.
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.1-0r.ancient"
msgid "I have prepared gifts for you, assassin, don’t be shy."
msgstr "Я падрыхтавала для цябе падарункі, забойца. Не саромейся."

# [ua] З-поміж усіх її маріонеток ти дивуєш мене найбільше.
# [pl] Z jej wszystkich marionetek, ty mnie zaskakujesz najbardziej.
# [ru] Из всех ее марионеток ты удивляешь меня больше всех.
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.2-0.ancient"
msgid "Of all of her puppets, you surprise me most."
msgstr "З усіх ейных марыянетак ты здзіўляеш мяне найбольш."

# [ua] Мовчати
# [pl] Nic nie mów
# [ru] Промолчать
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.2-0.next"
msgid "Say Nothing"
msgstr "Прамаўчаць"

# [ua] ...
# [pl] ...
# [ru] …
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.2-1.char"
msgid "..."
msgstr "..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Що забрало твоє перше життя? Чи Няу [sine]знайшла[/sine] тебе?
# Шкода, що ти не говориш.
# [pl] Co odebrało twoje pierwsze życie? Czy Neow cię [sine]odnalazła[/sine]?
# Pewnie jest ci wstyd, ale do tego się nie przyznasz.
# [ru] Как смерть настигла тебя в первый раз? Ньяу [sine]нашла[/sine] тебя?
# Жаль, что ты такая молчаливая.
msgctxt "ancients.json:NONUPEIPE.talk.SILENT.2-2.ancient"
msgid "What took your first life? Did Neow [sine]find[/sine] you?\n"
"A shame you don’t speak."
msgstr "Як ты першы раз пазбылася жыцця? Ці цябе [sine]знайшла[/sine] Няў?\n"
"Шкада, што ты не размаўляеш."

# [ua] У мене не було гостей вже тисячоліття!
# Ти виглядаєш доволі непоказно, ось, давай знайдемо тобі щось чудове для
# носіння.
# [pl] Nie miałam gości przez całe tysiąclecie!
# Wyglądasz ponuro, znajdziemy ci coś wspaniałego do ubrania.
# [ru] У меня не было гостей уже тысячу лет!
# Этот блеклый образ тебе не идет, давай подберем наряд поживописнее.
msgctxt "ancients.json:NONUPEIPE.talk.firstVisitEver.0-0.ancient"
msgid "I haven’t had a visitor in a millennia!\n"
"You’re looking quite drab, here, let’s find something delightful for you to wear."
msgstr "У мяне не было наведнікаў ужо тысячу гадоў!\n"
"Ты выглядаеш даволі блякла, давай, дазволь мне знайсці табе якую файную адзежу."

# [ua] Нонупейпе
# [pl] Nonupeipe
# [ru] Нонупейпе
msgctxt "ancients.json:NONUPEIPE.title"
msgid "Nonupeipe"
msgstr "Нанупэйпэ"

# [ua] Жива веселка
# [pl] Żywa Tęcza
# [ru] Живая радуга
msgctxt "ancients.json:OROBAS.epithet"
msgid "Living Rainbow"
msgstr "Жывая вясёлка"

# [ua] У Вас немає стартових реліквій чи карт.
# [pl] Nie masz żadnych startowych artefaktów ani kart.
# [ru] У вас нет начальных реликвий или карт.
msgctxt "ancients.json:OROBAS.pages.INITIAL.options.OPTION_POOL_3_LOCKED.description"
msgid "You have no starter relics or cards."
msgstr "Вы не маеце стартавых рэліквій або карт."

# [ua] Заблоковано
# [pl] Zablokowane
# [ru] Недоступно
msgctxt "ancients.json:OROBAS.pages.INITIAL.options.OPTION_POOL_3_LOCKED.title"
msgid "Locked"
msgstr "Недаступна"

# [ua] Спробуй це!!!
# [pl] Spróbuj tego!!!
# [ru] Примерь!
msgctxt "ancients.json:OROBAS.talk.ANY.0-0r.ancient"
msgid "Try this!!!"
msgstr "Надзень!!!"

# [ua] Дуже гарні знахідки!! Дивись дивись!
# [pl] Bardzo dobre znaleziska!! Popatrz, popatrz!
# [ru] Смотри, красота!
msgctxt "ancients.json:OROBAS.talk.ANY.1-0r.ancient"
msgid "Very good finds!! Look look!"
msgstr "Вельмі добрыя знаходкі!! Глядзі, глядзі!"

# [ua] Що! Конструкт-слуга?! Ще працює!!
# Чому тут? Чому не на Фабриці??
# [pl] Co?! Służący konstrukt?! Wciąż działa!!
# Czemu tutaj? Czemu nie w Fabryce??
# [ru] Что-о?! Агрегат-слуга?! На ходу?!
# А чего тут? Чего не на Фабрике?
msgctxt "ancients.json:OROBAS.talk.DEFECT.0-0.ancient"
msgid "What! Servant construct?! Still working!!\n"
"Why here? Why not at Factory??"
msgstr "Што! Механізм-слуга?! Яшчэ працуе?!\n"
"Чаму тут? Чаму не на Фабрыцы??"

# [ua] Блискучі сфери! Як працюють?
# [jitter]Ай!![/jitter]
# [pl] Lśniące sfery! Jak działają?
# [jitter]Auć!![/jitter]
# [ru] Яркие шары! Как это?
# [jitter]Ай![/jitter]
msgctxt "ancients.json:OROBAS.talk.DEFECT.1-0r.ancient"
msgid "Shiny orbs! How work?\n"
"[jitter]Ouch!![/jitter]"
msgstr "Бліскучыя шары! Як працуюць?\n"
"[jitter]Ой!![/jitter]"

# [ua] Ядро зламане? Няу використовує зламаний конструкт?
# Маніпулює?
# [pl] Rdzeń zepsuty? Neow wykorzystuje zepsuty konstrukt?
# Zmanipulowany?
# [ru] Ядро сломаться? У Ньяу сломаться агрегат?
# Ма-ни-пу-ля-ция?
msgctxt "ancients.json:OROBAS.talk.DEFECT.2-0.ancient"
msgid "Core broken? Neow use broken construct?\n"
"Manipulated?"
msgstr "Ядро зламалася? Няў выкарыстоўвае зламаны механізм?\n"
"Маніпулюе?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:OROBAS.talk.DEFECT.2-0.next"
msgid "Reply"
msgstr "Адказаць"

# [ua] [i][font_size=22]<тихо пікає>[/font_size][/i]
# [pl] [i][font_size=22]<ciche pikanie>[/font_size][/i]
# [ru] [i][font_size=22]<Тихое бибиканье>[/font_size][/i]
msgctxt "ancients.json:OROBAS.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]<quietly beeps>[/font_size][/i]"
msgstr "[i][font_size=22]<ціхае піканне>[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:OROBAS.talk.DEFECT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Архітектор полагодить?
# [pl] Architekt cię naprawił?
# [ru] Архитектор чинить?
msgctxt "ancients.json:OROBAS.talk.DEFECT.2-2.ancient"
msgid "Architect fix you?"
msgstr "Архітэктар выправіць цябе?"

# [ua] Залізнолад!? Як можливо?? Страшно. Дуже страшно!!
# [pl] Pancernik!? Jak możliwe?? Straszne. Bardzo straszne!!
# [ru] Латоносец?! Это как?! Страшный. Очень страшный!
msgctxt "ancients.json:OROBAS.talk.IRONCLAD.0-0.ancient"
msgid "An Ironclad!? How possible?? Scary. Very scary!!"
msgstr "Браняносец!? Як гэта магчыма?? Страшна. Вельмі страшна!!"

# [ua] Підписав контракт? Навіщо!? Поганий вибір? Так. Помилка!
# [pl] Zawarłeś pakt? Czemu!? Zły wybór? Tak. Błąd!
# [ru] Договориться? Зачем?! Плохо выбрать? Да. Ошибка!
msgctxt "ancients.json:OROBAS.talk.IRONCLAD.1-0r.ancient"
msgid "Contract signer? Why!? Bad choice? Yes. Mistake!"
msgstr "Падпісаў кантракт? Чаму!? Дрэнны выбар? Так. Памылка!"

# [ua] Бажаю тобі свободи!! Дуже бажаю!
# Вакуу поганий. Дуже поганий! Архітектор звільнить тебе?
# [pl] Życzę wolności!! Mocno życzę!
# Vakuu zły. Bardzo zły! Architekt cię uwolnił?
# [ru] Хочу, чтобы ты быть свободен! Хочу очень!
# Вакуу плохой. Очень плохой! Архитектор освободить?
msgctxt "ancients.json:OROBAS.talk.IRONCLAD.2-0.ancient"
msgid "Wishing you freedom!! Wishing hard!\n"
"Vakuu bad. Very bad! Architect free you?"
msgstr "Жадаю табе свабоды!! Моцна жадаю!\n"
"Вакуу дрэнны. Вельмі дрэнны! Архітэктар вызваліць?"

# [ua] Мертва?! Не мертва! Навіщо маріонетка? Велика рука!!
# [pl] Nie żyje?! Żyje! Czemu marionetka? Duża dłoń!!
# [ru] Мертвая?! Не мертвая! Почему кукла? Большая рука!
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.0-0.ancient"
msgid "Dead?! Not dead! Why puppet? Big hand!!"
msgstr "Мёртвая?! Не мёртвая! Чаму марыянетка? Вялікая рука!!"

# [ua] Говорити
# [pl] Rozmawiaj
# [ru] Говорить
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.0-0.next"
msgid "Talk"
msgstr "Паразмаўляць"

# [ua] Я не маріонетка. Є людина, яку я мушу вбити.
# Що ти можеш для мене зробити?
# [pl] Nie jestem żadną marionetką. Muszę zabić pewnego człowieka.
# Pomożesz mi?
# [ru] Я не кукла. Мне нужно кое-кого убить.
# Что можешь мне предложить?
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.0-1.char"
msgid "I’m no puppet. There’s a man I must kill.\n"
"What can you do for me?"
msgstr "Я не марыянетка. Я мушу сяго-таго забіць.\n"
"Што ты можаш для мяне зрабіць?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Вбивати погано!! Візьми краще це!
# [pl] Zabijanie złe!! Lepiej weź to!
# [ru] Убивать плохо! Бери вот!
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.0-2.ancient"
msgid "Killing bad!! Take this instead!"
msgstr "Забіваць дрэнна!! Вазьмі вось гэта!"

# [ua] Не мертва! Гарні дарунки для тебе!! Насильство погано.
# [pl] Niemartwa! Dobre dary dla ciebie!! Przemoc zła.
# [ru] Не мертвая! Дарить тебе хорошее! Жестокость плохо.
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.1-0r.ancient"
msgid "Not dead one! Good gifts for you!! Violence bad."
msgstr "Не мёртвая! Дам табе падаруначак!! Але гвалт дрэнна."

# [ua] Без насильства! Збирай блискуче замість цього... Блискуче!!
# [pl] Stop przemocy! Lepiej zbierać świecidełka... Świecidełka!!
# [ru] Насилие нет! Лучше собирать… Собирать хорошее!
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.2-0.ancient"
msgid "No violence! Collect shiny instead... Shiny!!"
msgstr "Без гвалту! Лепш вазьмі бліскотку... Яна бліскучая!!"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Мій похід закінчиться лише коли Архітектора не стане.
# Насильство неминуче.
# [pl] Moja misja skończy się dopiero wtedy, gdy Architekta już nie będzie.
# Przemoc jest nieunikniona.
# [ru] Мое предназначение исполнится только со смертью Архитектора.
# Насилие неизбежно.
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.2-1.char"
msgid "My quest will only end when the Architect is no more.\n"
"Violence is inevitable."
msgstr "Мае пошукі скончацца толькі тады, калі Архітэктара больш не будзе.\n"
"Гвалт непазбежны."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Архітектор не поганий! Може поговорити? Розмова добре!! Дуже добре!
# [pl] Architekt nie zły! Może rozmowa? Rozmowa dobra!! Bardzo dobra!
# [ru] Архитектор не плохой! Поговорить? Говорить хорошо! Очень хорошо!
msgctxt "ancients.json:OROBAS.talk.NECROBINDER.2-2.ancient"
msgid "Architect not bad! Maybe talk? Talking good!! Very good!"
msgstr "Архітэктар не дрэнны! Можа, пагаворым? Размова добрая!! Вельмі добрая!"

# [ua] Мандрівник! З космосу!? Звідки в космосі?
# Як з космосу? Гостра голова! Маленькі друзі!!
# [pl] Podróżnik! Z kosmosu!? Gdzie w kosmosie?
# Jak z kosmosu? Szpiczastogłowy! Mali przyjaciele!!
# [ru] Путе-шест-венник! Из космоса?! Где из космоса?
# Как из космоса? Острая голова! Маленькие друзья!
msgctxt "ancients.json:OROBAS.talk.REGENT.0-0.ancient"
msgid "Traveller! From space!? Where in space?\n"
"How from space? Pointy head! Little friends!!"
msgstr "Падарожнік! З космасу!? Адкуль у космасе?\n"
"Як з космасу? Вострая галава! Маленькія сябры!!"

# [ua] Розповісти
# [pl] Ugość
# [ru] Представиться
msgctxt "ancients.json:OROBAS.talk.REGENT.0-0.next"
msgid "Regale"
msgstr "Прадставіцца"

# [ua] [i][font_size=22]Регент монологізує годинами.[/font_size][/i]
# [pl] [i][font_size=22]Monarcha wygłasza kilkugodzinny
# monolog.[/font_size][/i]
# [ru] [i][font_size=22]Наследник заводит многочасовой
# монолог.[/font_size][/i]
msgctxt "ancients.json:OROBAS.talk.REGENT.0-1.char"
msgid "[i][font_size=22]The Regent monologues for hours.[/font_size][/i]"
msgstr "[i][font_size=22]Рэгент заводзіць шматгадзінны маналог.[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:OROBAS.talk.REGENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Захопливо! Вражаюче!! Ще! Ще!!!
# [pl] Ekscytujące! Imponujące!! Więcej! Więcej!!
# [ru] Интересно! Невероятно! Еще! Еще!
msgctxt "ancients.json:OROBAS.talk.REGENT.0-2.ancient"
msgid "Exciting! Impressive!! More! More!!!"
msgstr "Захапляльна! Уражвае!! Больш! Больш!!!"

# [ua] Більше історій! Знайшов для тебе ось це!
# Тепер розкажи ще!!
# [pl] Więcej historii! Znalazłem to dla ciebie!
# Teraz opowiedz więcej historii!!
# [ru] Говорить истории! Бери вот!
# Теперь говорить истории!
msgctxt "ancients.json:OROBAS.talk.REGENT.1-0r.ancient"
msgid "More stories! Found these for you!\n"
"Now tell more story!!"
msgstr "Больш гісторый! Знайшоў для цябе вось гэта!\n"
"Цяпер раскажы яшчэ гісторыю!!"

# [ua] Мій фанат номер один! Оробас, друже!
# Як приємно бачити, що ти ще живий!
# [pl] Mój największy fan! Orobas, przyjacielu!
# Wspaniale widzieć cię wciąż żywego!
# [ru] Мой самый преданный поклонник! Оробас, дружище!
# Рад видеть тебя в добром здравии!
msgctxt "ancients.json:OROBAS.talk.REGENT.2-0.char"
msgid "My number one fan! Orobas, friend!\n"
"Lovely to see you’re still alive!"
msgstr "Мой фанат нумар адзін! Аробас, дружа!\n"
"Прыемна бачыць, што ты яшчэ жывы!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:OROBAS.talk.REGENT.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Історії?!
# [pl] Historie?!
# [ru] Истории?!
msgctxt "ancients.json:OROBAS.talk.REGENT.2-1.ancient"
msgid "Stories?!"
msgstr "Гісторыі?!"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:OROBAS.talk.REGENT.2-1.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Звісно, звісно... але чи знайшов ти для мене якісь дрібнички?
# [pl] Tak, tak, oczywiście... Ale czy znalazłeś dla mnie jakieś świecidełka?
# [ru] Конечно, само собой… А ты мне что взамен?
msgctxt "ancients.json:OROBAS.talk.REGENT.2-2.char"
msgid "Of course of course... but have you found any trinkets for me?"
msgstr "Вядома, вядома... але ці знайшоў ты для мяне якія-небудзь бірулькі?"

# [ua] Зараза...? [jitter]СКВЕРНА!?[/jitter] Бери й іди!!
# [pl] Infekcja...? [jitter]ZARAZA!?[/jitter] Weź to i odejdź!!
# [ru] Инфекция?… [jitter]ГНИЛЬ?![/jitter] Бери и уходи!
msgctxt "ancients.json:OROBAS.talk.SILENT.0-0.ancient"
msgid "Infection...? [jitter]BLIGHT!?[/jitter] Take and go!!"
msgstr "Інфекцыя...? [jitter]ПОШАСЦЬ?![/jitter] Бяры і сыходзь!!"

# [ua] Мовчати
# [pl] Nic nie mów
# [ru] Промолчать
msgctxt "ancients.json:OROBAS.talk.SILENT.0-0.next"
msgid "Say Nothing"
msgstr "Прамаўчаць"

# [ua] [sine]...[/sine]
# [pl] [sine]...[/sine]
# [ru] [sine]...[/sine]
msgctxt "ancients.json:OROBAS.talk.SILENT.0-1.char"
msgid "[sine]...[/sine]"
msgstr "[sine]...[/sine]"

# [ua] Не заразна? Дуже помираєш? Архітектор допоможе?
# [pl] Niezaraźliwe? Bardzo umierasz? Architekt ci pomógł?
# [ru] Не заразить? Очень смерть? Архитектор поможет?
msgctxt "ancients.json:OROBAS.talk.SILENT.1-0r.ancient"
msgid "Not contagious? Very dying? Architect help you?"
msgstr "Не заразны? Вельмі паміраеш? Архітэктар табе дапаможа?"

# [ua] Де сестри? Страшні злі сестри!
# Будь доброю! Не будь як сестри!!
# [pl] Gdzie siostry? Straszne niemiłe siostry!
# Bądź dobrą osobą! Nie bądź jak siostry!!
# [ru] Где сестры? Сестры страшные, злые!
# Быть хорошая! Не быть как сестры!
msgctxt "ancients.json:OROBAS.talk.SILENT.2-0.ancient"
msgid "Where sisters? Scary mean sisters!\n"
"Be good person! Don’t be like sisters!!"
msgstr "Дзе сёстры? Страшныя, злыя сёстры!\n"
"Будзь добрай! Не будзь як сёстры!!"

# [ua] Маріонетка маріонетка!! Аж сюди добралася?! Бери ось це, бери бери!
# [pl] Marionetka, marionetka!! Aż tak wysoko?! Weź to, weź, weź!
# [ru] Кукла, кукла! Так высоко?! Возьми, возьми!
msgctxt "ancients.json:OROBAS.talk.firstVisitEver.0-0.ancient"
msgid "Puppet puppet!! All the way up here?! Take these, take take!"
msgstr "Лялька, лялька! Так высока?! Бяры, бяры!"

# [ua] Оробас
# [pl] Orobas
# [ru] Оробас
msgctxt "ancients.json:OROBAS.title"
msgid "Orobas"
msgstr "Аробас"

# [ua] Дракон, що тане
# [pl] Topniejący Smok
# [ru] Тающий дракон
msgctxt "ancients.json:PAEL.epithet"
msgid "Melting Dragon"
msgstr "Цмок, што растае"

# [ua] [thinky_dots]Ласкаво просимо назад, друже. Нехай моя плоть допоможе
# тобі...[/thinky_dots]
# [pl] [thinky_dots]Witaj ponownie, przyjacielu. Moje ciało może tobie
# pomóc...[/thinky_dots]
# [ru] [thinky_dots]Добро пожаловать, друг. Пусть моя плоть принесет тебе
# пользу…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.ANY.0-0r.ancient"
msgid "[thinky_dots]Welcome back friend. Let my flesh help you...[/thinky_dots]"
msgstr "[thinky_dots]Сардэчна запрашаю, сябар. Няхай мая плоць паможа табе...[/thinky_dots]"

# [ua] [i][font_size=22]Паель спить. Його хропіння трясе
# кімнату.[/font_size][/i]
# [pl] [i][font_size=22]Pael śpi. Całe pomieszczenie trzęsie się od jego
# chrapania.[/font_size][/i]
# [ru] [i][font_size=22]Паэль в глубоком сне. От его храпа содрогаются
# стены.[/font_size][/i]
msgctxt "ancients.json:PAEL.talk.ANY.1-0r.ancient"
msgid "[i][font_size=22]Pael is sleeping. His snoring shakes the room.[/font_size][/i]"
msgstr "[i][font_size=22]Паэль спіць. Ад яго храпу дрыжаць сцены пакою.[/font_size][/i]"

# [ua] [thinky_dots]Знедолений автоматоне, шукаєш свого друга?
# Дозволь допомогти...[/thinky_dots]
# [pl] [thinky_dots]Szukasz swojego przyjaciela, zakłopotany automatonie?
# Pomogę ci...[/thinky_dots]
# [ru] [thinky_dots]Безутешный агрегат, ты ищешь друга?
# Разреши помочь…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.DEFECT.0-0.ancient"
msgid "[thinky_dots]Troubled automaton, looking for your friend?\n"
"Let me help...[/thinky_dots]"
msgstr "[thinky_dots]Засмучаны аўтаматон, шукаеш свайго сябра?\n"
"Дазволь дапамагчы...[/thinky_dots]"

# [ua] [thinky_dots]Чи сняться конструктам сни?
# Дивись і наслідуй мене...[/thinky_dots]
# [pl] [thinky_dots]Czy konstrukty śnią?
# Patrz i ucz się...[/thinky_dots]
# [ru] [thinky_dots]Снятся ли агрегатам сны?
# Повторяй за мной…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.DEFECT.1-0r.ancient"
msgid "[thinky_dots]Do constructs dream?\n"
"Watch and copy me...[/thinky_dots]"
msgstr "[thinky_dots]Ці механізмы бачаць сны?\n"
"Глядзі і паўтарай за мною...[/thinky_dots]"

# [ua] [thinky_dots]Мені наснився твій друг...
# Отець може відновити [aqua]Ваду[/aqua]...[/thinky_dots]
# [pl] [thinky_dots]Śnił mi się twój przyjaciel...
# Ojciec może przywrócić [aqua]Usterkę[/aqua]...[/thinky_dots]
# [ru] [thinky_dots]Я видел твоего друга во сне…
# Отец может восстановить [aqua]Изъяна[/aqua]…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.DEFECT.2-0.ancient"
msgid "[thinky_dots]I dreamt of your friend...\n"
"Father can restore [aqua]Flaw[/aqua]...[/thinky_dots]"
msgstr "[thinky_dots]Мне сніўся твой сябар...\n"
"Бацька можа аднавіць [aqua]Загану[/aqua]...[/thinky_dots]"

# [ua] [thinky_dots]У тобі стільки люті. Візьми від мене і знайди
# спокій...[/thinky_dots]
# [pl] [thinky_dots]Masz w sobie tyle złości. Weź cząstkę mnie i zaznaj trochę
# spokoju...[/thinky_dots]
# [ru] [thinky_dots]В тебе сокрыт великий гнев. Позволь помочь тебе обрести
# покой…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.IRONCLAD.0-0.ancient"
msgid "[thinky_dots]You contain such rage. Take from me and find some peace...[/thinky_dots]"
msgstr "[thinky_dots]У табе столькі гневу. Вазьмі частку мяне і спазнай крыху спакою...[/thinky_dots]"

# [ua] [thinky_dots]Ти пам'ятаєш, як це — бачити сни?
# Добре спати...[/thinky_dots]
# [pl] [thinky_dots]Czy pamiętasz jeszcze, jak to jest śnić?
# Dobrze jest spać...[/thinky_dots]
# [ru] [thinky_dots]Помнишь ли ты, каково это: видеть сны?
# Хорошо поспать — благое дело…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.IRONCLAD.1-0r.ancient"
msgid "[thinky_dots]Do you remember how it feels to dream?\n"
"It is good to sleep...[/thinky_dots]"
msgstr "[thinky_dots]Ці памятаеш ты, як гэта — бачыць сны?\n"
"Спаць — добра...[/thinky_dots]"

# [ua] [thinky_dots]Ти мусиш приборкати своє полум'я.
# Отець може звільнити тебе...[/thinky_dots]
# [pl] [thinky_dots]Musisz stłumić w sobie ogień.
# Ojciec może cię uwolnić...[/thinky_dots]
# [ru] [thinky_dots]Ты должен укротить свое пламя.
# Отец может освободить тебя…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.IRONCLAD.2-0.ancient"
msgid "[thinky_dots]You must quell your flames.\n"
"Father can free you...[/thinky_dots]"
msgstr "[thinky_dots]Ты мусіш сцішыць сваё полымя.\n"
"Бацька можа цябе вызваліць...[/thinky_dots]"

# [ua] [thinky_dots]Яка злоба фарбує твоє серце.[/thinky_dots]
# [pl] [thinky_dots]Tyle podłości w twoim sercu.[/thinky_dots]
# [ru] [thinky_dots]Слепая ненависть очерняет твою душу.[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.NECROBINDER.0-0.ancient"
msgid "[thinky_dots]Such malice paints your heart.[/thinky_dots]"
msgstr "[thinky_dots]Сляпая злосць пляміць тваё сэрца.[/thinky_dots]"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:PAEL.talk.NECROBINDER.0-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Ми ділили б ту саму фарбу, якби ти знав, що зі мною сталося.
# [pl] Gdybyś wiedział, co mnie spotkało, stanąłbyś po mojej stronie.
# [ru] Ты бы не назвал ее слепой, если бы видел случившееся моими глазами.
msgctxt "ancients.json:PAEL.talk.NECROBINDER.0-1.char"
msgid "We would share the same paint if you knew what’s befallen me."
msgstr "Ты б зразумеў, наколькі мы падобныя, калі б ведаў, што выпала на маю долю."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:PAEL.talk.NECROBINDER.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [thinky_dots]На твоєму шляху немає спокою.
# Візьми частину мене, щоб полегшити тягар...[/thinky_dots]
# [pl] [thinky_dots]Nie zaznasz spokoju na swojej ścieżce.
# Cząstka mnie może pomóc złagodzić twój ciężar...[/thinky_dots]
# [ru] [thinky_dots]На твоем пути нет умиротворения.
# Возьми часть меня, облегчи свою ношу…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.NECROBINDER.0-2.ancient"
msgid "[thinky_dots]There is no peace on your path.\n"
"Take a part of me to ease your burdens...[/thinky_dots]"
msgstr "[thinky_dots]Твая дарога не вядзе да спакою.\n"
"Вазьмі частку мяне, каб палегчыць сваю ношу...[/thinky_dots]"

# [ua] [thinky_dots]Та, що з Рукою, повертається.
# Болісні спогади. Візьми мою силу й іди...[/thinky_dots]
# [pl] [thinky_dots]Martwa Dłoń powraca.
# Bolesne wspomnienia. Zaczerpnij mojej siły i odejdź...[/thinky_dots]
# [ru] [thinky_dots]Владычица костяной руки вернулась.
# Горькие воспоминания. Возьми мою силу и уходи…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.NECROBINDER.1-0r.ancient"
msgid "[thinky_dots]The one with the Hand returns.\n"
"Painful memories. Take my strength and leave...[/thinky_dots]"
msgstr "[thinky_dots]Рукастая вяртаецца.\n"
"І прыносіць балючыя ўспаміны. Бяры маю сілу і ідзі...[/thinky_dots]"

# [ua] [thinky_dots]Вбивство [red]Отця[/red] не принесе спокою.[/thinky_dots]
# [pl] [thinky_dots]Zabicie [red]Ojca[/red] nie przyniesie
# pokoju.[/thinky_dots]
# [ru] [thinky_dots]Убив [red]Отца[/red], ты не обретешь покой.[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.NECROBINDER.2-0.ancient"
msgid "[thinky_dots]Killing [red]Father[/red] won’t bring peace.[/thinky_dots]"
msgstr "[thinky_dots]Забойства [red]Бацькі[/red] не прынясе спакою.[/thinky_dots]"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:PAEL.talk.NECROBINDER.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Ти називаєш цю [jitter]річ[/jitter] своїм батьком!?
# [pl] Nazywasz to [jitter]coś[/jitter] swoim ojcem!?
# [ru] Ты называешь эту [jitter]тварь[/jitter] своим отцом?!
msgctxt "ancients.json:PAEL.talk.NECROBINDER.2-1.char"
msgid "You call that [jitter]thing[/jitter] your father!?"
msgstr "Ты называеш таго [jitter]вырадка[/jitter] сваім бацькам!?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:PAEL.talk.NECROBINDER.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [thinky_dots]Ми не обираємо свою родину...[/thinky_dots]
# [pl] [thinky_dots]Rodziny się nie wybiera...[/thinky_dots]
# [ru] [thinky_dots]Семью не выбирают…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.NECROBINDER.2-2.ancient"
msgid "[thinky_dots]We do not choose our family...[/thinky_dots]"
msgstr "[thinky_dots]Не мы выбіраем сям'ю...[/thinky_dots]"

# [ua] Привіт! Я — Регент.
# Привііііт?? [jitter]ПРИВІТ!?[/jitter]
# [pl] Witaj! Jestem Dziedzicem Gwiezdnego Tronu.
# Haaalooo?? [jitter]HALO!?[/jitter]
# [ru] Приветствую! Я — Наследник.
# Эй! [jitter]АУ![/jitter]
msgctxt "ancients.json:PAEL.talk.REGENT.0-0.char"
msgid "Hello! I am the Regent.\n"
"Hellooo?? [jitter]HELLO!?[/jitter]"
msgstr "Вітаю! Я — Рэгент.\n"
"Віта-а-а?? [jitter]ГЭЙ!?[/jitter]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:PAEL.talk.REGENT.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [thinky_dots]Тихіше.
# Візьми частину мене і йди своєю дорогою...[/thinky_dots]
# [pl] [thinky_dots]Ciszej.
# Weź cząstkę mnie i ruszaj dalej...[/thinky_dots]
# [ru] [thinky_dots]Угомонись.
# Возьми часть меня — и можешь идти…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.REGENT.0-1.ancient"
msgid "[thinky_dots]Quiet down now.\n"
"Take a part of me and be on your way...[/thinky_dots]"
msgstr "[thinky_dots]Супакойся.\n"
"Вазьмі частку мяне і ідзі сабе...[/thinky_dots]"

# [ua] Я повернувся! А, ти спиш, звісно.
# Подивимось тут...
# [pl] Powróciłem! Ach, oczywiście, że śpisz.
# Zobaczmy...
# [ru] Я вернулся! Ах, как всегда дрыхнешь.
# Так, посмотрим…
msgctxt "ancients.json:PAEL.talk.REGENT.1-0r.char"
msgid "I’m back! Ah, you’re asleep of course.\n"
"Let’s see here..."
msgstr "Я вярнуўся! А, ты, вядома, спіш.\n"
"Паглядзім..."

# [ua] Чому ти роздаєш себе?
# [pl] Dlaczego tak łatwo rozdajesz swoje części ciała?
# [ru] Зачем ты раздаешь свою плоть?
msgctxt "ancients.json:PAEL.talk.REGENT.2-0.char"
msgid "Why do you give yourself away?"
msgstr "Навошта ты аддаеш часткі сябе?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:PAEL.talk.REGENT.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [thinky_dots]Чому б не давати, коли в мене надлишок
# плоті?[/thinky_dots]
# [pl] [thinky_dots]Czemu by nie dawać, skoro mam nadmiar?[/thinky_dots]
# [ru] [thinky_dots]Моя плоть в изобилии. Грех не поделиться.[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.REGENT.2-1.ancient"
msgid "[thinky_dots]Why not give when I have an abundance of flesh?[/thinky_dots]"
msgstr "[thinky_dots]Чаму б не аддаваць, калі ў мяне не бракуе плоці?[/thinky_dots]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:PAEL.talk.REGENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [thinky_dots]Коли ти повернешся, я відновлюся наново.
# Ось що дає сон...[/thinky_dots]
# [pl] [thinky_dots]Gdy powrócisz, będę odnowiony.
# Tak właśnie działa na mnie sen...[/thinky_dots]
# [ru] [thinky_dots]Когда ты вернешься, я вновь буду невредим.
# Вот чем важен сон…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.REGENT.2-2.ancient"
msgid "[thinky_dots]When you return, I will be replenished anew.\n"
"That’s what sleep does...[/thinky_dots]"
msgstr "[thinky_dots]Калі ты вернешся, я зноў буду абноўлены.\n"
"Вось чаму так важны сон…[/thinky_dots]"

# [ua] [thinky_dots]Кровожерна істото, тут не потрібне насильство.
# Візьми частину мене і знайди спокій...[/thinky_dots]
# [pl] [thinky_dots]Przemoc jest tu zbędna, mordercza istoto.
# Weź cząstkę mnie i zaznaj spokoju...[/thinky_dots]
# [ru] [thinky_dots]Кровожадное создание! Здесь нет нужды в насилии.
# Возьми часть меня и обрети покой…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.SILENT.0-0.ancient"
msgid "[thinky_dots]Murderous creature, no need for violence here.\n"
"Have part of me and find peace...[/thinky_dots]"
msgstr "[thinky_dots]Крыважэрная істота, тут няма патрэбы ў гвалце.\n"
"Вазьмі частку мяне і знайдзі спакой...[/thinky_dots]"

# [ua] [thinky_dots]Полюєш на трофеї? Гаразд, візьми частину мене...
# Що б не дарувало тобі втіху...[/thinky_dots]
# [pl] [thinky_dots]Szukasz trofeum? Oczywiście, weź cząstkę mnie...
# Cokolwiek przyniesie ci komfort...[/thinky_dots]
# [ru] [thinky_dots]Ищешь себе трофей? Хорошо, возьми часть меня…
# Надеюсь, тебе станет от этого легче…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.SILENT.1-0r.ancient"
msgid "[thinky_dots]Trophy hunting? Sure, take a part of me...\n"
"Whatever grants you comfort...[/thinky_dots]"
msgstr "[thinky_dots]Палюеш на трафеі? Вядома, вазьмі частку мяне...\n"
"Калі гэта прынясе табе спакой...[/thinky_dots]"

# [ua] [thinky_dots]Ти отруїла мене...?
# Що це буд...? зЗЗзз...[/thinky_dots]
# [pl] [thinky_dots]Otrułaś mnie...?
# Jaki to ma...? zZZzz...[/thinky_dots]
# [ru] [thinky_dots]Ты отравила меня…
# Что еще за… Хр-р-р…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.SILENT.2-0.ancient"
msgid "[thinky_dots]You’ve poisoned me...?\n"
"What is this going to...? zZZzz...[/thinky_dots]"
msgstr "[thinky_dots]Ты мяне атруціла...?\n"
"Які ў гэтым сэнс...? z-Z-Z-z-z...[/thinky_dots]"

# [ua] [thinky_dots]Маріонетка прибула?
# Чи можеш перевірити Отця? Я надто втомлений...[/thinky_dots]
# [pl] [thinky_dots]Marionetka przybyła?
# Sprawdzisz, co u Ojca? Jestem zbyt zmęczony...[/thinky_dots]
# [ru] [thinky_dots]Марионетка? Здесь?
# Можешь проведать Отца? Я слишком устал…[/thinky_dots]
msgctxt "ancients.json:PAEL.talk.firstVisitEver.0-0.ancient"
msgid "[thinky_dots]A puppet has arrived?\n"
"Can you check on Father? I’m too tired...[/thinky_dots]"
msgstr "[thinky_dots]Марыянетка прыбыла?\n"
"А можаш па дарозе зазірнуць да Бацькі? Я надта стомлены...[/thinky_dots]"

# [ua] Паель
# [pl] Pael
# [ru] Паэль
msgctxt "ancients.json:PAEL.title"
msgid "Pael"
msgstr "Паэль"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Продолжить
msgctxt "ancients.json:PROCEED.title"
msgid "Proceed"
msgstr "Працягнуць"

# [ua] Король Хімер
# [pl] Chimera Królewska
# [ru] Король-химера
msgctxt "ancients.json:TANX.epithet"
msgid "Khimera King"
msgstr "Кароль хімер"

# [ua] СТАВАЙ СИЛЬНІШИМ, ЩОБ МИ МОГЛИ БИТИСЯ!!!
# [pl] ROŚNIJ W SIŁĘ, ŻEBYŚMY MOGLI POWALCZYĆ!!!
# [ru] СТАНЬ СИЛЬНЕЕ, ЧТОБЫ МЫ МОГЛИ СРАЗИТЬСЯ!
msgctxt "ancients.json:TANX.talk.ANY.0-0r.ancient"
msgid "GROW STRONGER SO WE CAN FIGHT!!!"
msgstr "СТАНЬ МАЦНЕЙ, КАБ МЫ МАГЛІ БІЦЦА!!!"

# [ua] ЗБРОЇ БАГАТО НЕ БУВАЄ!!
# [pl] NIE MOŻNA MIEĆ ZA DUŻO BRONI!!
# [ru] ОРУЖИЯ МНОГО НЕ БЫВАЕТ!
msgctxt "ancients.json:TANX.talk.ANY.1-0r.ancient"
msgid "YOU CAN NEVER HAVE TOO MANY WEAPONS!!"
msgstr "ЗБРОІ НІКОЛІ НЕ БЫВАЕ ЗАШМАТ!!"

# [ua] КОНСТРУКТЕ! БЕЗ ЗБРОЇ!? ТРИМАЙ ЦЕ!
# [pl] KONSTRUKT! BEZ BRONI!? WEŹ TO!
# [ru] АГРЕГАТ! БЕЗ ОРУЖИЯ?! ДЕРЖИ!
msgctxt "ancients.json:TANX.talk.DEFECT.0-0.ancient"
msgid "CONSTRUCT! NO WEAPONS!? HAVE THIS!"
msgstr "МЕХАНІЗМ! БЕЗ ЗБРОІ?! ТРЫМАЙ!"

# [ua] СФЕРИ — ЦЕ НЕ ЗБРОЯ!!
# [pl] SFERY TO NIE BROŃ!!
# [ru] СФЕРЫ — НЕ ОРУЖИЕ!
msgctxt "ancients.json:TANX.talk.DEFECT.1-0r.ancient"
msgid "ORBS ARE NOT WEAPONS!!"
msgstr "СФЕРЫ — НЕ ЗБРОЯ!!"

# [ua] БИЙСЯ ЗІ МНОЮ, ДЕФЕКТЕ!!
# [pl] DEFEKCIE, SZYKUJ SIĘ DO WALKI!!
# [ru] СРАЗИСЬ СО МНОЙ, ДЕФЕКТ!
msgctxt "ancients.json:TANX.talk.DEFECT.2-0.ancient"
msgid "FIGHT ME, DEFECT!!"
msgstr "БІСЯ СА МНОЮ, ДЭФЕКТ!!"

# [ua] Битися
# [pl] Walcz
# [ru] Сразиться
msgctxt "ancients.json:TANX.talk.DEFECT.2-0.next"
msgid "Fight"
msgstr "Бітва"

# [ua] [i][font_size=22]Дефект відважно б'ється.[/font_size][/i]
# [pl] [i][font_size=22]Defekt walczy dzielnie.[/font_size][/i]
# [ru] [i][font_size=22]Дефект доблестно сражается.[/font_size][/i]
msgctxt "ancients.json:TANX.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]The Defect valiantly fights.[/font_size][/i]"
msgstr "[i][font_size=22]Дэфект мужна змагаецца.[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.DEFECT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] СФЕРИ [jitter]Є[/jitter] ЗБРОЄЮ!?
# [pl] SFERY TO [jitter]JEDNAK[/jitter] BROŃ!?
# [ru] СФЕРЫ — [jitter]ОРУЖИЕ[/jitter]?!
msgctxt "ancients.json:TANX.talk.DEFECT.2-2.ancient"
msgid "ORBS [jitter]ARE[/jitter] WEAPONS!?"
msgstr "СФЕРЫ — [jitter]ЗБРОЯ[/jitter]?!"

# [ua] ВРАЖАЮЧИЙ МЕЧ, ВОЇНЕ! ТОБІ ПОТРІБНО БІЛЬШЕ ЗБРОЇ!
# [pl] IMPONUJĄCY MIECZ, WOJOWNIKU! PRZYDA CI SIĘ WIĘCEJ BRONI!
# [ru] ТВОЙ МЕЧ ВПЕЧАТЛЯЕТ, ВОИН! ВОЗЬМИ ЕЩЕ ОРУЖИЯ!
msgctxt "ancients.json:TANX.talk.IRONCLAD.0-0.ancient"
msgid "IMPRESSIVE SWORD, WARRIOR! YOU CAN USE MORE WEAPONS!"
msgstr "САМАВІТЫ МЕЧ, ВАЯР! АЛЕ ТЫ МОЖАШ ЗАЙМЕЦЬ ЯШЧЭ БОЛЬШ ЗБРОІ!"

# [ua] ЗБРОЯ ДЛЯ ВОЇНА! ХАПАЙ ЗБРОЮ! ДАВАЙ БИТИСЯ!
# [pl] BRONIE DLA WOJOWNIKA! WEŹ BROŃ! WALCZMY!
# [ru] К ОРУЖИЮ, ВОИН! СРАЗИМСЯ!
msgctxt "ancients.json:TANX.talk.IRONCLAD.1-0r.ancient"
msgid "WEAPONS FOR THE WARRIOR! GRAB A WEAPON! LET’S FIGHT!"
msgstr "ЗБРОЯ ДЛЯ ВАЯРА! БЯРЫ ЗБРОЮ! БУДЗЕМ БІЦЦА!"

# [ua] БИЙСЯ ЗІ МНОЮ, ЗАЛІЗНОЛАДЕ!!
# [pl] PANCERNIKU, WYZYWAM CIĘ NA POJEDYNEK!!
# [ru] СРАЗИСЬ СО МНОЙ, ЛАТОНОСЕЦ!
msgctxt "ancients.json:TANX.talk.IRONCLAD.2-0.ancient"
msgid "FIGHT ME, IRONCLAD!!"
msgstr "БІСЯ СА МНОЮ, БРАНЯНОСЕЦ!!"

# [ua] Битися
# [pl] Walcz
# [ru] Сразиться
msgctxt "ancients.json:TANX.talk.IRONCLAD.2-0.next"
msgid "Fight"
msgstr "Бітва"

# [ua] [i][font_size=22]Залізнолад б'ється з Танксом.[/font_size][/i]
# [pl] [i][font_size=22]Pancernik walczy z Tanxem.[/font_size][/i]
# [ru] [i][font_size=22]Латоносец сражается с Танксом.[/font_size][/i]
msgctxt "ancients.json:TANX.talk.IRONCLAD.2-1.char"
msgid "[i][font_size=22]The Ironclad fights Tanx.[/font_size][/i]"
msgstr "[i][font_size=22]Браняносец змагаецца з Танксам.[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.IRONCLAD.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] ТАААК!! МОГУТНЯ БИТВА, ТРИМАЙ ЗБРОЮ!
# [pl] TAAAK!! POTĘŻNA WALKA, WEŹ BROŃ!
# [ru] ДА-А! МОГУЧАЯ СХВАТКА! К ОРУЖИЮ!
msgctxt "ancients.json:TANX.talk.IRONCLAD.2-2.ancient"
msgid "YEEES!! MIGHTY FIGHT, TAKE WEAPON!"
msgstr "ААА!! ДОБЛЕСНАЯ БІТВА, БЯРЫ ЗБРОЮ!"

# [ua] ЯКА МОГУТНЯ КОСА!
# [pl] ALE POTĘŻNA KOSA!
# [ru] МОГУЧАЯ КОСА!
msgctxt "ancients.json:TANX.talk.NECROBINDER.0-0.ancient"
msgid "WHAT A MIGHTY SCYTHE!"
msgstr "ЯКАЯ МАГУТНАЯ КАСА!"

# [ua] Говорити
# [pl] Rozmawiaj
# [ru] Говорить
msgctxt "ancients.json:TANX.talk.NECROBINDER.0-0.next"
msgid "Talk"
msgstr "Паразмаўляць"

# [ua] Так, вона спеціально створена для помсти.
# [pl] Prawda, wyostrzona specjalnie na zemstę.
# [ru] Да, она предназначена для возмездия.
msgctxt "ancients.json:TANX.talk.NECROBINDER.0-1.char"
msgid "Yes, it’s special-made for vengeance."
msgstr "Так, яна зроблена адмыслова для помсты."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.NECROBINDER.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] РУЦІ ТЕЖ ПОТРІБНА ЗБРОЯ!?
# [pl] CZY DŁOŃ POTRZEBUJE BRONI!?
# [ru] РУКЕ НУЖНО ОРУЖИЕ?!
msgctxt "ancients.json:TANX.talk.NECROBINDER.0-2.ancient"
msgid "DOES THE HAND NEED A WEAPON!?"
msgstr "ЦІ ПАТРЭБНА РУЦЭ ЗБРОЯ!?"

# [ua] БИЙСЯ ЗІ МНОЮ, ОСТІ!!
# [pl] KOSTEK, BIJEMY SIĘ!!
# [ru] СРАЗИСЬ СО МНОЙ, КОСТЯ!
msgctxt "ancients.json:TANX.talk.NECROBINDER.1-0r.ancient"
msgid "FIGHT ME, OSTY!!"
msgstr "ПАБІСЯ СА МНОЙ, КОСТУСЬ!!"

# [ua] БИЙСЯ ЗІ МНОЮ, НЕКРОЗВ'ЯЗУЮЧА!!
# [pl] NEKROMANTKO, STAŃ DO WALKI!!
# [ru] СРАЗИСЬ СО МНОЙ, ПРИЗЫВАЮЩАЯ!
msgctxt "ancients.json:TANX.talk.NECROBINDER.2-0.ancient"
msgid "FIGHT ME, NECROBINDER!!"
msgstr "БІСЯ СА МНОЮ, ЦЯМНАРКА!!"

# [ua] Битися
# [pl] Walcz
# [ru] Сразиться
msgctxt "ancients.json:TANX.talk.NECROBINDER.2-0.next"
msgid "Fight"
msgstr "Бітва"

# [ua] [i][font_size=22]Некрозв'язуюча та Ості борються з
# Танксом.[/font_size][/i]
# [pl] [i][font_size=22]Nekromantka i Kostek biją się z
# Tanxem.[/font_size][/i]
# [ru] [i][font_size=22]Призывающая и Костя сражаются с
# Танксом.[/font_size][/i]
msgctxt "ancients.json:TANX.talk.NECROBINDER.2-1.char"
msgid "[i][font_size=22]The Necrobinder and Osty scuffle with Tanx.[/font_size][/i]"
msgstr "[i][font_size=22]Цямнарка і Костусь змагаюцца з Танксам.[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.NECROBINDER.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] МОГУТНЯ КОМАНДНА РОБОТА!! ТРИМАЙ ЗБРОЮ!
# [pl] POTĘŻNA WSPÓŁPRACA!! WEŹCIE BROŃ!
# [ru] МОГУЧИЕ НАПАРНИКИ! ДЕРЖИТЕ ОРУЖИЕ!
msgctxt "ancients.json:TANX.talk.NECROBINDER.2-2.ancient"
msgid "MIGHTY TEAMWORK!! HAVE A WEAPON!"
msgstr "МАГУТНАЯ КАМАНДА!! ТРЫМАЙЦЕ ЗБРОЮ!"

# [ua] ОРАНЖЕВИЙ!? ЯК ЦЯ ІСТОТА ОРАНЖЕВА!??
# [pl] POMARAŃCZOWY!? CZEMU JESTEŚ TAKI POMARAŃCZOWY!??
# [ru] ОРАНЖЕВЫЙ?! ПОЧЕМУ ТЫ ОРАНЖЕВЫЙ?!
msgctxt "ancients.json:TANX.talk.REGENT.0-0.ancient"
msgid "ORANGE!? HOW IS THIS BEING ORANGE!??"
msgstr "АРАНЖАВЫ!? ЧАМУ ТЫ АРАНЖАВЫ!??"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:TANX.talk.REGENT.0-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Усім відомо, що оранжевий — найблагородніший колір!
# [pl] Przecież wiadomo, że jest to najbardziej królewski kolor!
# [ru] Всем известно, что оранжевый — самый благородный цвет!
msgctxt "ancients.json:TANX.talk.REGENT.0-1.char"
msgid "All know that orange is the most regal color!"
msgstr "Усім вядома, што аранжавы — самы шляхетны колер!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.REGENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] НЕЙМОВІРНО! ТАКЕ МОГУТНЄ!!
# [pl] NIESAMOWITE! ALE POTĘGA!!
# [ru] И САМЫЙ МОГУЧИЙ!
msgctxt "ancients.json:TANX.talk.REGENT.0-2.ancient"
msgid "INCREDIBLE! SO MIGHTY!!"
msgstr "НЕЙМАВЕРНА! ТАК МАГУТНА!!"

# [ua] ОРАНЖЕВИЙ!! ОБИРАЙ МОГУТНЮ ЗБРОЮ!
# [pl] POMARAŃCZOWY!! WYBIERZ POTĘŻNĄ BROŃ!
# [ru] ОРАНЖЕВЫЙ! ВЫБИРАЙ МОГУЧЕЕ ОРУЖИЕ!
msgctxt "ancients.json:TANX.talk.REGENT.1-0r.ancient"
msgid "ORANGE ONE!! CHOOSE A MIGHTY WEAPON!"
msgstr "ГЭЙ, АРАНЖАВЫ!! ВЫБЕРЫ ЗБРОЮ, МАГУТНУЮ!"

# [ua] БИЙСЯ ЗІ МНОЮ, РЕГЕНТЕ!!
# [pl] MONARCHO, WALCZ ZE MNĄ!!
# [ru] СРАЗИСЬ СО МНОЙ, НАСЛЕДНИК!
msgctxt "ancients.json:TANX.talk.REGENT.2-0.ancient"
msgid "FIGHT ME, REGENT!!"
msgstr "БІСЯ СА МНОЮ, РЭГЕНТ!!"

# [ua] Відмовити
# [pl] Odmów
# [ru] Не сражаться
msgctxt "ancients.json:TANX.talk.REGENT.2-0.next"
msgid "Deny"
msgstr "Адмовіцца"

# [ua] Ні! Ми вже билися, коли я був тут минулого разу!
# [pl] Nie! Walczyliśmy ostatnim razem, kiedy tu byłem!
# [ru] Нет! Мы уже сражались в прошлый раз!
msgctxt "ancients.json:TANX.talk.REGENT.2-1.char"
msgid "No! We fought last time I was here!"
msgstr "Не! Мы ж змагаліся ў мінулы раз!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.REGENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] БИЙСЯ ЗІ МНОЮ ЗНОВУ!!
# [pl] JA CHCĘ JESZCZE RAZ!!
# [ru] СРАЗИСЬ ЕЩЕ РАЗ!
msgctxt "ancients.json:TANX.talk.REGENT.2-2.ancient"
msgid "FIGHT ME AGAIN!!"
msgstr "ПАБІСЯ ЯШЧЭ РАЗ!!"

# [ua] МИСЛИВИЦЯ! Я НАГОСТРЮ ТВІЙ КІГОТЬ!!
# [pl] ŁOWCZYNI! NAOSTRZĘ TWOJE SZPONY!!
# [ru] ХИЩНИЦА! Я ЗАТОЧУ ТВОИ КОГТИ!
msgctxt "ancients.json:TANX.talk.SILENT.0-0.ancient"
msgid "A HUNTRESS! I WILL SHARPEN YOUR CLAW!!"
msgstr "ПАЛЯЎНІЧАЯ! Я НАВАСТРУ ТВАЕ КІПЦЮРЫ!!"

# [ua] НАВІЩО КИНДЖАЛИ!! НЕМОГУТНІ!
# [pl] CZEMU SZTYLETY!! NIEPOTĘŻNE!!
# [ru] НОЖИ?! НОЖИ НЕ МОГУЧИЕ!
msgctxt "ancients.json:TANX.talk.SILENT.1-0r.ancient"
msgid "WHY DAGGERS!! UNMIGHTY!"
msgstr "ЧАМУ КІНЖАЛЫ!! ЯНЫ НЕМАГУТНЫЯ!"

# [ua] БИЙСЯ ЗІ МНОЮ, МОВЧАЗНА!!
# [pl] ZJAWO, STAŃ DO POJEDYNKU!!
# [ru] СРАЗИСЬ СО МНОЙ, БЕЗМОЛВНАЯ!
msgctxt "ancients.json:TANX.talk.SILENT.2-0.ancient"
msgid "FIGHT ME, SILENT!!"
msgstr "БІСЯ СА МНОЮ, МАЎЧАЛЬНІЦА!!"

# [ua] Битися
# [pl] Walcz
# [ru] Сразиться
msgctxt "ancients.json:TANX.talk.SILENT.2-0.next"
msgid "Fight"
msgstr "Бітва"

# [ua] [i][font_size=22]Мовчазна тікає, вкравши зброю по
# дорозі.[/font_size][/i]
# [pl] [i][font_size=22]Zjawa przemknęła niepostrzeżenie niczym cień, przy
# okazji kradnąc jedną z broni.[/font_size][/i]
# [ru] [i][font_size=22]Безмолвная сбегает, прихватив с собой
# оружие.[/font_size][/i]
msgctxt "ancients.json:TANX.talk.SILENT.2-1.char"
msgid "[i][font_size=22]The Silent escapes, stealing a weapon on the way.[/font_size][/i]"
msgstr "[i][font_size=22]Маўчальніца ўцякае, па дарозе крадучы зброю.[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TANX.talk.SILENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] КУДИ ТИ ПОДІЛАСЯ!!!
# [pl] GDZIE TY SIĘ PODZIAŁAŚ!!!
# [ru] КУДА ТЫ ДЕЛАСЬ?!
msgctxt "ancients.json:TANX.talk.SILENT.2-2.ancient"
msgid "WHERE DID YOU GO!!!"
msgstr "КУДЫ ТЫ ДЗЕЛАСЯ!!!"

# [ua] ТАКИЙ СЛАБКИЙ! АЛЕ В ТЕБЕ Є ПОТЕНЦІАЛ!
# ВИКОРИСТАЙ ЦЮ ЗБРОЮ!!
# [pl] CO ZA MIĘCZAK! ACZKOLWIEK MASZ POTENCJAŁ!
# WEŹ TĘ BROŃ!!
# [ru] Я ЧУЮ СЛАБОСТЬ! НО ТАКЖЕ МОГУЧИЙ ПОТЕНЦИАЛ!
# ИСПОЛЬЗУЙ ЭТО ОРУЖИЕ!
msgctxt "ancients.json:TANX.talk.firstVisitEver.0-0.ancient"
msgid "SO WEAK! BUT YOU HAVE POTENTIAL!\n"
"USE THIS WEAPON!!"
msgstr "Я АДЧУВАЮ СЛАБАСЦЬ! АЛЕ ТЫ МАЕШ ПАТЭНЦЫЯЛ!\n"
"ВЫКАРЫСТАЙ ГЭТУ ЗБРОЮ!!"

# [ua] Танкс
# [pl] Tanx
# [ru] Танкс
msgctxt "ancients.json:TANX.title"
msgid "Tanx"
msgstr "Танкс"

# [ua] Та, що живить вогонь
# [pl] To, co karmi ogień
# [ru] Хранительница огня
msgctxt "ancients.json:TEZCATARA.epithet"
msgid "It Which Feeds the Fire"
msgstr "Тая, што жывіць агонь"

# [ua] З поверненням, любий. Дозволь мені [jitter][b]спалити[/b][/jitter] твої
# вади.
# [pl] Witaj z powrotem, iskierko. Już ja ci [jitter][b]spalę[/b][/jitter]
# wszystkie twoje zmartwienia.
# [ru] С возвращением, дорогуша. Позволь мне [jitter][b]сжечь[/b][/jitter]
# твои изъяны.
msgctxt "ancients.json:TEZCATARA.talk.ANY.0-0r.ancient"
msgid "Welcome back, sweetie. Let me [jitter][b]burn[/b][/jitter] away your flaws."
msgstr "З вяртаннем, золатка. Дазволь мне [jitter][b]спаліць[/b][/jitter] твае заганы."

# [ua] Заходь, заходь, любий! Що Тецкатара може зробити для тебе сьогодні?
# [pl] Chodź, usiądź sobie iskierko! W czym Tezcatara może ci dzisiaj pomóc?
# [ru] Заходи, солнышко! Чем Тецкатара может угодить тебе сегодня?
msgctxt "ancients.json:TEZCATARA.talk.ANY.1-0r.ancient"
msgid "Do come in, dear! What can Tezcatara do for you today?"
msgstr "Калі ласка, заходзь, мілка!\n"
"Чым Тэцкатара можа табе сёння памагчы?"

# [ua] [i][font_size=22]<привітальний сигнал>[/font_size][/i]
# [pl] [i][font_size=22]<pikanie na powitanie>[/font_size][/i]
# [ru] [i][font_size=22]<Приветственное гудение>[/font_size][/i]
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.0-0.char"
msgid "[i][font_size=22]<greetings beep>[/font_size][/i]"
msgstr "[i][font_size=22]<прывітальнае піканне>[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Не для того, щоб дратувати мене? Який [jitter][b]незвичний[/b][/jitter]
# маленький конструкт...
# [pl] Nie przyszedłeś mi podokuczać? Co za [jitter][b]nietypowy[/b][/jitter]
# mały konstrukt...
# [ru] Ты не собираешься докучать мне? Какой
# [jitter][b]незаурядный[/b][/jitter] агрегатик…
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.0-1.ancient"
msgid "Not here to annoy me? What an [jitter][b]unusual[/b][/jitter] little construct..."
msgstr "Ты тут не для таго, каб мяне раздражняць? Які незвычайны механізм..."

# [ua] Хіба не було б кумедно, якби його знищив його ж власний витвір?
# [pl] Pewnie byłoby mu trochę głupio, gdyby został pokonany przez jednego ze
# swoich.
# [ru] Было бы крайне забавно, если он сам окажется зачинщиком своей погибели,
# не так ли?
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.1-0r.ancient"
msgid "Now how silly would it be if he were unmade by one of his own?"
msgstr "Вох, як было б недарэчна, калі б ягоны ўласны твор стаў яму пагібеллю, праўда?"

# [ua] Ти впевнений, що хочеш, щоб тебе полагодили?
# [pl] Czy aby na pewno chcesz być naprawiony?
# [ru] Ты точно хочешь, чтобы тебя починили?
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.2-0.ancient"
msgid "Are you sure you want to be fixed up?"
msgstr "Ці ўпэўнены ты, што хочаш, каб цябе выправілі?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.2-0.next"
msgid "Reply"
msgstr "Адказаць"

# [ua] [i][font_size=22]<допитливий сигнал>[/font_size][/i]
# [pl] [i][font_size=22]<Dociekliwe pikanie>[/font_size][/i]
# [ru] [i][font_size=22]<Уверенное бибиканье>[/font_size][/i]
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]<inquisitive beep>[/font_size][/i]"
msgstr "[i][font_size=22]<дапытлівае піканне>[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ну, якщо ти справді [jitter][b]впевнений[/b][/jitter].
# [pl] Cóż, skoroś taki [jitter][b]pewien[/b][/jitter].
# [ru] Ну, раз уж ты [jitter][b]уверен[/b][/jitter]…
msgctxt "ancients.json:TEZCATARA.talk.DEFECT.2-2.ancient"
msgid "Well, if you’re really [jitter][b]certain[/b][/jitter]."
msgstr "Ну, калі ты сапраўды [jitter][b]упэўнены[/b][/jitter]."

# [ua] Ти так гарно [jitter][b]палаєш[/b][/jitter]! Заходь, заходь!
# [pl] Kochaniutki, jak ty pięknie [jitter][b]płoniesz[/b][/jitter]! Chodźże,
# chodź!
# [ru] Ты так прекрасно [jitter][b]горишь[/b][/jitter]! Заходи-заходи!
msgctxt "ancients.json:TEZCATARA.talk.IRONCLAD.0-0.ancient"
msgid "You [jitter][b]burn[/b][/jitter] so pretty! Come in, come in!"
msgstr "Ты так прыгожа [jitter][b]гарыш[/b][/jitter]! Заходзь, заходзь!"

# [ua] Який ти сильний хлопець! Заходь, поїж чогось.
# Не можна [jitter][b]різати[/b][/jitter] на голодний шлунок!
# [pl] Taki silny z ciebie mężczyzna! Chodź zjedz coś sobie.
# Nie można tak [jitter][b]bojować[/b][/jitter] z pustym żołądkiem!
# [ru] Ай да молодец, ай да силач! Проходи, перекуси.
# Нельзя устраивать [jitter][b]кровавую баню[/b][/jitter] на голодный желудок!
msgctxt "ancients.json:TEZCATARA.talk.IRONCLAD.1-0r.ancient"
msgid "Such a strong boy you are! Come and eat something.\n"
"Can’t [jitter][b]slaughter[/b][/jitter] on an empty stomach!"
msgstr "Які ж ты моцны хлопчык! Ідзі, паеш.\n"
"Нельга [jitter][b]забіваць[/b][/jitter] на пусты страўнік!"

# [ua] Ох, Архітектор ще живий? Убий його [jitter][b]швидше[/b][/jitter], будь
# ласка.
# Я почекаю тут!
# [pl] Ooo, Architekt wciąż żyje? Zabij go [jitter][b]szybciutko[/b][/jitter],
# co?
# Ja tu sobie będę cierpliwie czekać!
# [ru] Ох, Архитектор еще жив? Прикончи его [jitter][b]побыстрее[/b][/jitter],
# ладно?
# Я буду ждать здесь!
msgctxt "ancients.json:TEZCATARA.talk.IRONCLAD.2-0.ancient"
msgid "Ohh, Architect still alive? Kill him [jitter][b]quickly[/b][/jitter] would you?\n"
"I’ll be waiting right here!"
msgstr "О, Архітэктар яшчэ жывы? Забі яго як [jitter][b]найхутчэй[/b][/jitter], добра?\n"
"Я буду чакаць тут!"

# [ua] Що скелет робить у цих стінах?
# [pl] A skąd mi tu szkielet nagle wyskoczył?
# [ru] Так, а что в этих стенах забыл скелет?
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.0-0.ancient"
msgid "Now what’s a skeleton doing inside these walls?"
msgstr "Дык што шкілет робіць у гэтых сценах?"

# [ua] Говорити
# [pl] Rozmawiaj
# [ru] Говорить
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.0-0.next"
msgid "Talk"
msgstr "Паразмаўляць"

# [ua] Моя мета проста. Помста за мою родину.
# Я дістануся до вершини і змушу його заплатити.
# [pl] Mój cel jest prosty. Zemsta dla mojej rodziny.
# Dortę na szczyt i sprawię, że Architekt zapłaci najwyższą cenę.
# [ru] Все просто. Я жажду отомстить за семью.
# Я поднимусь наверх и заставлю его поплатиться.
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.0-1.char"
msgid "My aim is simple. Vengeance for my family.\n"
"I’ll reach the top and make him pay."
msgstr "Мая мэта простая. Адпомсціць за сваю сям'ю.\n"
"Я ўзбяруся на вяршыню і прымушу яго заплаціць."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [jitter][b]Чудово[/b][/jitter]!
# [pl] [jitter][b]Cudownie[/b][/jitter]!
# [ru] [jitter][b]Превосходно![/b][/jitter]
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.0-2.ancient"
msgid "[jitter][b]Wonderful[/b][/jitter]!"
msgstr "[jitter][b]Цудоўна[/b][/jitter]!"

# [ua] Заходь, заходь! Змусимо твоє полум'я палати
# [jitter][b]яскравіше[/b][/jitter].
# [pl] Chodźże, chodź! Trzeba dolać specjalnej oliwy do twojego
# [jitter][b]ognia[/b][/jitter].
# [ru] Заходи-заходи! Давай сделаем твое пламя [jitter][b]ярче[/b][/jitter].
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.1-0r.ancient"
msgid "Come in, come in! Let’s make your flames burn [jitter][b]brighter[/b][/jitter]."
msgstr "Заходзь, заходзь! Давай зробім твае полымя [jitter][b]ярчэйшым[/b][/jitter]."

# [ua] Те полум'я навколо тебе нагадує мені щось заборонене.
# [pl] Te płomienie wokół ciebie przypominają mi coś zakazanego.
# [ru] Твой огонь мне кое-что напоминает. Кое-что запретное.
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.2-0.ancient"
msgid "Those flames around you remind me of something forbidden."
msgstr "Полымя вакол цябе нагадвае мне пра нешта забароненае."

# [ua] Запитати
# [pl] Zapytaj
# [ru] Спросить
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.2-0.next"
msgid "Ask"
msgstr "Спытаць"

# [ua] Що ти знаєш?
# [pl] Wiesz coś o tym?
# [ru] Что тебе известно?
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.2-1.char"
msgid "What do you know?"
msgstr "Што ты ведаеш?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Я знаю, хто написав ту [jitter][b]книгу[/b][/jitter].
# [pl] Wiem, kto napisał tamtą [jitter][b]księgę[/b][/jitter].
# [ru] Я знаю, кто написал ту [jitter][b]книгу[/b][/jitter].
msgctxt "ancients.json:TEZCATARA.talk.NECROBINDER.2-2.ancient"
msgid "I know who wrote that [jitter][b]book[/b][/jitter]."
msgstr "Я ведаю, хто напісаў тую [jitter][b]кнігу[/b][/jitter]."

# [ua] О боже, який [jitter][b]екзотичний[/b][/jitter] гість! Хто ти, любий?
# [pl] Ojej, co to za [jitter][b]egzotyczny[/b][/jitter] gość mnie odwiedził!
# Opowiadaj iskierko, coś ty za jeden?
# [ru] Ой-ой-ой, какой [jitter][b]необычный[/b][/jitter] гость! Кто ты такой,
# дорогуша?
msgctxt "ancients.json:TEZCATARA.talk.REGENT.0-0.ancient"
msgid "Oh my, what an [jitter][b]exotic[/b][/jitter] visitor! Who might you be, sweetie?"
msgstr "Ой, які ж [jitter][b]экзатычны[/b][/jitter] госць! Хто ж ты такі, золатка?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:TEZCATARA.talk.REGENT.0-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Я не «любий»! Звертайтеся до мене з повагою, велетенська... річ-людина!
# [pl] Nie jestem żadną iskierką! Należy zwracać się do mnie z szacunkiem, ty
# wielka... osobo-podobna kreaturo!
# [ru] Никакой я не дорогуша! Обращайся ко мне с должным почтением… кто бы ты
# ни была!
msgctxt "ancients.json:TEZCATARA.talk.REGENT.0-1.char"
msgid "I’m no sweetie! Address me with respect, giant... thing-person!"
msgstr "Я не золатка! Звяртайся да мяне з павагай, гіганцкае... чалавекападобнае!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.REGENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Де мої манери?
# [i][font_size=22]Тецкатара з насолодою реготає.[/font_size][/i]
# [pl] Gdzie moje maniery?
# [i][font_size=22]Tezcatara chichocze rozbawiona.[/font_size][/i]
# [ru] Где же мои манеры?
# [i][font_size=22]Тецкатара восторженно хохочет.[/font_size][/i]
msgctxt "ancients.json:TEZCATARA.talk.REGENT.0-2.ancient"
msgid "Where are my manners?\n"
"[i][font_size=22]Tezcatara cackles with delight.[/font_size][/i]"
msgstr "Дзе ж мае манеры?\n"
"[i][font_size=22]Тэцкатара захоплена рагоча.[/font_size][/i]"

# [ua] Ти і твої друзі знову повернулися?
# Я приготувала для вас [jitter][b]ласощі[/b][/jitter]!
# [pl] Znowu mnie odwiedziłeś ze swoimi przyjaciółmi?
# Przyrządziłam dla was [jitter][b]smakołyki[/b][/jitter]!
# [ru] И сам вернулся, и друзей не забыл?
# А я подготовила вам [jitter][b]подарки[/b][/jitter]!
msgctxt "ancients.json:TEZCATARA.talk.REGENT.1-0r.ancient"
msgid "You and your friends are back again?\n"
"I’ve made [jitter][b]treats[/b][/jitter] for you!"
msgstr "Вы з сябрамі зноў вярнуліся?\n"
"Я прыгатавала для вас [jitter][b]ласункі[/b][/jitter]!"

# [ua] З поверненням, королівський хлопче! Схоже, у тебе там все
# [jitter][b]чудово[/b][/jitter].
# [pl] Witam z powrotem, księciuniu! Chyba sobie
# [jitter][b]świetnie[/b][/jitter] dajesz radę.
# [ru] С возвращением, маленький принц! Вижу, ты добился [jitter][b]больших
# успехов[/b][/jitter].
msgctxt "ancients.json:TEZCATARA.talk.REGENT.2-0.ancient"
msgid "Welcome back regal boy! Looks like you’re doing [jitter][b]great[/b][/jitter] out there."
msgstr "З вяртаннем, княжыч! Здаецца, у цябе там [jitter][b]выдатна[/b][/jitter] ідуць справы."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:TEZCATARA.talk.REGENT.2-0.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Так, звісно! Лише невеликі ускладнення на верхніх рівнях... як-от
# смерть.
# [pl] Tak, oczywiście! Mieliśmy drobne utrudnienia na wyższych piętrach takie
# jak... umieranie.
# [ru] Да, само собой! На этажах повыше бывают, конечно, загвоздки… Умираю,
# например.
msgctxt "ancients.json:TEZCATARA.talk.REGENT.2-1.char"
msgid "Yes of course! Just some minor setbacks at the upper levels... like dying."
msgstr "Так, вядома ж! Толькі ёсць невялікія нязручнасці на верхніх узроўнях... накшталт смерці."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.REGENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Усі ми мусимо вчитися на своїх помилках.
# [pl] Wszyscy uczymy się na błędach.
# [ru] На ошибках учатся.
msgctxt "ancients.json:TEZCATARA.talk.REGENT.2-2.ancient"
msgid "We all need to learn from our mistakes."
msgstr "Нам усім трэба вучыцца на сваіх памылках."

# [ua] Підійди ближче, тиха. Я погано бачу...
# [pl] Podejdź tu bliżej, cichutka duszyczko. Nie widzę cię za dobrze...
# [ru] Подойди, тихоня. Не могу тебя разглядеть…
msgctxt "ancients.json:TEZCATARA.talk.SILENT.0-0.ancient"
msgid "Come closer, quiet one. I can’t see well..."
msgstr "Падыдзі бліжэй, ціхоня. Я дрэнна цябе бачу..."

# [ua] Мовчати
# [pl] Nic nie mów
# [ru] Промолчать
msgctxt "ancients.json:TEZCATARA.talk.SILENT.0-0.next"
msgid "Say Nothing"
msgstr "Прамаўчаць"

# [ua] ...
# [pl] ...
# [ru] …
msgctxt "ancients.json:TEZCATARA.talk.SILENT.0-1.char"
msgid "..."
msgstr "..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.SILENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ти можеш мені [jitter][b]довіряти[/b][/jitter].
# [pl] Możesz mi [jitter][b]zaufać[/b][/jitter].
# [ru] Можешь мне [jitter][b]доверять[/b][/jitter].
msgctxt "ancients.json:TEZCATARA.talk.SILENT.0-2.ancient"
msgid "You can [jitter][b]trust[/b][/jitter] me."
msgstr "Ты можаш мне [jitter][b]давяраць[/b][/jitter]."

# [ua] Яка огидна [jitter][b]хвороба[/b][/jitter] в тебе. Давай подбаємо про
# тебе.
# [pl] Ale paskudne [jitter][b]choróbsko[/b][/jitter] cię dopadło. Zajmę się
# tobą.
# [ru] Эта твоя [jitter][b]хворь[/b][/jitter] такая гадкая. Я позабочусь о
# тебе.
msgctxt "ancients.json:TEZCATARA.talk.SILENT.1-0r.ancient"
msgid "Such a nasty [jitter][b]sickness[/b][/jitter] you have. Let’s take care of you."
msgstr "У цябе такая [jitter][b]прыкрая[/b][/jitter] хвароба. Давай я табой займуся."

# [ua] Я зустрічала твоїх сестер, знаєш? Такі чарівні дівчата.
# [pl] Wiesz, że kiedyś spotkałam twoje siostrzyczki? Takie z nich cudowne
# dziewczęta.
# [ru] Ты знала, что я виделась с твоими сестрами? Такие задорные девчонки.
msgctxt "ancients.json:TEZCATARA.talk.SILENT.2-0.ancient"
msgid "I’ve met your sisters, you know? Such lovely girls they are."
msgstr "Я сустракала тваіх сясцёр, ведаеш? Такія мілыя дзяўчаты."

# [ua] Мовчати
# [pl] Nic nie mów
# [ru] Промолчать
msgctxt "ancients.json:TEZCATARA.talk.SILENT.2-0.next"
msgid "Say Nothing"
msgstr "Прамаўчаць"

# [ua] ...
# [pl] ...
# [ru] …
msgctxt "ancients.json:TEZCATARA.talk.SILENT.2-1.char"
msgid "..."
msgstr "..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:TEZCATARA.talk.SILENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ой-ой... ви ж не [jitter][b]билися[/b][/jitter], правда?
# [pl] Oj iskierko... tylko mi nie mów, że się
# [jitter][b]pokłóciłyście[/b][/jitter]?
# [ru] О нет… Только не говори, что вы [jitter][b]поссорились[/b][/jitter]?
msgctxt "ancients.json:TEZCATARA.talk.SILENT.2-2.ancient"
msgid "Oh dear... you haven’t been [jitter][b]fighting[/b][/jitter] have you?"
msgstr "Ой... вы ж не [jitter][b]сварыліся[/b][/jitter], праўда?"

# [ua] О, гість! Заходь, заходь, любий!
# Що Тецкатара може зробити для тебе?
# [pl] A kto mnie tu odwiedził? Wchodź, iskierko!
# Czego ci potrzeba od Tezcatary?
# [ru] Ой, гости! Заходи, дорогуша!
# Чем Тецкатара может тебе помочь?
msgctxt "ancients.json:TEZCATARA.talk.firstVisitEver.0-0.ancient"
msgid "Oh, a visitor! Do come in, dear!\n"
"What can Tezcatara do for you?"
msgstr "О, госць! Калі ласка, заходзь, мілка!\n"
"Чым Тэцкатара можа памагчы?"

# [ua] Тецкатара
# [pl] Tezcatara
# [ru] Тецкатара
msgctxt "ancients.json:TEZCATARA.title"
msgid "Tezcatara"
msgstr "Тэцкатара"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.CONTINUE"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:THE_ARCHITECT.RESPOND"
msgid "Respond"
msgstr "Адказаць"

# [ua] Що ти тут робиш?
# [pl] Co ty tu robisz?
# [ru] Что ты здесь делаешь?
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.0-0r.ancient"
msgid "What are you doing here?"
msgstr "Што ты тут робіш?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.0-0r.next"
msgid "Answer"
msgstr "Адказаць"

# [ua] <невиразні перебиті рядки>
# [pl] <chaotycznie wygenerowany tekst>
# [ru] <Неразборчивые помехи>
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.0-1r.char"
msgid "<random garbled lines>"
msgstr "<Неразборлівыя перашкоды>"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.0-1r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Полагодити тебе? Змусь мене.
# [pl] Naprawić cię? Nie rozśmieszaj mnie.
# [ru] Починить? Вот еще!
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.0-2r.ancient"
msgid "Repair you? Make me."
msgstr "Направіць цябе? Не смяшы."

# [ua] Ти повернувся? Хіба я тебе не розібрав?
# [pl] Wróciłeś? Czy ja cię nie zdemontowałem?
# [ru] Ты снова здесь? Разве я тебя не разобрал?
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.1-0r.ancient"
msgid "You’re back? Didn’t I dismantle you?"
msgstr "Ты вярнуўся? Хіба ж я цябе не разабраў?"

# [ua] Пояснити
# [pl] Wyjaśnij
# [ru] Объяснить
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.1-0r.next"
msgid "Explain"
msgstr "Растлумачыць"

# [ua] <невиразні перебиті рядки>
# [pl] <chaotyczna sekwencja poleceń>
# [ru] <Неразборчивые помехи>
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.1-1r.char"
msgid "<random garbled lines>"
msgstr "<Неразборлівыя перашкоды>"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.1-1r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Полагодити тебе? Полагодити твого друга? Безглуздя.
# [pl] Naprawić cię? I twojego przyjaciela też? Absurd.
# [ru] Починить тебя? Починить твоего друга? Бессмыслица.
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.1-2r.ancient"
msgid "Fix you? Fix your friend? Ridiculous."
msgstr "Направіць цябе? І твайго сябра? Бязглуздзіца."

# [ua] Як ти продовжуєш повертатися? Це справа Няу?
# [pl] Jakim cudem ciągle tu wracasz? Czy to sprawka Neow?
# [ru] Почему ты снова здесь? Это что, проделки Ньяу?
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.2-0r.ancient"
msgid "How do you keep coming back? Is this Neow’s doing?"
msgstr "Як ты ўсё вяртаешся? Ці ў гэтым замяшана Няў?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.2-0r.next"
msgid "Reply"
msgstr "Адказаць"

# [ua] <невиразні перебиті рядки>
# [pl] <chaotyczna sekwencja poleceń>
# [ru] <Неразборчивые помехи>
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.2-1r.char"
msgid "<random garbled lines>"
msgstr "<Неразборлівыя перашкоды>"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.2-1r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Дурнувато
# [pl] Niedorzeczne.
# [ru] Какая глупость.
msgctxt "ancients.json:THE_ARCHITECT.talk.DEFECT.2-2r.ancient"
msgid "Foolish"
msgstr "Так недарэчна"

# [ua] Отже, раб архідемона прибув?
# [pl] Proszę, proszę, czy to sam niewolnik arcydemona?
# [ru] А вот и цепной пес архидемона.
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.0-0r.ancient"
msgid "So the arch demon’s thrall has arrived?"
msgstr "Вось як, сам нявольнік архідэмана прыцягнуўся?"

# [ua] Погрожувати
# [pl] Zastrasz groźbami
# [ru] Пригрозить
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.0-0r.next"
msgid "Threaten"
msgstr "Прыгразіць"

# [ua] Ворог...
# Вбити...
# [pl] Wróg...
# Zabiję...
# [ru] Жертва…
# Расправа…
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.0-1r.char"
msgid "Enemy...\n"
"Kill..."
msgstr "Вораг...\n"
"Забіць..."

# [ua] Прокляття битися вічно, так?
# [pl] Zdajesz sobie sprawę, że jesteś skazany na wieczną walkę?
# [ru] Обречен убивать и не можешь умереть, да?
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.1-0r.ancient"
msgid "Cursed to fight forever, aren’t you?"
msgstr "Ты ж пракляты ваяваць вечна, праўда?"

# [ua] Погрожувати
# [pl] Zastrasz groźbami
# [ru] Пригрозить
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.1-0r.next"
msgid "Threaten"
msgstr "Прыгразіць"

# [ua] Архітектор... арх... ворог!!
# [pl] Architekt... arcy.... wróg!!
# [ru] Архитектор… Арх… В прах!
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.1-1r.char"
msgid "Architect... arch... enemy!!"
msgstr "Архітэктар... закляты... вораг!!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.1-1r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ти взагалі знаєш своє ім'я?
# [pl] Czy ty w ogóle pamiętasz, jak się nazywasz?
# [ru] Ты хотя бы имя свое знаешь?
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.1-2r.ancient"
msgid "Do you even know your name?"
msgstr "Ты наогул імя сваё ведаеш?"

# [ua] Мені тебе шкода.
# [pl] Żałosne.
# [ru] Мне тебя жаль.
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.2-0r.ancient"
msgid "I pity you."
msgstr "Мне цябе шкада."

# [ua] Погрожувати
# [pl] Zastrasz groźbami
# [ru] Пригрозить
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.2-0r.next"
msgid "Threaten"
msgstr "Прыгразіць"

# [ua] Вбити...
# [pl] Zabij...
# [ru] Расправа…
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.2-1r.char"
msgid "Kill..."
msgstr "Забіваць..."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.2-1r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Повертайся на дно, Залізноладе.
# [pl] Wracaj na dół, Pancerniku.
# [ru] Возвращайся вниз, Латоносец.
msgctxt "ancients.json:THE_ARCHITECT.talk.IRONCLAD.2-2r.ancient"
msgid "Return to the bottom, Ironclad."
msgstr "Вяртайся ўніз, Браняносец."

# [ua] АРХІТЕКТОРЕ! Ти вбив моїх батьків. Ти вбив мого друга. Ти вбив моє
# ЖИТТЯ! ...а тепер я вб'ю ТЕБЕ!
# [pl] ARCHITEKCIE! Zabiłeś moich rodziców. Zabiłeś moich przyjaciół. Zabiłeś
# moje ŻYCIE! ...a teraz to ja zabiję CIEBIE!
# [ru] АРХИТЕКТОР! Ты отнял у меня родителей. Ты отнял у меня друга. Ты отнял
# у меня ЖИЗНЬ. Настал час ВОЗМЕЗДИЯ!
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.0-0.char"
msgid "ARCHITECT! You killed my parents. You killed my friend. You killed my LIFE! ...and now I will kill YOU!"
msgstr "АРХІТЭКТАР! Ты забраў маіх бацькоў. Ты забраў майго сябра. Ты забраў у мяне ЖЫЦЦЁ! ...і цяпер я забяру ТВАЁ!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Помста, значить? Ні, дякую.
# [pl] A więc chodzi o zemstę? Podziękuję.
# [ru] Месть? Спасибо, я пас.
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.0-1.ancient"
msgid "Vengeance is it? No thank you."
msgstr "Хочаш адпомсціць, так? Не, дзякуй."

# [ua] АРХІТЕКТОРЕ! Ти вбив моїх батьків. Ти вбив мого друга. Ти вбив моє—
# [pl] ARCHITEKCIE! Zabiłeś moich rodziców. Zabiłeś mojego przyjaciela.
# Zabiłeś moje-
# [ru] АРХИТЕКТОР! Ты отнял у меня родителей. Ты отнял у меня друга. Ты отнял
# у меня…
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.1-0r.char"
msgid "ARCHITECT! You killed my parents. You killed my friend. You killed my-"
msgstr "АРХІТЭКТАР! Ты забраў маіх бацькоў. Ты забраў майго сябра. Ты забраў у мя-"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.1-0r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ти не зміниш минуле гнівом.
# [pl] Gniew nie zmieni przeszłości.
# [ru] Гневом прошлого не изменить.
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.1-1r.ancient"
msgid "You cannot change the past with anger."
msgstr "Злосцю мінулае не зменіш."

# [ua] АРХІТЕКТОРЕ! Ти вбив моїх батьків. Ти вбив мого друга. Ти вбив моє
# ЖИТТЯ—
# [pl] ARCHITEKCIE! Zabiłeś moich rodziców. Zabiłeś mojego przyjaciela.
# Zabiłeś moje-
# [ru] АРХИТЕКТОР! Ты отнял у меня родителей. Ты отнял у меня друга. Ты отнял
# у меня ЖИЗНЬ…
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.2-0r.char"
msgid "ARCHITECT! You killed my parents. You killed my friend. You killed my LIFE-"
msgstr "АРХІТЭКТАР! Ты забраў маіх бацькоў. Ты забраў майго сябра. Ты забраў у мяне ЖЫЦЦЁ-"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.2-0r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Я зробив те, що мусив, для підтримки порядку.
# [pl] Zrobiłem to, co było konieczne do utrzymania porządku.
# [ru] Я обязан сохранять порядок.
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.2-1r.ancient"
msgid "I did what I must to maintain order."
msgstr "Я зрабіў тое, што мусіў, каб падтрымаць парадак."

# [ua] АРХІТЕКТОРЕ! Ти вбив моїх батьків. Ти вбив мого друга. Ти вбив моє—
# [pl] ARCHITEKCIE! Zabiłeś moich rodziców. Zabiłeś mojego przyjaciela.
# Zabiłeś moje-
# [ru] АРХИТЕКТОР! Ты отнял у меня родителей. Ты отнял у меня друга. Ты отнял
# у меня…
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.3-0r.char"
msgid "ARCHITECT! You killed my parents. You killed my friend. You killed my-"
msgstr "АРХІТЭКТАР! Ты забраў маіх бацькоў. Ты забраў майго сябра. Ты забраў у мя-"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.3-0r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Життя
# [pl] Życie.
# [ru] Жизнь.
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.3-1r.ancient"
msgid "Life"
msgstr "Жыццё"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.3-1r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Що...?! Помри, потворо!
# [pl] Co...?! Giń, potworze!
# [ru] Что?! Умри, чудовище!
msgctxt "ancients.json:THE_ARCHITECT.talk.NECROBINDER.3-2r.char"
msgid "What...?! Die, monster!"
msgstr "Што...?! Здохні, монстр!"

# [ua] Я прибув! Ти там, простолюдин! Це вершина?
# [pl] Oto jestem! Hej ty, plebsie! Czy to już szczyt?
# [ru] Король прибыл! Эй ты, холоп! Вершина тут?
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.0-0.char"
msgid "I’ve arrived! You there, commoner! Is this the top?"
msgstr "Я прыбыў! Гэй, ты, халопе! Ці гэта вяршыня?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.0-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Мені потрібна тиша...
# [pl] Potrzebuję ciszy...
# [ru] Мне нужна тишина…
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.0-1.ancient"
msgid "I need quiet..."
msgstr "Мне патрэбна цішыня..."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.0-1.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Я навчу тебе манерам!
# [pl] Już ja cię nauczę dobrych manier!
# [ru] Да как ты… Я научу тебя манерам!
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.0-2.char"
msgid "I’ll teach you some manners!"
msgstr "Я навучу цябе манерам!"

# [ua] Я знову прибув!
# [pl] Oto jestem! Znowu.
# [ru] Король прибыл! Снова!
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.1-0r.char"
msgid "I’ve arrived again!"
msgstr "Я зноў прыбыў!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.1-0r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Гучний дурень повернувся?
# [pl] Ten głośny idiota powrócił?
# [ru] Шут гороховый пожаловал?
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.1-1r.ancient"
msgid "The loud fool returns?"
msgstr "Дурань малёваны вярнуўся?"

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.1-1r.next"
msgid "Respond"
msgstr "Адказаць"

# [ua] Я не гучний і не дурень! Стій проти мене!
# [pl] Żaden ze mnie idiota! I nie jestem głośny!! Zmierz się ze mną!
# [ru] Я не шут и не гороховый! Защищайся!
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.1-2r.char"
msgid "I’m neither loud nor a fool! Face me!"
msgstr "Я не дурань і не малёваны! Абараняйся!"

# [ua] Мені набридли твої погані манери!
# [pl] Mam już dosyć twoich kiepskich manier!
# [ru] Хватит с меня твоей неотесанности!
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.2-0r.char"
msgid "I’ve had enough of your poor manners!"
msgstr "Мне надакучыў твой брак выхаванасці!"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.2-0r.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] У цьому ми згодні.
# [pl] Wreszcie się zgadzamy.
# [ru] Взаимно.
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.2-1r.ancient"
msgid "Something we can both agree on."
msgstr "Нарэшце мы ў нечым згаджаемся."

# [ua] Відповісти
# [pl] Zripostuj
# [ru] Возразить
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.2-1r.next"
msgid "Retort"
msgstr "Запярэчыць"

# [ua] До бою!
# [pl] Zatańczmy!
# [ru] Потанцуем!
msgctxt "ancients.json:THE_ARCHITECT.talk.REGENT.2-2r.char"
msgid "Let’s dance!"
msgstr "Станцуйма!"

# [ua] Навіть не представишся?
# [pl] Nawet się nie przedstawisz?
# [ru] Даже не представишься?
msgctxt "ancients.json:THE_ARCHITECT.talk.SILENT.0-0r.ancient"
msgid "Not even an introduction?"
msgstr "Нават не прадставішся?"

# [ua] Звідки ти прийшла?
# Чого ти хочеш?
# [pl] Skąd się tu wzięłaś?
# Czego chcesz?
# [ru] Откуда ты?
# Чего желаешь?
msgctxt "ancients.json:THE_ARCHITECT.talk.SILENT.1-0r.ancient"
msgid "Where did you come from?\n"
"What are you after?"
msgstr "Скуль ты?\n"
"Чаго ты хочаш?"

# [ua] [jitter]Хррг![/jitter]
# [jitter][red]ПОМРИ!![/red][/jitter]
# [pl] [jitter]Grrr![/jitter]
# [jitter][red]GIŃ!![/red][/jitter]
# [ru] [jitter]!!![/jitter]
# [jitter][red]УМРИ![/red][/jitter]
msgctxt "ancients.json:THE_ARCHITECT.talk.SILENT.2-0r.ancient"
msgid "[jitter]Hrrgh![/jitter]\n"
"[jitter][red]DIE!![/red][/jitter]"
msgstr "[jitter]Гр-р-р-р![/jitter]\n"
"[jitter][red]ПАМРЫ!![/red][/jitter]"

# [ua] Настирна нікчемо!
# [jitter]ЗНИКНИ!![/jitter]
# [pl] Przeklęty łotr!
# [jitter]ZNIKAJ STĄD!![/jitter]
# [ru] Настырная бестия!
# [jitter]ПРОЧЬ![/jitter]
msgctxt "ancients.json:THE_ARCHITECT.talk.SILENT.3-0r.ancient"
msgid "Annoying wretch!\n"
"[jitter]BE GONE!![/jitter]"
msgstr "Якая ж ты назола!\n"
"[jitter]ПРЭЧ![/jitter]"

# [ua] Архітектор
# [pl] Architekt
# [ru] Архитектор
msgctxt "ancients.json:THE_ARCHITECT.title"
msgid "The Architect"
msgstr "Архітэктар"

# [ua] Перший демон
# [pl] Pierwszy Demon
# [ru] Первый демон
msgctxt "ancients.json:VAKUU.epithet"
msgid "The First Demon"
msgstr "Першы дэман"

# [pl] {character} {characterGender:choose(masculine|feminine|neutral): nie
# przeczytał|nie przeczytała|nie przeczytał} warunków umowy
# [gold]Vakuu[/gold].
# [ru] {character}
# {characterGender:choose(neutral|masculine|feminine):заключил|заключил|заключила}
# неудачную сделку с [gold]Вакуу[/gold].
msgctxt "ancients.json:VAKUU.loss"
msgid "{character} took a bad deal from [gold]Vakuu[/gold]."
msgstr "{character} {characterGender:choose(neutral|masculine|feminine):не дачытала|не дачытаў|не дачытала} варункаў угоды з [gold]Вакуу[/gold]."

# [ua] Шукаєте слави у Шпилі? У мене є кілька пропозицій для Вас...
# [pl] Kolejny poszukiwacz chwały w Iglicy? Mam dla ciebie pewne propozycje...
# [ru] Покоритель Шпиля в поисках величия? Хочу тебе кое-что предложить.
msgctxt "ancients.json:VAKUU.talk.ANY.0-0r.ancient"
msgid "Seeking glory in the Spire are we? I have some propositions for you..."
msgstr "Шукаем славы ў Шпілі, га? Маю для цябе некалькі прапаноў..."

# [ua] 143. 143 рази ти був тут.
# [pl] 143. Przychodzisz do mnie już 143 raz.
# [ru] 143. Ты поднимаешься сюда уже в 143-й раз.
msgctxt "ancients.json:VAKUU.talk.ANY.1-0r.ancient"
msgid "143. 143 times you’ve been here."
msgstr "143. Ты тут ужо 143-ці раз."

# [ua] Ти розумієш, що це [sine]ніколи[/sine] не закінчиться?
# [pl] Zdajesz sobie sprawę, że to [sine]nigdy[/sine] się nie kończy?
# [ru] Ты же понимаешь, это [sine]никогда[/sine] не кончится?
msgctxt "ancients.json:VAKUU.talk.ANY.2-0r.ancient"
msgid "You realize this [sine]never[/sine] ends?"
msgstr "Ты ж разумееш, што гэта [sine]ніколі[/sine] не скончыцца?"

# [ua] Зламаний, дозволь мені [sine]вдосконалити[/sine] тебе.
# [pl] Pomogę ci osiągnąć [sine]perfekcję[/sine].
# [ru] Ты сломан… Позволь тебя [sine]усовершенствовать[/sine].
msgctxt "ancients.json:VAKUU.talk.DEFECT.0-0.ancient"
msgid "Broken one, let me [sine]perfect[/sine] you."
msgstr "Ты зламаны... дазволь [sine]удасканаліць[/sine] цябе."

# [ua] Тобі не здається дивним, що твої побратими-конструкти хочуть твоєї
# смерті?
# [pl] Nie dziwi cię, że inne konstrukty chcą cię zabić?
# [ru] Ты не находишь странным, что другие агрегаты хотят тебя уничтожить?
msgctxt "ancients.json:VAKUU.talk.DEFECT.1-0r.ancient"
msgid "Do you find it strange that your fellow constructs want you dead?"
msgstr "Ці не здаецца табе дзіўным, што іншыя механізмы хочуць тваёй смерці?"

# [ua] Якщо принесеш мені серце Архітектора, я відновлю твого
# [aqua]товариша[/aqua].
# [pl] Jeśli przyniesiesz mi serce Architekta, przywrócę twojego
# [aqua]towarzysza[/aqua].
# [ru] Принеси мне сердце Архитектора, и я восстановлю твоего
# [aqua]напарника[/aqua].
msgctxt "ancients.json:VAKUU.talk.DEFECT.2-0.ancient"
msgid "If you bring me the Architect’s heart, I will restore your [aqua]companion[/aqua]."
msgstr "Калі прынясеш мне сэрца Архітэктара, я вярну твайго [aqua]знаёмца[/aqua]."

# [ua] Відповісти
# [pl] Odpowiedz
# [ru] Ответить
msgctxt "ancients.json:VAKUU.talk.DEFECT.2-0.next"
msgid "Reply"
msgstr "Адказаць"

# [ua] [i][font_size=22]<наляканий писк>[/font_size][/i]
# [pl] [i][font_size=22]<przestraszone pikanie>[/font_size][/i]
# [ru] [i][font_size=22]<Боязливое бибиканье>[/font_size][/i]
msgctxt "ancients.json:VAKUU.talk.DEFECT.2-1.char"
msgid "[i][font_size=22]<fearful beeping>[/font_size][/i]"
msgstr "[i][font_size=22]<напужанае піканне>[/font_size][/i]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.DEFECT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Що важливіше? Твій творець чи твій друг?
# [pl] Kto jest ważniejszy? Twój stwórca czy twój przyjaciel?
# [ru] Что важнее: твой создатель или твой друг?
msgctxt "ancients.json:VAKUU.talk.DEFECT.2-2.ancient"
msgid "What’s more important? Your creator or your friend?"
msgstr "Што важней: твой стваральнік ці твой сябар?"

# [ua] Уяви собі — бачити [sine]тебе[/sine] знову після такого часу.
# [pl] Dziwnie znowu [sine]ciebie[/sine] widzieć po tak długim czasie.
# [ru] Поверить не могу, это и вправду [sine]ты[/sine]. Столько лет прошло…
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.0-0.ancient"
msgid "Imagine seeing [sine]you[/sine] again after so long."
msgstr "Паверыць не магу, ізноў [sine]ты[/sine]. Столькі год мінула..."

# [ua] Пробудитися
# [pl] Przebudź się
# [ru] Очнуться
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.0-0.next"
msgid "Awaken"
msgstr "Прачніся"

# [ua] [jitter][b]СВЯЩЕННИЙ ДЕМОНЕ![/b][/jitter]
# Що ти зі мною зробив!?
# [pl] [jitter][b]ARCYDEMONIE![/b][/jitter]
# Co ty mi zrobiłeś!?
# [ru] [jitter][b]СВЯЩЕННЫЙ ДЕМОН![/b][/jitter]
# Что ты со мной сделал?!
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.0-1.char"
msgid "[jitter][b]SACRED DEMON![/b][/jitter]\n"
"What have you done to me!?"
msgstr "[jitter][b]САКРАЛЬНЫ ДЭМАН![/b][/jitter]\n"
"Што ты са мной зрабіў!?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Саме те, на що ти погодився.
# [pl] Masz, co chciałeś, wszystko zgodnie z umową.
# [ru] Именно то, на что ты согласился.
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.0-2.ancient"
msgid "Exactly what you bargained for."
msgstr "Менавіта тое, на што ты пагадзіўся."

# [ua] Загиблі племена тяжать на тобі...?
# [i][font_size=22]Вакуу виє від сміху.[/font_size][/i]
# [pl] Martwisz się, że całe bractwo przez ciebie zniknęło?
# Przecież braci się nie traci! [i][font_size=22]Vakuu wyje ze
# śmiechu.[/font_size][/i]
# [ru] Коришь себя за истребленные племена?…
# [i][font_size=22]Вакуу заливается смехом.[/font_size][/i]
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.1-0r.ancient"
msgid "Do the lost tribes weigh on you...?\n"
"[i][font_size=22]Vakuu howls with laughter.[/font_size][/i]"
msgstr "Няўжо сумленне дакарае цябе за тыя знішчаныя плямёны...?\n"
"[i][font_size=22]Вакуу вые ад смеху.[/font_size][/i]"

# [ua] Маріонетко маріонеток... чому ти ще не вбив Архітектора?
# [pl] Moja marionetko marionetek... czemu jeszcze nie zabiłeś Architekta?
# [ru] Мой ферзь… Почему ты еще не убил Архитектора?
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.2-0.ancient"
msgid "My puppet of puppets... why haven’t you killed the Architect yet?"
msgstr "Мая ўлюбёная марыянетка... чаму ты яшчэ не забіў Архітэктара?"

# [ua] Пробудитися
# [pl] Przebudź się
# [ru] Очнуться
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.2-0.next"
msgid "Awaken"
msgstr "Прачніся"

# [ua] Коли я вб'ю Архітектора, я вб'ю [jitter][b]ТЕБЕ![/b][/jitter]
# [pl] Jak tylko go zabiję, [jitter][b]TY[/b][/jitter] będziesz następny!
# [ru] После того, как я убью Архитектора, я прикончу
# [jitter][b]ТЕБЯ![/b][/jitter]
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.2-1.char"
msgid "After I kill the Architect, I will kill [jitter][b]YOU![/b][/jitter]"
msgstr "Пасля таго, як я заб'ю Архітэктара, ты станеш [jitter][b]НАСТУПНЫМ![/b][/jitter]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] [i][font_size=22][sine]Позіхання[/sine][/font_size][/i]
# Я з нетерпінням чекаю, як ти зазнаєш невдачі.
# [pl] [i][font_size=22][sine]Ziew[/sine][/font_size][/i]
# Nie mogę się doczekać, aż ci się to nie uda.
# [ru] [i][font_size=22][sine]Зевает[/sine][/font_size][/i]
# Не терпится посмотреть на твои жалкие потуги.
msgctxt "ancients.json:VAKUU.talk.IRONCLAD.2-2.ancient"
msgid "[i][font_size=22][sine]Yawn[/sine][/font_size][/i]\n"
"I look forward to watching you fail."
msgstr "[i][font_size=22][sine]Пазяхае[/sine][/font_size][/i]\n"
"Я з нецярпеннем чакаю, як ты прайграеш."

# [ua] Ми обидва шукаємо [sine]помсти[/sine]. За це доведеться заплатити.
# [pl] Oboje pragniemy [sine]zemsty[/sine]. Będzie to sporo kosztować.
# [ru] Нас объединяет жажда [sine]возмездия[/sine]. Но у всего своя цена.
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.0-0.ancient"
msgid "We both seek [sine]vengeance[/sine]. It will have a cost to pay."
msgstr "Мы абодва прагнем [sine]помсты[/sine]. Але ўсяму свая цана."

# [ua] Говорити
# [pl] Rozmawiaj
# [ru] Говорить
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.0-0.next"
msgid "Talk"
msgstr "Паразмаўляць"

# [ua] Я приймаю будь-яку ціну. Кожну ціну за його смерть.
# [pl] Zrobię wszystko, co konieczne. Wszystko za jego śmierć.
# [ru] Я должна уничтожить его любой ценой.
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.0-1.char"
msgid "I accept any cost. Every cost for his death."
msgstr "Я прымаю любы кошт. Усякую цану за ягоную смерць."

# [ua] Я знаю, звідки ти отримала ту [sine]Руку[/sine].
# [pl] Wiem, skąd masz tę [sine]Dłoń[/sine].
# [ru] Я знаю, откуда у тебя эта [sine]рука[/sine].
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.1-0r.ancient"
msgid "I know where you got that [sine]Hand[/sine]."
msgstr "Я ведаю, адкуль у цябе гэтая [sine]рука[/sine]."

# [ua] Архітектор тяжко поранив нас обох.
# [pl] Architekt głęboko zranił nas oboje.
# [ru] Архитектор не только тебе оставил шрамы.
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.2-0.ancient"
msgid "The Architect has gravely wounded us both."
msgstr "Архітэктар цяжка параніў нас абаіх."

# [ua] Говорити
# [pl] Rozmawiaj
# [ru] Говорить
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.2-0.next"
msgid "Talk"
msgstr "Паразмаўляць"

# [ua] До справи, демоне. Покажи мені свої контракти.
# [pl] Przejdź do rzeczy, demonie. Pokaż mi swoje pakty.
# [ru] Выкладывай, демон. О чем хочешь договориться?
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.2-1.char"
msgid "Get on with it, demon. Show me your contracts."
msgstr "Давай, дэмане. Пакажы мне свае пакты."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Одразу до справи. Гаразд...
# [pl] Prosto do konkretów. Dobrze zatem...
# [ru] Сразу к делу. Как пожелаешь…
msgctxt "ancients.json:VAKUU.talk.NECROBINDER.2-2.ancient"
msgid "Straight to business. Very well..."
msgstr "Адразу да справы. Як пажадаеш..."

# [ua] Істота зі зірок? У цих проклятих стінах?
# [pl] Gwiezdna istota? W mojej przeklętej komnacie?
# [ru] Звездный обитатель? В наших проклятых стенах?
msgctxt "ancients.json:VAKUU.talk.REGENT.0-0.ancient"
msgid "A being from the stars? Within these accursed walls?"
msgstr "Зорная істота? У гэтых праклятых сценах?"

# [ua] Поговорити
# [pl] Rozmawiaj
# [ru] Поговорить
msgctxt "ancients.json:VAKUU.talk.REGENT.0-0.next"
msgid "Chat"
msgstr "Пагутарыць"

# [ua] Ти знаєш про мене?
# [pl] Słyszałeś o mnie?
# [ru] Ты обо мне слышал?
msgctxt "ancients.json:VAKUU.talk.REGENT.0-1.char"
msgid "Do you know of me?"
msgstr "Ты пра мяне ведаеш?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.REGENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Так, думаю, ми можемо допомогти один одному.
# [pl] Tak, myślę, że możemy sobie pomóc.
# [ru] Да. Думаю, мы можем друг другу помочь.
msgctxt "ancients.json:VAKUU.talk.REGENT.0-2.ancient"
msgid "Yes, I think we can help each other."
msgstr "Так, думаю, мы можам дапамагчы адзін аднаму."

# [ua] Більше моєї сили може стати твоєю за невелику ціну.
# [pl] Możesz posiąść moją moc za niewielką cenę.
# [ru] Я могу дать тебе еще больше своей силы — за небольшую цену.
msgctxt "ancients.json:VAKUU.talk.REGENT.1-0r.ancient"
msgid "More of my power can be yours for a small price."
msgstr "Больш маёй сілы можа стаць тваёй — за невялікую плату."

# [ua] Не думаю, що ці угоди вигідні. Мені не дуже добре.
# [pl] Te pakty nie wydają się być korzystne. Nie czuję się za dobrze.
# [ru] Зря я с тобой договорился. Мне что-то нехорошо…
msgctxt "ancients.json:VAKUU.talk.REGENT.2-0.char"
msgid "I don’t think these deals are good. I’m not feeling great."
msgstr "Не думаю, што гэтыя ўгоды мне на карысць. Неяк я кепска пачуваюся."

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.REGENT.2-0.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ти ж уважно прочитав контракти, чи не так?
# Ти підписав їх із повним усвідомленням та відповідальністю, чи ні?
# [pl] Przeczytałeś wszystkie pakty do końca?
# Podpisałeś je z pełną świadomością i odpowiedzialnością, prawda?
# [ru] Ты ведь внимательно читаешь мои договоры?
# Подписываешь их в ясном уме и твердой памяти, так?
msgctxt "ancients.json:VAKUU.talk.REGENT.2-1.ancient"
msgid "You read the contracts thoroughly have you not?\n"
"You have signed them with full intent and responsibility no?"
msgstr "Ты ж старанна прачытаў кантракты, праўда?\n"
"І падпісаў іх з поўным усведамленнем і адказнасцю, так?"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.REGENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Ти не збираєшся виконати свою частину угоди?
# Як щодо ще одного контракту? Хіба це не краще?
# [pl] Nie zamierzasz spełnić swojej części umowy?
# Może skusisz się na kolejną? Czy tak nie będzie lepiej?
# [ru] Ты не состоянии выполнить свою часть уговора?
# Может, еще один договор подпишем? Так ведь проще.
msgctxt "ancients.json:VAKUU.talk.REGENT.2-2.ancient"
msgid "Are you not going to fulfill your end of the bargain?\n"
"How about another contract? Isn’t that better?"
msgstr "Ты не збіраешся выканаць сваю частку ўгоды?\n"
"А як наконт яшчэ аднаго кантракта? Хіба так не лепей?"

# [ua] Вбивця.
# [pl] Morderczyni.
# [ru] Убийца.
msgctxt "ancients.json:VAKUU.talk.SILENT.0-0.ancient"
msgid "Killer."
msgstr "Забойца."

# [ua] Мовчати
# [pl] Nic nie mów
# [ru] Промолчать
msgctxt "ancients.json:VAKUU.talk.SILENT.0-0.next"
msgid "Say Nothing"
msgstr "Нічога не адказаць"

# [ua] [sine]...[/sine]
# [pl] [sine]...[/sine]
# [ru] [sine]...[/sine]
msgctxt "ancients.json:VAKUU.talk.SILENT.0-1.char"
msgid "[sine]...[/sine]"
msgstr "[sine]...[/sine]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.SILENT.0-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Це [jitter]погано[/jitter] закінчиться для тебе.
# [pl] To się nie [jitter]skończy[/jitter] dla ciebie dobrze.
# [ru] Для тебя это добром [jitter]не закончится[/jitter].
msgctxt "ancients.json:VAKUU.talk.SILENT.0-2.ancient"
msgid "This won’t [jitter]end[/jitter] well for you."
msgstr "Гэта для цябе добрым не [jitter]закончыцца[/jitter]."

# [ua] [i][font_size=22]Вакуу показує Мовчазній свої різноманітні
# контракти[/font_size][/i]
# [pl] [i][font_size=22]Vakuu prezentuje Zjawie przeróżne pakty
# [/font_size][/i]
# [ru] [i][font_size=22]Вакуу показывает Безмолвной различные
# договоры.[/font_size][/i]
msgctxt "ancients.json:VAKUU.talk.SILENT.1-0r.ancient"
msgid "[i][font_size=22]Vakuu displays his various contracts to the Silent[/font_size][/i]"
msgstr "[i][font_size=22]Вакуу дэманструе Маўчальніцы розныя кантракты[/font_size][/i]"

# [ua] Архітектора замало, убий також своїх сестер!
# [pl] Architekt to dopiero początek, zabij też swoje siostry!
# [ru] Одного Архитектора мало. Убей заодно и своих сестер!
msgctxt "ancients.json:VAKUU.talk.SILENT.2-0.ancient"
msgid "The Architect is not enough, kill your sisters too!"
msgstr "Аднаго Архітэктара мала, забі яшчэ і сваіх сясцёр!"

# [ua] Мовчати
# [pl] Nic nie mów
# [ru] Промолчать
msgctxt "ancients.json:VAKUU.talk.SILENT.2-0.next"
msgid "Say Nothing"
msgstr "Прамаўчаць"

# [ua] [sine]...[/sine]
# [pl] [sine]...[/sine]
# [ru] [sine]...[/sine]
msgctxt "ancients.json:VAKUU.talk.SILENT.2-1.char"
msgid "[sine]...[/sine]"
msgstr "[sine]...[/sine]"

# [ua] Далі
# [pl] Kontynuuj
# [ru] Далее
msgctxt "ancients.json:VAKUU.talk.SILENT.2-1.next"
msgid "Continue"
msgstr "Працягнуць"

# [ua] Слова не потрібні, ми однакові.
# [pl] Nie musisz nic mówić, jesteśmy tacy sami.
# [ru] Мы понимаем друг друга без лишних слов.
msgctxt "ancients.json:VAKUU.talk.SILENT.2-2.ancient"
msgid "No need for words, we are the same."
msgstr "Слоў не трэба, мы і так адно аднаго разумеем."

# [ua] Віддай себе мені, і тебе боятимуться так само, як і мене.
# [pl] Wystarczy, że skusisz się na jedną umowę, a będziesz wszystkich
# paraliżować strachem tak jak ja.
# [ru] Отдайся мне — и будешь вселять в сердца такой же страх, что и я.
msgctxt "ancients.json:VAKUU.talk.firstVisitEver.0-0.ancient"
msgid "Give yourself to me and you will be feared as much as I."
msgstr "Аддайся мне — і цябе будуць лякацца гэтак жа, як і мяне."

# [ua] Вакуу
# [pl] Vakuu
# [ru] Вакуу
msgctxt "ancients.json:VAKUU.title"
msgid "Vakuu"
msgstr "Вакуу"

# [ua] Грайте без модифікаторів Випробування.
# [pl] Graj bez utrudnień Wyniesienia.
# [ru] Игра без модификаторов Возвышения.
msgctxt "ascension.json:LEVEL_00.description"
msgid "Play without any Ascension modifiers."
msgstr "Гуляць без мадыфікатараў Узнясення."

# [ua] Без Випробування
# [pl] Bez Wyniesienia
# [ru] Без Возвышения
msgctxt "ascension.json:LEVEL_00.title"
msgid "No Ascension"
msgstr "Без Узнясення"

# [ua] [gold]Еліти[/gold] з'являються частіше.
# [pl] [gold]Elitarni przeciwnicy[/gold] pojawiają się częściej.
# [ru] [gold]Элитные враги[/gold] встречаются чаще.
msgctxt "ascension.json:LEVEL_01.description"
msgid "[gold]Elites[/gold] spawn more often."
msgstr "[gold]Элітныя праціўнікі[/gold] з'яўляюцца часцей."

# [ua] Зграя Еліт
# [pl] Elitarna horda
# [ru] Заговор элит
msgctxt "ascension.json:LEVEL_01.title"
msgid "Swarming Elites"
msgstr "Засілле эліт"

