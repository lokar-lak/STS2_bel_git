msgctxt "cards.json:TORIC_TOUGHNESS.description"
msgid "Gain {Block:diff()} [gold]Block[/gold].\n"
"Gain {Block:diff()} [gold]Block[/gold] at the start of the next {Turns:diff()} {Turns:plural:turn|turns}."
msgstr "Дае {Block:diff()} [gold]брані[/gold].\n"
"Дае {Block:diff()} [gold]брані[/gold] на пачатку {Turns:plural:наступнага ходу|наступных {Turns:diff()} хадоў|наступных {Turns:diff()} хадоў}."

