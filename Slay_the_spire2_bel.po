# [ru] [gold]Призывает[/gold] {DevourLifePower:diff()}, когда вы разыгрываете
# [gold]«Душу»[/gold].
msgctxt "cards.json:DEVOUR_LIFE.description"
msgid "Whenever you play a [gold]Soul[/gold], [gold]Summon[/gold] {DevourLifePower:diff()}."
msgstr "Кожны раз, калі вы разыгрываеце [gold]«Душу»[/gold], [gold]выклікае[/gold] {DevourLifePower:diff()}."

# [ua] Пожирання Душ
# [pl] Pożeranie życia
# [ru] Пожиратель жизни
