# [ru] [gold]Призывает[/gold] {Summon:diff()} X раз.
# Добавляет X [gold]{IfUpgraded:show:«Душ+»|«Душ»}[/gold] в [gold]стопку
# добора[/gold].
msgctxt "cards.json:DIRGE.description"
msgid "[gold]Summon[/gold] {Summon:diff()} X times.\n"
"Add X [gold]{IfUpgraded:show:Souls+|Souls}[/gold] into your [gold]Draw Pile[/gold]."
msgstr "[gold]Выклікае[/gold] {Summon:diff()} X разоў.\n"
"Дадае X [gold]{IfUpgraded:show:Душ+|Душ}[/gold] у ваш [gold]стос дабору[/gold]."

# [ua] Реквієм
# [pl] Pieśń żałobna
# [ru] Лития
msgctxt "cards.json:DIRGE.title"
msgid "Dirge"
msgstr "Галашэнне"

# [ua] Обираєте 1 з 3 випадкових карт, щоб додати до [gold]Руки[/gold]. Цього
