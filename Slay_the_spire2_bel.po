msgid "Come back when you're a little [jitter]richer[/jitter]."
msgstr "Вяртайцеся, калі крыху [jitter]разбагацееце[/jitter]."

# [ua] Я не даю в [jitter]борг[/jitter].
# [pl] Nie udzielam [jitter]pożyczek[/jitter].
# [ru] В долг [jitter]не даю![/jitter]
msgctxt "merchant_room.json:MERCHANT.talk.purchaseFailureGold.line4"
msgid "I don't deal in [jitter]credit[/jitter]."
msgstr "У [jitter]доўг[/jitter] не даю."

