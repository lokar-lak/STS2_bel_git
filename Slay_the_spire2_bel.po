msgid "Tries to escape the combat {Amount:plural:this turn|after [blue]{}[/blue] turns}."
msgstr "{Amount:plural:Спрабуе ўцячы з бою гэтым ходам|Спрабуе ўцячы з бою праз [blue]{}[/blue] хады|Спрабуе ўцячы з бою праз [blue]{}[/blue] хадоў}."

# [ua] Майстер втечі
# [pl] Zawodowy tchórz
# [ru] Побег
