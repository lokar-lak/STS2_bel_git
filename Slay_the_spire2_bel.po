msgctxt "cards.json:THRUMMING_HATCHET.description"
msgid "Deal {Damage:diff()} damage.\n"
"At the start of your next turn, return this to your [gold]Hand[/gold]."
msgstr "Прычыняе {Damage:diff()} пашкоджання.\n"
"На пачатку вашага наступнага ходу вяртаецца вам у [gold]руку[/gold]."

# [ua] Гудяча сокира
# [pl] Grzmiący topór
# [ru] Возвратный топорик
msgctxt "cards.json:THRUMMING_HATCHET.title"
msgid "Thrumming Hatchet"
msgstr "Гудучая сякерка"

