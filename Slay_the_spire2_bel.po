msgstr "{Amount:plural:Першая разыграная за ход карта Атакі або Умення| Першыя {} разыграныя за ход карты Атакі або Умення|Першыя {} разыграных за ход карт Атакі або Умення} {Amount:plural:кладзецца|кладуцца|кладуцца} наверх [gold]стоса дабору[/gold]."

# [ua] Ностальгія
# [pl] Nostalgia
# [ru] Ностальгия
msgctxt "powers.json:NOSTALGIA_POWER.title"
msgid "Nostalgia"
msgstr "Настальгія"

# [ua] На початку Вашого ходу застосуйте [blue]2[/blue] [gold]Отрути[/gold] до
# ВСІХ ворогів.
# [pl] Na początku tury nałóż [blue]2[/blue] pkt. [gold]Trucizny[/gold] na
# WSZYSTKICH przeciwników.
# [ru] Накладывает [blue]2[/blue] [gold]яда[/gold] на ВСЕХ врагов в начале
# хода.
msgctxt "powers.json:NOXIOUS_FUMES_POWER.description"
msgid "At the start of your turn, apply [blue]2[/blue] [gold]Poison[/gold] to ALL enemies."
msgstr "На пачатку вашага ходу накладае [blue]2[/blue] [gold]атруты[/gold] на УСІХ праціўнікаў."

# [ua] На початку Вашого ходу застосуйте [blue]{Amount}[/blue]
# [gold]Отрути[/gold] до ВСІХ ворогів.
# [pl] Na początku tury nałóż [blue]{Amount}[/blue] pkt. [gold]Trucizny[/gold]
# na WSZYSTKICH przeciwników.
# [ru] Накладывает [blue]{Amount}[/blue] [gold]яда[/gold] на ВСЕХ врагов в
# начале хода.
msgctxt "powers.json:NOXIOUS_FUMES_POWER.smartDescription"
msgid "At the start of your turn, apply [blue]{Amount}[/blue] [gold]Poison[/gold] to ALL enemies."
msgstr "На пачатку вашага ходу накладае [blue]{Amount}[/blue] [gold]атруты[/gold] на УСІХ праціўнікаў."

# [ua] Токсичний туман
# [pl] Trujące opary
# [ru] Едкие испарения
msgctxt "powers.json:NOXIOUS_FUMES_POWER.title"
msgid "Noxious Fumes"
msgstr "Атрутныя выпарэнні"

# [ua] Ви не можете отримувати [gold]Броню[/gold] від карт.
# [pl] Nie możesz otrzymywać [gold]Bloku[/gold] z kart.
# [ru] Карты не дают [gold]защиту[/gold].
msgctxt "powers.json:NO_BLOCK_POWER.description"
msgid "You cannot gain [gold]Block[/gold] from cards."
msgstr "Вы не можаце атрымліваць [gold]браню[/gold] ад карт."

# [ua] Ви не можете отримувати [gold]Броню[/gold] від карт протягом
# {Amount:plural:[blue]{}[/blue] ходу|[blue]{}[/blue] ходів|[blue]{}[/blue]
# ходів}.
# [pl] Nie możesz otrzymywać [gold]Bloku[/gold] z kart {Amount:plural:do końca
# tury|przez [blue]{}[/blue] następne tury|przez [blue]{}[/blue] następnych
# tur}.
# [ru] {Amount:plural(ru):В этом ходу карты|Карты|Карты} не дают
# [gold]защиту[/gold]{Amount:plural(ru):| в течение [blue]{}[/blue] ходов| в
# течение [blue]{}[/blue] ходов}.
msgctxt "powers.json:NO_BLOCK_POWER.smartDescription"
msgid "You cannot gain [gold]Block[/gold] from cards for {Amount:plural:[blue]{}[/blue] turn|[blue]{}[/blue] turns}."
msgstr "Вы не можаце атрымліваць [gold]браню[/gold] ад карт цягам {Amount:plural:[blue]{}[/blue] ходу|[blue]{}[/blue] хадоў|[blue]{}[/blue] хадоў}."

# [ua] Без броні
# [pl] Bez Bloku
# [ru] Без защиты
msgctxt "powers.json:NO_BLOCK_POWER.title"
msgid "No Block"
msgstr "Без брані"

# [ua] Ви більше не можете брати карти цього ходу.
# [pl] Nie możesz dobierać więcej kart w tej turze.
# [ru] Вы не можете добирать карты в этом ходу.
msgctxt "powers.json:NO_DRAW_POWER.description"
msgid "You may not draw any more cards this turn."
msgstr "У гэтым ходзе вы больш не можаце дабіраць карты."

# [ua] Ви більше не можете брати карти цього ходу.
# [pl] Nie możesz dobierać więcej kart w tej turze.
# [ru] Вы не можете добирать карты в этом ходу.
msgctxt "powers.json:NO_DRAW_POWER.smartDescription"
msgid "You may not draw any more cards this turn."
msgstr "У гэтым ходзе вы больш не можаце дабіраць карты."

# [ua] Без добору
# [pl] Bez dobierania
# [ru] Без добора
msgctxt "powers.json:NO_DRAW_POWER.title"
msgid "No Draw"
msgstr "Без дабору"

# [pl] Nie możesz zyskać więcej {energyPrefix:energyIcons(1)} w tej turze.
# [ru] Вы не можете получать {energyPrefix:energyIcons(1)} до конца хода.
msgctxt "powers.json:NO_ENERGY_GAIN_POWER.description"
msgid "You cannot gain additional {energyPrefix:energyIcons(1)} this turn."
msgstr "У гэтым ходзе вы не можаце атрымліваць дадатковай {energyPrefix:energyIcons(1)}."

# [pl] Nie możesz zyskać więcej {energyPrefix:energyIcons(1)} w tej turze.
# [ru] Вы не можете получать {energyPrefix:energyIcons(1)} до конца хода.
msgctxt "powers.json:NO_ENERGY_GAIN_POWER.smartDescription"
msgid "You cannot gain additional {energyPrefix:energyIcons(1)} this turn."
msgstr "У гэтым ходзе вы не можаце атрымліваць дадатковай {energyPrefix:energyIcons(1)}."

# [pl] Bez Energii
# [ru] Предел энергии
msgctxt "powers.json:NO_ENERGY_GAIN_POWER.title"
msgid "No Energy Gain"
msgstr "Без прытоку энергіі"

# [ua] Наприкінці [blue]3[/blue] ходів отримує [blue]50[/blue]
# [gold]Загибелі[/gold].
# [pl] Za [blue]3[/blue] tury otrzymuje [blue]50[/blue] pkt.
# [gold]Zagłady[/gold].
# [ru] Получит [blue]50[/blue] [gold]злого рока[/gold] в конце
# [blue]3-го[/blue] хода.
msgctxt "powers.json:NO_ESCAPE_POWER.description"
msgid "At the end of [blue]3[/blue] turns, gains [blue]50[/blue] [gold]Doom[/gold]."
msgstr "Напрыканцы [blue]3[/blue] хадоў атрымлівае [blue]50[/blue] [gold]пагібелі[/gold]."

# [ua] Наприкінці {Amount:plural:цього ходу|[blue]{}[/blue]
# ходів|[blue]{}[/blue] ходів} отримує [blue]{DoomPower}[/blue]
# [gold]Загибелі[/gold].
# [pl] {Amount:plural:Pod koniec tej tury|Za [blue]{}[/blue] tury|Za
# [blue]{}[/blue] tur} otrzyma [blue]{DoomPower}[/blue] pkt.
# [gold]Zagłady[/gold].
# [ru] Получит [blue]{DoomPower}[/blue] [gold]злого рока[/gold] в конце
# {Amount:plural(ru):этого хода|[blue]{}-го[/blue] хода|[blue]{}-го[/blue]
# хода}.
msgctxt "powers.json:NO_ESCAPE_POWER.smartDescription"
msgid "At the end of {Amount:plural:this turn|[blue]{}[/blue] turns}, gains [blue]{DoomPower}[/blue] [gold]Doom[/gold]."
msgstr "Напрыканцы {Amount:plural:гэтага ходу|[blue]{}[/blue] хадоў|[blue]{}[/blue] хадоў} атрымлівае [blue]{DoomPower}[/blue] [gold]пагібелі[/gold]."

# [ua] Немає виходу
# [pl] Nie ma ucieczki
# [ru] Замкнутый круг
msgctxt "powers.json:NO_ESCAPE_POWER.title"
msgid "No Escape"
msgstr "Замкнутае кола"

# [ua] Щоразу, коли Ви граєте карту, цей ворог отримує [blue]1[/blue]
# [gold]Загибелі[/gold].
# [pl] Kiedykolwiek zagrasz kartę, ten przeciwnik otrzymuje [blue]1[/blue]
# pkt. [gold]Zagłady[/gold].
# [ru] Получает [blue]1[/blue] [gold]злого рока[/gold], когда вы разыгрываете
# карту.
msgctxt "powers.json:OBLIVION_POWER.description"
msgid "Whenever you play a card, this enemy gains [blue]1[/blue] [gold]Doom[/gold]."
msgstr "Кожны раз, калі вы разыгрываеце карту, гэты праціўнік атрымлівае [blue]1[/blue] [gold]пагібелі[/gold]."

# [ua] Щоразу, коли Ви граєте карту, цей ворог отримує [blue]{Amount}[/blue]
# [gold]Загибелі[/gold].
# [pl] Kiedykolwiek zagrasz kartę, ten przeciwnik otrzymuje
# [blue]{Amount}[/blue] pkt. [gold]Zagłady[/gold].
# [ru] Получает [blue]{Amount}[/blue] [gold]злого рока[/gold], когда вы
# разыгрываете карту.
msgctxt "powers.json:OBLIVION_POWER.smartDescription"
msgid "Whenever you play a card, this enemy gains [blue]{Amount}[/blue] [gold]Doom[/gold]."
msgstr "Кожны раз, калі вы разыгрываеце карту, гэты праціўнік атрымлівае [blue]{Amount}[/blue] [gold]пагібелі[/gold]."

# [ua] Забуття
# [pl] Wymazanie z pamięci
# [ru] Забвение
msgctxt "powers.json:OBLIVION_POWER.title"
msgid "Oblivion"
msgstr "Забыццё"

# [ua] Ваша наступна Атака цього ходу розігрується ще раз.
# [pl] W tej turze następny Atak zostanie zagrany dwukrotnie.
# [ru] Следующая Атака в этом ходу разыгрывается дополнительный раз.
msgctxt "powers.json:ONE_TWO_PUNCH_POWER.description"
msgid "Your next Attack is played an extra time this turn."
msgstr "Наступная разыграная вамі ў гэтым ходзе карта Атакі разыгрываецца яшчэ раз."

# [ua] Ваші наступні {Amount:plural:Атака розігрується|[blue]{}[/blue] Атак
# розігруються|[blue]{}[/blue] Атак розігруються} ще раз цього ходу.
# [pl] {Amount:plural:Następny Atak zostanie zagrany|Następne [blue]{}[/blue]
# Ataki zostaną zagrane|Następnych [blue]{}[/blue] Ataków zostanie zagranych}
# dwukrotnie.
# [ru] {Amount:plural(ru):Следующая Атака в этом ходу разыгрывается|Следующие
# [blue]{}[/blue] Атаки в этом ходу разыгрываются|Следующие [blue]{}[/blue]
# Атак в этом ходу разыгрываются} дополнительный раз.
msgctxt "powers.json:ONE_TWO_PUNCH_POWER.smartDescription"
msgid "Your next {Amount:plural:Attack is|[blue]{}[/blue] Attacks are} played an extra time this turn."
msgstr "{Amount:plural:Наступная разыграная вамі ў гэтым ходзе карта Атакі разыгрываецца|Наступныя [blue]{}[/blue] разыграныя вамі ў гэтым ходзе карты Атакі разыгрываюцца|Наступных [blue]{}[/blue] разыграных вамі ў гэтым ходзе карт Атакі разыгрываюцца} яшчэ раз."

# [ua] Комбо-удар
# [pl] Cios za ciosem
# [ru] Комбо
msgctxt "powers.json:ONE_TWO_PUNCH_POWER.title"
msgid "One-Two Punch"
msgstr "Раз-два!"

# [ua] Кожні [blue]4[/blue] витраченої Енергії отримуйте одиницю Енергії.
# [pl] Zyskaj [blue]1[/blue] pkt. Energii po wydaniu [blue]4[/blue] pkt.
# Energii.
# [ru] Дает энергию за каждые [blue]4[/blue] потраченные энергии.
msgctxt "powers.json:ORBIT_POWER.description"
msgid "Every [blue]4[/blue] Energy you spend, gain an Energy."
msgstr "За кожныя [blue]4[/blue] адз. выдаткаванай энергіі дае 1 энергію."

# [ua] Кожні {Energy:energyIcons()} витраченої Енергії отримуйте
# {Amount:energyIcons()}.
# [pl] Zyskaj {Energy:energyIcons()} po wydaniu {Amount:energyIcons()}.
# [ru] Дает {Amount:energyIcons()} за каждые потраченные
# {Energy:energyIcons()}.
msgctxt "powers.json:ORBIT_POWER.smartDescription"
msgid "Every {Energy:energyIcons()} you spend, gain {Amount:energyIcons()}."
msgstr "За кожныя {Energy:energyIcons()} адз. выдаткаванай энергіі дае {Amount:energyIcons()}."

# [ua] Орбіта
# [pl] Orbita
# [ru] Орбита
msgctxt "powers.json:ORBIT_POWER.title"
msgid "Orbit"
msgstr "Арбіта"

# [ua] Цей ворог може використовувати силу [gold]Сфер[/gold].
# [gold]Сфери[/gold] активуються наприкінці Вашого ходу та не залежать від
# посилень чи послаблень.
# [pl] Ten przeciwnik wykorzystuje technologię [gold]Sfer[/gold], które
# aktywują się pod koniec twojej tury. [gold]Sfery[/gold] są niezależne od
# wzmocnień i osłabień.
# [ru] Этот враг использует энергию [gold]сфер[/gold]. [gold]Сферы[/gold]
# срабатывают в конце вашего хода, на них не влияют положительные или
# отрицательные эффекты.
msgctxt "powers.json:ORB_GENERATOR.description"
msgid "This enemy can harness the power of [gold]Orbs[/gold]. [gold]Orbs[/gold] will trigger at the end of your turn and are unaffected by buffs or debuffs."
msgstr "Гэты праціўнік можа карыстацца сілай [gold]сфер[/gold]. [gold]Сферы[/gold] спрацоўваюць напрыканцы вашага ходу, і на іх не ўплываюць пасіленні ці знясіленні."

# [ua] Генератор сфер
# [pl] Generator Sfer
# [ru] Генератор сфер
msgctxt "powers.json:ORB_GENERATOR.title"
msgid "Orb Generator"
msgstr "Генератар сфер"

# [ua] Кожні [blue]10[/blue] разів застосування [gold]Отрути[/gold] завдавайте
# шкоду ВСІМ ворогам.
# [pl] Zadaj {OutbreakPower:diff()} pkt. obrażeń WSZYSTKIM przeciwnikom po
# nałożeniu [gold]Trucizny[/gold] [blue]10[/blue] razy.
# [ru] Наносит урон ВСЕМ врагам за каждый [blue]10-й[/blue] раз, когда вы
# накладываете [gold]яд[/gold].
msgctxt "powers.json:OUTBREAK_POWER.description"
msgid "Every [blue]10[/blue] times you apply [gold]Poison[/gold], deal damage to ALL enemies."
msgstr "Кожны [blue]10-ы[/blue] раз, калі вы накладаеце [gold]атруту[/gold], прычыняе пашкоджанне УСІМ праціўнікам."

# [ua] Кожні [blue]{Repeat}[/blue] разів застосування [gold]Отрути[/gold]
# завдавайте [blue]{Amount}[/blue] шкоди ВСІМ ворогам.
# [pl] Zadaj [blue]{Amount}[/blue] pkt. obrażeń WSZYSTKIM przeciwnikom po
# nałożeniu [gold]Trucizny[/gold] [blue]{Repeat}[/blue] razy.
# [ru] Наносит [blue]{Amount}[/blue] урона ВСЕМ врагам за каждый
# [blue]{Repeat}-й[/blue] раз, когда вы накладываете [gold]яд[/gold].
msgctxt "powers.json:OUTBREAK_POWER.smartDescription"
msgid "Every [blue]{Repeat}[/blue] times you apply [gold]Poison[/gold], deal [blue]{Amount}[/blue] damage to ALL enemies."
msgstr "Кожны [blue]{Repeat}-ы[/blue] раз, калі вы накладаеце [gold]атруту[/gold], прычыняе [blue]{Amount}[/blue] пашкоджання УСІМ праціўнікам."

# [ua] Спалах
# [pl] Pandemia
# [ru] Эпидемия
msgctxt "powers.json:OUTBREAK_POWER.title"
msgid "Outbreak"
msgstr "Мор"

# [ua] Щоразу, коли Ви берете [gold]Ефемерну[/gold] карту, беріть ще
# [blue]1[/blue] карту.
# [pl] Kiedykolwiek dobierzesz [gold]Eteryczną[/gold] kartę, dobierz
# [blue]1[/blue] kartę.
# [ru] Вы добираете [blue]1[/blue] карту, когда добираете [gold]эфирную[/gold]
# карту.
msgctxt "powers.json:PAGESTORM_POWER.description"
msgid "Whenever you draw an [gold]Ethereal[/gold] card, draw [blue]1[/blue] card."
msgstr "Кожны раз, калі вы дабіраеце [gold]эфемерную[/gold] карту, вы дабіраеце [blue]1[/blue] карту."

# [ua] Щоразу, коли Ви берете [gold]Ефемерну[/gold] карту, беріть
# [blue]{Amount}[/blue] {Amount:plural:карту|карти|карт}.
# [pl] Kiedykolwiek dobierzesz [gold]Eteryczną[/gold] kartę, dobierz
# [blue]{Amount}[/blue] {Amount:plural:kartę|karty|kart}.
# [ru] Вы добираете [blue]{Amount}[/blue]
# {Amount:plural(ru):карту|карты|карт}, когда добираете [gold]эфирную[/gold]
# карту.
msgctxt "powers.json:PAGESTORM_POWER.smartDescription"
msgid "Whenever you draw an [gold]Ethereal[/gold] card, draw [blue]{Amount}[/blue] {Amount:plural:card|cards}."
msgstr "Кожны раз, калі вы дабіраеце [gold]эфемерную[/gold] карту, вы дабіраеце [blue]{Amount}[/blue] {Amount:plural:карту|карты|карт}."

# [ua] Буря сторінок
# [pl] Testament
# [ru] Переплет
msgctxt "powers.json:PAGESTORM_POWER.title"
msgid "Pagestorm"
msgstr "Бура старонак"

# [ua] Перемішайте [blue]1[/blue] [gold]Рану[/gold] у [gold]Відбій[/gold]
# кожного разу, коли Ви отримуєте незаблоковану шкоду від атаки.
# [pl] Wtasuj [blue]1[/blue] [gold]Ranę[/gold] do [gold]stosu kart
# odrzuconych[/gold] po otrzymaniu niezablokowanych obrażeń od ataków.
# [ru] Добавляет [blue]1[/blue] [gold]«Рану»[/gold] в [gold]стопку
# сброса[/gold], когда вы получаете от атак урон по ОЗ.
msgctxt "powers.json:PAINFUL_STABS_POWER.description"
msgid "Shuffle [blue]1[/blue] [gold]Wound[/gold] into your [gold]Discard Pile[/gold] each time you receive unblocked attack damage."
msgstr "Замешвае [blue]1[/blue] карту [gold]«Рана»[/gold] у ваш [gold]стос скідання[/gold] штораз, калі атрымлівае незаблакаванае пашкоджанне."

# [ua] Перемішайте [blue]{Amount}[/blue]
# [gold]{Amount:plural:Рану|Рани|Ран}[/gold] у [gold]Відбій[/gold] кожного
# разу, коли Ви отримуєте незаблоковану шкоду від атаки.
# [pl] Wtasuj [blue]{Amount}[/blue] [gold]{Amount:plural:Ranę|Rany|Ran}[/gold]
# do [gold]stosu kart odrzuconych[/gold] po otrzymaniu niezablokowanych
# obrażeń od ataków.
# [ru] Добавляет [blue]{Amount}[/blue]
# [gold]{Amount:plural(ru):«Рану»|«Раны»|«Ран»}[/gold] в [gold]стопку
# сброса[/gold], когда вы получаете от атак урон по ОЗ.
msgctxt "powers.json:PAINFUL_STABS_POWER.smartDescription"
msgid "Shuffle [blue]{Amount}[/blue] [gold]{Amount:plural:Wound|Wounds}[/gold] into your [gold]Discard Pile[/gold] each time you receive unblocked attack damage."
msgstr "Замешвае [blue]{Amount}[/blue] [gold]{Amount:plural:карту «Рана»|карты «Рана»|карт «Рана»}[/gold] ў ваш [gold]стос скідання[/gold] штораз, калі вы атрымліваеце незаблакаванае пашкоджанне."

# [ua] Болючі удари
# [pl] Bolesne rany
# [ru] Болезненные порезы
msgctxt "powers.json:PAINFUL_STABS_POWER.title"
msgid "Painful Stabs"
msgstr "Балючыя раны"

# [ua] Якщо Ви зіграєте достатньо карт за хід, беріть додаткові карти на
# початку наступного ходу.
# [pl] Po zagraniu wystarczająco kart w jednej turze dobierz dodatkowe karty
# na początku następnej tury.
# [ru] Вы добираете дополнительные карты в следующем ходу, если разыгрываете
# достаточно карт в текущем.
msgctxt "powers.json:PALE_BLUE_DOT_POWER.description"
msgid "If you play enough cards in a turn, draw additional cards at the start of your next turn."
msgstr "Калі вы разыграеце дастаткова карт за ход, на пачатку наступнага ходу вы дабераце дадатковыя карты."

# [ua] Якщо Ви зіграєте [blue]{CardPlay}[/blue] або більше карт за хід, беріть
# [blue]{Amount}[/blue] додаткових {Amount:plural:карту|карти|карт} на початку
# наступного ходу.
# [pl] Po zagraniu co najmniej [blue]{CardPlay}[/blue] kart w jednej turze
# dobierz dodatkowo [blue]{Amount}[/blue] {Amount:plural:kartę|karty|kart} na
# początku następnej tury.
# [ru] Вы добираете [blue]{Amount}[/blue] {Amount:plural(ru):дополнительную
