# [blue]{Amount:abs()}[/blue].
msgctxt "powers.json:FOCUS_POWER.smartDescription"
msgid "{Amount:cond:<0?Decreases|Increases} the effectiveness of Orbs by [blue]{Amount:abs()}[/blue]."
msgstr "{Amount:cond:<0?Зніжае|Павялічвае} эфектыўнасць сфер на [blue]{Amount:abs()}[/blue]."

# [ua] Зосередження
# [pl] Skupienie
# [ru] Фокус
